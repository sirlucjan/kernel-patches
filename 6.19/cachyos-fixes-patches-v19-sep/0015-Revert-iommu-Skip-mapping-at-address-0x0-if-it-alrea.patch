From fb92816dadc368b5d8827819a631cf8fe418ca7e Mon Sep 17 00:00:00 2001
From: Eric Naim <dnaim@cachyos.org>
Date: Fri, 6 Mar 2026 01:52:29 +0800
Subject: [PATCH 15/18] Revert "iommu: Skip mapping at address 0x0 if it
 already exists"

This reverts commit b94178678822f9c6d6dfc639428d0a7b4f9c48ca.

Signed-off-by: Eric Naim <dnaim@cachyos.org>
---
 drivers/iommu/iommu.c | 5 -----
 1 file changed, 5 deletions(-)

diff --git a/drivers/iommu/iommu.c b/drivers/iommu/iommu.c
index 7c50e672d..2ca990dfb 100644
--- a/drivers/iommu/iommu.c
+++ b/drivers/iommu/iommu.c
@@ -1218,11 +1218,6 @@ static int iommu_create_device_direct_mappings(struct iommu_domain *domain,
 				ret = iommu_map(domain, addr - map_size,
 						addr - map_size, map_size,
 						entry->prot, GFP_KERNEL);
-				if (ret == -EADDRINUSE && addr - map_size == 0) {
-					dev_warn_once(dev,
-						"iommu: identity mapping at addr 0x0 already exists, skipping\n");
-					ret = 0;
-				}
 				if (ret)
 					goto out;
 				map_size = 0;
-- 
2.53.0

