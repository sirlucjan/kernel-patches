From 976d60b097e521a41f1de9156fbad3a76dd9c540 Mon Sep 17 00:00:00 2001
From: Eric Naim <dnaim@cachyos.org>
Date: Thu, 2 Apr 2026 23:17:58 +0800
Subject: [PATCH 39/40] Revert "vga_switcheroo: Defer probe of display devices
 on T2 Macs"

This reverts commit 67316318f71c0252899e3342fcc50cc4f97959a2.

Signed-off-by: Eric Naim <dnaim@cachyos.org>
---
 drivers/gpu/vga/vga_switcheroo.c | 4 +---
 1 file changed, 1 insertion(+), 3 deletions(-)

diff --git a/drivers/gpu/vga/vga_switcheroo.c b/drivers/gpu/vga/vga_switcheroo.c
index 5e1d73ab3..7580172da 100644
--- a/drivers/gpu/vga/vga_switcheroo.c
+++ b/drivers/gpu/vga/vga_switcheroo.c
@@ -31,7 +31,6 @@
 #define pr_fmt(fmt) "vga_switcheroo: " fmt
 
 #include <linux/apple-gmux.h>
-#include <linux/cachy-t2.h>
 #include <linux/console.h>
 #include <linux/debugfs.h>
 #include <linux/fb.h>
@@ -439,8 +438,7 @@ find_active_client(struct list_head *head)
 bool vga_switcheroo_client_probe_defer(struct pci_dev *pdev)
 {
 	if (pci_is_display(pdev)) {
-		if (apple_gmux_present() && !vgasr_priv.handler_flags &&
-		    (pdev != vga_default_device() || apple_is_t2_mac()))
+		if (apple_gmux_present() && !vgasr_priv.handler_flags)
 			return true;
 	}
 
