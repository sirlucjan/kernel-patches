index ee06cba5c..01f079cf4 100644
--- a/include/linux/sched.h
+++ b/include/linux/sched.h
@@ -817,6 +817,12 @@ struct kmap_ctrl {
 #endif
 };
 
+struct infinity_ctx {
+	u64		ema;
+	u64		last_sleep_ns;
+	u64		fork_time_ns;
+};
+
 struct task_struct {
 #ifdef CONFIG_THREAD_INFO_IN_TASK
 	/*
@@ -871,6 +877,7 @@ struct task_struct {
 	struct sched_entity		se;
 	struct sched_rt_entity		rt;
 	struct sched_dl_entity		dl;
+	struct infinity_ctx		infinity;
 	struct sched_dl_entity		*dl_server;
 #ifdef CONFIG_SCHED_CLASS_EXT
 	struct sched_ext_entity		scx;
diff --git a/init/init_task.c b/init/init_task.c
index b5f48ebdc..a12f3350d 100644
--- a/init/init_task.c
+++ b/init/init_task.c
@@ -148,6 +148,10 @@ struct task_struct init_task __aligned(L1_CACHE_BYTES) = {
 	.children	= LIST_HEAD_INIT(init_task.children),
 	.sibling	= LIST_HEAD_INIT(init_task.sibling),
 	.group_leader	= &init_task,
+	.infinity		= {
+				.ema		= 0,
+				.last_sleep_ns	= 0,
+	},
 	RCU_POINTER_INITIALIZER(real_cred, &init_cred),
