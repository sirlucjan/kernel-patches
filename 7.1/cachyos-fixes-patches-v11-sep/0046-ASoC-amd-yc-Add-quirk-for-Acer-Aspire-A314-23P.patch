From fa1c62f984efbd5382dc5b5a4cf84d8dde1a61a0 Mon Sep 17 00:00:00 2001
From: Peter Jung <admin@ptr1337.dev>
Date: Mon, 6 Jul 2026 19:05:01 +0200
Subject: [PATCH 46/51] ASoC: amd: yc: Add quirk for Acer Aspire A314-23P

The Acer Aspire A314-23P uses the ACP6x DMIC path for its internal microphone, but the machine driver is not selected without a DMI quirk. Add the model to the ACP6x quirk table so the DMIC capture device is registered.

Fixes: https://github.com/CachyOS/linux-cachyos/issues/919
Signed-off-by: Peter Jung <admin@ptr1337.dev>
---
 sound/soc/amd/yc/acp6x-mach.c | 7 +++++++
 1 file changed, 7 insertions(+)

diff --git a/sound/soc/amd/yc/acp6x-mach.c b/sound/soc/amd/yc/acp6x-mach.c
index ce229f5d0..cd3cb7b28 100644
--- a/sound/soc/amd/yc/acp6x-mach.c
+++ b/sound/soc/amd/yc/acp6x-mach.c
@@ -577,6 +577,13 @@ static const struct dmi_system_id yc_acp_quirk_table[] = {
 			DMI_MATCH(DMI_PRODUCT_NAME, "Swift SFA16-41"),
 		}
 	},
+	{
+		.driver_data = &acp6x_card,
+		.matches = {
+			DMI_MATCH(DMI_BOARD_VENDOR, "RB"),
+			DMI_MATCH(DMI_PRODUCT_NAME, "Aspire A314-23P"),
+		}
+	},
 	{
 		.driver_data = &acp6x_card,
 		.matches = {
-- 
