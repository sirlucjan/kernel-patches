From 2ced736f9c28129f8c52444ad02cde2af67102cc Mon Sep 17 00:00:00 2001
From: Peter Jung <admin@ptr1337.dev>
Date: Sat, 20 Jun 2026 13:03:29 +0200
Subject: [PATCH 97/98] ASoC: codecs: aw87xxx: Remove obsolete of_gpio.h
 includes

The of_gpio.h header was removed along with the legacy
of_get_named_gpio() API. The aw87xxx driver does not use this API, so
remove the now-invalid includes.

Fixes: 05fc6ce94fb2 ("gpio: remove of_get_named_gpio() and <linux/of_gpio.h>")
Signed-off-by: Peter Jung <admin@ptr1337.dev>
---
 sound/soc/codecs/aw87xxx/aw87xxx.c           | 1 -
 sound/soc/codecs/aw87xxx/aw87xxx_bin_parse.c | 1 -
 sound/soc/codecs/aw87xxx/aw87xxx_device.c    | 2 --
 sound/soc/codecs/aw87xxx/aw87xxx_monitor.c   | 2 --
 4 files changed, 6 deletions(-)

diff --git a/sound/soc/codecs/aw87xxx/aw87xxx.c b/sound/soc/codecs/aw87xxx/aw87xxx.c
index 3d732400e..18b29f609 100644
--- a/sound/soc/codecs/aw87xxx/aw87xxx.c
+++ b/sound/soc/codecs/aw87xxx/aw87xxx.c
@@ -16,7 +16,6 @@
 #include <sound/pcm.h>
 #include <sound/pcm_params.h>
 #include <linux/gpio.h>
-#include <linux/of_gpio.h>
 #include <linux/gpio/consumer.h>
 #include <linux/interrupt.h>
 #include <linux/delay.h>
diff --git a/sound/soc/codecs/aw87xxx/aw87xxx_bin_parse.c b/sound/soc/codecs/aw87xxx/aw87xxx_bin_parse.c
index c40055460..89984a607 100644
--- a/sound/soc/codecs/aw87xxx/aw87xxx_bin_parse.c
+++ b/sound/soc/codecs/aw87xxx/aw87xxx_bin_parse.c
@@ -12,7 +12,6 @@
 #include <linux/module.h>
 #include <linux/kernel.h>
 #include <linux/i2c.h>
-#include <linux/of_gpio.h>
 #include <linux/delay.h>
 #include <linux/device.h>
 #include <linux/firmware.h>
diff --git a/sound/soc/codecs/aw87xxx/aw87xxx_device.c b/sound/soc/codecs/aw87xxx/aw87xxx_device.c
index a4c9ad7d9..35a0f9114 100644
--- a/sound/soc/codecs/aw87xxx/aw87xxx_device.c
+++ b/sound/soc/codecs/aw87xxx/aw87xxx_device.c
@@ -14,7 +14,6 @@
 
 #include <linux/i2c.h>
 #include <linux/gpio.h>
-#include <linux/of_gpio.h>
 #include <linux/interrupt.h>
 #include <linux/delay.h>
 #include <linux/kernel.h>
@@ -974,4 +973,3 @@ int aw87xxx_dev_init(struct aw_device *aw_dev)
 	return ret;
 }
 
-
diff --git a/sound/soc/codecs/aw87xxx/aw87xxx_monitor.c b/sound/soc/codecs/aw87xxx/aw87xxx_monitor.c
index f580506b2..7d8dadd00 100644
--- a/sound/soc/codecs/aw87xxx/aw87xxx_monitor.c
+++ b/sound/soc/codecs/aw87xxx/aw87xxx_monitor.c
@@ -23,7 +23,6 @@
 #include <linux/hrtimer.h>
 #include <linux/i2c.h>
 #include <linux/gpio.h>
-#include <linux/of_gpio.h>
 #include <linux/interrupt.h>
 #include <linux/irq.h>
 #include <linux/firmware.h>
@@ -1205,4 +1204,3 @@ void aw87xxx_monitor_exit(struct aw_monitor *monitor)
 				&aw_monitor_control_group);
 	}
 }
-
