From 8f216defe33787a76f0590d148247a5bf74cb838 Mon Sep 17 00:00:00 2001
From: Florian Zitzelsberger <florianz@valvesoftware.com>
Date: Wed, 29 Apr 2026 15:12:25 -0700
Subject: [PATCH 89/98] Fixes two issues with the LED driver.

1. Use a separate port to enable/disable the strip as opposed to
   entangling enablement with mode selection.

2. After changing modes, re-write the colors. Some effects animate
   colors, clobbering previously applied state.

Signed-off-by: Florian Zitzelsberger <florianz@valvesoftware.com>
---
 drivers/leds/rgb/leds-valve.c | 39 ++++++++++++++++++++---------------
 1 file changed, 22 insertions(+), 17 deletions(-)

diff --git a/drivers/leds/rgb/leds-valve.c b/drivers/leds/rgb/leds-valve.c
index 2c52046d2..d90ec18a9 100644
--- a/drivers/leds/rgb/leds-valve.c
+++ b/drivers/leds/rgb/leds-valve.c
@@ -39,6 +39,7 @@
 #define VALVE_PORT_BASE                  0xde8
 #define VALVE_PORT_BIOS_LED_CTRL         (0xde8 - VALVE_PORT_BASE)
 #define VALVE_PORT_BRIGHTNESS_STARTUP    (0xdec - VALVE_PORT_BASE)
+#define VALVE_PORT_STRIP_ENABLE          (0xdef - VALVE_PORT_BASE)
 #define VALVE_PORT_INTENSITY             (0xe39 - VALVE_PORT_BASE)
 #define VALVE_PORT_MODE                  (0xe6c - VALVE_PORT_BASE)
 #define VALVE_PORT_DELAY                 (0xe6e - VALVE_PORT_BASE)
@@ -113,6 +114,7 @@ struct valve_leds {
 		int index;
 	} leds[VALVE_NUM_LEDS];
 
+	int enabled;
 	int effect_index;
 	int delay;
 	int breath_offset;
@@ -125,9 +127,6 @@ struct valve_leds {
 
 static struct platform_device *pdev;
 
-/* Index that corresponds to off and normal states for `enabled` cycling */
-#define VALVE_INDEX_DISABLED 4
-#define VALVE_INDEX_NORMAL   3
 static const char *const effect_names[] = {
 	"patrol",
 	"breath",
@@ -147,15 +146,15 @@ static void valve_leds_send_ec_cmd(unsigned char cmd)
 static ssize_t enabled_show(struct device *dev, struct device_attribute *attr, char *buf)
 {
 	struct valve_leds *leds = dev_get_drvdata(dev->parent);
-	unsigned int mode;
+	unsigned int val;
 	ssize_t len = 0;
 	int ret;
 
-	ret = regmap_read(leds->regmap, VALVE_PORT_MODE, &mode);
+	ret = regmap_read(leds->regmap, VALVE_PORT_STRIP_ENABLE, &val);
 	if (ret)
 		return ret;
 
-	len = sysfs_emit(buf, "%d\n", (mode != VALVE_INDEX_DISABLED));
+	len = sysfs_emit(buf, "%d\n", val);
 
 	return len;
 }
@@ -164,15 +163,14 @@ static ssize_t enabled_store(struct device *dev, struct device_attribute *attr,
 			     const char *buf, size_t count)
 {
 	struct valve_leds *leds = dev_get_drvdata(dev->parent);
-	int mode, ret;
+	int ret;
 	bool enabled;
 
 	ret = kstrtobool(buf, &enabled);
 	if (ret < 0)
 		return ret;
 
-	mode = enabled ? leds->effect_index : VALVE_INDEX_DISABLED;
-	ret = regmap_write(leds->regmap, VALVE_PORT_MODE, mode);
+	ret = regmap_write(leds->regmap, VALVE_PORT_STRIP_ENABLE, (int)enabled);
 	if (ret)
 		return ret;
 
@@ -200,7 +198,8 @@ static ssize_t effect_store(struct device *dev, struct device_attribute *attr,
 			    const char *buf, size_t count)
 {
 	struct valve_leds *leds = dev_get_drvdata(dev->parent);
-	int mode, ret;
+	u8 rgb[VALVE_NUM_LEDS * VALVE_PORT_STRIDE];
+	int led, comp, mode, ret;
 
 	mode = __sysfs_match_string(effect_names, ARRAY_SIZE(effect_names), buf);
 	if (mode < 0)
@@ -210,9 +209,17 @@ static ssize_t effect_store(struct device *dev, struct device_attribute *attr,
 	if (ret)
 		return ret;
 
-	/* cache last enabled mode for enabled node to restore */
-	if (mode != VALVE_INDEX_DISABLED)
-		leds->effect_index = mode;
+	/*
+	 * Some effects animate and clobber colors, thus re-write colors after
+	 * setting the mode.
+	 */
+	for (led = 0; led < VALVE_NUM_LEDS; led++)
+		for (comp = 0; comp < VALVE_NUM_COMPONENTS; comp++)
+			rgb[led * VALVE_NUM_COMPONENTS + comp] = leds->leds[led].rgb[comp].intensity;
+
+	ret = regmap_bulk_write(leds->regmap, VALVE_LED_PORT(0), rgb, ARRAY_SIZE(rgb));
+	if (ret)
+		return ret;
 
 	return count;
 }
@@ -451,6 +458,7 @@ static int valve_leds_sync_from_hw(struct valve_leds *leds)
 		return ret;
 	}
 
+	VALVE_REG_SYNC_FROM_HW(leds, VALVE_PORT_STRIP_ENABLE, leds->enabled);
 	VALVE_REG_SYNC_FROM_HW(leds, VALVE_PORT_MODE, leds->effect_index);
 	VALVE_REG_SYNC_FROM_HW(leds, VALVE_PORT_DELAY, leds->delay);
 	VALVE_REG_SYNC_FROM_HW(leds, VALVE_PORT_BREATH_OFFSET, leds->breath_offset);
@@ -502,6 +510,7 @@ static int valve_leds_sync_to_hw(struct valve_leds *leds)
 	VALVE_REG_SYNC_TO_HW(leds, VALVE_PORT_BRIGHTNESS_CTRL, leds->brightness_ctrl);
 	VALVE_REG_SYNC_TO_HW(leds, VALVE_PORT_BRIGHTNESS_SCALE, leds->brightness_scale);
 	VALVE_REG_SYNC_TO_HW(leds, VALVE_PORT_MODE, leds->effect_index);
+	VALVE_REG_SYNC_TO_HW(leds, VALVE_PORT_STRIP_ENABLE, leds->enabled);
 
 	return 0;
 }
@@ -591,10 +600,6 @@ static int valve_leds_probe(struct platform_device *pdev)
 		return ret;
 	}
 
-	/* If the initial state is disabled use the normal state as default */
-	if (vleds->effect_index == VALVE_INDEX_DISABLED)
-		vleds->effect_index = VALVE_INDEX_NORMAL;
-
 	for (i = 0; i < VALVE_NUM_LEDS; i++) {
 		for (c = 0; c < VALVE_NUM_COMPONENTS; c++) {
 			vleds->leds[i].rgb[c].color_index = LED_COLOR_ID_RED + c;
-- 
2.54.0

