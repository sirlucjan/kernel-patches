From 4b5d82c0bf990245c2c8ee982088816d9c0607cc Mon Sep 17 00:00:00 2001
From: Peter Jung <admin@ptr1337.dev>
Date: Sat, 27 Jun 2026 18:35:15 +0200
Subject: [PATCH 2/2] bbr: Fix bbr name to bbr3

Signed-off-by: Peter Jung <admin@ptr1337.dev>
---
 net/ipv4/Kconfig    | 4 ++++
 net/ipv4/tcp_bbr3.c | 2 +-
 2 files changed, 5 insertions(+), 1 deletion(-)

diff --git a/net/ipv4/Kconfig b/net/ipv4/Kconfig
index f8c35c77f..b529a6371 100644
--- a/net/ipv4/Kconfig
+++ b/net/ipv4/Kconfig
@@ -733,6 +733,9 @@ choice
 	config DEFAULT_BBR
 		bool "BBR" if TCP_CONG_BBR=y
 
+	config DEFAULT_BBR3
+		bool "BBR3" if TCP_CONG_BBR3=y
+
 	config DEFAULT_RENO
 		bool "Reno"
 endchoice
@@ -757,6 +760,7 @@ config DEFAULT_TCP_CONG
 	default "dctcp" if DEFAULT_DCTCP
 	default "cdg" if DEFAULT_CDG
 	default "bbr" if DEFAULT_BBR
+	default "bbr3" if DEFAULT_BBR3
 	default "cubic"
 
 config TCP_SIGPOOL
diff --git a/net/ipv4/tcp_bbr3.c b/net/ipv4/tcp_bbr3.c
index aa93a5ef7..0697a9c95 100644
--- a/net/ipv4/tcp_bbr3.c
+++ b/net/ipv4/tcp_bbr3.c
@@ -2350,7 +2350,7 @@ __bpf_kfunc static void bbr_set_state(struct sock *sk, u8 new_state)
 
 static struct tcp_congestion_ops tcp_bbr_cong_ops __read_mostly = {
 	.flags		= TCP_CONG_NON_RESTRICTED | TCP_CONG_WANTS_CE_EVENTS,
-	.name		= "bbr",
+	.name		= "bbr3",
 	.owner		= THIS_MODULE,
 	.init		= bbr_init,
 	.cong_control	= bbr_main,
-- 
2.54.0

