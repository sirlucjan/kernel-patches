+		u64 ema_pct = div64_u64(gcfs_rq->group_ema * 100ULL,
+					INFINITY_CGROUP_EMA_CLIMB_NS);
+		if (ema_pct > 50) {
+			long reduced = shares * (100 - INFINITY_CGROUP_WEIGHT_REDUCE_PCT) / 100;
+			shares = max(reduced, (long)MIN_SHARES);
+		}
+	}
+
