@@ -1437,9 +1440,22 @@ enqueue_task_rt(struct rq *rq, struct task_struct *p, int flags)
 {
 	struct sched_rt_entity *rt_se = &p->rt;
 
-	if (flags & ENQUEUE_WAKEUP)
+	if (flags & ENQUEUE_WAKEUP) {
 		rt_se->timeout = 0;
 
+		/* Infinity: time-proportional RT EMA decay on wakeup */
+		if (p->infinity.last_sleep_ns) {
+			u64 now = rq_clock(rq);
+			if (now > p->infinity.last_sleep_ns)
+				infinity_rt_wakeup(&p->infinity,
+					now - p->infinity.last_sleep_ns);
