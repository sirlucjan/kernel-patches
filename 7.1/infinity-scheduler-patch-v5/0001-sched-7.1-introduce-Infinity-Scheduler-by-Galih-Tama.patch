 	check_schedstat_required();
 	update_stats_wait_start_rt(rt_rq_of_se(rt_se), rt_se);
 
@@ -1459,6 +1475,10 @@ static bool dequeue_task_rt(struct rq *rq, struct task_struct *p, int flags)
 	update_curr_rt(rq);
 	dequeue_rt_entity(rt_se, flags);
 
+	/* Infinity: record sleep timestamp for time-proportional RT decay */
+	if ((flags & DEQUEUE_SLEEP) && p)
+		p->infinity.last_sleep_ns = rq_clock(rq);
+
 	dequeue_pushable_task(rq, p);
 
 	return true;
@@ -1475,6 +1495,47 @@ requeue_rt_entity(struct rt_rq *rt_rq, struct sched_rt_entity *rt_se, int head)
 		struct rt_prio_array *array = &rt_rq->active;
 		struct list_head *queue = array->queue + rt_se_prio(rt_se);
 
+		/*
+		 * Modulate queue placement by EMA consumption for RT tasks.
+		 * A task that has consumed significant RT runtime (high rt_ema)
+		 * is placed in a lower-priority queue so that well-behaved RT
+		 * tasks (low rt_ema) run first.  The task's actual priority is
+		 * unchanged; only its queue position is modulated.
+		 *
+		 * For RT group scheduling, skip group entities since they
+		 * represent a CPU reservation, not an individual task.
+		 */
+		if (!group_rt_rq(rt_se)) {
+			struct task_struct *p = rt_task_of(rt_se);
+			/*
+			 * Restrict priority modulation to the root task group.
+			 * Nested systemd cgroups have parent group entities that
+			 * read rt_rq->highest_prio.curr from child runqueues.
+			 * Mutating p->prio on a child task without updating the
+			 * parent tracking state desynchronizes the cgroup
+			 * hierarchy, causing pick_next_rt_entity() to dereference
+			 * an empty list on a stale bitmap bit.
+			 */
+			if (rt_rq_of_se(rt_se)->tg == &root_task_group) {
+				int old_prio = p->prio;
+				int qprio = infinity_rt_effective_prio(
+						p->normal_prio, &p->infinity);
+				if (qprio != old_prio) {
+					queue = array->queue + qprio;
+					if (head)
+						list_move(&rt_se->run_list, queue);
+					else
+						list_move_tail(&rt_se->run_list, queue);
+					if (list_empty(array->queue + old_prio))
+						__clear_bit(old_prio,
+							    array->bitmap);
+					__set_bit(qprio, array->bitmap);
+					p->prio = qprio;
+					return;
+				}
+			}
+		}
+
 		if (head)
 			list_move(&rt_se->run_list, queue);
 		else
