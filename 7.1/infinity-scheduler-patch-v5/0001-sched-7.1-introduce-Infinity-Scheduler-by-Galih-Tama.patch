 include/uapi/linux/sched.h    |   4 +-
 init/init_task.c              |   5 +
 kernel/futex/waitwake.c       |   5 +-
 kernel/sched/Makefile         |   1 +
 kernel/sched/fair.c           |  80 +++++++-
 kernel/sched/infinity_sched.c | 365 ++++++++++++++++++++++++++++++++++
 kernel/sched/infinity_sched.h | 165 +++++++++++++++
