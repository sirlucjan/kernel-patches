From 6d9359bac9b4149bb7e5e820c15b363fd12b429c Mon Sep 17 00:00:00 2001
From: Eric Naim <dnaim@cachyos.org>
Date: Tue, 2 Jun 2026 10:27:28 +0700
Subject: [PATCH 32/43] i2c: Force ASUE140D touchpad i2c freq to 100khz

A user reported random 300-500ms input delays for this touchpad on a
ASUS ZenBook UX3404 / Q410VA. Force it to run on 100khz instead to get
rid of those random delays.

Signed-off-by: Eric Naim <dnaim@cachyos.org>
---
 drivers/i2c/i2c-core-acpi.c | 1 +
 1 file changed, 1 insertion(+)

diff --git a/drivers/i2c/i2c-core-acpi.c b/drivers/i2c/i2c-core-acpi.c
index 28c0e4884..fabd87cfb 100644
--- a/drivers/i2c/i2c-core-acpi.c
+++ b/drivers/i2c/i2c-core-acpi.c
@@ -370,6 +370,7 @@ static const struct acpi_device_id i2c_acpi_force_100khz_device_ids[] = {
 	 * the device works without issues on Windows at what is expected to be
 	 * a 400KHz frequency. The root cause of the issue is not known.
 	 */
+	{ "ASUE140D", 0 },
 	{ "DLL0945", 0 },
 	{ "ELAN0678", 0 },
 	{ "ELAN06FA", 0 },
-- 
2.54.0

