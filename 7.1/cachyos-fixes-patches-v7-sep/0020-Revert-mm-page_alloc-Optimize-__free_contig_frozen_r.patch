From 6a879e8306dd7bfdcebfa491f9c29fd19db81aac Mon Sep 17 00:00:00 2001
From: Eric Naim <dnaim@cachyos.org>
Date: Fri, 8 May 2026 19:43:53 +0800
Subject: [PATCH 20/50] Revert "mm/page_alloc: Optimize
 __free_contig_frozen_range()"

This reverts commit 923a7b69e05410575cc767cde18414361f7545cb.

Signed-off-by: Eric Naim <dnaim@cachyos.org>
---
 mm/page_alloc.c | 3 ++-
 1 file changed, 2 insertions(+), 1 deletion(-)

diff --git a/mm/page_alloc.c b/mm/page_alloc.c
index 6d74d30a3..92dcb4261 100644
--- a/mm/page_alloc.c
+++ b/mm/page_alloc.c
@@ -7028,7 +7028,8 @@ static int __alloc_contig_verify_gfp_mask(gfp_t gfp_mask, gfp_t *gfp_cc_mask)
 
 static void __free_contig_frozen_range(unsigned long pfn, unsigned long nr_pages)
 {
-	__free_contig_range_common(pfn, nr_pages, /* is_frozen= */ true);
+	for (; nr_pages--; pfn++)
+		free_frozen_pages(pfn_to_page(pfn), 0);
 }
 
