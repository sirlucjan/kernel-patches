From 84acb55ee7fe77bcd2351cc8101f3be7ee4ec3a9 Mon Sep 17 00:00:00 2001
From: Peter Jung <admin@ptr1337.dev>
Date: Mon, 6 Jul 2026 15:27:16 +0200
Subject: [PATCH 10/11] Revert "sched/fair: Fix overflow in
 update_tg_cfs_runnable()"

This reverts commit 7d71e9da953e361186bf9dfd07490c420512c990.
---
 kernel/sched/fair.c | 5 ++---
 1 file changed, 2 insertions(+), 3 deletions(-)

diff --git a/kernel/sched/fair.c b/kernel/sched/fair.c
index cfaed2cb9..5e74c492a 100644
--- a/kernel/sched/fair.c
+++ b/kernel/sched/fair.c
@@ -5305,8 +5305,7 @@ static inline void
 update_tg_cfs_runnable(struct cfs_rq *cfs_rq, struct sched_entity *se, struct cfs_rq *gcfs_rq)
 {
 	long delta_sum, delta_avg = gcfs_rq->avg.runnable_avg - se->avg.runnable_avg;
-	u64 new_sum;
-	u32 divider;
+	u32 new_sum, divider;
 
 	/* Nothing to update */
 	if (!delta_avg)
@@ -5320,7 +5319,7 @@ update_tg_cfs_runnable(struct cfs_rq *cfs_rq, struct sched_entity *se, struct cf
 
 	/* Set new sched_entity's runnable */
 	se->avg.runnable_avg = gcfs_rq->avg.runnable_avg;
-	new_sum = (u64)se->avg.runnable_avg * divider;
+	new_sum = se->avg.runnable_avg * divider;
 	delta_sum = (long)new_sum - (long)se->avg.runnable_sum;
 	se->avg.runnable_sum = new_sum;
 
-- 
2.55.0

