 # }
 
+# Marie LRU {
+config LRU_MARIE
+	bool "Marie LRU"
+	def_bool y
+	depends on MMU
+	help
+	  Marie LRU represents each folio's reclaim state as a single
+	  byte in a flat per-PFN array allocated once at boot. install,
+	  delete, and aging are all single byte writes — there is no
+	  allocation in any fault-path Marie operation, and no linked
+	  lists for the reclaim path to chase. isolate batches the array
+	  with SIMD plus a persistent cursor, so a 32-folio batch
+	  typically costs a few hundred PFNs of sequential read.
+
+	  The PTE young-bit walker is SIMD-accelerated and auto-dispatched
+	  at boot (AVX-512F > AVX2 > SSE2 on x86; scalar elsewhere); a
+	  bloom-filter forward feedback from rmap keeps walker cost on
+	  hot PMDs.
+
+	  Memory cost: ~1 byte per RAM PFN (4 MiB on 16 GiB, 16 MiB on
+	  64 GiB, capped at 4 GiB by the 32-bit PFN limit Marie requires).
+
+	  Enabled by default; disable at boot with lru_marie=0 on the
+	  kernel cmdline (selected once at boot -- there is no runtime
+	  toggle). When disabled, vmscan falls through to the in-tree LRU
+	  paths unchanged.
+
+	  Say Y unless you understand what this is.
+
+config LRU_MARIE_DEFRAG
+	bool "Marie defragmentation"
+	depends on LRU_MARIE && COMPACTION
+	default y
+	help
+	  Marie defragmentation reuses Marie's dense per-PFN state array and
+	  aging generations to drive memory defragmentation at far lower cost
+	  than mainline compaction: it scores 2 MiB pageblocks by the cost to
+	  evacuate them and clears only the few cold/unmapped stragglers of
+	  near-empty movable blocks -- MOVE (reusing migrate_pages()) or, for
+	  cold-dead clean file, a cheap DROP.
+
+	  When enabled, the /sys/kernel/mm/lru_marie/defrag switch (default 1)
+	  makes Marie defrag REPLACE stock compaction inside kcompactd on both
+	  paths (demand = MOVE+DROP, proactive = MOVE-only); write 0 to fall
+	  back to stock kernel compaction at runtime. The histogram adds one
+	  atomic per Marie gen transition (install/aging/free). When N, all hooks
+	  compile out and the kernel image is identical to plain Marie. See
+	  mm/lru_marie/defrag_design.md.
+
+	  Prototype: verified safe (refault-free migration, bounded DROP, no
+	  corruption); the yield-vs-stock A/B is real-HW territory and not yet
+	  done. Default y on this Marie tree; set N to exclude it entirely.
+# }
+
 config ARCH_SUPPORTS_PER_VMA_LOCK
        def_bool n
 
