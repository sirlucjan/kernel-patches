+	int err = kstrtouint(buf, 10, &v);
+
+	if (err)
+		return err;
+	if (v > 1)
+		return -EINVAL;
+	WRITE_ONCE(marie_low_swappiness_mode, v);
+	/* Effective swappiness changed: restart the proportional controller. */
+	lru_marie_swappiness_changed();
+	return count;
+}
