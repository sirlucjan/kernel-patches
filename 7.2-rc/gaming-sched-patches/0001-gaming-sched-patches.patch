  * Func: min(fraction(nr_cpus * tg->shares), nice -20)
  *
@@ -4921,6 +4934,9 @@ void __sched_cgroup_mode_update(int mode)
 	case 3:
 		func = &calc_max_shares;
 		break;
+	case 4:
+		func = &calc_tasks_shares;
+		break;
 	}
 	static_call_update(calc_group_shares, func);
 }
