-static int aw_dev_hw_crc_check(struct aw88399 *aw88399)
-{
-	struct aw_device *aw_dev = aw88399->aw_pa;
-	int ret;
-
-	ret = regmap_update_bits(aw_dev->regmap, AW88399_I2SCFG1_REG,
