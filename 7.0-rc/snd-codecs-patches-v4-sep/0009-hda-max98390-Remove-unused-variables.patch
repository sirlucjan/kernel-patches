 sound/hda/codecs/realtek/alc269.c           | 1 +
 sound/hda/codecs/side-codecs/max98390_hda.c | 2 +-
 2 files changed, 2 insertions(+), 1 deletion(-)

diff --git a/sound/hda/codecs/realtek/alc269.c b/sound/hda/codecs/realtek/alc269.c
