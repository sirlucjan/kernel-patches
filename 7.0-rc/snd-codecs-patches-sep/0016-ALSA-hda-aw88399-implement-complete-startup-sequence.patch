 #define AW88399_DSPBY_START_BIT		2
 #define AW88399_DSPBY_MASK		(~(1 << AW88399_DSPBY_START_BIT))
 #define AW88399_DSPBY_BYPASS_VALUE	(1 << AW88399_DSPBY_START_BIT)
