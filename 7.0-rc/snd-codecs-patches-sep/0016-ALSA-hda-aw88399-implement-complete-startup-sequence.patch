 sound/soc/codecs/aw88399-lib.c | 291 ++++++++++++++++++++++++++++++---
 1 file changed, 265 insertions(+), 26 deletions(-)

diff --git a/sound/soc/codecs/aw88399-lib.c b/sound/soc/codecs/aw88399-lib.c
index 68acb7e6f..9753c3d13 100644
--- a/sound/soc/codecs/aw88399-lib.c
