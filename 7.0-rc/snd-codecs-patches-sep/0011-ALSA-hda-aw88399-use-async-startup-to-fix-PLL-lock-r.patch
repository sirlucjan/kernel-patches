From dd82477c4a035f987924decb395eda4702b98edf Mon Sep 17 00:00:00 2001
From: Yakov Till <yakov.till@gmail.com>
Date: Mon, 8 Dec 2025 10:33:41 +0100
Subject: [PATCH 11/17] ALSA: hda: aw88399: use async startup to fix PLL lock
 race

---
 sound/hda/codecs/side-codecs/aw88399_hda.c | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/sound/hda/codecs/side-codecs/aw88399_hda.c b/sound/hda/codecs/side-codecs/aw88399_hda.c
index 796c30313..684f693f5 100644
--- a/sound/hda/codecs/side-codecs/aw88399_hda.c
+++ b/sound/hda/codecs/side-codecs/aw88399_hda.c
@@ -58,7 +58,7 @@ static void aw88399_hda_playback_hook(struct device *dev, int action)
 	case HDA_GEN_PCM_ACT_PREPARE:
 		/* Start amplifier */
 		if (core)
-			aw88399_start(core, AW88399_SYNC_START);
+			aw88399_start(core, AW88399_ASYNC_START);
 		break;
 	case HDA_GEN_PCM_ACT_CLEANUP:
 		/* Stop amplifier */
@@ -421,7 +421,7 @@ static int aw88399_hda_runtime_resume(struct device *dev)
 	aw88399->suspended = false;
 
 	if (aw88399->core && aw88399->aw_dev && aw88399->playing)
-		aw88399_start(aw88399->core, AW88399_SYNC_START);
+		aw88399_start(aw88399->core, AW88399_ASYNC_START);
 
 	return 0;
 }
-- 
2.53.0

