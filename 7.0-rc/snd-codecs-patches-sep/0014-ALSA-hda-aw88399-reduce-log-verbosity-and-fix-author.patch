From 468e6bc16e3f1a64729dd51a0f0b131496807396 Mon Sep 17 00:00:00 2001
From: Yakov Till <yakov.till@gmail.com>
Date: Fri, 12 Dec 2025 21:42:40 +0100
Subject: [PATCH 14/17] ALSA: hda: aw88399: reduce log verbosity and fix author

- Change verbose dev_info() calls to dev_dbg() for routine messages
  (ACPI parsing, quirk application, unbind/remove)
- Keep dev_info() only for one-time probe success messages
- Fix MODULE_AUTHOR to use real name and email

Signed-off-by: Yakov Till <yakov.till@gmail.com>
---
 sound/hda/codecs/side-codecs/aw88399_hda.c | 34 +++++++++++-----------
 1 file changed, 17 insertions(+), 17 deletions(-)

diff --git a/sound/hda/codecs/side-codecs/aw88399_hda.c b/sound/hda/codecs/side-codecs/aw88399_hda.c
index 2f93104fc..5e53ac375 100644
--- a/sound/hda/codecs/side-codecs/aw88399_hda.c
+++ b/sound/hda/codecs/side-codecs/aw88399_hda.c
@@ -143,7 +143,7 @@ static void aw88399_hda_unbind(struct device *dev, struct device *master, void *
 		memset(comp, 0, sizeof(*comp));
 
 	aw88399->codec = NULL;
-	dev_info(dev, "Unbound from HDA codec\n");
+	dev_dbg(dev, "Unbound from HDA codec\n");
 }
 
 static const struct component_ops aw88399_hda_comp_ops = {
@@ -187,7 +187,7 @@ static bool aw88399_hda_try_dsd_index(struct aw88399_hda *aw88399, int addr_inde
 	}
 
 	aw88399->index = value;
-	dev_info(dev, "Using _DSD dev-index %u (I2C suggested %d)\n", value, addr_index);
+	dev_dbg(dev, "Using _DSD dev-index %u (I2C suggested %d)\n", value, addr_index);
 
 	return true;
 }
@@ -204,7 +204,7 @@ static void aw88399_hda_parse_speaker_props(struct aw88399_hda *aw88399)
 		if (value < AW88399_HDA_MAX_AMPS) {
 			aw88399->speaker_pos = value;
 			aw88399->speaker_pos_valid = true;
-			dev_info(dev, "Speaker position from _DSD: %u\n", value);
+			dev_dbg(dev, "Speaker position from _DSD: %u\n", value);
 		} else {
 			dev_warn(dev, "_DSD speaker-position %u out of range\n", value);
 		}
@@ -213,7 +213,7 @@ static void aw88399_hda_parse_speaker_props(struct aw88399_hda *aw88399)
 	if (!device_property_read_u32(dev, AW88399_ACPI_PROP_SPK_ID, &value)) {
 		aw88399->speaker_id = value;
 		aw88399->speaker_id_valid = true;
-		dev_info(dev, "Speaker ID from _DSD: %u\n", value);
+		dev_dbg(dev, "Speaker ID from _DSD: %u\n", value);
 	}
 }
 
@@ -275,8 +275,8 @@ static int aw88399_hda_acpi_probe(struct aw88399_hda *aw88399)
 
 	adev = ACPI_COMPANION(dev);
 	if (!adev) {
-		dev_info(dev, "No ACPI companion, using I2C addr 0x%02x for index %d\n",
-			 i2c->addr, aw88399->index);
+		dev_dbg(dev, "No ACPI companion, using I2C addr 0x%02x for index %d\n",
+			i2c->addr, aw88399->index);
 		goto metadata;
 	}
 
@@ -288,8 +288,8 @@ static int aw88399_hda_acpi_probe(struct aw88399_hda *aw88399)
 		ret = acpi_dev_uid_to_integer(adev, &uid);
 		if (ret) {
 			aw88399->index = addr_index;
-			dev_info(dev, "No ACPI _UID, using I2C addr 0x%02x for index %d\n",
-				 i2c->addr, aw88399->index);
+			dev_dbg(dev, "No ACPI _UID, using I2C addr 0x%02x for index %d\n",
+				i2c->addr, aw88399->index);
 		} else if (uid >= AW88399_HDA_MAX_AMPS) {
 			dev_warn(dev, "ACPI _UID %llu out of range, falling back to I2C index %d\n",
 				 uid, addr_index);
@@ -297,12 +297,12 @@ static int aw88399_hda_acpi_probe(struct aw88399_hda *aw88399)
 		} else {
 			aw88399->index = (int)uid;
 			if (aw88399->index != addr_index)
-				dev_info(dev,
-					 "ACPI _UID %d overrides I2C addr 0x%02x suggestion %d\n",
-					 aw88399->index, i2c->addr, addr_index);
+				dev_dbg(dev,
+					"ACPI _UID %d overrides I2C addr 0x%02x suggestion %d\n",
+					aw88399->index, i2c->addr, addr_index);
 			else
-				dev_info(dev, "ACPI _UID: %d (addr 0x%02x)\n",
-					 aw88399->index, i2c->addr);
+				dev_dbg(dev, "ACPI _UID: %d (addr 0x%02x)\n",
+					aw88399->index, i2c->addr);
 		}
 	}
 
@@ -323,8 +323,8 @@ static int aw88399_hda_acpi_probe(struct aw88399_hda *aw88399)
 
 			if (quirk->flags & AW88399_QUIRK_SWAP_LR) {
 				aw88399->channel = 1 - aw88399->channel;
-				dev_info(dev, "Quirk: swapped to channel %d (index %d, addr 0x%02x)\n",
-					 aw88399->channel, aw88399->index, i2c->addr);
+				dev_dbg(dev, "Quirk: swapped to channel %d (index %d, addr 0x%02x)\n",
+					aw88399->channel, aw88399->index, i2c->addr);
 			}
 		}
 	}
@@ -411,7 +411,7 @@ void aw88399_hda_remove(struct device *dev)
 
 	aw88399_dev_deinit(aw88399->aw_dev);
 
-	dev_info(dev, "AW88399 HDA side codec removed\n");
+	dev_dbg(dev, "AW88399 HDA side codec removed\n");
 }
 EXPORT_SYMBOL_NS_GPL(aw88399_hda_remove, "SND_HDA_SCODEC_AW88399");
 
@@ -486,5 +486,5 @@ const struct dev_pm_ops aw88399_hda_pm_ops = {
 EXPORT_SYMBOL_NS_GPL(aw88399_hda_pm_ops, "SND_HDA_SCODEC_AW88399");
 
 MODULE_DESCRIPTION("HDA AW88399 driver");
-MODULE_AUTHOR("Lyapsus");
+MODULE_AUTHOR("Yakov Till <yakov.till@gmail.com>");
 MODULE_LICENSE("GPL");
-- 
2.53.0

