index 8b4897fc8..9cf5b7ab5 100644
--- a/tools/sched_ext/include/scx/compat.h
+++ b/tools/sched_ext/include/scx/compat.h
@@ -180,8 +180,18 @@ static inline long scx_hotplug_seq(void)
 })
 
