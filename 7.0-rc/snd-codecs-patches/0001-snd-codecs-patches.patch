  * struct aw88399_dev - AW88399 device context
  * @dev: parent device
@@ -123,6 +129,7 @@
  * @aw_cfg: loaded firmware container
  * @lock: mutex for device access
  * @fw_status: firmware load status
+ * @dither_st: dither state from firmware (to restore after start)
  */
