+#define AW88399_DITHER_EN_ENABLE_VALUE	(1 << AW88399_DITHER_EN_START_BIT)
+#define AW88399_DITHER_EN_DISABLE_VALUE	(0 << AW88399_DITHER_EN_START_BIT)
+
