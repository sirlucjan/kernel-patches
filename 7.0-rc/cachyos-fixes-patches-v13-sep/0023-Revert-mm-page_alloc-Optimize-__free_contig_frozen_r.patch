From 09a14ace9663fdc35744d3055fb13a7d63b9ffca Mon Sep 17 00:00:00 2001
From: Eric Naim <dnaim@cachyos.org>
Date: Sun, 5 Apr 2026 02:27:03 +0800
Subject: [PATCH 23/29] Revert "mm/page_alloc: Optimize
 __free_contig_frozen_range()"

This reverts commit 7e2e35eeb78708f10ae8f2cadf394c211eb7cbcf.

Signed-off-by: Eric Naim <dnaim@cachyos.org>
---
 mm/page_alloc.c | 3 ++-
 1 file changed, 2 insertions(+), 1 deletion(-)

diff --git a/mm/page_alloc.c b/mm/page_alloc.c
index 26b110028..27f69256f 100644
--- a/mm/page_alloc.c
+++ b/mm/page_alloc.c
@@ -7099,7 +7099,8 @@ static int __alloc_contig_verify_gfp_mask(gfp_t gfp_mask, gfp_t *gfp_cc_mask)
 
 static void __free_contig_frozen_range(unsigned long pfn, unsigned long nr_pages)
 {
-	__free_contig_range_common(pfn, nr_pages, true);
+	for (; nr_pages--; pfn++)
+		free_frozen_pages(pfn_to_page(pfn), 0);
 }
 
