+/* SPDX-License-Identifier: GPL-2.0-or-later */
+#ifndef _LINUX_RBTREE_WAVL_TYPES_H
+#define _LINUX_RBTREE_WAVL_TYPES_H
+
+/*
+ * WAVL-backed rbtree type proxy.
+ *
+ * Include this INSTEAD of <linux/rbtree_types.h> to transparently
+ * replace red-black tree types with WAVL tree types while keeping
+ * the rb_* naming convention.
+ *
+ * The native wavl_* API (wavl_types.h) remains available for code
+ * that needs to use both tree types in the same file.
+ */
+
+#include <linux/wavl_types.h>
+
+/* Struct type names: struct rb_node → struct wavl_node, etc. */
+#undef rb_node
+#undef rb_root
+#undef rb_root_cached
+#define rb_node			wavl_node
+#define rb_root			wavl_root
+#define rb_root_cached		wavl_root_cached
+
+/* Struct member names */
+#undef __rb_parent_color
+#undef rb_left
+#undef rb_right
+#undef rb_leftmost
+#define __rb_parent_color	__wavl_parent
+#define rb_left			wavl_left
+#define rb_right		wavl_right
+#define rb_leftmost		wavl_leftmost
+
+/* Initializers */
+#undef RB_ROOT
+#undef RB_ROOT_CACHED
+#define RB_ROOT			WAVL_ROOT
+#define RB_ROOT_CACHED		WAVL_ROOT_CACHED
+
+#endif	/* _LINUX_RBTREE_WAVL_TYPES_H */
