+ */
+struct task_rq {
+	struct load_weight	load;
+	unsigned int		nr_queued;
+
+	s64			avg_vruntime;
+	u64			avg_load;
+	u64			zero_vruntime;
+
+#ifdef CONFIG_SCHED_WAVL
+	struct wavl_root_cached	tasks_timeline;		/* wavl-tree of sched_entity (tasks only) */
+#else
+	struct rb_root_cached	tasks_timeline;		/* rb-tree of sched_entity (tasks only) */
+#endif
+
+	struct sched_entity	*curr;
+	struct sched_entity	*next;
+
+	/* PELT */
+	struct sched_avg	avg;
+#ifndef CONFIG_64BIT
+	u64			last_update_time_copy;
+#endif
+
+	/* Owner: the leaf group_entity that owns this task_rq */
+	struct group_entity	*owner;
+
+	/* Back-pointers */
+	struct task_group	*tg;
+	struct rq		*rq;
+
+	/* Cross-CPU load tracking for adaptive group weight */
+	u64			last_update_tg_load_avg;
+	unsigned long		tg_load_avg_contrib;
+
+	/* Hierarchical load for load balancing */
+	unsigned long		h_load;
+	u64			last_h_load_update;
+
+	/* Leaf list for load balancing */
+	int			on_list;
+	struct list_head	leaf_trq_list;
+};
