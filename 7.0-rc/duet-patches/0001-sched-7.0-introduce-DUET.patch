diff --git a/include/linux/wavl.h b/include/linux/wavl.h
new file mode 100644
index 000000000..c058639b6
--- /dev/null
+++ b/include/linux/wavl.h
@@ -0,0 +1,132 @@
+/* SPDX-License-Identifier: GPL-2.0-or-later */
+/*
+ * Weak AVL (WAVL) Trees
+ *
+ * Drop-in alternative to rbtrees with the same API shape.
+ * See Documentation/core-api/rbtree.rst for the rbtree docs
+ * whose conventions this file mirrors.
+ */
+
+#ifndef _LINUX_WAVL_H
+#define _LINUX_WAVL_H
+
+#include <linux/container_of.h>
+#include <linux/wavl_types.h>
+#include <linux/stddef.h>
+
+#define wavl_parent(n)		((struct wavl_node *)((n)->__wavl_parent))
+
+#define wavl_entry(ptr, type, member) container_of(ptr, type, member)
+
+#define WAVL_EMPTY_ROOT(root)	(READ_ONCE((root)->wavl_node) == NULL)
+
+#define WAVL_EMPTY_NODE(node) \
+	((node)->__wavl_parent == (unsigned long)(node))
+#define WAVL_CLEAR_NODE(node) \
+	((node)->__wavl_parent = (unsigned long)(node))
+
+extern void wavl_insert_rebalance(struct wavl_node *, struct wavl_root *);
+extern void wavl_erase(struct wavl_node *, struct wavl_root *);
+
+extern struct wavl_node *wavl_next(const struct wavl_node *);
+extern struct wavl_node *wavl_prev(const struct wavl_node *);
+extern struct wavl_node *wavl_first(const struct wavl_root *);
+extern struct wavl_node *wavl_last(const struct wavl_root *);
+
+extern struct wavl_node *wavl_first_postorder(const struct wavl_root *);
+extern struct wavl_node *wavl_next_postorder(const struct wavl_node *);
+
+extern void wavl_replace_node(struct wavl_node *victim, struct wavl_node *new,
+			      struct wavl_root *root);
+
+static inline void wavl_link_node(struct wavl_node *node,
+				  struct wavl_node *parent,
+				  struct wavl_node **link)
+{
+	node->__wavl_parent = (unsigned long)parent;
+	node->wavl_left = node->wavl_right = NULL;
+	node->rank = 0;
+
+	*link = node;
+}
+
+#define wavl_entry_safe(ptr, type, member) \
+	({ typeof(ptr) ____ptr = (ptr); \
+	   ____ptr ? wavl_entry(____ptr, type, member) : NULL; \
+	})
+
+#define rbtree_postorder_for_each_entry_safe_wavl(pos, n, root, field) \
+	for (pos = wavl_entry_safe(wavl_first_postorder(root), \
+				   typeof(*pos), field); \
+	     pos && ({ n = wavl_entry_safe( \
+			wavl_next_postorder(&pos->field), \
+			typeof(*pos), field); 1; }); \
+	     pos = n)
+
+/* Same as wavl_first(), but O(1) */
+#define wavl_first_cached(root) (root)->wavl_leftmost
+
+static inline void wavl_insert_rebalance_cached(struct wavl_node *node,
+						struct wavl_root_cached *root,
+						bool leftmost)
+{
+	if (leftmost)
+		root->wavl_leftmost = node;
+	wavl_insert_rebalance(node, &root->wavl_root);
+}
+
+static inline struct wavl_node *
+wavl_erase_cached(struct wavl_node *node, struct wavl_root_cached *root)
+{
+	struct wavl_node *leftmost = NULL;
+
+	if (root->wavl_leftmost == node)
+		leftmost = root->wavl_leftmost = wavl_next(node);
+
+	wavl_erase(node, &root->wavl_root);
+
+	return leftmost;
+}
+
+static inline void wavl_replace_node_cached(struct wavl_node *victim,
+					    struct wavl_node *new,
+					    struct wavl_root_cached *root)
+{
+	if (root->wavl_leftmost == victim)
+		root->wavl_leftmost = new;
+	wavl_replace_node(victim, new, &root->wavl_root);
+}
+
+/**
+ * wavl_add_cached() - insert @node into the leftmost cached tree @tree
+ * @node: node to insert
+ * @tree: leftmost cached tree to insert @node into
+ * @less: operator defining the (partial) node order
+ *
+ * Returns @node when it is the new leftmost, or NULL.
+ */
+static __always_inline struct wavl_node *
+wavl_add_cached(struct wavl_node *node, struct wavl_root_cached *tree,
+		bool (*less)(struct wavl_node *, const struct wavl_node *))
+{
+	struct wavl_node **link = &tree->wavl_root.wavl_node;
+	struct wavl_node *parent = NULL;
+	bool leftmost = true;
+
+	while (*link) {
+		parent = *link;
+		if (less(node, parent)) {
+			link = &parent->wavl_left;
+		} else {
+			link = &parent->wavl_right;
+			leftmost = false;
+		}
+	}
+
+	wavl_link_node(node, parent, link);
+	wavl_insert_rebalance_cached(node, tree, leftmost);
+
+	return leftmost ? node : NULL;
+}
+
+#endif	/* _LINUX_WAVL_H */
diff --git a/include/linux/wavl_augmented.h b/include/linux/wavl_augmented.h
new file mode 100644
index 000000000..100c7ca40
--- /dev/null
+++ b/include/linux/wavl_augmented.h
@@ -0,0 +1,263 @@
+/* SPDX-License-Identifier: GPL-2.0-or-later */
+/*
+ * Weak AVL (WAVL) Trees — augmented tree support.
+ *
+ * Mirrors include/linux/rbtree_augmented.h.
+ * Only struct wavl_augment_callbacks, wavl_insert_augmented(),
+ * wavl_erase_augmented(), and the WAVL_DECLARE_CALLBACKS* macros
+ * are public API.  Everything else is implementation detail.
+ */
+
+#ifndef _LINUX_WAVL_AUGMENTED_H
+#define _LINUX_WAVL_AUGMENTED_H
+
+#include <linux/compiler.h>
+#include <linux/wavl.h>
+
+struct wavl_augment_callbacks {
+	void (*propagate)(struct wavl_node *node, struct wavl_node *stop);
+	void (*copy)(struct wavl_node *old, struct wavl_node *new);
+	void (*rotate)(struct wavl_node *old, struct wavl_node *new);
+};
+
+extern void __wavl_insert_augmented(struct wavl_node *node,
+	struct wavl_root *root,
+	void (*augment_rotate)(struct wavl_node *old, struct wavl_node *new));
+
+static inline void
+wavl_insert_augmented(struct wavl_node *node, struct wavl_root *root,
+		      const struct wavl_augment_callbacks *augment)
+{
+	__wavl_insert_augmented(node, root, augment->rotate);
+}
+
+static inline void
+wavl_insert_augmented_cached(struct wavl_node *node,
+			     struct wavl_root_cached *root, bool newleft,
+			     const struct wavl_augment_callbacks *augment)
+{
+	if (newleft)
+		root->wavl_leftmost = node;
+	wavl_insert_augmented(node, &root->wavl_root, augment);
+}
+
+static __always_inline struct wavl_node *
+wavl_add_augmented_cached(struct wavl_node *node,
+			  struct wavl_root_cached *tree,
+			  bool (*less)(struct wavl_node *,
+				       const struct wavl_node *),
+			  const struct wavl_augment_callbacks *augment)
+{
+	struct wavl_node **link = &tree->wavl_root.wavl_node;
+	struct wavl_node *parent = NULL;
+	bool leftmost = true;
+
+	while (*link) {
+		parent = *link;
+		if (less(node, parent)) {
+			link = &parent->wavl_left;
+		} else {
+			link = &parent->wavl_right;
+			leftmost = false;
+		}
+	}
+
+	wavl_link_node(node, parent, link);
+	augment->propagate(parent, NULL);
+	wavl_insert_augmented_cached(node, tree, leftmost, augment);
+
+	return leftmost ? node : NULL;
+}
+
+/*
+ * Template for declaring augmented WAVL callbacks (generic case).
+ * Mirrors RB_DECLARE_CALLBACKS.
+ */
+#define WAVL_DECLARE_CALLBACKS(WSTATIC, WNAME,				\
+			       WSTRUCT, WFIELD, WAUGMENTED, WCOMPUTE)	\
+static inline void							\
+WNAME ## _propagate(struct wavl_node *wavl, struct wavl_node *stop)	\
+{									\
+	while (wavl != stop) {						\
+		WSTRUCT *node = wavl_entry(wavl, WSTRUCT, WFIELD);	\
+		if (WCOMPUTE(node, true))				\
+			break;						\
+		wavl = wavl_parent(&node->WFIELD);			\
+	}								\
+}									\
+static inline void							\
+WNAME ## _copy(struct wavl_node *wavl_old, struct wavl_node *wavl_new)	\
+{									\
+	WSTRUCT *old = wavl_entry(wavl_old, WSTRUCT, WFIELD);		\
+	WSTRUCT *new = wavl_entry(wavl_new, WSTRUCT, WFIELD);		\
+	new->WAUGMENTED = old->WAUGMENTED;				\
+}									\
+static void								\
+WNAME ## _rotate(struct wavl_node *wavl_old, struct wavl_node *wavl_new)\
+{									\
+	WSTRUCT *old = wavl_entry(wavl_old, WSTRUCT, WFIELD);		\
+	WSTRUCT *new = wavl_entry(wavl_new, WSTRUCT, WFIELD);		\
+	new->WAUGMENTED = old->WAUGMENTED;				\
+	WCOMPUTE(old, false);						\
+}									\
+WSTATIC const struct wavl_augment_callbacks WNAME = {			\
+	.propagate = WNAME ## _propagate,				\
+	.copy = WNAME ## _copy,						\
+	.rotate = WNAME ## _rotate					\
+};
+
+/*
+ * Template for max-tracking augmented WAVL callbacks.
+ * Mirrors RB_DECLARE_CALLBACKS_MAX.
+ */
+#define WAVL_DECLARE_CALLBACKS_MAX(WSTATIC, WNAME, WSTRUCT, WFIELD,	      \
+				   WTYPE, WAUGMENTED, WCOMPUTE)		      \
+static inline bool WNAME ## _compute_max(WSTRUCT *node, bool exit)	      \
+{									      \
+	WSTRUCT *child;							      \
+	WTYPE max = WCOMPUTE(node);					      \
+	if (node->WFIELD.wavl_left) {					      \
+		child = wavl_entry(node->WFIELD.wavl_left, WSTRUCT, WFIELD);  \
+		if (child->WAUGMENTED > max)				      \
+			max = child->WAUGMENTED;			      \
+	}								      \
+	if (node->WFIELD.wavl_right) {					      \
+		child = wavl_entry(node->WFIELD.wavl_right, WSTRUCT, WFIELD); \
+		if (child->WAUGMENTED > max)				      \
+			max = child->WAUGMENTED;			      \
+	}								      \
+	if (exit && node->WAUGMENTED == max)				      \
+		return true;						      \
+	node->WAUGMENTED = max;						      \
+	return false;							      \
+}									      \
+WAVL_DECLARE_CALLBACKS(WSTATIC, WNAME,					      \
+		       WSTRUCT, WFIELD, WAUGMENTED,			      \
+		       WNAME ## _compute_max)
+
+/* ---- Implementation details below ---- */
+
+static inline void wavl_set_parent(struct wavl_node *node,
+				   struct wavl_node *parent)
+{
+	node->__wavl_parent = (unsigned long)parent;
+}
+
+static inline void
+__wavl_change_child(struct wavl_node *old, struct wavl_node *new,
+		    struct wavl_node *parent, struct wavl_root *root)
+{
+	if (parent) {
+		if (parent->wavl_left == old)
+			WRITE_ONCE(parent->wavl_left, new);
+		else
+			WRITE_ONCE(parent->wavl_right, new);
+	} else {
+		WRITE_ONCE(root->wavl_node, new);
+	}
+}
+
+extern void __wavl_erase_rebalance(struct wavl_node *parent,
+	struct wavl_root *root,
+	void (*augment_rotate)(struct wavl_node *old, struct wavl_node *new));
+
+static __always_inline struct wavl_node *
+__wavl_erase_augmented(struct wavl_node *node, struct wavl_root *root,
+		       const struct wavl_augment_callbacks *augment)
+{
+	struct wavl_node *child = node->wavl_right;
+	struct wavl_node *tmp = node->wavl_left;
+	struct wavl_node *parent, *rebalance;
+
+	if (!tmp) {
+		/*
+		 * Case 1: node has no left child.
+		 * Replace node with its right child (may be NULL).
+		 */
+		parent = wavl_parent(node);
+		__wavl_change_child(node, child, parent, root);
+		if (child)
+			wavl_set_parent(child, parent);
+		rebalance = parent;
+		tmp = parent;
+	} else if (!child) {
+		/* Case 1b: node has no right child. */
+		parent = wavl_parent(node);
+		__wavl_change_child(node, tmp, parent, root);
+		wavl_set_parent(tmp, parent);
+		rebalance = parent;
+		tmp = parent;
+	} else {
+		struct wavl_node *successor = child, *child2;
+
+		tmp = child->wavl_left;
+		if (!tmp) {
+			/*
+			 * Case 2: node's successor is its right child.
+			 */
+			parent = successor;
+			child2 = successor->wavl_right;
+
+			augment->copy(node, successor);
+		} else {
+			/*
+			 * Case 3: node's successor is leftmost under
+			 * node's right child subtree.
+			 */
+			do {
+				parent = successor;
+				successor = tmp;
+				tmp = tmp->wavl_left;
+			} while (tmp);
+			child2 = successor->wavl_right;
+			WRITE_ONCE(parent->wavl_left, child2);
+			WRITE_ONCE(successor->wavl_right, child);
+			wavl_set_parent(child, successor);
+
+			augment->copy(node, successor);
+			augment->propagate(parent, successor);
+		}
+
+		tmp = node->wavl_left;
+		WRITE_ONCE(successor->wavl_left, tmp);
+		wavl_set_parent(tmp, successor);
+
+		{
+			struct wavl_node *nparent = wavl_parent(node);
+
+			__wavl_change_child(node, successor, nparent, root);
+			wavl_set_parent(successor, nparent);
+		}
+
+		if (child2)
+			wavl_set_parent(child2, parent);
+		successor->rank = node->rank;
+		rebalance = parent;
+		tmp = successor;
+	}
+
+	augment->propagate(tmp, NULL);
+	return rebalance;
+}
+
+static __always_inline void
+wavl_erase_augmented(struct wavl_node *node, struct wavl_root *root,
+		     const struct wavl_augment_callbacks *augment)
+{
+	struct wavl_node *rebalance = __wavl_erase_augmented(node, root,
+							     augment);
+	if (rebalance)
+		__wavl_erase_rebalance(rebalance, root, augment->rotate);
+}
+
+static __always_inline void
+wavl_erase_augmented_cached(struct wavl_node *node,
+			    struct wavl_root_cached *root,
+			    const struct wavl_augment_callbacks *augment)
+{
+	if (root->wavl_leftmost == node)
+		root->wavl_leftmost = wavl_next(node);
+	wavl_erase_augmented(node, &root->wavl_root, augment);
+}
+
+#endif	/* _LINUX_WAVL_AUGMENTED_H */
diff --git a/include/linux/wavl_types.h b/include/linux/wavl_types.h
new file mode 100644
index 000000000..89a14baad
--- /dev/null
+++ b/include/linux/wavl_types.h
@@ -0,0 +1,33 @@
+/* SPDX-License-Identifier: GPL-2.0-or-later */
+#ifndef _LINUX_WAVL_TYPES_H
+#define _LINUX_WAVL_TYPES_H
+
+/*
+ * Weak AVL (WAVL) Trees — rank-balanced binary search trees.
+ *
+ * Compared to red-black trees, WAVL trees perform at most 2 rotations
+ * per insert/delete while maintaining O(log n) height.  Balance is
+ * tracked via integer ranks: every parent-child rank difference is
+ * 1 or 2, leaves have rank 0, and NULL has conceptual rank -1.
+ */
+
+struct wavl_node {
+	unsigned long __wavl_parent;
+	struct wavl_node *wavl_right;
+	struct wavl_node *wavl_left;
+	int rank;
+} __attribute__((aligned(sizeof(long))));
+
+struct wavl_root {
+	struct wavl_node *wavl_node;
+};
+
+struct wavl_root_cached {
+	struct wavl_root wavl_root;
+	struct wavl_node *wavl_leftmost;
+};
+
+#define WAVL_ROOT (struct wavl_root) { NULL, }
+#define WAVL_ROOT_CACHED (struct wavl_root_cached) { {NULL, }, NULL }
+
+#endif
