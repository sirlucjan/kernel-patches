diff --git a/lib/wavl.c b/lib/wavl.c
new file mode 100644
index 000000000..226d6c257
--- /dev/null
+++ b/lib/wavl.c
@@ -0,0 +1,553 @@
+// SPDX-License-Identifier: GPL-2.0-or-later
+/*
+ * Weak AVL (WAVL) Trees
+ *
+ * WAVL invariants:
+ *   - Every node carries a non-negative integer rank.
+ *   - Leaf rank = 0.  NULL (external) rank = -1.
+ *   - Parent-child rank difference is always 1 or 2.
+ *
+ * Insert: promote (rank++) up the spine while (0,1); at most 1
+ *   rotation (single or double) to finish.
+ * Delete: demote down the spine while (2,2)-leaf or (3,2)/(3,1 with
+ *   2,2-sibling); at most 1 rotation to finish.
+ */
+
+#include <linux/wavl_augmented.h>
+#include <linux/export.h>
+
+/* ----- helpers ----- */
+
+static inline int wavl_rank_of(struct wavl_node *n)
+{
+	return n ? n->rank : -1;
+}
+
+static inline int wavl_rank_diff(struct wavl_node *parent,
+				 struct wavl_node *child)
+{
+	return parent->rank - wavl_rank_of(child);
+}
+
+/*
+ * Rotation helper: old is replaced by new in the tree, and old
+ * becomes a child of new.  Parent pointer of new is set to old's
+ * former parent.
+ */
+static inline void
+__wavl_rotate_set_parents(struct wavl_node *old, struct wavl_node *new,
+			  struct wavl_root *root)
+{
+	struct wavl_node *parent = wavl_parent(old);
+
+	wavl_set_parent(new, parent);
+	wavl_set_parent(old, new);
+	__wavl_change_child(old, new, parent, root);
+}
+
+/* ----- insert rebalancing ----- */
+
+/*
+ * After linking a new rank-0 leaf with wavl_link_node(), call this to
+ * restore WAVL balance.
+ *
+ * Algorithm:
+ *   While the new node creates a 0-child (rank diff 0):
+ *     - If sibling has rank diff 1 → promote parent, continue up.
+ *     - If sibling has rank diff 2 → rotate (single or double), done.
+ */
+static __always_inline void
+__wavl_insert(struct wavl_node *node, struct wavl_root *root,
+	      void (*augment_rotate)(struct wavl_node *old,
+				     struct wavl_node *new))
+{
+	struct wavl_node *parent = wavl_parent(node), *tmp;
+
+	/*
+	 * Promote loop: while parent is a (0,1) node, promote it so
+	 * rank differences become (1,2).  This may cascade upward.
+	 */
+	while (parent) {
+		int ld = wavl_rank_diff(parent, parent->wavl_left);
+		int rd = wavl_rank_diff(parent, parent->wavl_right);
+
+		if (ld + rd != 1)
+			break;
+
+		parent->rank++;
+		node = parent;
+		parent = wavl_parent(node);
+	}
+
+	if (!parent || wavl_rank_diff(parent, node) != 0)
+		return;
+
+	/*
+	 * Rotation needed: parent is a (0,2) node.
+	 */
+	if (parent->wavl_left == node) {
+		tmp = node->wavl_right;
+		if (!tmp || wavl_rank_diff(node, tmp) == 2) {
+			/*
+			 * Single right rotation at parent.
+			 *
+			 *        P(r)            N(r)
+			 *       / \             / \
+			 *     N(r) S(r-2) → .   P(r-1)
+			 *    / \                / \
+			 *   .   T              T   S
+			 */
+			struct wavl_node *mid = node->wavl_right;
+
+			WRITE_ONCE(parent->wavl_left, mid);
+			WRITE_ONCE(node->wavl_right, parent);
+			if (mid)
+				wavl_set_parent(mid, parent);
+			__wavl_rotate_set_parents(parent, node, root);
+			augment_rotate(parent, node);
+			parent->rank--;
+		} else {
+			/*
+			 * Double rotation: left at node, right at parent.
+			 *
+			 *      P             T
+			 *     / \           / \
+			 *    N   S   →    N     P
+			 *     \          / \   / \
+			 *      T        .   . .   S
+			 */
+			/* tmp == node->wavl_right == T */
+			struct wavl_node *tl = tmp->wavl_left;
+			struct wavl_node *tr = tmp->wavl_right;
+
+			WRITE_ONCE(node->wavl_right, tl);
+			WRITE_ONCE(tmp->wavl_left, node);
+			if (tl)
+				wavl_set_parent(tl, node);
+			wavl_set_parent(node, tmp);
+			augment_rotate(node, tmp);
+
+			WRITE_ONCE(parent->wavl_left, tr);
+			WRITE_ONCE(tmp->wavl_right, parent);
+			if (tr)
+				wavl_set_parent(tr, parent);
+			__wavl_rotate_set_parents(parent, tmp, root);
+			augment_rotate(parent, tmp);
+
+			tmp->rank++;
+			parent->rank--;
+			node->rank--;
+		}
+	} else {
+		/* Symmetric: node is right child */
+		tmp = node->wavl_left;
+		if (!tmp || wavl_rank_diff(node, tmp) == 2) {
+			/* Single left rotation at parent */
+			struct wavl_node *mid = node->wavl_left;
+
+			WRITE_ONCE(parent->wavl_right, mid);
+			WRITE_ONCE(node->wavl_left, parent);
+			if (mid)
+				wavl_set_parent(mid, parent);
+			__wavl_rotate_set_parents(parent, node, root);
+			augment_rotate(parent, node);
+			parent->rank--;
+		} else {
+			/* Double rotation: right at node, left at parent */
+			struct wavl_node *tl = tmp->wavl_left;
+			struct wavl_node *tr = tmp->wavl_right;
+
+			WRITE_ONCE(node->wavl_left, tr);
+			WRITE_ONCE(tmp->wavl_right, node);
+			if (tr)
+				wavl_set_parent(tr, node);
+			wavl_set_parent(node, tmp);
+			augment_rotate(node, tmp);
+
+			WRITE_ONCE(parent->wavl_right, tl);
+			WRITE_ONCE(tmp->wavl_left, parent);
+			if (tl)
+				wavl_set_parent(tl, parent);
+			__wavl_rotate_set_parents(parent, tmp, root);
+			augment_rotate(parent, tmp);
+
+			tmp->rank++;
+			parent->rank--;
+			node->rank--;
+		}
+	}
+}
+
+/* ----- erase rebalancing ----- */
+
+/*
+ * After BST removal (__wavl_erase_augmented), rebalance from @parent
+ * which is the parent of the physically removed node.
+ *
+ * Algorithm:
+ *   1. Fix (2,2)-leaves: demote and continue upward.
+ *   2. Fix 3-children:
+ *      a. (3,2): demote parent, continue.
+ *      b. (3,1) with (2,2)-sibling: double demote, continue.
+ *      c. Otherwise: rotate (single or double), done.
+ */
+static __always_inline void
+____wavl_erase_rebalance(struct wavl_node *parent, struct wavl_root *root,
+	void (*augment_rotate)(struct wavl_node *old, struct wavl_node *new))
+{
+	struct wavl_node *sibling, *tmp;
+
+	while (parent) {
+		struct wavl_node *left = parent->wavl_left;
+		struct wavl_node *right = parent->wavl_right;
+		int ld = wavl_rank_diff(parent, left);
+		int rd = wavl_rank_diff(parent, right);
+
+		/* Valid tree: no violation */
+		if (ld <= 2 && rd <= 2) {
+			/* (2,2)-leaf: demote and check upward */
+			if (ld == 2 && rd == 2 && !left && !right) {
+				parent->rank = 0;
+				parent = wavl_parent(parent);
+				continue;
+			}
+			break;
+		}
+
+		if (ld == 3) {
+			/* Left deficit: sibling is on the right */
+			sibling = right;
+
+			if (rd == 2) {
+				/* (3,2): demote parent */
+				parent->rank--;
+				parent = wavl_parent(parent);
+				continue;
+			}
+
+			/* rd == 1 */
+			{
+				int sl = wavl_rank_diff(sibling,
+							sibling->wavl_left);
+				int sr = wavl_rank_diff(sibling,
+							sibling->wavl_right);
+
+				if (sl == 2 && sr == 2) {
+					/* Double demote */
+					parent->rank--;
+					sibling->rank--;
+					parent = wavl_parent(parent);
+					continue;
+				}
+
+				if (sr == 1) {
+					/*
+					 * Single left rotation at parent.
+					 *
+					 *    P              S
+					 *   / \            / \
+					 *  n   S    →    P   Sr
+					 *     / \       / \
+					 *    Sl  Sr    n   Sl
+					 */
+					tmp = sibling->wavl_left;
+					WRITE_ONCE(parent->wavl_right, tmp);
+					WRITE_ONCE(sibling->wavl_left, parent);
+					if (tmp)
+						wavl_set_parent(tmp, parent);
+					__wavl_rotate_set_parents(parent,
+								  sibling,
+								  root);
+					augment_rotate(parent, sibling);
+					sibling->rank++;
+					if (!parent->wavl_left &&
+					    !parent->wavl_right)
+						parent->rank -= 2;
+					else
+						parent->rank--;
+					break;
+				}
+
+				/* sr == 2 && sl == 1: double rotation */
+				{
+					struct wavl_node *s_left =
+						sibling->wavl_left;
+					struct wavl_node *sll =
+						s_left->wavl_left;
+					struct wavl_node *slr =
+						s_left->wavl_right;
+
+					/* Right rotate at sibling */
+					WRITE_ONCE(sibling->wavl_left, slr);
+					WRITE_ONCE(s_left->wavl_right,
+						   sibling);
+					if (slr)
+						wavl_set_parent(slr, sibling);
+					wavl_set_parent(sibling, s_left);
+					augment_rotate(sibling, s_left);
+
+					/* Left rotate at parent */
+					WRITE_ONCE(parent->wavl_right, sll);
+					WRITE_ONCE(s_left->wavl_left, parent);
+					if (sll)
+						wavl_set_parent(sll, parent);
+					__wavl_rotate_set_parents(parent,
+								  s_left,
+								  root);
+					augment_rotate(parent, s_left);
+
+					parent->rank -= 2;
+					s_left->rank += 2;
+					sibling->rank--;
+					break;
+				}
+			}
+		}
+
+		if (rd == 3) {
+			/* Right deficit: sibling is on the left (symmetric) */
+			sibling = left;
+
+			if (ld == 2) {
+				parent->rank--;
+				parent = wavl_parent(parent);
+				continue;
+			}
+
+			/* ld == 1 */
+			{
+				int sl = wavl_rank_diff(sibling,
+							sibling->wavl_left);
+				int sr = wavl_rank_diff(sibling,
+							sibling->wavl_right);
+
+				if (sl == 2 && sr == 2) {
+					parent->rank--;
+					sibling->rank--;
+					parent = wavl_parent(parent);
+					continue;
+				}
+
+				if (sl == 1) {
+					/* Single right rotation at parent */
+					tmp = sibling->wavl_right;
+					WRITE_ONCE(parent->wavl_left, tmp);
+					WRITE_ONCE(sibling->wavl_right,
+						   parent);
+					if (tmp)
+						wavl_set_parent(tmp, parent);
+					__wavl_rotate_set_parents(parent,
+								  sibling,
+								  root);
+					augment_rotate(parent, sibling);
+					sibling->rank++;
+					if (!parent->wavl_left &&
+					    !parent->wavl_right)
+						parent->rank -= 2;
+					else
+						parent->rank--;
+					break;
+				}
+
+				/* sl == 2 && sr == 1: double rotation */
+				{
+					struct wavl_node *s_right =
+						sibling->wavl_right;
+					struct wavl_node *srl =
+						s_right->wavl_left;
+					struct wavl_node *srr =
+						s_right->wavl_right;
+
+					/* Left rotate at sibling */
+					WRITE_ONCE(sibling->wavl_right, srl);
+					WRITE_ONCE(s_right->wavl_left,
+						   sibling);
+					if (srl)
+						wavl_set_parent(srl, sibling);
+					wavl_set_parent(sibling, s_right);
+					augment_rotate(sibling, s_right);
+
+					/* Right rotate at parent */
+					WRITE_ONCE(parent->wavl_left, srr);
+					WRITE_ONCE(s_right->wavl_right,
+						   parent);
+					if (srr)
+						wavl_set_parent(srr, parent);
+					__wavl_rotate_set_parents(parent,
+								  s_right,
+								  root);
+					augment_rotate(parent, s_right);
+
+					parent->rank -= 2;
+					s_right->rank += 2;
+					sibling->rank--;
+					break;
+				}
+			}
+		}
+
+		break; /* should not be reached */
+	}
+}
+
+/* Non-augmented erase rebalance (exported) */
+void __wavl_erase_rebalance(struct wavl_node *parent, struct wavl_root *root,
+	void (*augment_rotate)(struct wavl_node *old, struct wavl_node *new))
+{
+	____wavl_erase_rebalance(parent, root, augment_rotate);
+}
+EXPORT_SYMBOL(__wavl_erase_rebalance);
+
+/* ----- Non-augmented wrappers ----- */
+
+static inline void dummy_propagate(struct wavl_node *n, struct wavl_node *s) {}
+static inline void dummy_copy(struct wavl_node *o, struct wavl_node *n) {}
+static inline void dummy_rotate(struct wavl_node *o, struct wavl_node *n) {}
+
+static const struct wavl_augment_callbacks dummy_callbacks = {
+	.propagate = dummy_propagate,
+	.copy = dummy_copy,
+	.rotate = dummy_rotate,
+};
+
+void wavl_insert_rebalance(struct wavl_node *node, struct wavl_root *root)
+{
+	__wavl_insert(node, root, dummy_rotate);
+}
+EXPORT_SYMBOL(wavl_insert_rebalance);
+
+void __wavl_insert_augmented(struct wavl_node *node, struct wavl_root *root,
+	void (*augment_rotate)(struct wavl_node *old, struct wavl_node *new))
+{
+	__wavl_insert(node, root, augment_rotate);
+}
+EXPORT_SYMBOL(__wavl_insert_augmented);
+
+void wavl_erase(struct wavl_node *node, struct wavl_root *root)
+{
+	struct wavl_node *rebalance;
+
+	rebalance = __wavl_erase_augmented(node, root, &dummy_callbacks);
+	if (rebalance)
+		____wavl_erase_rebalance(rebalance, root, dummy_rotate);
+}
+EXPORT_SYMBOL(wavl_erase);
+
+/* ----- Iteration ----- */
+
+struct wavl_node *wavl_first(const struct wavl_root *root)
+{
+	struct wavl_node *n = root->wavl_node;
+
+	if (!n)
+		return NULL;
+	while (n->wavl_left)
+		n = n->wavl_left;
+	return n;
+}
+EXPORT_SYMBOL(wavl_first);
+
+struct wavl_node *wavl_last(const struct wavl_root *root)
+{
+	struct wavl_node *n = root->wavl_node;
+
+	if (!n)
+		return NULL;
+	while (n->wavl_right)
+		n = n->wavl_right;
+	return n;
+}
+EXPORT_SYMBOL(wavl_last);
+
+struct wavl_node *wavl_next(const struct wavl_node *node)
+{
+	struct wavl_node *parent;
+
+	if (WAVL_EMPTY_NODE(node))
+		return NULL;
+
+	if (node->wavl_right) {
+		node = node->wavl_right;
+		while (node->wavl_left)
+			node = node->wavl_left;
+		return (struct wavl_node *)node;
+	}
+
+	while ((parent = wavl_parent(node)) && node == parent->wavl_right)
+		node = parent;
+
+	return parent;
+}
+EXPORT_SYMBOL(wavl_next);
+
+struct wavl_node *wavl_prev(const struct wavl_node *node)
+{
+	struct wavl_node *parent;
+
+	if (WAVL_EMPTY_NODE(node))
+		return NULL;
+
+	if (node->wavl_left) {
+		node = node->wavl_left;
+		while (node->wavl_right)
+			node = node->wavl_right;
+		return (struct wavl_node *)node;
+	}
+
+	while ((parent = wavl_parent(node)) && node == parent->wavl_left)
+		node = parent;
+
+	return parent;
+}
+EXPORT_SYMBOL(wavl_prev);
+
+void wavl_replace_node(struct wavl_node *victim, struct wavl_node *new,
+		       struct wavl_root *root)
+{
+	struct wavl_node *parent = wavl_parent(victim);
+
+	*new = *victim;
+
+	if (victim->wavl_left)
+		wavl_set_parent(victim->wavl_left, new);
+	if (victim->wavl_right)
+		wavl_set_parent(victim->wavl_right, new);
+	__wavl_change_child(victim, new, parent, root);
+}
+EXPORT_SYMBOL(wavl_replace_node);
+
+static struct wavl_node *wavl_left_deepest_node(const struct wavl_node *node)
+{
+	for (;;) {
+		if (node->wavl_left)
+			node = node->wavl_left;
+		else if (node->wavl_right)
+			node = node->wavl_right;
+		else
+			return (struct wavl_node *)node;
+	}
+}
+
+struct wavl_node *wavl_next_postorder(const struct wavl_node *node)
+{
+	const struct wavl_node *parent;
+
+	if (!node)
+		return NULL;
+	parent = wavl_parent(node);
+
+	if (parent && node == parent->wavl_left && parent->wavl_right)
+		return wavl_left_deepest_node(parent->wavl_right);
+	else
+		return (struct wavl_node *)parent;
+}
+EXPORT_SYMBOL(wavl_next_postorder);
+
+struct wavl_node *wavl_first_postorder(const struct wavl_root *root)
+{
+	if (!root->wavl_node)
+		return NULL;
+
+	return wavl_left_deepest_node(root->wavl_node);
+}
+EXPORT_SYMBOL(wavl_first_postorder);
