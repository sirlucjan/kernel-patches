diff --git a/include/linux/rbtree_wavl.h b/include/linux/rbtree_wavl.h
new file mode 100644
index 000000000..12bd6110e
--- /dev/null
+++ b/include/linux/rbtree_wavl.h
@@ -0,0 +1,79 @@
+/* SPDX-License-Identifier: GPL-2.0-or-later */
+#ifndef _LINUX_RBTREE_WAVL_H
+#define _LINUX_RBTREE_WAVL_H
+
+/*
+ * WAVL-backed rbtree API proxy.
+ *
+ * Include this INSTEAD of <linux/rbtree.h> to transparently
+ * replace red-black tree operations with WAVL tree operations
+ * while keeping the rb_* naming convention.
+ */
+
+#include <linux/wavl.h>
+#include <linux/rbtree_wavl_types.h>
+
+/* Core accessors */
+#undef rb_parent
+#undef rb_entry
+#define rb_parent		wavl_parent
+#define rb_entry		wavl_entry
+
+/* State checks */
+#undef RB_EMPTY_ROOT
+#undef RB_EMPTY_NODE
+#undef RB_CLEAR_NODE
+#define RB_EMPTY_ROOT		WAVL_EMPTY_ROOT
+#define RB_EMPTY_NODE		WAVL_EMPTY_NODE
+#define RB_CLEAR_NODE		WAVL_CLEAR_NODE
+
+/* Tree operations */
+#undef rb_insert_color
+#undef rb_erase
+#define rb_insert_color		wavl_insert_rebalance
+#define rb_erase		wavl_erase
+
+/* Traversal */
+#undef rb_next
+#undef rb_prev
+#undef rb_first
+#undef rb_last
+#undef rb_first_postorder
+#undef rb_next_postorder
+#define rb_next			wavl_next
+#define rb_prev			wavl_prev
+#define rb_first		wavl_first
+#define rb_last			wavl_last
+#define rb_first_postorder	wavl_first_postorder
+#define rb_next_postorder	wavl_next_postorder
+
+/* Replacement */
+#undef rb_replace_node
+#undef rb_replace_node_cached
+#define rb_replace_node		wavl_replace_node
+#define rb_replace_node_cached	wavl_replace_node_cached
+
+/* Insertion helper */
+#undef rb_link_node
+#define rb_link_node		wavl_link_node
+
+/* Safe entry access */
+#undef rb_entry_safe
+#define rb_entry_safe		wavl_entry_safe
+
+/* Iteration */
+#undef rbtree_postorder_for_each_entry_safe
+#define rbtree_postorder_for_each_entry_safe \
+				rbtree_postorder_for_each_entry_safe_wavl
+
+/* Cached (leftmost) variants */
+#undef rb_first_cached
+#undef rb_insert_color_cached
+#undef rb_erase_cached
+#undef rb_add_cached
+#define rb_first_cached		wavl_first_cached
+#define rb_insert_color_cached	wavl_insert_rebalance_cached
+#define rb_erase_cached		wavl_erase_cached
+#define rb_add_cached		wavl_add_cached
+
+#endif	/* _LINUX_RBTREE_WAVL_H */
