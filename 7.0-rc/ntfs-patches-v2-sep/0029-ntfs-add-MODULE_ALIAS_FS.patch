From ee8646829b9e702aab8d2b3502f6821fb2584f90 Mon Sep 17 00:00:00 2001
From: Woody Suwalski <terraluna977@gmail.com>
Date: Thu, 5 Mar 2026 17:35:48 +0900
Subject: [PATCH 29/43] ntfs: add MODULE_ALIAS_FS

Add missing MODUE_ALIAS record to the ntfs driver to allow automatic
loading of the module.

Signed-off-by: Woody Suwalski <terraluna977@gmail.com>
Signed-off-by: Namjae Jeon <linkinjeon@kernel.org>
---
 fs/ntfs/super.c | 1 +
 1 file changed, 1 insertion(+)

diff --git a/fs/ntfs/super.c b/fs/ntfs/super.c
index 830dfc5ae..39a5c3b81 100644
--- a/fs/ntfs/super.c
+++ b/fs/ntfs/super.c
@@ -2630,6 +2630,7 @@ static struct file_system_type ntfs_fs_type = {
 	.kill_sb                = kill_block_super,
 	.fs_flags               = FS_REQUIRES_DEV | FS_ALLOW_IDMAP,
 };
+MODULE_ALIAS_FS("ntfs");
 
 static int ntfs_workqueue_init(void)
 {
-- 
2.53.0

