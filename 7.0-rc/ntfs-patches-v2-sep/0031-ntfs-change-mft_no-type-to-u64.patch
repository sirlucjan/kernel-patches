+				"Not enough memory to complete mapping for inode 0x%llx. Returning 0.",
 				ni->mft_no);
 			break;
 		default:
 			ntfs_error(vol->sb,
-				"Failed to complete mapping for inode 0x%lx.  Run chkdsk. Returning 0.",
+				"Failed to complete mapping for inode 0x%llx.  Run chkdsk. Returning 0.",
 				ni->mft_no);
 			break;
 		}
