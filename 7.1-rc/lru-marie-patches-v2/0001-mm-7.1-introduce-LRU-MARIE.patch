diff --git a/mm/lru_marie.c b/mm/lru_marie.c
new file mode 100644
index 000000000..bf9658881
--- /dev/null
+++ b/mm/lru_marie.c
@@ -0,0 +1,2406 @@
+// SPDX-License-Identifier: GPL-2.0
+/*
+ * mm/lru_marie.c — Marie LRU.
+ *
+ * Multi-graded Adaptive Reclaim & Independent Eviction (Marie)
+ *
+ * Architecture in one paragraph (see mm/Kconfig::LRU_MARIE for the
+ * MGLRU bottlenecks this works around — forced inc_min_seq treadmill
+ * and shared max_seq across anon/file):
+ *   - per-CPU lock-free pending queues at the fault path; sl->lock is
+ *     never taken on add
+ *   - per-lruvec sl with private gens and per-type state (anon / file
+ *     fully independent: separate iteration counters, separate ring)
+ *   - per-pgdat walker driven from reclaim, with rmap-fed bloom
+ *     feedback so PMD scans concentrate on hot regions
+ *   - dynamic gen list (no MAX_NR_GENS cap)
+ *   - SIMD PTE young-bit batch scan with boot-time AVX-512F / AVX2 /
+ *     SSE2 dispatch on x86; scalar fallback on arm64 and elsewhere
+ *
+ * Core types:
+ *
+ *   struct marie_gen     — one generation; folios linked directly via
+ *                        folio->lru into per-(type, zone) gen lists
+ *   struct marie_type    — per-type list of generations (anon / file)
+ *   struct marie_lruvec  — Marie's per-lruvec state (anon + file types)
+ *
+ *   marie_lruvec_xa      — side-channel xarray:
+ *                          key  = (unsigned long)lruvec pointer
+ *                          val  = struct marie_lruvec *
+ *
+ *   marie_get_lruvec()   — lazy lookup/allocation
+ *   marie_drop_lruvec()  — remove and free one entry
+ *   lru_marie_exit_memcg()   — drop all entries belonging to a dying memcg
+ */
+
+#define pr_fmt(fmt) "lru_marie: " fmt
+
+#include <linux/cpuhotplug.h>
+#include <linux/hash.h>
+#include <linux/init.h>
+#include <linux/jiffies.h>
+#include <linux/jump_label.h>
+#include <linux/kobject.h>
+#include <linux/list.h>
+#include <linux/llist.h>
+#include <linux/memcontrol.h>
+#include <linux/mm.h>
+#include <linux/mm_inline.h>
+#include <linux/mmzone.h>
+#include <linux/pagewalk.h>
+#include <linux/percpu.h>
+#include <linux/printk.h>
+#include <linux/rmap.h>
+#include <linux/sched.h>
+#include <linux/sched/mm.h>
+#include <linux/sched/signal.h>
+#include <linux/lru_marie.h>
+#include <linux/lru_marie_simd.h>
+#include <linux/slab.h>
+#include <linux/spinlock.h>
+#include <linux/swap.h>
+#include <linux/sysfs.h>
+#include <linux/vmstat.h>
+#include <linux/workqueue.h>
+#include <linux/writeback.h>
+#include <linux/xarray.h>
+
+#include "internal.h"		/* struct scan_control, shrink_folio_list */
+#include "lru_marie_residency.h"
+
+DEFINE_STATIC_KEY_TRUE(lru_marie_enabled_key);
+EXPORT_SYMBOL_GPL(lru_marie_enabled_key);
+
+/*
+ * ---------------------------------------------------------------------
+ *  marie_pending — per-CPU lock-free queues for fault and walker promote
+ * ---------------------------------------------------------------------
+ *
+ * The fault path and walker hot path are decoupled from sl->lock by
+ * deferring all sl-state mutations through two per-CPU lock-free
+ * queues:
+ *
+ *   marie_add_queue     — enqueued by lru_marie_add_folio() at fault time;
+ *                       drained at marie_isolate_folios() entry under
+ *                       sl->lock, where the folio is list_add'd into the
+ *                       head gen's per-(type, zone) folio list.
+ *   marie_promote_queue — enqueued by marie_walk_pmd_range() when a young
+ *                       PTE references a folio whose tier was already
+ *                       saturated (MARIE_TIER_WIDTH max); drained the
+ *                       same way and the folio is list_move'd to the head
+ *                       gen + tier 0.
+ *
+ * Each pending entry holds a folio reference (folio_get) so the folio
+ * cannot be freed while it is queued. The reference is dropped when
+ * the drain processes the entry.
+ *
+ * Cross-memcg: per-CPU queues collect entries from any lruvec; the
+ * drain only processes entries whose folio_lruvec() matches the
+ * caller's sl. Mismatched entries are re-enqueued and will be picked
+ * up by the next call into marie_isolate_folios for the matching sl.
+ */
+
+/*
+ * struct marie_pending, the per-CPU marie_add_queue / marie_promote_queue /
+ * marie_deferred_put_q / marie_drain_depth, and the helpers
+ * marie_pending_alloc/free, marie_defer_pending_put, marie_defer_folio_put,
+ * marie_drain_deferred_puts, marie_drain_enter/exit/in_drain now live in
+ * the residency ADT (mm/lru_marie_residency.{c,h}).
+ */
+
+/*
+ * ---------------------------------------------------------------------
+ *  data structures (struct definitions live in mm/lru_marie_residency.h)
+ * ---------------------------------------------------------------------
+ *
+ * struct marie_gen / marie_type / marie_lruvec, the MARIE_MIN/MAX_NR_GENS and
+ * MARIE_NR_TIERS / MARIE_TIER_MAX / MARIE_ISOLATE_BATCH constants, and
+ * the marie_gen slab cache and its alloc/free helpers
+ * (marie_alloc_lruvec, marie_free_lruvec, marie_advance_max_seq,
+ * marie_try_drop_oldest, marie_age, marie_age_on_add,
+ * marie_get_or_create_gen, marie_nr_gens) now live in the residency
+ * ADT.  Runtime-tunable knobs (marie_gen_growth_threshold,
+ * marie_add_watermark, etc.) live in the sysfs section at the bottom
+ * of this file.  Lifecycle (xarray lookup, RCU defer, memcg teardown)
+ * stays here.
+ */
+
+/*
+ * Side-channel mapping: lruvec pointer → struct marie_lruvec.
+ *
+ * XA_FLAGS_LOCK_IRQ so xa_load/xa_store are safe from atomic contexts
+ * (folio_add_lru can run with irqs disabled).
+ */
+DEFINE_XARRAY_FLAGS(marie_lruvec_xa, XA_FLAGS_LOCK_IRQ);
+static atomic_long_t marie_nr_lruvecs;
+
+/*
+ * Exported via mm/lru_marie_residency.h for ADT internals (install / promote
+ * / drain helpers in mm/lru_marie_residency.c) to update during transitions.
+ * Lifecycle (stats_show) keeps reading via this same atomic.
+ */
+atomic_long_t marie_nr_folios;
+
+/**
+ * marie_get_lruvec - lookup or lazily allocate the Marie state for @lv.
+ *
+ * Returns NULL if Marie is disabled (so callers can skip cheaply) or if
+ * an atomic-context allocation fails.  Otherwise returns the per-lruvec
+ * state, which lives until marie_drop_lruvec() or lru_marie_exit_memcg().
+ */
+static struct marie_lruvec *marie_get_lruvec(struct lruvec *lv)
+{
+	struct marie_lruvec *sl, *old;
+	gfp_t gfp;
+
+	if (!lru_marie_enabled())
+		return NULL;
+
+	sl = xa_load(&marie_lruvec_xa, (unsigned long)lv);
+	if (likely(sl))
+		return sl;
+
+	/* Use GFP_ATOMIC to be safe from any context.  The first hit
+	 * for any given lruvec pays this cost; subsequent xa_loads are
+	 * cheap. */
+	gfp = (in_task() && !irqs_disabled()) ? GFP_KERNEL : GFP_ATOMIC;
+	sl = marie_alloc_lruvec(lv, gfp);
+	if (!sl)
+		return NULL;
+
+	old = xa_cmpxchg(&marie_lruvec_xa, (unsigned long)lv, NULL, sl, gfp);
+	if (xa_is_err(old)) {
+		marie_free_lruvec(sl);
+		return NULL;
+	}
+	if (old) {
+		/* lost the race; another CPU allocated first */
+		marie_free_lruvec(sl);
+		return old;
+	}
+
+	atomic_long_inc(&marie_nr_lruvecs);
+	return sl;
+}
+
+/* Forward declaration: drain implementation lives further down with
+ * marie_fill_one_lruvec near the change_state machinery. */
+static void marie_drain_one_lruvec(struct lruvec *lruvec);
+
+static void marie_drop_lruvec(struct lruvec *lv)
+{
+	struct marie_lruvec *sl;
+
+	/*
+	 * Atomic "drain + xa_erase" under @lv->lru_lock.
+	 *
+	 * The previous order — xa_erase first, then later free — opened a
+	 * structural race during shutdown / memcg teardown:
+	 *
+	 *   T0: xa_erase(@lv) -- @sl is no longer reachable via xa_load.
+	 *   T1: a concurrent folio_put on a still-RESIDENT folio (whose
+	 *       page table mapping just got torn down) reaches
+	 *       __page_cache_release -> lruvec_del_folio ->
+	 *       lru_marie_del_folio.
+	 *   T2: lru_marie_del_folio's TRACKED check passes (folio still
+	 *       has MARIE_TRACKED=1 from install), but xa_load(@lv)
+	 *       returns NULL because of T0. The fallback path clears
+	 *       MARIE_STATE_MASK and returns true so the dispatcher
+	 *       skips legacy list_del — but the folio is STILL LINKED
+	 *       into the orphan gen list of @sl, with its prev/next
+	 *       still pointing at neighbours that are about to be freed.
+	 *   T3: the folio is freed via free_frozen_pages. Its struct
+	 *       page is reused; its lru pointers are scribbled.
+	 *   T4: marie_free_lruvec -> marie_type_destroy iterates the
+	 *       gen list and dereferences the now-corrupt folio,
+	 *       crashing at __page_cache_release.part.0+0x... with the
+	 *       canonical NULL+0x8 (entry->next->prev where entry->next
+	 *       is the scribbled NULL).
+	 *
+	 * Draining the gen lists (moving folios back to the legacy LRU
+	 * and clearing MARIE_STATE_MASK on each) under the same lru_lock
+	 * that brackets xa_erase closes the race: every TRACKED bit for
+	 * this lv is cleared *before* we publish the xa_erase, so the
+	 * fallback path described at T2 is reached only with TRACKED=0
+	 * (which short-circuits at the earlier check). lru_marie_add_folio
+	 * holds lru_lock too, so it cannot install new TRACKED folios
+	 * during our critical section.
+	 *
+	 * Drain itself does not sleep — it operates entirely on gen
+	 * lists, the per-CPU pending-wrapper pool, and atomic counters,
+	 * so it is safe inside spin_lock_irq.
+	 *
+	 * drop_lruvec is rare (toggle / memcg teardown); the extra drain
+	 * work paid here is not on any hot path.
+	 */
+	/*
+	 * Pin the CPU across drain + deferred-put drain. The residue
+	 * path inside marie_drain_one_lruvec enqueues onto the local
+	 * CPU's marie_deferred_put_q under spin_lock_irq; once we
+	 * spin_unlock the task can migrate before
+	 * marie_drain_deferred_puts() reads this_cpu_ptr, leaking the
+	 * just-enqueued wrappers and their folio_get references.
+	 *
+	 * migrate_disable keeps producer and consumer on the same CPU
+	 * without disabling preemption.
+	 */
+	migrate_disable();
+	spin_lock_irq(&lv->lru_lock);
+	marie_drain_one_lruvec(lv);
+	sl = xa_erase(&marie_lruvec_xa, (unsigned long)lv);
+	spin_unlock_irq(&lv->lru_lock);
+
+	/*
+	 * Drain folio_puts deferred by marie_drain_one_lruvec's residue
+	 * handling. Must happen with lru_lock released because the
+	 * deferred puts may recurse into __page_cache_release, which
+	 * re-acquires lru_lock.
+	 */
+	marie_drain_deferred_puts();
+	migrate_enable();
+
+	if (!sl)
+		return;
+	atomic_long_dec(&marie_nr_lruvecs);
+
+	/*
+	 * Wait for any walker (xa_for_each under rcu_read_lock) that may
+	 * have observed @sl before the xa_erase. The walker does not
+	 * take lru_lock so the spinlock dance above does not cover it.
+	 */
+	synchronize_rcu();
+
+	/*
+	 * Producers that scheduled the drain_worker before our xa_erase
+	 * (under lru_lock, so necessarily before our drain started) may
+	 * still have a queued or running work item on @sl. After our
+	 * drain the queues are empty, but the work_struct itself can be
+	 * pending; cancel_work_sync waits for it. After the xa_erase no
+	 * new schedules can target @sl (producers reach xa_load -> NULL
+	 * and bail), so this wait is bounded.
+	 */
+	cancel_work_sync(&sl->drain_work);
+	marie_free_lruvec(sl);
+}
+
+/*
+ * ---------------------------------------------------------------------
+ *  generation lifecycle (helpers in mm/lru_marie_residency.c)
+ * ---------------------------------------------------------------------
+ *
+ * Marie keeps a small ring of generations per (lruvec, type), like
+ * MGLRU. Aging is driven by three signals:
+ *
+ *   - lru_marie_add_folio always lands on the head gen (newest).
+ *   - marie_isolate_folios always pulls from the tail gen (oldest).
+ *   - shrink_folio_list classifies each isolated folio:
+ *       FOLIOREF_RECLAIM  → freed (this folio truly was cold)
+ *       FOLIOREF_KEEP     → returned in folio_list, putback re-routes
+ *       FOLIOREF_ACTIVATE → ditto, with PG_active set
+ *     putback re-installs the survivor in the head gen via
+ *     marie_putback_batch — a one-step promotion.
+ *   - When the tail gen empties, marie_try_drop_oldest frees it and
+ *     bumps oldest_seq, cascading the next-oldest into the tail
+ *     position.
+ *   - Before each isolation we call marie_age which tops the gen ring up
+ *     to MARIE_MIN_NR_GENS, allocating new head gens as needed but
+ *     never growing past MARIE_MAX_NR_GENS.
+ *
+ * The reclaim cycle alone does not surface every hot folio; a per-pgdat
+ * SIMD walker (mm/lru_marie_walker.c) clears young PTEs and bumps tier
+ * counts on RESIDENT folios. When tier saturates, the walker enqueues
+ * the folio onto sl->promote_queue; the next sl-locked drain moves it
+ * into the head gen at tier 0. The rmap path (lru_marie_look_around)
+ * feeds the walker via a per-pgdat bloom filter so PMD scans
+ * concentrate on regions the rmap recently flagged hot.
+ *
+ * The ring helpers (marie_nr_gens, marie_advance_max_seq, marie_try_drop_oldest,
+ * marie_age, marie_age_on_add, marie_get_or_create_gen) and the
+ * MARIE_*_NR_GENS / MARIE_NR_TIERS constants now live in the
+ * residency ADT (mm/lru_marie_residency.{c,h}).  The growth threshold
+ * is now the runtime variable marie_gen_growth_threshold (see sysfs).
+ */
+
+/*
+ * ---------------------------------------------------------------------
+ *  folio add / del
+ * ---------------------------------------------------------------------
+ */
+
+/*
+ * lru_marie_add_folio: lock-free producer.
+ *
+ * Fault path defers all sl-state mutation through the residency ADT's
+ * state-aware per-CPU enqueue: a CMPXCHG attempts NONE -> PENDING_ADD
+ * on folio->flags, and only on success does the ADT folio_get +
+ * marie_pending_alloc + llist_add the entry. The next call into
+ * marie_isolate_folios for the matching sl drains the queue under
+ * sl->lock and installs the folio. Duplicate enqueue is
+ * structurally impossible because losing the CMPXCHG -> noop.
+ *
+ * Skipped folio classes:
+ *
+ *   - Large folios (THPs): split-folio path treats folio->lru as a
+ *     list_head and races with Marie's gen-list link. THP-aware
+ *     tracking is a future-work item.
+ *
+ *   - Unevictable folios: struct folio overlays folio->lru with
+ *     folio->mlock_count via union (lru.prev's low 4 bytes ==
+ *     mlock_count). mm/mlock.c's __mlock_folio / __munlock_folio
+ *     write mlock_count directly while the folio is "owned" by an
+ *     lruvec but NOT on a list (legacy LRU intentionally skips
+ *     list_add for LRU_UNEVICTABLE — see mm_inline.h
+ *     lruvec_add_folio). If Marie list_add'd such folios into a
+ *     gen list, the mlock_count writes would clobber the gen
+ *     list's prev pointer's low 32 bits and corrupt the list. Pass
+ *     unevictable folios through to the legacy path so mlock_count
+ *     stays addressable.
+ */
+bool lru_marie_add_folio(struct lruvec *lv, struct folio *folio, bool reclaiming)
+{
+	struct marie_lruvec *sl;
+
+	if (!lru_marie_enabled())
+		return false;
+	if (folio_test_unevictable(folio))
+		return false;
+
+	sl = marie_get_lruvec(lv);
+	if (!sl)
+		return false;
+
+	/*
+	 * Large folios (THP) take a synchronous install path under sl->lock
+	 * instead of the lock-free PENDING_ADD enqueue. Rationale:
+	 *
+	 *   - THP fault rate is low compared to single-page faults; the
+	 *     lock-free producer optimisation is less critical here.
+	 *
+	 *   - Many code paths (Phase 1b reclaim accounting, walker filters,
+	 *     drain bookkeeping) assume "1 wrapper == 1 page". Avoiding
+	 *     wrappers for THPs sidesteps that invariant entirely.
+	 *
+	 *   - lru_lock is already held by the caller, so adding sl->lock is
+	 *     a single extra acquisition.
+	 *
+	 * NONE -> RESIDENT transits straight into the head gen via
+	 * __marie_install_locked, skipping the PENDING_ADD intermediate.
+	 */
+	if (folio_test_large(folio)) {
+		bool ok;
+		int type = folio_is_file_lru(folio);
+
+		scoped_guard(marie_type_sl, &sl->types[type])
+			ok = marie_transit(sl, folio, MARIE_R_NONE,
+					 MARIE_R_RESIDENT,
+					 &marie_transit_ctx_zero);
+		return ok;
+	}
+
+	return marie_residency_enqueue_add(sl, folio);
+}
+EXPORT_SYMBOL_GPL(lru_marie_add_folio);
+
+/**
+ * lru_marie_split_folio - install a freshly-split tail folio under Marie.
+ * @lv:        head folio's lruvec (caller holds lru_lock)
+ * @head:      THP head folio currently RESIDENT in Marie
+ * @new_folio: tail folio created by __split_huge_page
+ *
+ * Mirrors mm/huge_memory.c::lru_add_split_folio's
+ * "list_add_tail(&new_folio->lru, &folio->lru)" for the Marie case so
+ * that @new_folio:
+ *
+ *   - lands on @head's gen list (inheriting head's age, like the legacy
+ *     path), not on the head gen as a fresh install would
+ *   - carries MARIE_TRACKED so dispatcher del routes through Marie
+ *     (without TRACKED, the new tail would be on Marie's gen list but
+ *     dispatcher del would fall through to legacy update_lru_size,
+ *     bypassing sl->types[].nr_pages bookkeeping)
+ *
+ * Accounting note: lru_size and sl->types[].nr_pages are NOT
+ * incremented for @new_folio. The original head install +N covered the
+ * full pre-split compound, and each sub-folio's eventual del decrements
+ * by its own folio_nr_pages; the sum balances. marie_nr_folios IS
+ * incremented because it is a folio count, not a page count, and the
+ * post-split state has 1 + ntails folios where there was 1 before.
+ *
+ * Caller MUST hold @lv->lru_lock and have established that @head is
+ * Marie-tracked (folio_marie_test_tracked) before invoking this. The
+ * helper takes sl->lock internally.
+ *
+ * No-op (and returns) if @head is unevictable -- legacy
+ * lru_add_split_folio handles that branch separately, before calling
+ * here.
+ */
+void lru_marie_split_folio(struct lruvec *lv, struct folio *head,
+			 struct folio *new_folio)
+{
+	struct marie_lruvec *sl;
+
+	/*
+	 * Caller already checked lru_marie_enabled() via the static branch,
+	 * but @head may not be Marie-tracked (e.g. THP added to legacy LRU
+	 * because Marie alloc failed at the original add). Fall back to
+	 * plain list_add_tail in that case so @new_folio joins @head's
+	 * neighbour link on the legacy LRU list as it would have without
+	 * Marie.
+	 */
+	if (!folio_marie_test_tracked(head)) {
+		list_add_tail(&new_folio->lru, &head->lru);
+		return;
+	}
+
+	if (folio_test_unevictable(head))
+		return;
+
+	sl = marie_get_lruvec(lv);
+	if (!sl) {
+		/*
+		 * Race with marie_drop_lruvec or alloc failure. Fall back to
+		 * plain list_add_tail; @new_folio joins @head's neighbour
+		 * link without TRACKED. Future del routes to legacy del,
+		 * which does the symmetric -update_lru_size against the same
+		 * mz->lru_zone_size that Marie's install +1'd. Counter stays
+		 * balanced; only sl->types[].nr_pages and marie_nr_folios go
+		 * stale, which is acceptable for this rare transient case.
+		 */
+		list_add_tail(&new_folio->lru, &head->lru);
+		return;
+	}
+
+	/* Marie's invariant: clear PG_active before publishing TRACKED. */
+	if (folio_test_active(new_folio))
+		folio_clear_active(new_folio);
+
+	/* Head and new_folio share the same Marie type (folio split does
+	 * not change LRU category), so head's per-type lock guards both. */
+	scoped_guard(marie_type_sl, &sl->types[folio_is_file_lru(head)]) {
+		/*
+		 * Order mirrors __marie_install_locked: list link first, then
+		 * MARIE_TRACKED. PG_lru is set by the caller (lru_add_split_folio)
+		 * after this returns, satisfying the "TRACKED before PG_lru"
+		 * publishing rule.
+		 */
+		list_add_tail(&new_folio->lru, &head->lru);
+		set_mask_bits(&new_folio->flags.f, MARIE_STATE_MASK,
+			      MARIE_TRACKED_MASK);
+		atomic_long_inc(&marie_nr_folios);
+	}
+}
+EXPORT_SYMBOL_GPL(lru_marie_split_folio);
+
+bool lru_marie_del_folio(struct lruvec *lv, struct folio *folio, bool reclaiming)
+{
+	struct marie_lruvec *sl;
+	bool removed, was_resident;
+
+	/*
+	 * TRACKED takes priority over the lru_marie_enabled() gate.  A
+	 * folio with TRACKED=1 may still be on Marie's gen list /
+	 * add_queue / promote_queue after the gate flips false during a
+	 * disable transition: marie_change_state iterates lruvecs
+	 * serially, and between the gate flip and the per-lruvec
+	 * drain_one_lruvec there is a window where not-yet-drained
+	 * lruvecs hold TRACKED folios.  If we bailed at the gate here,
+	 * the dispatcher (mm_inline.h::lruvec_del_folio) would fall
+	 * through to legacy list_del, corrupting Marie's gen list,
+	 * tripping the mz->lru_zone_size underflow WARN, and producing
+	 * downstream "Bad page state" BUGs when the broken list
+	 * pointers cause a freed folio to be re-listed.
+	 *
+	 * Trusting TRACKED is safe regardless of the gate: TRACKED is
+	 * only ever set under Marie's residency ADT (CMPXCHG in
+	 * __marie_transit_*_to_pending_add / __marie_install_locked /
+	 * marie_fill_one_lruvec) and only ever cleared by Marie's del
+	 * paths or by drain_one_lruvec.
+	 */
+	if (!folio_marie_test_tracked(folio))
+		return false;
+
+	/*
+	 * Direct xa_load (rather than marie_get_lruvec) so we work
+	 * even when the gate is off mid-transition.  Race against
+	 * marie_drop_lruvec is closed by lru_lock serialisation:
+	 * marie_drop_lruvec's xa_erase runs under the same lv->lru_lock
+	 * that our caller (lruvec_del_folio) holds.
+	 */
+	sl = xa_load(&marie_lruvec_xa, (unsigned long)lv);
+	if (!sl) {
+		/*
+		 * @lv has no sl: Marie is gated off mid-flight (marie_disable
+		 * cleared all sls), or marie_alloc_lruvec(lv, GFP_ATOMIC) just
+		 * failed. The folio still carries TRACKED bits from a prior
+		 * sl that no longer exists. Clearing the residency bits and
+		 * returning true is safe — no live gen list references
+		 * @folio anywhere (post lru_reparent_memcg / marie_drop_lruvec).
+		 */
+		set_mask_bits(&folio->flags.f, MARIE_STATE_MASK, 0);
+		if (folio_test_active(folio))
+			folio_clear_active(folio);
+		return true;
+	}
+
+	{
+		int type = folio_is_file_lru(folio);
+
+		/*
+		 * Re-entrant drain: marie_in_drain_type(type) is true iff this
+		 * CPU is already inside a critical section that holds the
+		 * per-type lock for *this* folio's type. In that case the lock
+		 * is held by us via the outer guard and re-acquiring would
+		 * self-deadlock. Skip the lock and run the body directly.
+		 *
+		 * If the outer guard holds only the *other* type's lock
+		 * (marie_in_drain_type(type) == 0 even though we are inside
+		 * some drain on this CPU), the recursion is on a different
+		 * lock and we must take it here.
+		 */
+		if (marie_in_drain_type(type)) {
+			removed = marie_residency_del_folio_locked(sl, folio,
+							&was_resident);
+			if (removed && was_resident)
+				atomic_long_dec(&marie_nr_folios);
+			return removed;
+		}
+
+		scoped_guard(marie_type_sl, &sl->types[type])
+			removed = marie_residency_del_folio_locked(sl, folio,
+							&was_resident);
+	}
+
+	if (removed && was_resident)
+		atomic_long_dec(&marie_nr_folios);
+	return removed;
+}
+EXPORT_SYMBOL_GPL(lru_marie_del_folio);
+
+/*
+ * ---------------------------------------------------------------------
+ *  memcg lifecycle hook
+ * ---------------------------------------------------------------------
+ */
+
+void lru_marie_exit_memcg(struct mem_cgroup *memcg)
+{
+	int nid;
+
+	for_each_node(nid) {
+		struct lruvec *lv = mem_cgroup_lruvec(memcg, NODE_DATA(nid));
+
+		marie_drop_lruvec(lv);
+	}
+}
+EXPORT_SYMBOL_GPL(lru_marie_exit_memcg);
+
+void lru_marie_reparent_lruvec(struct lruvec *child_lv, struct lruvec *parent_lv)
+{
+	struct marie_lruvec *child_sl, *parent_sl;
+	long migrated;
+
+	if (!lru_marie_enabled())
+		return;
+
+	child_sl = xa_load(&marie_lruvec_xa, (unsigned long)child_lv);
+	if (!child_sl)
+		return;
+
+	/*
+	 * Best-effort parent_sl materialisation. We are called with both
+	 * lruvecs' lru_lock held and IRQs disabled (objcg_lock pinned by
+	 * memcontrol.c::reparent_locks), so marie_get_lruvec falls back to
+	 * GFP_ATOMIC. On allocation failure we still detach folios from
+	 * @child cleanly — they re-enter Marie via folio_add_lru on next
+	 * access, no stale gen list links remain.
+	 */
+	parent_sl = marie_get_lruvec(parent_lv);
+
+	/*
+	 * Reparent touches both per-type gen lists on child_sl; take both
+	 * locks in canonical order via the marie_both_sl guard. Caller has
+	 * IRQs disabled (objcg_lock pinned), matching the guard's
+	 * spin_lock_irqsave contract.
+	 */
+	scoped_guard(marie_both_sl, child_sl)
+		migrated = marie_residency_reparent_locked(child_sl, parent_sl);
+
+	/*
+	 * Folios left @child's RESIDENT count (marie_nr_folios was inc'd at
+	 * each install). Parent's drain will inc back when each folio
+	 * reaches RESIDENT — net zero across the migration. If parent_sl
+	 * was NULL the inc never happens and the count permanently
+	 * decreases by @migrated, which matches reality (those folios are
+	 * no longer Marie-tracked).
+	 */
+	if (migrated)
+		atomic_long_sub(migrated, &marie_nr_folios);
+}
+EXPORT_SYMBOL_GPL(lru_marie_reparent_lruvec);
+
+/*
+ * lru_marie_zone_size - Marie's per-(lru, zone) count for @lv.
+ *
+ * Composes the "total tracked on this lruvec for (lru, zid)" figure
+ * alongside mz->lru_zone_size (which is legacy-only after Marie was
+ * decoupled). lruvec_lru_size() sums both. Lock-free atomic read.
+ */
+unsigned long lru_marie_zone_size(struct lruvec *lv, enum lru_list lru, int zid)
+{
+	struct marie_lruvec *sl;
+	long val;
+
+	if (!lru_marie_enabled())
+		return 0;
+	sl = xa_load(&marie_lruvec_xa, (unsigned long)lv);
+	if (!sl)
+		return 0;
+	val = atomic_long_read(&sl->marie_lru_zone_size[lru][zid]);
+	return val > 0 ? (unsigned long)val : 0;
+}
+EXPORT_SYMBOL_GPL(lru_marie_zone_size);
+
+/*
+ * ---------------------------------------------------------------------
+ *  enable / disable
+ * ---------------------------------------------------------------------
+ */
+
+/*
+ * Per-lruvec migration helpers used by marie_change_state(). Caller
+ * holds @lruvec->lru_lock with IRQs disabled, which orders correctly
+ * against the inner sl->lock taken by the scoped_guard(marie_sl) below.
+ *
+ * marie_drain_one_lruvec(): move every folio out of @sl's gen lists
+ * (and any add_queue residue) onto @lruvec->lists[lru]. Clears Marie
+ * state bits per folio, then drops @sl from the lookup xarray and frees
+ * it. After return, the lruvec is purely legacy LRU.
+ *
+ * marie_fill_one_lruvec(): force-allocate @sl for @lruvec and pull
+ * every small evictable folio off @lruvec->lists[lru] into @sl's head
+ * gens. Sets the TRACKED bit per folio. After return, the lruvec's
+ * standard lru lists hold only large folios (which Marie never
+ * tracks) and unevictable folios.
+ */
+
+/* Non-allocating lookup; mirror of marie_get_lruvec without the
+ * lru_marie_enabled() gate (state-change runs while the gate is
+ * mid-flip). */
+static struct marie_lruvec *marie_lookup_lruvec(struct lruvec *lv)
+{
+	return xa_load(&marie_lruvec_xa, (unsigned long)lv);
+}
+
+/* As marie_get_lruvec() but bypasses the lru_marie_enabled() gate. */
+static struct marie_lruvec *marie_force_alloc_lruvec(struct lruvec *lv,
+						 gfp_t gfp)
+{
+	struct marie_lruvec *sl, *old;
+
+	sl = xa_load(&marie_lruvec_xa, (unsigned long)lv);
+	if (sl)
+		return sl;
+
+	sl = marie_alloc_lruvec(lv, gfp);
+	if (!sl)
+		return NULL;
+
+	old = xa_cmpxchg(&marie_lruvec_xa, (unsigned long)lv, NULL, sl, gfp);
+	if (xa_is_err(old)) {
+		marie_free_lruvec(sl);
+		return NULL;
+	}
+	if (old) {
+		marie_free_lruvec(sl);
+		return old;
+	}
+	atomic_long_inc(&marie_nr_lruvecs);
+	return sl;
+}
+
+static void marie_drain_one_lruvec(struct lruvec *lruvec)
+{
+	struct marie_lruvec *sl = marie_lookup_lruvec(lruvec);
+	int t, z;
+
+	if (!sl)
+		return;
+
+	scoped_guard(marie_both_sl, sl) {
+		/* Materialise every queued folio onto a gen list (or, on
+		 * install -ENOMEM, leave a wrapper on add_queue for the
+		 * residue pass below). */
+		marie_drain_add_queue_locked(sl);
+		marie_drain_promote_queue_locked(sl);
+
+		/* Move every gen-list folio onto its corresponding legacy
+		 * lru list. Bit clear publishes "no longer tracked" while
+		 * we still hold both per-type locks so a concurrent reader
+		 * cannot see the folio on the legacy list with TRACKED set. */
+		for (t = 0; t < ANON_AND_FILE; t++) {
+			struct marie_gen *g, *tmp_g;
+
+			list_for_each_entry_safe(g, tmp_g,
+						 &sl->types[t].gens, gen_node) {
+				for (z = 0; z < MAX_NR_ZONES; z++) {
+					struct folio *f, *next_f;
+
+					list_for_each_entry_safe(f, next_f,
+								 &g->folios[t][z],
+								 lru) {
+						long nr = folio_nr_pages(f);
+						enum lru_list lru;
+
+						set_mask_bits(&f->flags.f,
+							      MARIE_STATE_MASK,
+							      0);
+						/*
+						 * Mirror Marie's install
+						 * invariant: PG_active=0
+						 * before computing the lru
+						 * index, so the -nr on
+						 * marie_lru_zone_size lands
+						 * on the same INACTIVE
+						 * bucket Marie's install
+						 * +nr'd.
+						 */
+						if (folio_test_active(f))
+							folio_clear_active(f);
+						lru = folio_lru_list(f);
+						/*
+						 * Legacy LRU intentionally keeps
+						 * unevictable folios off any
+						 * list (mm_inline.h
+						 * lruvec_add_folio: skip
+						 * list_add for LRU_UNEVICTABLE)
+						 * so folio->mlock_count stays
+						 * addressable. With
+						 * commit "skip unevictable
+						 * folios in
+						 * lru_marie_add_folio" no
+						 * unevictable folios should
+						 * reach this loop, but stale
+						 * pre-fix state on the gen
+						 * lists is handled defensively:
+						 * detach without re-listing.
+						 */
+						if (lru != LRU_UNEVICTABLE)
+							list_move(&f->lru,
+								  &lruvec->lists[lru]);
+						else
+							list_del_init(&f->lru);
+						/*
+						 * Transfer mz->lru_zone_size
+						 * ownership back to legacy:
+						 * Marie was holding the +nr in
+						 * its own counter, the folio
+						 * now lives on the legacy list
+						 * so mz must reflect it. The
+						 * eventual legacy del will
+						 * decrement mz, balancing this
+						 * +nr.
+						 *
+						 * NR_*_LRU vmstat is unchanged
+						 * because the folio remains on
+						 * the same lruvec; only the
+						 * list-head it occupies moves.
+						 */
+						atomic_long_sub(nr, &sl->types[t].nr_pages);
+						atomic_long_dec(&marie_nr_folios);
+						atomic_long_sub(nr,
+							&sl->marie_lru_zone_size[lru][z]);
+#ifdef CONFIG_MEMCG
+						if (lru != LRU_UNEVICTABLE)
+							mem_cgroup_update_lru_size(
+								lruvec, lru, z, nr);
+#endif
+					}
+				}
+			}
+		}
+
+		/* Add-queue residue: install kept failing under -ENOMEM, so
+		 * the wrapper is still on the queue with folio->lru as a
+		 * self-loop. Each entry holds a folio_get from the original
+		 * enqueue; route to legacy and defer that ref drop until
+		 * after the caller releases lru_lock.
+		 *
+		 * folio_put cannot run inline here: __page_cache_release
+		 * needs lv->lru_lock to lruvec_del_folio when refcount
+		 * reaches zero, and the caller already holds it. Under
+		 * shutdown the wrapper's folio_get is frequently the last
+		 * reference (process exited, mapping torn down) so the
+		 * inline path would recursively re-acquire lv->lru_lock
+		 * and deadlock. marie_defer_folio_put queues the put on
+		 * the per-CPU deferred_put_q; the caller drains the queue
+		 * via marie_drain_deferred_puts() after spin_unlock_irq. */
+		{
+			int tq;
+
+			for (tq = 0; tq < ANON_AND_FILE; tq++) {
+				struct llist_node *first, *node, *next;
+
+				first = llist_del_all(&sl->types[tq].add_queue);
+				llist_for_each_safe(node, next, first) {
+					struct marie_pending *p =
+						container_of(node, struct marie_pending,
+							     node);
+					struct folio *f = p->folio;
+					enum lru_list lru = folio_lru_list(f);
+
+					set_mask_bits(&f->flags.f, MARIE_STATE_MASK, 0);
+					folio_set_lru(f);
+					/*
+					 * lru_marie_add_folio bails on unevictable, so
+					 * residue entries are evictable in the
+					 * post-fix world. Mirror legacy
+					 * lruvec_add_folio's "skip list_add for
+					 * LRU_UNEVICTABLE" rule defensively in case
+					 * any pre-fix wrapper survived.
+					 */
+					if (lru != LRU_UNEVICTABLE)
+						list_add(&f->lru, &lruvec->lists[lru]);
+					update_lru_size(lruvec, lru, folio_zonenum(f),
+							folio_nr_pages(f));
+					marie_pending_free(p);
+					marie_defer_folio_put(f);
+				}
+			}
+		}
+	}
+}
+
+static void marie_fill_one_lruvec(struct lruvec *lruvec)
+{
+	struct marie_lruvec *sl;
+	enum lru_list lru;
+
+	sl = marie_force_alloc_lruvec(lruvec, GFP_ATOMIC);
+	if (!sl)
+		return;
+
+	scoped_guard(marie_both_sl, sl) {
+		for (lru = 0; lru < NR_LRU_LISTS; lru++) {
+			struct folio *f, *next_f;
+			bool is_file;
+			int zone;
+
+			if (lru == LRU_UNEVICTABLE)
+				continue;
+			is_file = is_file_lru(lru);
+
+			list_for_each_entry_safe(f, next_f,
+						 &lruvec->lists[lru], lru) {
+				struct marie_gen *g;
+				long nr;
+				enum lru_list new_lru;
+
+				/*
+				 * Large folios (THP) are now Marie-tracked at
+				 * fault time (commit "track large folios
+				 * (THP) under Marie"); the runtime ON toggle
+				 * mirrors that by moving any THPs that the
+				 * legacy LRU still holds (because they were
+				 * added while Marie was OFF) into Marie's gen
+				 * lists. folio_zonenum / folio_nr_pages /
+				 * folio_is_file_lru all operate on the head
+				 * folio, and the tail pages stay part of the
+				 * compound — only head->lru is moved.
+				 */
+
+				g = marie_get_or_create_gen(sl, is_file,
+							  GFP_ATOMIC);
+				if (!g)
+					continue;	/* leave on legacy on -ENOMEM */
+
+				zone = folio_zonenum(f);
+				nr = folio_nr_pages(f);
+				/*
+				 * Mirror Marie's invariant: install always
+				 * lands a folio on Marie's gen list with
+				 * PG_active=0. Clear it BEFORE computing
+				 * the new index for Marie's per-bucket
+				 * counter so a folio coming from the legacy
+				 * ACTIVE list lands in Marie's INACTIVE
+				 * bucket -- matching what Marie's eventual
+				 * del will use for the -nr.
+				 */
+				if (folio_test_active(f))
+					folio_clear_active(f);
+				new_lru = folio_lru_list(f);
+				set_mask_bits(&f->flags.f, MARIE_STATE_MASK,
+					      MARIE_TRACKED_MASK);
+				list_move(&f->lru, &g->folios[is_file][zone]);
+				/*
+				 * Transfer mz->lru_zone_size ownership: the
+				 * folio was on legacy LRU's @lru list, so
+				 * legacy mz[lru] holds the +nr. Marie takes
+				 * custody at @new_lru (its post-clear-active
+				 * index). lruvec_lru_size() sums mz and
+				 * marie_lru_zone_size, so the consolidated
+				 * total is preserved across the transition.
+				 *
+				 * NR_*_LRU vmstat is not touched: the folio
+				 * remains on the same lruvec; the per-CPU
+				 * fold doesn't change. Only the list-head
+				 * it occupies (and possibly the active
+				 * bucket vs inactive bucket from mz's POV)
+				 * changes.
+				 */
+				g->nr_installs += nr;
+				atomic_long_add(nr, &sl->types[is_file].nr_pages);
+				atomic_long_inc(&marie_nr_folios);
+#ifdef CONFIG_MEMCG
+				mem_cgroup_update_lru_size(lruvec, lru, zone,
+							   -nr);
+#endif
+				atomic_long_add(nr,
+					&sl->marie_lru_zone_size[new_lru][zone]);
+			}
+		}
+	}
+}
+
+static int marie_change_state(bool enable)
+{
+	static DEFINE_MUTEX(state_mutex);
+	struct mem_cgroup *memcg;
+
+	cgroup_lock();
+	cpus_read_lock();
+	get_online_mems();
+	mutex_lock(&state_mutex);
+
+	if (enable == static_branch_likely(&lru_marie_enabled_key))
+		goto unlock;
+
+	/*
+	 * Gate is flipped BEFORE the per-lruvec walk in both directions.
+	 *
+	 * Disable: gate flips off first so no new TRACKED bits get set
+	 *   while we drain.  lru_marie_add_folio sees gate=off and bails;
+	 *   drain_one_lruvec catches in-flight adds via lru_lock
+	 *   serialisation.  Concurrent lru_marie_del_folio relies on the
+	 *   TRACKED-first check (not the gate) to route TRACKED folios
+	 *   through Marie on not-yet-drained lruvecs.
+	 *
+	 * Enable: gate flips on first so concurrent lru_marie_add_folio
+	 *   routes new faults into Marie's PENDING_ADD path while we walk
+	 *   existing legacy LRU lists to install pre-fault folios.  If
+	 *   the gate flipped after fill (the historical order), dels of
+	 *   already-filled folios (TRACKED=1) would race against gate=off
+	 *   and the dispatcher would corrupt the gen list via legacy
+	 *   list_del.
+	 */
+	if (enable)
+		static_branch_enable_cpuslocked(&lru_marie_enabled_key);
+	else
+		static_branch_disable_cpuslocked(&lru_marie_enabled_key);
+
+	memcg = mem_cgroup_iter(NULL, NULL, NULL);
+	do {
+		int nid;
+
+		for_each_node(nid) {
+			struct lruvec *lruvec = mem_cgroup_lruvec(memcg,
+								  NODE_DATA(nid));
+
+			/*
+			 * Pin the CPU across the drain/fill plus the deferred-
+			 * put drain. residue path inside marie_drain_one_lruvec
+			 * enqueues to the local per-CPU queue; migration
+			 * between spin_unlock and marie_drain_deferred_puts()
+			 * would leak those entries on the abandoned CPU.
+			 * migrate_disable keeps producer + consumer on the same
+			 * CPU without disabling preemption.
+			 */
+			migrate_disable();
+			spin_lock_irq(&lruvec->lru_lock);
+			if (enable)
+				marie_fill_one_lruvec(lruvec);
+			else
+				marie_drain_one_lruvec(lruvec);
+			spin_unlock_irq(&lruvec->lru_lock);
+
+			/*
+			 * marie_drain_one_lruvec defers folio_puts for add_queue
+			 * residue entries onto the per-CPU deferred_put_q so
+			 * they don't recurse into __page_cache_release while we
+			 * hold lru_lock. Drain them now, with both lru_lock and
+			 * the per-type locks released. marie_fill_one_lruvec
+			 * does not produce deferred puts but the call is cheap
+			 * (empty-q llist_del_all) so leave it unconditional.
+			 */
+			marie_drain_deferred_puts();
+			migrate_enable();
+
+			/*
+			 * marie_drop_lruvec must run outside lru_lock for
+			 * the synchronize_rcu + cancel_work_sync portion
+			 * (both can sleep).  Its internal xa_erase
+			 * critical section retakes lru_lock briefly to
+			 * serialise against the dispatcher's
+			 * lru_marie_del_folio xa_load.  Idempotent
+			 * (xa_erase returns NULL on a second visit), so
+			 * safe even when this memcg/nid had no sl.
+			 */
+			if (!enable)
+				marie_drop_lruvec(lruvec);
+
+			cond_resched();
+		}
+	} while ((memcg = mem_cgroup_iter(NULL, memcg, NULL)));
+
+	pr_info("%s\n", enable ? "enabled" : "disabled");
+
+unlock:
+	mutex_unlock(&state_mutex);
+	put_online_mems();
+	cpus_read_unlock();
+	cgroup_unlock();
+	return 0;
+}
+
+/* boot param: lru_marie=0 / lru_marie=1. At boot the cgroup tree is
+ * not yet populated and no lruvec carries folios, so a plain static-key
+ * toggle is sufficient — marie_change_state's mem_cgroup_iter would
+ * have nothing to migrate anyway. */
+static int __init marie_setup(char *str)
+{
+	int v;
+
+	if (!str || kstrtoint(str, 0, &v))
+		return 0;
+	if (v)
+		static_branch_enable(&lru_marie_enabled_key);
+	else
+		static_branch_disable(&lru_marie_enabled_key);
+	return 1;
+}
+__setup("lru_marie=", marie_setup);
+
+/*
+ * ---------------------------------------------------------------------
+ *  promote-in-place (look-around / Phase-2 PG_active feedback)
+ * ---------------------------------------------------------------------
+ *
+ * Promotion in Phase 2 of marie_isolate_folios is performed inline via
+ * marie_transit(sl, folio, MARIE_R_RESIDENT, MARIE_R_RESIDENT, &ctx)
+ * when a candidate carries PG_active — either set by the public
+ * access path or as a side effect of an earlier lru_marie_look_around()
+ * over the surrounding PMD. The transit moves @folio into the head
+ * gen at tier 0 without unhooking it from Marie, saving the
+ * folio_putback round trip that would otherwise reinstall via the
+ * slow add path.
+ *
+ * Walker-driven promotion (when tier saturates on a young PTE) takes
+ * a different route: marie_residency_tier_inc enqueues the folio onto
+ * sl->promote_queue (RESIDENT -> PENDING_PROMOTE); the next sl-locked
+ * drain runs the same RESIDENT-to-RESIDENT transit.
+ */
+/**
+ * marie_putback_batch - reinstall a list of folios into @sl as tier-0
+ *                     in the head gen, under a single sl->lock cycle.
+ * @sl:        per-lruvec Marie state
+ * @folio_list: list of folios returned by shrink_folio_list (linked
+ *             via folio->lru as a struct list_head — the Marie bits in
+ *             folio->flags are cleared, so the lru slot is back to
+ *             list_head meaning).
+ *
+ * For each folio:
+ *   1. unlink from @folio_list
+ *   2. attempt marie_install_folio_locked under sl->lock
+ *   3. on install failure (gen-alloc -ENOMEM under GFP_ATOMIC), arm
+ *      the folio as PENDING_ADD on @sl->add_queue. The next drain
+ *      retries the install, or marie_residency_isolate_pending_add
+ *      reclaims it directly when gen-alloc remains unavailable.
+ *
+ * The legacy folio_putback_lru fallback that earlier revisions used
+ * routed survivors onto @sl->lruvec->lists[lru], which is a black hole
+ * under Marie: shrink_inactive_list is not on the Marie reclaim path, so
+ * folios stranded there are structurally invisible to reclaim.
+ *
+ * Replaces the per-folio folio_putback_lru loop in marie_shrink_one_type:
+ * one sl->lock acquisition for the whole batch instead of one per
+ * folio (which would each go through folio_add_lru -> lruvec_add_folio
+ * -> lru_marie_add_folio (lock-free producer) -> later drain via sl->lock).
+ *
+ * Caller MUST NOT hold sl->lock on entry.
+ */
+static void marie_putback_batch(struct marie_lruvec *sl, int type,
+			      struct list_head *folio_list)
+{
+	struct folio *folio, *next;
+
+	/*
+	 * Pure Marie putback. NONE -> RESIDENT direct install is a
+	 * pure list op so it cannot fail under list-only state; the only
+	 * residual failure mode is gen-alloc -ENOMEM under GFP_ATOMIC
+	 * (kmem_cache_zalloc(marie_gen_cache)). On that, fall back to
+	 * NONE -> PENDING_ADD via marie_residency_enqueue_add — the next
+	 * drain retries the install when memory pressure eases.
+	 *
+	 * If even enqueue_add fails (marie_pending wrapper slab also
+	 * exhausted), drop the iso ref; the folio loses tracking and a
+	 * subsequent folio_add_lru on next access re-tags it. No legacy
+	 * LRU fallback (Marie runs in pure mode when marie_enabled()).
+	 *
+	 * Lock order: lru_lock outer, sl->lock inner. The +1 done inside
+	 * __marie_install_locked's marie_update_lru_size needs lru_lock
+	 * to serialise mz->lru_zone_size against legacy / MGLRU updaters.
+	 * See marie_isolate_folios for the full ordering rationale.
+	 */
+	/*
+	 * Putback list is type-pure: isolation only pulls from @type's gen
+	 * ring (Phase 1) and @type's add_queue (Phase 1b's
+	 * marie_residency_isolate_pending_add_one_type). shrink_folio_list
+	 * may have split folios but splits preserve LRU type, so every
+	 * folio reaching here is of @type. One per-type lock is enough.
+	 *
+	 * migrate_disable pins the CPU across the accumulate (inside
+	 * scoped_guard, via marie_defer_folio_put) and drain
+	 * (marie_drain_deferred_puts) so we don't migrate between them
+	 * and lose the per-CPU queue entries. Preemption is unaffected.
+	 */
+	migrate_disable();
+	scoped_guard(spinlock_irq, &sl->lruvec->lru_lock)
+	scoped_guard(marie_type_sl, &sl->types[type]) {
+		struct marie_transit_ctx ctx = { };
+
+		list_for_each_entry_safe(folio, next, folio_list, lru) {
+			list_del(&folio->lru);
+
+			if (marie_transit(sl, folio, MARIE_R_NONE,
+					MARIE_R_RESIDENT, &ctx)) {
+				marie_defer_folio_put(folio);
+				continue;
+			}
+			if (marie_residency_enqueue_add(sl, folio)) {
+				marie_defer_folio_put(folio);
+				continue;
+			}
+			/* Catastrophic dual-fail: drop iso ref. */
+			marie_defer_folio_put(folio);
+		}
+	}
+
+	/* Drain deferred puts outside both locks — folio_put can chain
+	 * into __page_cache_release which itself takes lru_lock. The
+	 * marie_sl guard no longer auto-drains because
+	 * lru_marie_del_folio's invocation context (lruvec_del_folio
+	 * under caller-held lru_lock) made auto-drain a self-deadlock
+	 * vector. */
+	marie_drain_deferred_puts();
+	migrate_enable();
+}
+
+/*
+ * ---------------------------------------------------------------------
+ *  isolation
+ * ---------------------------------------------------------------------
+ *
+ * marie_isolate_folios() drains folios out of the oldest gen of @type and
+ * deposits them on @dst, ready to be handed to shrink_folio_list().
+ *
+ * Three phases under one sl->lock cycle:
+ *
+ *   Phase 1 (collect): walk the oldest gen's per-(type, zone) folio
+ *     lists with prefetch-pipelined iteration so the folios are warm
+ *     in cache by the time Phase 2 touches them. Up to
+ *     MARIE_ISOLATE_BATCH candidate folio* pointers are stashed.
+ *
+ *   Phase 2 (process): for each candidate, first check PG_active —
+ *     if set, the folio is hot (workingset_refault /
+ *     __lru_cache_activate_folio observed external access) and gets
+ *     promoted to head gen via the RESIDENT -> RESIDENT transit.
+ *     Otherwise try LRU isolation; on success deposit on @dst, on
+ *     failure simply drop from Marie too — the folio will re-add
+ *     via folio_add_lru if it survives.  Either way we list_del_init
+ *     from the gen list + clear Marie bits and update accounting.
+ *     The list_del_init is O(1).
+ *
+ *   Phase 1b (fallback collect): if Phase 1 did not fill the batch,
+ *     drain remaining PENDING_ADD entries directly from sl->add_queue
+ *     and route them onto @dst. Folios whose install kept failing
+ *     under sustained gen-alloc(GFP_ATOMIC) pressure would otherwise
+ *     be invisible to reclaim, since Marie builds do not call
+ *     shrink_inactive_list.
+ *
+ * Because folios are bucketed per-zone at lru_marie_add_folio() time, every
+ * folio in g->folios[type][zone] is guaranteed to live in @zone — the
+ * sc->reclaim_idx clamp is just the outer loop's upper bound, no
+ * per-folio zone re-check is needed.
+ *
+ * Caller holds no locks.  We acquire sl->lock for the whole walk;
+ * shrink_folio_list() runs after the lock is dropped.
+ */
+static unsigned long
+marie_isolate_folios(struct marie_lruvec *sl, int type, unsigned long nr_to_scan,
+		   struct list_head *dst, struct scan_control *sc,
+		   unsigned long *nr_scanned,
+		   unsigned int *tail_walker_visits)
+{
+	struct folio *batch[MARIE_ISOLATE_BATCH];
+	unsigned long nr_taken = 0;
+	unsigned long total_scan = 0;
+	struct marie_gen *g;
+	int max_zone;
+	unsigned long n_batch = 0;
+	int i;
+
+	*tail_walker_visits = 0;
+
+	/*
+	 * Lock order: lru_lock outer, sl->lock inner.
+	 *
+	 * Every Marie path that ends up calling marie_update_lru_size has
+	 * to do so under lru_lock so that the embedded
+	 * mem_cgroup_update_lru_size update on mz->lru_zone_size is
+	 * serialised against the legacy/MGLRU updaters. The dispatcher
+	 * entries (lru_marie_add_folio, lru_marie_del_folio,
+	 * lru_marie_reparent_lruvec) are already invoked under their
+	 * caller's lru_lock; this internal entry takes lru_lock itself
+	 * and pins the same outer-then-inner order so concurrent
+	 * lruvec_del_folio (lru_lock then sl->lock) does not invert.
+	 *
+	 * Every transit is a pure list op (folios live directly on
+	 * folio->lru in the gen list), so there is no catastrophic
+	 * alloc-failure path that needs a fallback list to drain to
+	 * legacy LRU.
+	 *
+	 * migrate_disable pins the CPU so the deferred-put queue
+	 * enqueued inside the guard (via marie_defer_pending_put /
+	 * marie_defer_folio_put) is drained by the same CPU's
+	 * this_cpu_ptr lookup in marie_drain_deferred_puts() below.
+	 * Preemption stays enabled.
+	 */
+	migrate_disable();
+	scoped_guard(spinlock_irq, &sl->lruvec->lru_lock)
+	scoped_guard(marie_type_sl, &sl->types[type]) {
+
+	/* Drain this type's pending queues so the head gen reflects every
+	 * folio that faulted in since the last call, and tail-gen tier
+	 * status reflects every walker-promoted folio for *this* type.
+	 * The other type's queues remain in place — they will be drained
+	 * by the next isolation pass for that type. Install failures stay
+	 * PENDING_ADD on add_queue (no-op transit) and are picked up
+	 * directly by Phase 1b below. */
+	marie_drain_add_queue_one_type_locked(sl, type);
+	marie_drain_promote_queue_one_type_locked(sl, type);
+
+	marie_age(sl, type, GFP_ATOMIC);
+
+	max_zone = min_t(int, sc->reclaim_idx, MAX_NR_ZONES - 1);
+
+	/*
+	 * Phase 1 (collect): rolling tier-threshold sweep over the oldest
+	 * gen, prefetch-pipelined. Returns the tail gen via @g for use in
+	 * the per-folio evict accounting below; @n_batch is the candidate
+	 * count. @g may be NULL when the gen ring is empty (initial state
+	 * or after sustained gen-alloc failure has kept all folios in
+	 * PENDING_ADD); Phase 1b handles that case.
+	 */
+	n_batch = marie_residency_pop_oldest_batch(sl, type, nr_to_scan,
+						 batch, ARRAY_SIZE(batch),
+						 max_zone, &g);
+	if (g)
+		*tail_walker_visits = g->walker_visits;
+
+	/*
+	 * Phase 2 (process): classify each candidate.
+	 *
+	 * Prefetch batch[i+MARIE_PHASE2_PREFETCH] into L1 while we touch
+	 * batch[i]. The body does ~5-8 random folio-struct accesses;
+	 * without a software prefetch each batch[i] access can stall on
+	 * L2/L3. Phase 1's prime-and-stride prefetch only covered the
+	 * collect walk, not the process loop.
+	 */
+#define MARIE_PHASE2_PREFETCH	8
+	for (i = 0; i < n_batch; i++) {
+		struct folio *folio = batch[i];
+		long nr_pages = folio_nr_pages(folio);
+		int folio_type = folio_is_file_lru(folio);
+		int folio_zone = folio_zonenum(folio);
+
+		if (i + MARIE_PHASE2_PREFETCH < n_batch)
+			__builtin_prefetch(batch[i + MARIE_PHASE2_PREFETCH], 0, 3);
+
+		total_scan += nr_pages;
+
+		struct marie_transit_ctx ctx = {
+			.gen = g, .type = folio_type,
+			.zone = folio_zone, .nr = nr_pages,
+		};
+
+		/*
+		 * PG_active is the explicit "definitely hot" signal — set by
+		 * workingset_refault, __lru_cache_activate_folio, and the
+		 * migrate paths. Marie never uses it for its own bookkeeping
+		 * (tier is the in-band hotness counter), so its presence
+		 * here means an external path observed a strong access event
+		 * and we promote the folio in place rather than evict.
+		 *
+		 * PG_referenced is intentionally NOT consulted here: in Marie
+		 * the user-access signal is funnelled into tier via
+		 * lru_marie_mark_accessed (mm/swap.c folio_mark_accessed), and the
+		 * gen ring's pop_oldest_batch already filters by tier. Reading
+		 * PG_referenced here would re-introduce the double-counting
+		 * hot signal that starved kswapd reclaim under fault burst.
+		 */
+		if (folio_test_clear_active(folio)) {
+			marie_transit(sl, folio, MARIE_R_RESIDENT,
+				    MARIE_R_RESIDENT, &ctx);
+			continue;
+		}
+
+		/*
+		 * Defer folios that shrink_folio_list cannot reclaim this
+		 * pass.  Mirrors MGLRU sort_folio() (mm/vmscan.c).
+		 *
+		 *   - PG_writeback (any type): I/O is in flight; isolating
+		 *     would just hit activate_locked in shrink_folio_list
+		 *     and bounce back with 0 reclaimed, driving the outer
+		 *     lru_marie_shrink_lruvec zero-progress loop and
+		 *     forcing reclaim_throttle sleeps.
+		 *
+		 *   - file && dirty: needs a writeback round-trip first;
+		 *     direct-reclaim pageout is the IO-storm path the
+		 *     writeback infrastructure exists to avoid.
+		 *
+		 *   - anon && dirty: NOT skipped — shrink_folio_list's
+		 *     add_to_swap + swap_writeout (zswap / zram sync path)
+		 *     reclaims them inline.
+		 *
+		 * Promote to head gen via the active-folio transit edge so
+		 * the next pop_oldest_batch picks fresh candidates instead
+		 * of the same writeback set.  tier=0 reset is benign: walker
+		 * re-bumps tier on subsequent young-bit hits.
+		 */
+		if (folio_test_writeback(folio) ||
+		    (folio_is_file_lru(folio) && folio_test_dirty(folio))) {
+			marie_transit(sl, folio, MARIE_R_RESIDENT,
+				    MARIE_R_RESIDENT, &ctx);
+			continue;
+		}
+
+		if (folio_try_get(folio)) {
+			if (folio_test_clear_lru(folio)) {
+				marie_transit(sl, folio, MARIE_R_RESIDENT,
+					    MARIE_R_NONE, &ctx);
+				list_add(&folio->lru, dst);
+				nr_taken += nr_pages;
+				atomic_long_dec(&marie_nr_folios);
+				continue;
+			}
+			/* folio_test_clear_lru lost the race: defer the
+			 * isolation-ref drop to avoid AB-BA. */
+			marie_defer_folio_put(folio);
+		}
+
+		/*
+		 * folio_try_get failed (about to be freed) or
+		 * folio_test_clear_lru lost the race: a concurrent path
+		 * (__page_cache_release after folio_put hits zero,
+		 * compaction's isolate_migratepages_block, kcompactd's
+		 * isolate_lru_folio) is doing the del. Try to win
+		 * folio_test_clear_lru ourselves; if we do, run the full
+		 * transit (which decrements mz->lru_zone_size). If we
+		 * lose, leave the folio's Marie state intact -- the
+		 * concurrent winner's lruvec_del_folio will reach
+		 * lru_marie_del_folio's slow path under sl->lock once we
+		 * release and run the RESIDENT->NONE transit there
+		 * (single decrement). list_empty here also guards against
+		 * a path that already removed @folio from its gen list.
+		 */
+		if (folio_marie_test_tracked(folio) && !list_empty(&folio->lru) &&
+		    folio_test_clear_lru(folio)) {
+			marie_transit(sl, folio, MARIE_R_RESIDENT,
+				    MARIE_R_NONE, &ctx);
+			atomic_long_dec(&marie_nr_folios);
+		}
+	}
+
+	if (g)
+		marie_try_drop_oldest(sl, type);
+
+	/*
+	 * Phase 1b (NEW reclaim source): when the gen ring did not fill
+	 * the batch, drain remaining @type PENDING_ADD entries directly as
+	 * isolation candidates. Each entry is a folio whose install kept
+	 * failing under sustained gen-alloc(GFP_ATOMIC) pressure; routing
+	 * them straight to @dst here is what keeps Marie reclaim making
+	 * progress in that regime — without this fallback the folios
+	 * would be invisible to all reclaim paths, the legacy
+	 * lruvec->lists[lru] route having been removed because Marie builds
+	 * do not call shrink_inactive_list.
+	 *
+	 * Per-type variant so @dst stays type-pure — we hold only @type's
+	 * lock and the caller's accounting (sc->nr.file_taken) credits
+	 * exactly @type's reclaim.
+	 */
+	if (nr_taken < ARRAY_SIZE(batch)) {
+		unsigned long n_pa;
+		int cap = (int)(ARRAY_SIZE(batch) - nr_taken);
+
+		n_pa = marie_residency_isolate_pending_add_one_type(
+				sl, type, dst, cap);
+		/* Marie skips large folios at lru_marie_add_folio entry, so each
+		 * Phase 1b folio is exactly one page; pages == count. */
+		nr_taken += n_pa;
+		total_scan += n_pa;
+	}
+
+	}  /* both scoped_guards exit here — per-type lock then lru_lock */
+
+	/* Drain deferred puts outside both locks — folio_put can chain
+	 * into __page_cache_release which itself takes lru_lock. */
+	marie_drain_deferred_puts();
+	migrate_enable();
+
+	*nr_scanned = total_scan;
+	return nr_taken;
+}
+
+
+/*
+ * ---------------------------------------------------------------------
+ *  shrink_lruvec dispatch
+ * ---------------------------------------------------------------------
+ *
+ * Each iteration runs one isolate → shrink_folio_list → putback cycle
+ * bounded by MARIE_ISOLATE_BATCH (= SWAP_CLUSTER_MAX) folios on a single
+ * type.  We loop until sc->nr_reclaimed reaches sc->nr_to_reclaim or
+ * progress stalls (no folio reclaimed in a round) — matching legacy
+ * shrink_lruvec's contract that the caller's outer priority loop only
+ * runs again on the next pass.
+ *
+ * Anon vs file is decided by a token bucket: each round adds
+ * sc_swappiness tokens; whenever the accumulator >= MAX_SWAPPINESS we
+ * spend MAX_SWAPPINESS on anon, otherwise file.  Over many rounds the
+ * spend ratio converges to s : (200 - s).  swappiness == 0 stays
+ * file-only forever; SWAPPINESS_ANON_ONLY (== 201) immediately and
+ * permanently picks anon.
+ *
+ * sc->may_swap gates the anon branch entirely; if it's clear we never
+ * spend tokens and the bucket simply caps at MAX_SWAPPINESS.  If the
+ * picked type is empty we fall through to the other if it's available
+ * (and allowed), avoiding wasted no-op rounds while sl is non-empty.
+ *
+ * Putback uses marie_putback_batch(): a single sl->lock cycle that
+ * reinstalls every survivor directly into the head gen as tier 0.
+ * This replaces the per-folio folio_putback_lru -> folio_add_lru ->
+ * lru_marie_add_folio (lock-free producer) -> later sl-locked drain
+ * dance, collapsing one acquisition per folio into one per batch.
+ */
+
+static int marie_swappiness(struct scan_control *sc, struct mem_cgroup *memcg)
+{
+#ifdef CONFIG_MEMCG
+	if (sc->proactive && sc->proactive_swappiness)
+		return *sc->proactive_swappiness;
+	return mem_cgroup_swappiness(memcg);
+#else
+	return READ_ONCE(vm_swappiness);
+#endif
+}
+
+/*
+ * Per-type accumulator state for batched shrink_folio_list flushing.
+ *
+ * Marie's MARIE_ISOLATE_BATCH (= SWAP_CLUSTER_MAX = 32) sets a small
+ * stack array bound for one isolation pass.  Calling shrink_folio_list
+ * per 32-folio batch makes try_to_unmap_flush_dirty issue a TLB
+ * shootdown IPI per batch -- under tail /dev/zero we measured this as
+ * the dominant cause of user-visible stutter on other tasks (every IPI
+ * interrupts every CPU briefly).  MGLRU amortises this by accumulating
+ * many isolation passes' worth of folios into one shrink_folio_list
+ * call (its scan_batch caps at MAX_LRU_BATCH = 4096).
+ *
+ * We mirror that here: lru_marie_shrink_lruvec accumulates each type's
+ * isolated folios into its own list, flushing only when the
+ * accumulator reaches marie_shrink_batch_threshold, when type empties
+ * out, or at exit.  Lock-hold time per marie_isolate_folios is
+ * unchanged (still 32 folios per pass), but IPI frequency drops by the
+ * accumulation factor.
+ */
+struct marie_type_batch {
+	struct list_head folios;
+	unsigned long nr_taken;
+	unsigned long nr_scanned;
+	unsigned int walker_min;	/* min tail_walker_visits across sub-batches */
+};
+
+/*
+ * Helper: isolate a 32-folio batch and append it to @b.  Updates
+ * NR_ISOLATED and PGSCAN as the previous (combined) shrink_one_type
+ * did at this point.  Returns nr_taken (0 means gen drained).
+ */
+static unsigned long marie_isolate_into_batch(struct marie_lruvec *sl,
+					    int type, unsigned long nr_to_scan,
+					    struct marie_type_batch *b,
+					    struct scan_control *sc)
+{
+	struct pglist_data *pgdat = lruvec_pgdat(sl->lruvec);
+	unsigned long nr_taken, nr_scanned = 0;
+	unsigned int walker_visits = 0;
+	int off;
+
+	nr_taken = marie_isolate_folios(sl, type, nr_to_scan, &b->folios,
+				      sc, &nr_scanned, &walker_visits);
+	if (!nr_taken)
+		return 0;
+
+	__mod_node_page_state(pgdat, NR_ISOLATED_ANON + type, nr_taken);
+
+	off = vmscan_reclaimer_offset(sc);
+	mod_lruvec_state(sl->lruvec, PGSCAN_KSWAPD + off, nr_scanned);
+	mod_lruvec_state(sl->lruvec, PGSCAN_ANON + type, nr_scanned);
+
+	b->nr_taken += nr_taken;
+	b->nr_scanned += nr_scanned;
+	if (walker_visits < b->walker_min)
+		b->walker_min = walker_visits;
+	return nr_taken;
+}
+
+/*
+ * Helper: run shrink_folio_list over the accumulated batch (one IPI
+ * for the whole flush), then post-shrink accounting + putback.
+ *
+ * Returns nr_reclaimed.  Resets @b to empty so the caller can reuse
+ * it; folios that survived shrink_folio_list are reinstalled into
+ * Marie via marie_putback_batch and are no longer on @b->folios.
+ *
+ * @type identifies what the entire batch contains (we never mix anon
+ * and file in one accumulator -- per-type bookkeeping requires it).
+ *
+ * tail_walker_visits gating: shrink_folio_list's ignore_references
+ * fast path is safe only when every contributing isolation pass saw
+ * a warmed gen (walker_visits >= 1).  If any sub-batch came from a
+ * cold gen, fall back to the full rmap walk for the whole flush.
+ * Worst case is slightly more rmap CPU; this is correct (the
+ * pessimistic choice for the merged set).
+ */
+/*
+ * Marie shrink-batch natural merge sort. Implementation lives in
+ * lru_marie_sort.c and is pulled in here as a translation-unit
+ * fragment (NOT a standalone object — see the file header for the
+ * rationale: keeps `static` linkage, lets the comparator inline into
+ * the merge / run-detection inner loops). lru_marie_sort.c is not
+ * listed in mm/Makefile and is reached only via this directive.
+ */
+#include "lru_marie_sort.c"
+
+static unsigned long marie_flush_shrink_batch(struct marie_lruvec *sl,
+					    int type,
+					    struct marie_type_batch *b,
+					    struct scan_control *sc)
+{
+	struct pglist_data *pgdat = lruvec_pgdat(sl->lruvec);
+	struct reclaim_stat stat = {};
+	unsigned long nr_reclaimed;
+	unsigned long nr_taken = b->nr_taken;
+	unsigned long nr_scanned = b->nr_scanned;
+	int off;
+
+	if (!nr_taken)
+		return 0;
+
+	/*
+	 * Group folios by mapping before handing the batch to
+	 * shrink_folio_list so consecutive try_to_unmap calls hit the
+	 * same rwsem in cache. See marie_natural_sort comment block.
+	 */
+	marie_natural_sort(&b->folios);
+
+	nr_reclaimed = shrink_folio_list(&b->folios, pgdat, sc, &stat,
+					 b->walker_min >= 1,
+					 sl->memcg);
+
+	__mod_node_page_state(pgdat, NR_ISOLATED_ANON + type, -(long)nr_taken);
+
+	off = vmscan_reclaimer_offset(sc);
+	mod_lruvec_state(sl->lruvec, PGSTEAL_KSWAPD + off, nr_reclaimed);
+	mod_lruvec_state(sl->lruvec, PGSTEAL_ANON + type, nr_reclaimed);
+
+	sc->nr_reclaimed += nr_reclaimed;
+	sc->nr_scanned += nr_scanned;
+
+	/*
+	 * Mirror the legacy shrink_inactive_list bookkeeping so that
+	 * shrink_node()'s writeback throttle can fire under Marie.
+	 * If every isolated dirty folio was unqueued for writeback, kick
+	 * the flushers as legacy does.
+	 */
+	if (stat.nr_unqueued_dirty == nr_taken)
+		wakeup_flusher_threads(WB_REASON_VMSCAN);
+
+	sc->nr.dirty		+= stat.nr_dirty;
+	sc->nr.congested	+= stat.nr_congested;
+	sc->nr.unqueued_dirty	+= stat.nr_unqueued_dirty;
+	sc->nr.writeback	+= stat.nr_writeback;
+	sc->nr.immediate	+= stat.nr_immediate;
+	sc->nr.taken		+= nr_taken;
+	if (type == 1)
+		sc->nr.file_taken += nr_taken;
+
+	marie_putback_batch(sl, type, &b->folios);
+
+	/* Reset for reuse. */
+	b->nr_taken = 0;
+	b->nr_scanned = 0;
+	b->walker_min = UINT_MAX;
+	return nr_reclaimed;
+}
+
+/*
+ * Pick the type to scan this round.  Reads/updates sl->swap_tokens
+ * under sl->lock.  Returns the chosen type (0 = anon, 1 = file), or
+ * -1 if neither type has anything to scan.
+ */
+/*
+ * clean_min_ratio working-set protection.
+ *
+ * When non-zero, refuse to evict file folios while the node's file
+ * pagecache is below this percentage of node_present_pages. Diverts
+ * marie_pick_type to anon (or returns -1 if anon is unavailable).
+ *
+ * Targets the "code/library/font cache eviction storm" scenario:
+ * file pages are unique on storage, so refault costs an I/O round
+ * trip — evicting working-set file under transient pressure causes
+ * UI-visible stalls on subsequent access.
+ *
+ * Default 15 -- conservative working-set floor mirroring the typical
+ * le9uo vm.clean_min_ratio recommendation for desktop workloads.
+ * Tunable via /sys/kernel/mm/lru_marie/clean_min_ratio (range 0..100); set
+ * to 0 to disable the hard floor entirely.
+ *
+ * Per le9uo design analysis: anon_min_ratio and clean_low_ratio
+ * intentionally not implemented — the former is largely redundant
+ * with vm.swappiness in zram-swap environments (kcompmari makes
+ * anon refault sub-millisecond), and the latter is a soft hint
+ * that overlaps with the existing swap_tokens token bucket.
+ */
+static unsigned int marie_clean_min_ratio = 15;	/* 0..100 */
+
+static int marie_pick_type(struct marie_lruvec *sl, struct scan_control *sc,
+			 int swappiness)
+{
+	int picked;
+	/*
+	 * Anon reclaim requires both kernel-side permission (sc->may_swap)
+	 * AND a swap backend with at least one free entry. When
+	 * get_nr_swap_pages() reaches 0, folio_alloc_swap inside
+	 * shrink_folio_list returns NULL for every anon folio in the batch
+	 * — marie_isolate_folios still hands out 32 candidates per round, but
+	 * shrink_folio_list keeps every one of them. The outer
+	 * lru_marie_shrink_lruvec loop then spins indefinitely (taken > 0 while
+	 * nr_reclaimed stays 0). Honour the runtime gate the same way
+	 * vanilla can_reclaim_anon_pages does, so the loop bails to its
+	 * caller (try_to_free_pages → __alloc_pages_slowpath) which can
+	 * then drive the OOM path via no_progress_loops / the early-OOM
+	 * watermark.
+	 */
+	bool can_anon = sc->may_swap && get_nr_swap_pages() > 0;
+
+	/*
+	 * Lock-free token bucket update. The picker's decision (anon vs
+	 * file) is a pure function of the current bucket value, swappiness,
+	 * and can_anon; commit it via atomic_try_cmpxchg and let the rest of
+	 * the function (empty-fallback, clean_min_ratio) run under sl->lock
+	 * as before.
+	 */
+	{
+		int old = atomic_read(&sl->swap_tokens);
+		int new;
+
+		for (;;) {
+			if (can_anon && old + swappiness >= MAX_SWAPPINESS) {
+				new = old + swappiness - MAX_SWAPPINESS;
+				picked = 0;	/* anon */
+			} else {
+				/* Cap the bucket so disabling may_swap doesn't let
+				 * it overflow, then bias straight to file. */
+				new = (old + swappiness < MAX_SWAPPINESS)
+				      ? (old + swappiness) : old;
+				picked = 1;	/* file */
+			}
+			if (atomic_try_cmpxchg(&sl->swap_tokens, &old, new))
+				break;
+			/* retry with refreshed @old */
+		}
+	}
+
+	/*
+	 * Empty-fallback and clean_min_ratio inspection both run lockless
+	 * via atomic_long_read on nr_pages. The reads are advisory: a stale
+	 * non-zero read at most causes one wasted isolation pass (Phase 1
+	 * returns 0 candidates and Phase 1b drains PENDING_ADD); a stale
+	 * zero read at most defers reclaim for that type until the next
+	 * pick. Both modes are bounded and self-correcting.
+	 */
+	if (atomic_long_read(&sl->types[picked].nr_pages) == 0) {
+		int other = 1 - picked;
+
+		if (atomic_long_read(&sl->types[other].nr_pages) == 0)
+			picked = -1;
+		else if (other == 0 && !can_anon)
+			picked = -1;
+		else
+			picked = other;
+	}
+
+	/*
+	 * clean_min_ratio hard floor: divert from file → anon when the
+	 * node's file pagecache is below the configured percentage of
+	 * node_present_pages. Read the knob with READ_ONCE so the compiler
+	 * doesn't re-read it later in the function (it's sysfs-writable and
+	 * could race).
+	 */
+	if (picked == 1) {
+		unsigned int min_ratio = READ_ONCE(marie_clean_min_ratio);
+
+		if (min_ratio) {
+			struct pglist_data *pgdat = lruvec_pgdat(sl->lruvec);
+			unsigned long file_pages =
+				node_page_state(pgdat, NR_ACTIVE_FILE) +
+				node_page_state(pgdat, NR_INACTIVE_FILE);
+			unsigned long file_min =
+				pgdat->node_present_pages * min_ratio / 100;
+
+			if (file_pages < file_min) {
+				/* Protected: try anon, else give up. */
+				if (can_anon &&
+				    atomic_long_read(&sl->types[0].nr_pages) > 0)
+					picked = 0;
+				else
+					picked = -1;
+			}
+		}
+	}
+
+	return picked;
+}
+
+/*
+ * marie_zero_progress_throttle: consecutive zero-reclaim iterations
+ * tolerated before lru_marie_shrink_lruvec sleeps for writeback to complete.
+ * Tail-of-LRU dirty folios cycle through pageout (queued, returns 0
+ * reclaimed) → activate_locked (PG_writeback, returns 0) without
+ * actual freeing happening until I/O completes.  Without aging or a
+ * direct-reclaim throttle path, a busy progress-loop would burn CPU
+ * during that window.  HZ/10 sleep per throttle gives writeback a
+ * chance to land before we re-isolate.
+ *
+ * Default 1: sleep immediately on the first zero-progress iteration.
+ * Empirically this gave the best tail /dev/zero interactivity --
+ * higher values (the original 4) spent ~100 ms of CPU each per
+ * writeback cycle bouncing the same folios through shrink_folio_list,
+ * starving other tasks of their share.  The writeback-skip in Phase 2
+ * isolation (see marie_isolate_folios) also reduces how often this
+ * throttle fires.
+ *
+ * Exposed via /sys/kernel/mm/lru_marie/zero_progress_throttle.
+ */
+unsigned int marie_zero_progress_throttle = 1;
+
+void lru_marie_shrink_lruvec(struct lruvec *lruvec, struct scan_control *sc)
+{
+	struct marie_lruvec *sl = marie_get_lruvec(lruvec);
+	struct pglist_data *pgdat;
+	int swappiness;
+	int zero_streak = 0;
+	int type;
+	unsigned int zero_throttle = READ_ONCE(marie_zero_progress_throttle);
+	unsigned long flush_threshold =
+		READ_ONCE(marie_shrink_batch_threshold);
+	/*
+	 * Per-type accumulators.  Each holds isolated folios of a single
+	 * type so PGSTEAL / NR_ISOLATED bookkeeping stays per-type, while
+	 * shrink_folio_list (and its trailing try_to_unmap_flush_dirty
+	 * TLB IPI) runs only once per @flush_threshold pages instead of
+	 * once per MARIE_ISOLATE_BATCH.
+	 */
+	struct marie_type_batch batch[ANON_AND_FILE] = {
+		[0] = { .folios = LIST_HEAD_INIT(batch[0].folios),
+			.walker_min = UINT_MAX },
+		[1] = { .folios = LIST_HEAD_INIT(batch[1].folios),
+			.walker_min = UINT_MAX },
+	};
+
+	if (!sl)
+		return;
+
+	/*
+	 * Proactive aging via the per-pgdat walker.
+	 * SIMD-driven PTE scan with adaptive rate (HZ/30 .. HZ depending
+	 * on memory pressure). Internally rate-limited per pgdat; concurrent
+	 * reclaimers no-op. Pass-end drains promote_queue so marie_pick_type
+	 * below sees a consistent gen ring.
+	 */
+	pgdat = lruvec_pgdat(lruvec);
+	marie_walk_pgdat(pgdat);
+
+	swappiness = marie_swappiness(sc, sl->memcg);
+
+	/*
+	 * Drain per-CPU queues before the first marie_pick_type so
+	 * sl->types[type].nr_pages reflects every faulted-in folio. Without
+	 * this drain, marie_pick_type would observe nr_pages == 0 and return
+	 * -1, leaving every folio stuck in the pending queue and the
+	 * reclaim loop unable to make progress (memhog OOMs without ever
+	 * touching swap).
+	 */
+	marie_drain_pending(sl);
+
+	while (sc->nr_reclaimed < sc->nr_to_reclaim) {
+		unsigned long taken;
+		unsigned long reclaimed_before;
+
+		type = marie_pick_type(sl, sc, swappiness);
+		if (type < 0)
+			break;
+
+		taken = marie_isolate_into_batch(sl, type, MARIE_ISOLATE_BATCH,
+					       &batch[type], sc);
+		if (!taken) {
+			/*
+			 * Gen drained for this type.  Flush whatever we
+			 * have accumulated for it so far, then exit (the
+			 * other type may still have work, but
+			 * marie_pick_type's empty-fallback would have
+			 * routed us there already if applicable).
+			 */
+			if (batch[type].nr_taken)
+				marie_flush_shrink_batch(sl, type,
+						       &batch[type], sc);
+			break;
+		}
+
+		if (batch[type].nr_taken < flush_threshold) {
+			cond_resched();
+			continue;
+		}
+
+		/*
+		 * Threshold reached -- flush this type's accumulator and
+		 * check for zero-progress (writeback bounce).  Progress is
+		 * judged at the flush boundary now that isolate and shrink
+		 * are decoupled.
+		 */
+		reclaimed_before = sc->nr_reclaimed;
+		marie_flush_shrink_batch(sl, type, &batch[type], sc);
+
+		if (sc->nr_reclaimed == reclaimed_before) {
+			/*
+			 * Every folio came back as PG_writeback (queued I/O
+			 * but still pinned).  Sleep after zero_throttle
+			 * consecutive misses so we don't busy-spin while
+			 * waiting on swap completion.  shrink_node()'s
+			 * own throttle is kswapd-only; this covers direct
+			 * reclaim too.  PF_LOCAL_THROTTLE / hibernation
+			 * gates mirror mm/vmscan.c shrink_node.
+			 */
+			if (++zero_streak >= zero_throttle) {
+				if (sc->hibernation_mode ||
+				    (current->flags & PF_LOCAL_THROTTLE))
+					break;
+				reclaim_throttle(pgdat,
+						 VMSCAN_THROTTLE_WRITEBACK);
+				zero_streak = 0;
+			}
+		} else {
+			zero_streak = 0;
+		}
+
+		cond_resched();
+	}
+
+	/* Final flush of anything left in either accumulator. */
+	for (type = 0; type < ANON_AND_FILE; type++) {
+		if (batch[type].nr_taken)
+			marie_flush_shrink_batch(sl, type, &batch[type], sc);
+	}
+}
+
