 # }
 
+# Marie LRU {
+config LRU_MARIE
+	bool "Marie LRU"
+	def_bool y
+	depends on MMU
+	help
+	  Multi-graded Adaptive Reclaim & Independent Eviction (Marie):
+	  an out-of-tree experimental LRU implementation that aims to
+	  preserve MGLRU's PTE-walk efficiency while removing two
+	  structural defects that show up in practice:
+
+	  1. Forced inc_min_seq treadmill: with a fixed MAX_NR_GENS, every
+	     aging step that pushes the gen count to its maximum forces
+	     the oldest generation to drain even if its folios are
+	     unevictable (e.g. clean_min_ratio-protected file cache).
+
+	  2. Shared max_seq across anon/file: vm.swappiness cannot be
+	     enforced as a proportional control because both types share a
+	     single iteration counter.
+
+	  Marie's identity is a SIMD-accelerated PTE young-bit batch
+	  scan auto-dispatched at boot (AVX-512F > AVX2 > SSE2 baseline
+	  on x86; scalar fallback on arm64 and other arches) plus an
+	  rmap -> walker bloom
+	  forward feedback that keeps walker cost on hot PMDs only.
+	  Per-lruvec sl with lock-free pending queues, dynamically grown
+	  gen list, fully independent per-type state, and a deadline-gated
+	  walker that adapts to memory pressure (33ms .. 1s).
+
+	  Enabled by default; disable at boot with lru_marie=0 on the kernel
+	  cmdline, or at runtime via /sys/kernel/mm/lru_marie/enabled. When
+	  disabled, vmscan falls through to the existing MGLRU / Legacy
+	  LRU path unchanged.
+
+	  Say Y unless you understand what this is.
+# }
+
 config ARCH_SUPPORTS_PER_VMA_LOCK
        def_bool n
 
