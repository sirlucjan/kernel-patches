+/*
+ * ---------------------------------------------------------------------
+ *  Reclaim / walker tunables (runtime-adjustable via sysfs)
+ * ---------------------------------------------------------------------
+ *
+ * marie_zero_progress_throttle is defined alongside lru_marie_shrink_lruvec
+ * above; the rest live here next to their sysfs knobs.
+ *
+ * All eight variables are read with READ_ONCE on their hot paths.
+ * Reclaim-loop snapshots take their value at the top of each pass, so
+ * concurrent sysfs writes take effect on the next pass without locking.
+ */
+
+/*
+ * marie_add_watermark — per-sl producer queue depth at which
+ * lru_marie_add_folio kicks the marie_drain_worker. Lower values drain
+ * sooner (lower install latency, more frequent sl->lock cycles); higher
+ * values amortize lock cost. Default mirrors the original MARIE_ADD_WATERMARK.
+ */
+unsigned long marie_add_watermark = 256UL;
+
+/*
+ * marie_gen_growth_threshold — pages installed onto the head gen before
+ * marie_age_on_add cuts a fresh head. Default mirrors the original
+ * MARIE_GEN_GROWTH_THRESHOLD (= MARIE_ISOLATE_BATCH << 8 = 8192 pages,
+ * i.e. 32 MiB).  Lower values produce finer gen granularity (more
+ * aging churn but tighter hot/cold separation); higher values coarsen
+ * the ring (less churn, broader gens).
+ */
+unsigned long marie_gen_growth_threshold = (unsigned long)SWAP_CLUSTER_MAX << 8;
+
+/*
+ * marie_pending_pool_lowmark — per-CPU LIFO refill trigger (0..7).
+ * When pool->top falls below this, the refill workqueue is kicked.
+ * Default 2: trades pool memory against alloc-miss frequency.  Raising
+ * to MARIE_PENDING_POOL_DEPTH (8) keeps the pool eagerly full;
+ * lowering to 0 disables proactive refill.
+ */
+unsigned int marie_pending_pool_lowmark = 2;
+
+/*
+ * marie_walker_interval_* — adaptive walker pass deadline per pgdat,
+ * stored in jiffies. marie_walker_interval() picks one based on the
+ * zone's free-page state relative to its watermarks:
+ *
+ *   free < min      -> critical
+ *   free < low      -> low
+ *   free < high     -> normal
+ *   free >= high    -> idle
+ *
+ * Defaults mirror the original literal cadence (HZ/30, HZ/10, HZ/4,
+ * HZ — ~33 ms, 100 ms, 250 ms, 1 s on HZ=1000).  Hot writers see the
+ * value via READ_ONCE inside marie_walker_interval(); the sysfs
+ * helpers convert to and from ms for user friendliness.
+ */
+unsigned long marie_walker_interval_critical = HZ / 30;
+unsigned long marie_walker_interval_low      = HZ / 10;
+unsigned long marie_walker_interval_normal   = HZ / 4;
+unsigned long marie_walker_interval_idle     = HZ;
+
+/*
+ * marie_shrink_batch_threshold — pages accumulated across multiple
+ * MARIE_ISOLATE_BATCH (= 32) isolation passes before
+ * lru_marie_shrink_lruvec flushes through shrink_folio_list.  Each
+ * flush issues exactly one try_to_unmap_flush_dirty TLB IPI, so
+ * raising this divides IPI frequency proportionally.  MGLRU
+ * accumulates up to MAX_LRU_BATCH = 4096 per evict_folios call (and
+ * its callers cap it lower via nr_to_scan); 256 is a conservative
+ * default that gives ~8x IPI reduction over the un-accumulated path
+ * while keeping NR_ISOLATED_ANON / NR_ISOLATED_FILE bounded so
+ * shrink_node's too_many_isolated check stays meaningful.
+ *
+ * Range 32 .. 8192.  Lower values approach the legacy per-batch
+ * behaviour; higher values reduce IPI rate further at the cost of
+ * holding more pages "in flight" (charged against NR_ISOLATED).
+ */
+unsigned long marie_shrink_batch_threshold = 256UL;
+
+static ssize_t zero_progress_throttle_show(struct kobject *kobj,
+					   struct kobj_attribute *attr,
+					   char *buf)
+{
+	return sysfs_emit(buf, "%u\n",
+			  READ_ONCE(marie_zero_progress_throttle));
+}
+
+static ssize_t zero_progress_throttle_store(struct kobject *kobj,
+					    struct kobj_attribute *attr,
+					    const char *buf, size_t count)
+{
+	unsigned int v;
+	int err = kstrtouint(buf, 10, &v);
+
+	if (err)
+		return err;
+	if (v < 1 || v > 1024)
+		return -EINVAL;
+	WRITE_ONCE(marie_zero_progress_throttle, v);
+	return count;
+}
+
+static struct kobj_attribute marie_zero_progress_throttle_attr =
+	__ATTR_RW(zero_progress_throttle);
+
+static ssize_t shrink_batch_threshold_show(struct kobject *kobj,
+					   struct kobj_attribute *attr,
+					   char *buf)
+{
+	return sysfs_emit(buf, "%lu\n",
+			  READ_ONCE(marie_shrink_batch_threshold));
+}
+
+static ssize_t shrink_batch_threshold_store(struct kobject *kobj,
+					    struct kobj_attribute *attr,
+					    const char *buf, size_t count)
+{
+	unsigned long v;
+	int err = kstrtoul(buf, 10, &v);
+
+	if (err)
+		return err;
+	/*
+	 * Lower bound = MARIE_ISOLATE_BATCH: below this, accumulation
+	 * cannot fit even one isolation pass and the loop would flush
+	 * on every iteration (defeating the purpose).
+	 * Upper bound = 8192 pages = 32 MiB: keeps NR_ISOLATED bounded
+	 * so vmscan throttling stays meaningful.
+	 */
+	if (v < SWAP_CLUSTER_MAX || v > 8192UL)
+		return -EINVAL;
+	WRITE_ONCE(marie_shrink_batch_threshold, v);
+	return count;
+}
+
+static struct kobj_attribute marie_shrink_batch_threshold_attr =
+	__ATTR_RW(shrink_batch_threshold);
+
+static ssize_t add_watermark_show(struct kobject *kobj,
+				  struct kobj_attribute *attr, char *buf)
+{
+	return sysfs_emit(buf, "%lu\n", READ_ONCE(marie_add_watermark));
+}
+
+static ssize_t add_watermark_store(struct kobject *kobj,
+				   struct kobj_attribute *attr,
+				   const char *buf, size_t count)
+{
+	unsigned long v;
+	int err = kstrtoul(buf, 10, &v);
+
+	if (err)
+		return err;
+	if (v < 1 || v > (1UL << 30))
+		return -EINVAL;
+	WRITE_ONCE(marie_add_watermark, v);
+	return count;
+}
+
+static struct kobj_attribute marie_add_watermark_attr =
+	__ATTR_RW(add_watermark);
+
+static ssize_t gen_growth_threshold_show(struct kobject *kobj,
+					 struct kobj_attribute *attr,
+					 char *buf)
+{
+	return sysfs_emit(buf, "%lu\n",
+			  READ_ONCE(marie_gen_growth_threshold));
+}
+
+static ssize_t gen_growth_threshold_store(struct kobject *kobj,
+					  struct kobj_attribute *attr,
+					  const char *buf, size_t count)
+{
+	unsigned long v;
+	int err = kstrtoul(buf, 10, &v);
+
+	if (err)
+		return err;
+	/* Must hold at least one MARIE_ISOLATE_BATCH-sized pop. */
+	if (v < SWAP_CLUSTER_MAX || v > (1UL << 28))
+		return -EINVAL;
+	WRITE_ONCE(marie_gen_growth_threshold, v);
+	return count;
+}
+
+static struct kobj_attribute marie_gen_growth_threshold_attr =
+	__ATTR_RW(gen_growth_threshold);
+
+static ssize_t pending_pool_lowmark_show(struct kobject *kobj,
+					 struct kobj_attribute *attr,
+					 char *buf)
+{
+	return sysfs_emit(buf, "%u\n",
+			  READ_ONCE(marie_pending_pool_lowmark));
+}
+
+static ssize_t pending_pool_lowmark_store(struct kobject *kobj,
+					  struct kobj_attribute *attr,
+					  const char *buf, size_t count)
+{
+	unsigned int v;
+	int err = kstrtouint(buf, 10, &v);
+
+	if (err)
+		return err;
+	/* Pool depth is compile-time MARIE_PENDING_POOL_DEPTH (= 8). */
+	if (v > 8)
+		return -EINVAL;
+	WRITE_ONCE(marie_pending_pool_lowmark, v);
+	return count;
+}
+
+static struct kobj_attribute marie_pending_pool_lowmark_attr =
+	__ATTR_RW(pending_pool_lowmark);
+
+/*
+ * Walker-interval knob factory: every stage uses the same show/store
+ * shape (ms in, jiffies stored, clamped to >= 1 jiffy).  Range is
+ * 1..60000 ms — anything shorter than a jiffy is meaningless on
+ * commodity HZ, anything longer than a minute defeats the adaptive
+ * gating.
+ */
+#define MARIE_WALKER_INTERVAL_KNOB(name, var)				\
+static ssize_t name##_show(struct kobject *kobj,			\
+			   struct kobj_attribute *attr, char *buf)	\
+{									\
+	return sysfs_emit(buf, "%u\n",					\
+			  jiffies_to_msecs(READ_ONCE(var)));		\
+}									\
+static ssize_t name##_store(struct kobject *kobj,			\
+			    struct kobj_attribute *attr,		\
+			    const char *buf, size_t count)		\
+{									\
+	unsigned int ms;						\
+	unsigned long j;						\
+	int err = kstrtouint(buf, 10, &ms);				\
+									\
+	if (err)							\
+		return err;						\
+	if (ms < 1 || ms > 60000)					\
+		return -EINVAL;						\
+	j = msecs_to_jiffies(ms);					\
+	if (j < 1)							\
+		j = 1;							\
+	WRITE_ONCE(var, j);						\
+	return count;							\
+}									\
+static struct kobj_attribute marie_##name##_attr = __ATTR_RW(name)
+
+MARIE_WALKER_INTERVAL_KNOB(walker_interval_critical_ms,
+			   marie_walker_interval_critical);
+MARIE_WALKER_INTERVAL_KNOB(walker_interval_low_ms,
+			   marie_walker_interval_low);
+MARIE_WALKER_INTERVAL_KNOB(walker_interval_normal_ms,
+			   marie_walker_interval_normal);
+MARIE_WALKER_INTERVAL_KNOB(walker_interval_idle_ms,
+			   marie_walker_interval_idle);
+
+static struct attribute *marie_attrs[] = {
+	&marie_enabled_attr.attr,
+	&marie_stats_attr.attr,
+	&marie_clean_min_ratio_attr.attr,
+#ifdef CONFIG_SWAP
+	&marie_kcompmari_attr.attr,
+#endif
+#ifdef CONFIG_X86
+	&marie_simd_attr.attr,
+#endif
+	&marie_zero_progress_throttle_attr.attr,
+	&marie_shrink_batch_threshold_attr.attr,
+	&marie_add_watermark_attr.attr,
+	&marie_gen_growth_threshold_attr.attr,
+	&marie_pending_pool_lowmark_attr.attr,
+	&marie_walker_interval_critical_ms_attr.attr,
+	&marie_walker_interval_low_ms_attr.attr,
+	&marie_walker_interval_normal_ms_attr.attr,
+	&marie_walker_interval_idle_ms_attr.attr,
+	NULL,
+};
+
+static const struct attribute_group marie_attr_group = {
+	.attrs = marie_attrs,
+};
+
+static int __init marie_init(void)
+{
+	struct kobject *marie_kobj;
+	int err;
+
+	printk(KERN_INFO "%s %s by %s\n",
+	       MARIE_PROGNAME, MARIE_VERSION, MARIE_AUTHOR);
+
+	/*
+	 * Residency ADT init: marie_pending + marie_gen slab caches,
+	 * per-CPU LIFO pending-wrapper pool, background refill workqueue,
+	 * and the pending-pool cpuhp callback.
+	 */
+	err = marie_residency_init();
+	if (err < 0)
+		return err;
+
+	marie_walker_init();
+
+	marie_kobj = kobject_create_and_add("lru_marie", mm_kobj);
+	if (!marie_kobj) {
+		pr_err("failed to create /sys/kernel/mm/lru_marie\n");
+		return -ENOMEM;
+	}
+
+	err = sysfs_create_group(marie_kobj, &marie_attr_group);
+	if (err) {
+		pr_err("failed to create /sys/kernel/mm/lru_marie attributes: %d\n", err);
+		kobject_put(marie_kobj);
+		return err;
+	}
+
+	pr_info("currently %s\n",
+		static_branch_likely(&lru_marie_enabled_key) ? "enabled" : "disabled");
+	return 0;
+}
+subsys_initcall(marie_init);
diff --git a/mm/lru_marie_residency.c b/mm/lru_marie_residency.c
new file mode 100644
index 000000000..a1bfffdc1
--- /dev/null
+++ b/mm/lru_marie_residency.c
@@ -0,0 +1,1907 @@
+// SPDX-License-Identifier: GPL-2.0
+/*
+ * mm/lru_marie_residency.c — Marie residency ADT implementation.
+ *
+ * The ADT owns the per-folio "where does this folio live in Marie"
+ * state and every operation that mutates it. See mm/lru_marie_residency.h
+ * for the API surface.
+ *
+ * Folios are linked into per-(type, zone) gen lists directly via
+ * folio->lru — there is no chunk overlay; folio->lru is always
+ * interpreted as a list_head. Per-CPU LIFO pools serve struct
+ * marie_pending (PENDING_ADD / PENDING_PROMOTE wrappers) and the
+ * gen-spare cache.
+ */
+
+#define pr_fmt(fmt) "marie_residency: " fmt
+
+#include <linux/cpuhotplug.h>
+#include <linux/init.h>
+#include <linux/list.h>
+#include <linux/llist.h>
+#include <linux/memcontrol.h>
+#include <linux/mm.h>
+#include <linux/mm_inline.h>
+#include <linux/mm_types.h>
+#include <linux/mmzone.h>
+#include <linux/percpu.h>
+#include <linux/printk.h>
+#include <linux/lru_marie.h>
+#include <linux/slab.h>
+#include <linux/smp.h>
+#include <linux/spinlock.h>
+#include <linux/swap.h>
+#include <linux/workqueue.h>
+
+#include "lru_marie_residency.h"
+
+/*
+ * ---------------------------------------------------------------------
+ *  Per-CPU pending queues + drain depth + deferred put
+ * ---------------------------------------------------------------------
+ */
+
+static struct kmem_cache *marie_pending_cache;
+
+/*
+ * Dedicated WQ_UNBOUND workqueue for marie_drain_worker.
+ *
+ * The drain holds sl->lock + lru_lock and processes the entire
+ * add_queue + promote_queue in one go. Under fault-burst workloads
+ * the queues can contain thousands of entries and the run easily
+ * exceeds the 10 ms threshold on which the system_wq watchdog WARNs
+ * ("workqueue: marie_drain_worker hogged CPU for >10000us").
+ *
+ * WQ_UNBOUND lets the worker thread:
+ *   - be scheduled on any CPU (load-balanced by the scheduler),
+ *   - be treated as a long-running worker by the workqueue core, so
+ *     the per-CPU stall watchdog does not fire.
+ *
+ * WQ_MEM_RECLAIM ensures the workqueue makes forward progress when
+ * the system is under memory pressure (rescuer thread reserved).
+ *
+ * max_active=0 = workqueue default (typically 256 per node), which is
+ * way more than the number of concurrent draining sls in practice.
+ */
+static struct workqueue_struct *marie_drain_wq;
+
+/*
+ * ---------------------------------------------------------------------
+ *  Per-CPU LIFO pool for marie_pending wrappers
+ * ---------------------------------------------------------------------
+ *
+ * Pop on the alloc hot path is a single decrement + load; free pushes
+ * back into the local pool; a background workqueue refills with
+ * GFP_KERNEL. With a warm pool the per-CPU
+ * marie_residency_enqueue_add / marie_defer_folio_put paths never see
+ * GFP_ATOMIC, and the WARN_ONCE inline-put fallback is effectively
+ * dead code.
+ *
+ * Memory cost: MARIE_PENDING_POOL_DEPTH * sizeof(marie_pending) * NR_CPUS
+ * = 8 * 24 B * NR_CPUS = 192 B / CPU.
+ *
+ * MARIE_PENDING_POOL_DEPTH stays a #define because it sizes the per-CPU
+ * stack[] array.  The low-water refill trigger is runtime-tunable as
+ * marie_pending_pool_lowmark (sysfs default 2; range 0..8).
+ */
+#define MARIE_PENDING_POOL_DEPTH		8
+
+struct marie_pending_pool {
+	struct marie_pending	*stack[MARIE_PENDING_POOL_DEPTH];
+	int			top;
+	struct work_struct	refill_work;
+};
+static DEFINE_PER_CPU(struct marie_pending_pool, marie_pending_pool);
+
+static DEFINE_PER_CPU(unsigned long, marie_pending_pool_hits);
+static DEFINE_PER_CPU(unsigned long, marie_pending_pool_misses);
+static atomic_long_t marie_pending_alloc_failures;
+static atomic_long_t marie_pending_refills;
+
+static void marie_pending_pool_refill_work(struct work_struct *w);
+
+static inline void marie_pending_pool_maybe_refill(int cpu)
+{
+	struct marie_pending_pool *pool = per_cpu_ptr(&marie_pending_pool, cpu);
+
+	if (!work_pending(&pool->refill_work))
+		schedule_work_on(cpu, &pool->refill_work);
+}
+
+/*
+ * Per-CPU deferred-put llist and per-type drain-depth counters.
+ *
+ * The deferred-put queue is sl-agnostic (any locked region's defers ride
+ * the local CPU's queue and are drained on guard exit).
+ *
+ * Drain-depth is per type: the marie_type_sl guard increments only its
+ * type's counter, the marie_both_sl guard increments both. A folio_put
+ * recursing into lru_marie_del_folio checks the counter for *its own*
+ * folio type — when set, the per-type lock for that type is already
+ * held by the current CPU and re-acquiring would self-deadlock; when
+ * zero, the recursive del needs to take the lock itself (the outer
+ * guard holds only the other type's lock).
+ */
+DEFINE_PER_CPU(struct llist_head, marie_deferred_put_q);
+static DEFINE_PER_CPU(int[ANON_AND_FILE], marie_drain_depth);
+
+void marie_drain_enter_type(int type)
+{
+	this_cpu_inc(marie_drain_depth[type]);
+}
+void marie_drain_exit_type(int type)
+{
+	this_cpu_dec(marie_drain_depth[type]);
+}
+bool marie_in_drain_type(int type)
+{
+	return this_cpu_read(marie_drain_depth[type]) > 0;
+}
+
+/*
+ * Pop from the local CPU's LIFO; on miss fall back to GFP_ATOMIC slab
+ * and kick a background refill so subsequent allocs hit the pool.
+ * Caller is marie-locked or otherwise non-migratable.
+ */
+struct marie_pending *marie_pending_alloc(struct folio *folio)
+{
+	struct marie_pending_pool *pool = this_cpu_ptr(&marie_pending_pool);
+	struct marie_pending *p;
+
+	if (likely(pool->top > 0)) {
+		p = pool->stack[--pool->top];
+		this_cpu_inc(marie_pending_pool_hits);
+		if (pool->top < READ_ONCE(marie_pending_pool_lowmark))
+			marie_pending_pool_maybe_refill(smp_processor_id());
+		p->folio = folio;
+		return p;
+	}
+
+	this_cpu_inc(marie_pending_pool_misses);
+	p = kmem_cache_alloc(marie_pending_cache, GFP_ATOMIC);
+	if (p)
+		p->folio = folio;
+	else
+		atomic_long_inc(&marie_pending_alloc_failures);
+	marie_pending_pool_maybe_refill(smp_processor_id());
+	return p;
+}
+
+/*
+ * Push back onto the local CPU's LIFO; on full return to the slab
+ * cache. Caller is non-migratable.
+ */
+void marie_pending_free(struct marie_pending *p)
+{
+	struct marie_pending_pool *pool = this_cpu_ptr(&marie_pending_pool);
+
+	if (pool->top < MARIE_PENDING_POOL_DEPTH) {
+		pool->stack[pool->top++] = p;
+		return;
+	}
+	kmem_cache_free(marie_pending_cache, p);
+}
+
+/*
+ * Background refill: GFP_KERNEL alloc outside any IRQ-disabled
+ * critical section, then publish into the local pool with IRQs
+ * briefly disabled.
+ */
+static void marie_pending_pool_refill_work(struct work_struct *w)
+{
+	struct marie_pending *batch[MARIE_PENDING_POOL_DEPTH];
+	struct marie_pending_pool *pool;
+	unsigned long flags;
+	int n = 0, want, i;
+
+	pool = this_cpu_ptr(&marie_pending_pool);
+	want = MARIE_PENDING_POOL_DEPTH - READ_ONCE(pool->top);
+	if (want <= 0)
+		return;
+
+	while (n < want) {
+		batch[n] = kmem_cache_alloc(marie_pending_cache, GFP_KERNEL);
+		if (!batch[n])
+			break;
+		n++;
+	}
+
+	local_irq_save(flags);
+	pool = this_cpu_ptr(&marie_pending_pool);
+	for (i = 0; i < n && pool->top < MARIE_PENDING_POOL_DEPTH; i++)
+		pool->stack[pool->top++] = batch[i];
+	local_irq_restore(flags);
+
+	for (; i < n; i++)
+		kmem_cache_free(marie_pending_cache, batch[i]);
+
+	atomic_long_inc(&marie_pending_refills);
+}
+
+static int marie_pending_pool_cpu_online(unsigned int cpu)
+{
+	marie_pending_pool_maybe_refill(cpu);
+	return 0;
+}
+
+void marie_residency_pending_pool_stats(unsigned long *hits,
+				      unsigned long *misses,
+				      long *failures,
+				      long *refills)
+{
+	unsigned long h = 0, m = 0;
+	int cpu;
+
+	for_each_possible_cpu(cpu) {
+		h += per_cpu(marie_pending_pool_hits, cpu);
+		m += per_cpu(marie_pending_pool_misses, cpu);
+	}
+	*hits     = h;
+	*misses   = m;
+	*failures = atomic_long_read(&marie_pending_alloc_failures);
+	*refills  = atomic_long_read(&marie_pending_refills);
+}
+
+/*
+ * Stash the pending wrapper for later folio_put + slab return.
+ * Called under sl->lock with IRQs off (drain hot path).
+ */
+void marie_defer_pending_put(struct marie_pending *p)
+{
+	llist_add(&p->node, this_cpu_ptr(&marie_deferred_put_q));
+}
+
+/*
+ * Defer a bare folio_put (no pre-existing marie_pending wrapper). Used
+ * by marie_putback_batch and the marie_isolate_folios lost-race path
+ * where we are still under sl->lock and cannot safely chain into
+ * __page_cache_release.
+ *
+ * Allocates a tiny marie_pending wrapper from the per-CPU LIFO pool
+ * (see marie_pending_alloc). Pool hits are zero-slab; misses fall back
+ * to GFP_ATOMIC kmem_cache_alloc, which the workqueue refill should
+ * keep non-empty under all but the most pathological burst. On
+ * persistent failure the WARN_ONCE inline put briefly re-opens the
+ * AB-BA window; marie_pending_alloc_failures counts how often that
+ * fallback fires.
+ */
+void marie_defer_folio_put(struct folio *folio)
+{
+	struct marie_pending *p = marie_pending_alloc(folio);
+
+	if (likely(p)) {
+		llist_add(&p->node, this_cpu_ptr(&marie_deferred_put_q));
+		return;
+	}
+	WARN_ONCE(1, "marie_defer_folio_put: pending pool exhausted, inline put\n");
+	folio_put(folio);
+}
+
+/*
+ * Drain the local CPU's deferred-put llist. MUST be called with no
+ * sl->lock held — folio_put can recurse into lruvec_del_folio ->
+ * lru_marie_del_folio which would re-acquire sl->lock. Idempotent and cheap
+ * (single READ_ONCE of llist head) on miss.
+ */
+void marie_drain_deferred_puts(void)
+{
+	struct llist_node *first, *node, *next;
+
+	first = llist_del_all(this_cpu_ptr(&marie_deferred_put_q));
+	if (!first)
+		return;
+
+	llist_for_each_safe(node, next, first) {
+		struct marie_pending *p =
+			container_of(node, struct marie_pending, node);
+		folio_put(p->folio);
+		marie_pending_free(p);
+	}
+}
+
+/*
+ * ---------------------------------------------------------------------
+ *  Residency state transitions (S3 — marie_transit dispatch)
+ * ---------------------------------------------------------------------
+ *
+ * Each __marie_transit_X_to_Y is the body of one (from, to) edge in the
+ * state diagram (see mm/lru_marie_residency.h). Callers reach these only via
+ * the __always_inline marie_transit() template which dead-code-eliminates
+ * all but the matching branch. PG_active hygiene and other
+ * cross-cutting concerns are concentrated here.
+ */
+
+/*
+ * Producer-side watermark check.
+ *
+ * Bumps this CPU's monotonic push counter. Every (MARIE_ADD_SAMPLE_MASK + 1)
+ * pushes per CPU, sums the cross-CPU counters and compares the delta
+ * against the sl-lock-protected baseline. On overflow,
+ * dispatches marie_drain_worker via schedule_work(); concurrent
+ * dispatches are deduplicated by the workqueue layer (returns false
+ * if already pending).
+ *
+ * Caller context: the lruvec spin_lock_irq* held by the folio_batch
+ * flush disables preemption, satisfying __this_cpu_inc_return's
+ * requirement.
+ *
+ * READ_ONCE on add_count_drained pairs with WRITE_ONCE in
+ * marie_drain_worker; the sample is intentionally lockless on this side.
+ */
+static inline void marie_pending_inc_and_check(struct marie_lruvec *sl)
+{
+	unsigned long local;
+
+	/*
+	 * Caller is inside folio_batch_move_lru with lruvec->lru_lock
+	 * held (IRQ off, preempt off), so smp_processor_id() is stable
+	 * for the duration of the increment and matches the slot we
+	 * touch on every subsequent producer call from this CPU.
+	 */
+	local = atomic_long_inc_return(
+			&sl->add_count[smp_processor_id()].count);
+	if (likely(local & MARIE_ADD_SAMPLE_MASK))
+		return;
+
+	{
+		unsigned long sum = 0, baseline;
+		int cpu;
+
+		for_each_possible_cpu(cpu)
+			sum += atomic_long_read(&sl->add_count[cpu].count);
+		baseline = READ_ONCE(sl->add_count_drained);
+		if (unlikely(sum - baseline > READ_ONCE(marie_add_watermark)))
+			queue_work(marie_drain_wq, &sl->drain_work);
+	}
+}
+
+bool __marie_transit_none_to_pending_add(struct marie_lruvec *sl,
+				       struct folio *folio)
+{
+	unsigned long old, new;
+	struct marie_pending *p;
+
+	/*
+	 * Atomic NONE -> PENDING_ADD: only proceed if MARIE_TRACKED was clear
+	 * when we observed it AND we win the CMPXCHG. Any concurrent path
+	 * (another CPU's enqueue, an in-progress install/del/promote)
+	 * leaves TRACKED set and we noop. Single live queue entry per folio
+	 * is therefore structurally guaranteed.
+	 */
+	old = READ_ONCE(folio->flags.f);
+	do {
+		if (old & MARIE_TRACKED_MASK)
+			return false;
+		new = old | MARIE_TRACKED_MASK;
+	} while (!try_cmpxchg(&folio->flags.f, &old, new));
+
+	/*
+	 * Defensive normalise: folio->lru may carry LIST_POISON from a
+	 * prior list_del (legacy isolator path). folio->lru is always a
+	 * list_head in this design; INIT_LIST_HEAD gives a self-loop,
+	 * which is the right starting state for a PENDING_ADD entry
+	 * that the Phase 1b reclaim path will list_add onto a
+	 * caller-supplied dst.
+	 */
+	INIT_LIST_HEAD(&folio->lru);
+
+	/*
+	 * PG_active hygiene: Marie never uses PG_active. Workingset
+	 * refault / __lru_cache_activate_folio / migrate paths can stamp it
+	 * onto a folio in entry windows; clearing it here, after we own the
+	 * NONE -> PENDING_ADD transition, is race-free and removes the need
+	 * for defensive clears elsewhere.
+	 */
+	if (folio_test_active(folio))
+		folio_clear_active(folio);
+
+	p = marie_pending_alloc(folio);
+	if (!p) {
+		/* Roll back to NONE so a future attempt can retry. The
+		 * payload is already a valid list_head from the INIT above,
+		 * so the NONE invariant is preserved by clearing bits only. */
+		set_mask_bits(&folio->flags.f, MARIE_STATE_MASK, 0);
+		return false;
+	}
+	folio_get(folio);
+	llist_add(&p->node, &sl->types[folio_is_file_lru(folio)].add_queue);
+	marie_pending_inc_and_check(sl);
+	return true;
+}
+
+/*
+ * PENDING_ADD -> NONE: cancel a queued entry. The entry stays on the
+ * per-CPU marie_add_queue and the drain will see TRACKED=0 and discard it
+ * with just a folio_put. Marie never inc'd the standard NR_*_LRU counter
+ * for this folio (it never reached RESIDENT), so there's no lru_size
+ * mirror to undo and no per-gen counter to decrement.
+ *
+ * INIT_LIST_HEAD before the bit clear establishes the NONE-state
+ * payload invariant: folio->lru is always a valid list_head. This
+ * makes the post-NONE folio safe for
+ * marie_residency_isolate_pending_add, which list_add's it onto a
+ * caller-supplied dst.
+ */
+bool __marie_transit_pending_add_to_none(struct marie_lruvec *sl,
+				       struct folio *folio)
+{
+	INIT_LIST_HEAD(&folio->lru);
+	set_mask_bits(&folio->flags.f, MARIE_STATE_MASK, 0);
+	return true;
+}
+
+/*
+ * Shared install body: PENDING_ADD -> RESIDENT and NONE -> RESIDENT
+ * (sl-locked direct install, used by marie_putback_batch). The starting
+ * state difference is invisible at the bit level — on success
+ * MARIE_STATE_MASK is unconditionally rewritten to (TRACKED=1, tier=0)
+ * and folio->lru is list_add'd into the head gen's per-(type, zone)
+ * folio list.
+ *
+ * Only failure is gen-alloc under GFP_ATOMIC. The caller decides the
+ * fallback policy:
+ *   - PENDING_ADD source: re-llist_add the wrapper to add_queue, retry
+ *     on next drain (marie_drain_add_queue_locked). When the gen ring
+ *     is exhausted, marie_residency_isolate_pending_add reclaims
+ *     these directly.
+ *   - NONE source (marie_putback_batch): convert NONE -> PENDING_ADD
+ *     via marie_residency_enqueue_add and let the next drain pick it up.
+ *
+ * On success the global marie_nr_folios is incremented and the lru_size
+ * mirror is updated.
+ */
+static bool __marie_install_locked(struct marie_lruvec *sl, struct folio *folio)
+{
+	int type = folio_is_file_lru(folio);
+	int zone = folio_zonenum(folio);
+	long nr = folio_nr_pages(folio);
+	struct marie_gen *g;
+
+	g = marie_get_or_create_gen(sl, type, GFP_ATOMIC);
+	if (!g)
+		return false;
+
+	/*
+	 * Authoritative install: link folio->lru into the per-(type, zone)
+	 * gen list. list_add cannot fail; install is now a pure list op
+	 * plus counter / bit updates.
+	 */
+	list_add(&folio->lru, &g->folios[type][zone]);
+
+	/*
+	 * PG_active hygiene: the putback caller may bring in a folio
+	 * with PG_active set (shrink_folio_list FOLIOREF_ACTIVATE return).
+	 * Marie never uses PG_active; clear it on the way in so a subsequent
+	 * eviction does not VM_BUG_ON_FOLIO(folio_test_active).
+	 */
+	if (folio_test_active(folio))
+		folio_clear_active(folio);
+
+	/*
+	 * Order matters: TRACKED must be published BEFORE PG_lru is set.
+	 *
+	 * lru_marie_del_folio's lock-free fast path is:
+	 *   if (!lru_marie_enabled())            return false;
+	 *   if (!folio_marie_test_tracked(folio)) return false;
+	 *
+	 * Concurrent __page_cache_release atomically clears PG_lru, then
+	 * (only on success) takes lru_lock and calls lruvec_del_folio,
+	 * which dispatches via the test_tracked() check. If we set PG_lru
+	 * before TRACKED, a concurrent del that fires inside the window
+	 * (folio on gen list, PG_lru=1, TRACKED=0) clears PG_lru, observes
+	 * TRACKED=0, falls through to legacy list_del, and corrupts the
+	 * gen list — yielding the observed 0xdead000000000108 list-poison
+	 * dereference downstream when a later del attempts list_del_init
+	 * on the now-poisoned folio->lru.
+	 *
+	 * Setting TRACKED first eliminates the window: between list_add
+	 * and folio_set_lru, PG_lru remains 0 in the NONE -> RESIDENT
+	 * (putback) path so test_clear_lru fails and no del fires; in the
+	 * PENDING_ADD -> RESIDENT (drain) path TRACKED was already 1 at
+	 * entry (set by the enqueue CMPXCHG), so this set_mask_bits is
+	 * idempotent and the invariant holds throughout.
+	 */
+	set_mask_bits(&folio->flags.f, MARIE_STATE_MASK, MARIE_TRACKED_MASK);
+	folio_set_lru(folio);
+	g->nr_installs += nr;
+	atomic_long_add(nr, &sl->types[type].nr_pages);
+	marie_age_on_add(sl, type, g, GFP_ATOMIC);
+
+	atomic_long_inc(&marie_nr_folios);
+
+	{
+		enum lru_list inst_lru = folio_lru_list(folio);
+
+		marie_update_lru_size(sl->lruvec, inst_lru, zone, nr);
+		atomic_long_add(nr, &sl->marie_lru_zone_size[inst_lru][zone]);
+	}
+	return true;
+}
+
+bool __marie_transit_pending_add_to_resident(struct marie_lruvec *sl,
+					   struct folio *folio)
+{
+	/*
+	 * Stale-wrapper guard. The lock-free CMPXCHG in
+	 * __marie_transit_none_to_pending_add ensures only one TRACKED=0->1
+	 * transition succeeds per attempt, but it does NOT prevent a
+	 * PENDING_ADD -> NONE -> PENDING_ADD round-trip from leaving two
+	 * wrappers in @sl->add_queue for the same folio:
+	 *
+	 *   CPU X: lru_marie_add_folio: CMPXCHG TRACKED=0->1, wrapper W_X
+	 *          enqueued, folio_get.
+	 *   CPU Y: lruvec_del_folio (e.g. via compaction's
+	 *          isolate_lru_folio, which clears PG_lru and routes through
+	 *          our del path independent of the folio's refcount):
+	 *          marie_residency_del_folio_locked observes TRACKED=1 +
+	 *          list_empty=true, runs PENDING_ADD -> NONE, clears TRACKED.
+	 *   CPU Z: lru_marie_add_folio: CMPXCHG TRACKED=0->1 succeeds again,
+	 *          wrapper W_Z enqueued, second folio_get.
+	 *
+	 * Now @sl->add_queue holds W_X and W_Z for the same folio. drain
+	 * processes W_X: folio_marie_test_tracked == true (Z set it),
+	 * list_empty == true (Z's INIT_LIST_HEAD), install runs and the
+	 * folio joins a gen list. drain then processes W_Z: TRACKED still
+	 * set, but list_empty == false because the folio is already on the
+	 * gen list — without this guard, install runs again and list_add
+	 * splices the folio into a second gen list head, corrupting both
+	 * lists. The downstream symptom is the canonical
+	 *   list_add @ __marie_install_locked: head->next == LIST_POISON1
+	 * after a subsequent list_del traverses the duplicated link.
+	 *
+	 * Mirrors __marie_transit_pending_promote_to_resident's
+	 * (TRACKED && !list_empty) precondition. PENDING_ADD's invariant is
+	 * the dual: list_empty must be true to install. If false, the live
+	 * wrapper is the one that already installed; drop us. Caller treats
+	 * a false return as "stale, defer the put" via the same
+	 * marie_defer_pending_put path it already takes for cancelled
+	 * (TRACKED=0) wrappers.
+	 */
+	if (!list_empty(&folio->lru))
+		return false;
+
+	return __marie_install_locked(sl, folio);
+}
+
+bool __marie_transit_none_to_resident(struct marie_lruvec *sl,
+				    struct folio *folio)
+{
+	return __marie_install_locked(sl, folio);
+}
+
+bool __marie_transit_resident_to_none(struct marie_lruvec *sl, struct folio *folio,
+				    struct marie_transit_ctx *ctx)
+{
+	int type = ctx->type;
+	int zone = ctx->zone;
+	long nr = ctx->nr;
+
+	/*
+	 * The caller pre-resolved (type, zone, nr). The folio's gen is
+	 * recovered structurally from list_del_init: removing it from
+	 * whichever gen's folios list it currently sits in cannot fail
+	 * (folio->lru's prev/next pointers identify the neighbours
+	 * regardless of which gen owns the list).
+	 */
+	list_del_init(&folio->lru);
+	atomic_long_sub(nr, &sl->types[type].nr_pages);
+
+	/*
+	 * PG_active hygiene MUST happen before folio_lru_list() below.
+	 * __marie_install_locked clears PG_active and then computes the
+	 * lru index, so install always credits INACTIVE_*. If we read
+	 * folio_lru_list() here while PG_active is still set (e.g. via
+	 * folio_activate() on a RESIDENT folio between install and del),
+	 * we would decrement ACTIVE_* -- an LRU index Marie's install
+	 * never +1'd -- and trip the mz->lru_zone_size underflow WARN.
+	 * Mirror install's order: clear PG_active, then compute lru.
+	 *
+	 * Also drops PG_active for shrink_folio_list, which trips
+	 * VM_BUG_ON_FOLIO(folio_test_active) otherwise.
+	 */
+	if (folio_test_active(folio))
+		folio_clear_active(folio);
+
+	marie_update_lru_size(sl->lruvec, folio_lru_list(folio), zone, -nr);
+
+	/*
+	 * Symmetric inverse of __marie_install_locked's "TRACKED then
+	 * PG_lru" publishing order: clear PG_lru first, then TRACKED.
+	 * The (TRACKED=0, PG_lru=1) window must never be observable to
+	 * concurrent del callers gated on folio_test_clear_lru, otherwise
+	 * they pass the gate, see TRACKED=0 in the lru_marie_del_folio
+	 * fast path, fall through to legacy update_lru_size, and trip
+	 * mz->lru_zone_size below 0 (Marie's install never +1'd that
+	 * counter).
+	 *
+	 * Idempotent for callers that already cleared PG_lru via
+	 * folio_test_clear_lru before reaching the transit
+	 * (__page_cache_release, marie_isolate_folios Phase 2 mainline).
+	 */
+	folio_clear_lru(folio);
+	set_mask_bits(&folio->flags.f, MARIE_STATE_MASK, 0);
+
+	return true;
+}
+
+bool __marie_transit_resident_to_resident(struct marie_lruvec *sl,
+					struct folio *folio,
+					struct marie_transit_ctx *ctx)
+{
+	struct marie_type *t = &sl->types[ctx->type];
+	struct marie_gen *head_gen;
+	int zone = ctx->zone;
+
+	if (list_empty(&t->gens))
+		return true;	/* no head to move to; treat as no-op */
+	head_gen = list_first_entry(&t->gens, struct marie_gen, gen_node);
+
+	/*
+	 * Pure list move: list_move detaches folio->lru from whichever
+	 * gen's folios list currently holds it and inserts it at the
+	 * head_gen's. No allocation; this transit cannot fail. tier
+	 * resets to 0 to give the freshly-promoted folio a full window
+	 * before the next walker pass can re-saturate.
+	 */
+	list_move(&folio->lru, &head_gen->folios[ctx->type][zone]);
+	set_mask_bits(&folio->flags.f, MARIE_TIER_MASK, 0);
+	return true;
+}
+
+bool __marie_transit_pending_promote_to_resident(struct marie_lruvec *sl,
+					       struct folio *folio,
+					       struct marie_transit_ctx *ctx)
+{
+	/*
+	 * The drain dequeues a promote entry whose folio bits are still
+	 * RESIDENT (PENDING_PROMOTE is queue-side state). A live folio
+	 * therefore takes the same list-move path as direct
+	 * RESIDENT -> RESIDENT promote.
+	 */
+	if (!folio_marie_test_tracked(folio) || list_empty(&folio->lru))
+		return false;
+
+	ctx->type = folio_is_file_lru(folio);
+	ctx->zone = folio_zonenum(folio);
+	ctx->nr   = folio_nr_pages(folio);
+	return __marie_transit_resident_to_resident(sl, folio, ctx);
+}
+
+/*
+ * Lock-free state-aware enqueue used by mm/lru_marie.c::lru_marie_add_folio. Thin
+ * wrapper around the NONE -> PENDING_ADD transit.
+ */
+bool marie_residency_enqueue_add(struct marie_lruvec *sl, struct folio *folio)
+{
+	return marie_transit(sl, folio, MARIE_R_NONE, MARIE_R_PENDING_ADD,
+			   &marie_transit_ctx_zero);
+}
+
+enum marie_tier_inc_result marie_residency_tier_inc(struct marie_lruvec *sl,
+						struct folio *folio)
+{
+	unsigned int prev = folio_marie_inc_tier(folio);
+	struct marie_pending *p;
+
+	if (prev != MARIE_TIER_MAX)
+		return MARIE_TIER_INC_OK;
+
+	/*
+	 * Saturated: enqueue a RESIDENT -> PENDING_PROMOTE transit. The
+	 * drain at the next marie_isolate_folios entry (or this walker
+	 * pass's end) moves the folio to head gen + tier 0 under sl->lock
+	 * and updates nr_per_tier accurately on both sides.
+	 */
+	p = marie_pending_alloc(folio);
+	if (!p)
+		return MARIE_TIER_INC_FAILED;
+	folio_get(folio);
+	llist_add(&p->node, &sl->types[folio_is_file_lru(folio)].promote_queue);
+	return MARIE_TIER_INC_SATURATED;
+}
+
+unsigned long
+marie_residency_pop_oldest_batch(struct marie_lruvec *sl, int type,
+			       unsigned long nr_to_scan,
+			       struct folio **batch, int batch_cap,
+			       int max_zone, struct marie_gen **out_gen)
+{
+	struct marie_gen *g;
+	int zone, n_batch = 0;
+	unsigned long taken_pages = 0;
+	/*
+	 * Per-tier overflow buffers for tiers 1..MARIE_TIER_MAX. Tier 0 is the
+	 * coldest, and the common cold-start workload (memhog, bulk ingest)
+	 * fills @batch from tier 0 alone — those scans never touch the
+	 * overflow stack. Higher tiers get parked here only when tier 0 is
+	 * sparse enough that a full sweep of the gen completes without
+	 * filling @batch.
+	 */
+	struct folio *overflow[MARIE_NR_TIERS - 1][MARIE_ISOLATE_BATCH];
+	int overflow_n[MARIE_NR_TIERS - 1] = { };
+	int t;
+
+	if (list_empty(&sl->types[type].gens)) {
+		*out_gen = NULL;
+		return 0;
+	}
+
+	g = list_last_entry(&sl->types[type].gens, struct marie_gen, gen_node);
+	*out_gen = g;
+
+	/*
+	 * Single-pass tier classification over the per-(type, zone) folio
+	 * list. tier 0 candidates flow straight into @batch; tier-{1..MAX}
+	 * candidates are parked in per-tier overflow buckets and drained in
+	 * ascending tier order if @batch was not filled by tier 0 alone.
+	 *
+	 * Two stop conditions:
+	 *
+	 *   - n_batch >= batch_cap: hard array bound; @batch cannot hold more
+	 *     pointers regardless of how many pages each folio represents.
+	 *
+	 *   - taken_pages >= nr_to_scan: page-budget bound, mirroring legacy
+	 *     isolate_lru_folios's "while (scan < nr_to_scan)" semantic.
+	 *     Without this, a single THP (up to 512 pages on order-9) would
+	 *     consume one of the 32 batch slots while the caller's
+	 *     nr_to_scan was, e.g., 32 pages -- a 512x over-isolation in
+	 *     direct reclaim. The page-budget check pulls Marie's
+	 *     isolation granularity in line with legacy / MGLRU.
+	 *
+	 * The check is AFTER the add so the very first folio is always taken
+	 * even if it overshoots: e.g., a single THP > nr_to_scan still gets
+	 * isolated rather than leaving the gen ring undrainable.
+	 *
+	 * One-step prefetch: list_for_each_entry_safe gives us the next
+	 * folio pointer (next_f) before the body executes, which is enough
+	 * to hide a single cache-line fetch on each iteration.
+	 *
+	 * Walker stays lock-free; @nr_per_tier is no longer consulted (it
+	 * was a stale hint — the walker bumps tier bits without touching
+	 * the per-gen counter).
+	 */
+	for (zone = max_zone; zone >= 0; zone--) {
+		struct folio *f, *next_f;
+
+		list_for_each_entry_safe(f, next_f,
+					 &g->folios[type][zone], lru) {
+			unsigned int tier;
+			long nr_pages;
+
+			__builtin_prefetch(next_f, 0, 3);
+			tier = folio_marie_get_tier(f);
+
+			if (tier == 0) {
+				nr_pages = folio_nr_pages(f);
+				batch[n_batch++] = f;
+				taken_pages += nr_pages;
+				if (taken_pages >= nr_to_scan ||
+				    n_batch >= batch_cap)
+					goto done;
+				continue;
+			}
+
+			/* Park higher tiers until the sweep completes. */
+			if (overflow_n[tier - 1] < MARIE_ISOLATE_BATCH)
+				overflow[tier - 1][overflow_n[tier - 1]++] = f;
+		}
+
+		/* Per-zone progress check: also covers the page-budget case
+		 * where the inner add path above did not fire (e.g. tier-0
+		 * candidates ran out partway through @cap_pages). */
+		if (taken_pages >= nr_to_scan || n_batch >= batch_cap)
+			break;
+	}
+
+	/*
+	 * Tier-0 stream did not exhaust the budget. Top up from overflow
+	 * buckets in ascending tier order (coldest first). Per-folio loop
+	 * (no memcpy) so we can update taken_pages each step.
+	 */
+	for (t = 0; t < MARIE_NR_TIERS - 1; t++) {
+		int i;
+
+		for (i = 0; i < overflow_n[t]; i++) {
+			struct folio *f = overflow[t][i];
+			long nr_pages = folio_nr_pages(f);
+
+			batch[n_batch++] = f;
+			taken_pages += nr_pages;
+			if (taken_pages >= nr_to_scan ||
+			    n_batch >= batch_cap)
+				goto done;
+		}
+	}
+
+done:
+	return n_batch;
+}
+
+/*
+ * marie_residency_del_folio_locked - lru_marie_del_folio body (sl->lock held).
+ *
+ * Universal external-removal entry: dispatches PENDING_ADD or RESIDENT
+ * to the matching transit. Caller (lru_marie_del_folio in mm/lru_marie.c) decrements
+ * marie_nr_folios when *did_inc_lru_size is true.
+ *
+ * Returning true tells the dispatcher (lruvec_del_folio in
+ * include/linux/mm_inline.h) "Marie owns this folio, do not fall
+ * through to legacy".
+ *
+ * The MARIE_R_NONE branch returns true defensively. Under the
+ * lru_lock invariant established by Stage 1 (all Marie state
+ * mutations happen with lru_lock held), this branch is unreachable:
+ * for state to flip to NONE between lru_marie_del_folio's fast-path
+ * test (which observed TRACKED=1) and this slow path's
+ * marie_residency_of(), another thread would need to clear TRACKED
+ * while the caller holds lru_lock -- which is impossible because
+ * every TRACKED clear site (transit functions, gen_destroy, reparent,
+ * marie_drain_one_lruvec) is itself reached only with lru_lock held.
+ * Returning true keeps the safe behaviour if the invariant ever
+ * regresses: a stray legacy update_lru_size on a folio Marie already
+ * accounted would double-decrement mz->lru_zone_size.
+ */
+bool marie_residency_del_folio_locked(struct marie_lruvec *sl, struct folio *folio,
+				    bool *did_inc_lru_size)
+{
+	enum marie_residency state = marie_residency_of(folio);
+	struct marie_transit_ctx ctx = { };
+
+	*did_inc_lru_size = false;
+
+	switch (state) {
+	case MARIE_R_NONE:
+		return true;
+	case MARIE_R_PENDING_ADD:
+		return marie_transit(sl, folio, MARIE_R_PENDING_ADD,
+				   MARIE_R_NONE, &ctx);
+	case MARIE_R_RESIDENT:
+		ctx.type = folio_is_file_lru(folio);
+		ctx.zone = folio_zonenum(folio);
+		ctx.nr   = folio_nr_pages(folio);
+		*did_inc_lru_size = true;
+		return marie_transit(sl, folio, MARIE_R_RESIDENT,
+				   MARIE_R_NONE, &ctx);
+	default:
+		return false;
+	}
+}
+
+/*
+ * ---------------------------------------------------------------------
+ *  drain helpers
+ * ---------------------------------------------------------------------
+ */
+
+/*
+ * Per-type implementation of marie_drain_add_queue_locked. Exposed so
+ * isolation callers (which already hold a single per-type lock) can
+ * drain only the type they will scan.
+ */
+void marie_drain_add_queue_one_type_locked(struct marie_lruvec *sl,
+					   int type)
+{
+	struct llist_head *q = &sl->types[type].add_queue;
+	struct llist_node *first, *node, *next;
+
+	if (llist_empty(q))
+		return;
+
+	first = llist_del_all(q);
+
+	/*
+	 * Per-sl queue: every entry belongs to @sl by construction (the
+	 * producer enqueued onto sl->types[type].add_queue after
+	 * marie_get_lruvec resolved the matching sl). No cross-memcg bounce
+	 * loop is needed.
+	 */
+	llist_for_each_safe(node, next, first) {
+		struct marie_pending *p =
+			container_of(node, struct marie_pending, node);
+		struct folio *folio = p->folio;
+		struct marie_transit_ctx ctx = { };
+
+		if (next) {
+			struct marie_pending *np =
+				container_of(next, struct marie_pending, node);
+			__builtin_prefetch(np->folio, 0, 3);
+		}
+
+		/* PENDING_ADD cancellation: lruvec_del_folio cleared TRACKED
+		 * before our drain reached this entry. */
+		if (!folio_marie_test_tracked(folio)) {
+			marie_defer_pending_put(p);
+			continue;
+		}
+
+		/*
+		 * Stale-wrapper drop. PENDING_ADD residency requires
+		 * list_empty(&folio->lru). If a prior wrapper for this folio
+		 * has already installed it (via a PENDING_ADD -> NONE ->
+		 * PENDING_ADD round-trip that re-armed TRACKED via a fresh
+		 * CMPXCHG), the folio is already RESIDENT on a gen list. Re-
+		 * installing would splice the folio into a second gen list
+		 * head and corrupt both.
+		 */
+		if (!list_empty(&folio->lru)) {
+			marie_defer_pending_put(p);
+			continue;
+		}
+
+		/*
+		 * PENDING_ADD -> RESIDENT install. On gen-alloc failure
+		 * (GFP_ATOMIC) __marie_install_locked is a true no-op:
+		 * neither folio->flags nor folio->lru is touched, so the folio
+		 * remains in PENDING_ADD with the existing list_head payload
+		 * invariant intact. Re-llist_add the wrapper so the next
+		 * drain (watermark-triggered or marie_isolate_folios entry) retries
+		 * the install once gen-alloc(GFP_ATOMIC) succeeds (typically
+		 * after the gen-spare pool's workqueue refill).
+		 *
+		 * If install fails persistently AND the gen ring is exhausted,
+		 * marie_residency_isolate_pending_add (called from
+		 * marie_isolate_folios Phase 1b) will dequeue the wrapper and
+		 * route the folio through PENDING_ADD -> NONE -> reclaim
+		 * directly, so no folio is ever stranded.
+		 */
+		if (!marie_transit(sl, folio, MARIE_R_PENDING_ADD,
+				 MARIE_R_RESIDENT, &ctx)) {
+			llist_add(&p->node, q);
+			continue;
+		}
+
+		marie_defer_pending_put(p);
+	}
+}
+
+void marie_drain_add_queue_locked(struct marie_lruvec *sl)
+{
+	int type;
+
+	for (type = 0; type < ANON_AND_FILE; type++)
+		marie_drain_add_queue_one_type_locked(sl, type);
+}
+
+/*
+ * Phase 1b reclaim source: convert PENDING_ADD entries directly into
+ * isolation candidates on @dst, bypassing the install path entirely.
+ *
+ * Called from marie_isolate_folios after pop_oldest_batch when the
+ * gen ring did not fill the caller's batch. Each consumed entry
+ * undergoes PENDING_ADD -> NONE (clears Marie bits and INIT_LIST_HEADs the
+ * payload), claims PG_lru via folio_test_clear_lru, then list_adds onto
+ * @dst. The wrapper's folio_get reference becomes the caller's
+ * isolation reference; the wrapper struct is returned to the slab pool.
+ *
+ * Lost-race handling: a concurrent compaction / __page_cache_release
+ * may have cleared TRACKED or PG_lru between fault-time enqueue and our
+ * drain. Such entries are dropped (marie_defer_pending_put balances the
+ * fault-time folio_get) without making it onto @dst.
+ *
+ * Cap handling: when @cap_remaining is exhausted mid-chain, remaining
+ * popped entries are llist_add'd back onto @sl->add_queue so the next
+ * drain pass services them. The popped chain is fully consumed by
+ * llist_for_each_safe regardless of cap, so no entry leaks.
+ *
+ * Caller MUST hold @sl->lock.
+ */
+/*
+ * Per-type implementation of marie_residency_isolate_pending_add. The
+ * wrapper below loops over both types so the legacy caller semantics
+ * (one call drains PENDING_ADD candidates regardless of type) are
+ * preserved while the queues are now partitioned per type. Also exposed
+ * so isolation can reclaim only its own type's PENDING_ADD entries.
+ */
+unsigned long
+marie_residency_isolate_pending_add_one_type(struct marie_lruvec *sl,
+					     int type,
+					     struct list_head *dst,
+					     int cap_remaining)
+{
+	struct llist_head *q = &sl->types[type].add_queue;
+	struct llist_node *first, *node, *next;
+	unsigned long n_taken = 0;
+
+	if (cap_remaining <= 0 || llist_empty(q))
+		return 0;
+
+	first = llist_del_all(q);
+	llist_for_each_safe(node, next, first) {
+		struct marie_pending *p =
+			container_of(node, struct marie_pending, node);
+		struct folio *folio = p->folio;
+		struct marie_transit_ctx ctx = { };
+
+		if (n_taken >= (unsigned long)cap_remaining) {
+			llist_add(&p->node, q);
+			continue;
+		}
+
+		if (!folio_marie_test_tracked(folio)) {
+			marie_defer_pending_put(p);
+			continue;
+		}
+
+		/*
+		 * Stale-wrapper drop (mirrors marie_drain_add_queue_locked).
+		 * If a prior wrapper has already installed this folio onto a
+		 * gen list via a PENDING_ADD -> NONE -> PENDING_ADD round-trip,
+		 * the folio is RESIDENT, not PENDING_ADD. Running the
+		 * PENDING_ADD -> NONE transit on a RESIDENT folio would
+		 * INIT_LIST_HEAD over its valid gen-list pointers, leaving
+		 * the gen list's neighbors with dangling links into the
+		 * mid-isolation folio.
+		 */
+		if (!list_empty(&folio->lru)) {
+			marie_defer_pending_put(p);
+			continue;
+		}
+
+		/*
+		 * Claim PG_lru first to win against concurrent isolators
+		 * (compaction's isolate_lru_folio, __page_cache_release).
+		 * On a lost race the folio belongs to the other isolator;
+		 * we must not also claim it. Drop the wrapper's folio_get
+		 * via marie_defer_pending_put.
+		 */
+		if (!folio_test_clear_lru(folio)) {
+			marie_defer_pending_put(p);
+			continue;
+		}
+
+		(void)marie_transit(sl, folio, MARIE_R_PENDING_ADD,
+				  MARIE_R_NONE, &ctx);
+
+		list_add(&folio->lru, dst);
+		n_taken++;
+
+		/* Wrapper's folio_get reference is transferred to the
+		 * caller (= shrink_folio_list's isolation reference);
+		 * only the wrapper struct returns to the slab pool. */
+		marie_pending_free(p);
+	}
+
+	return n_taken;
+}
+
+unsigned long
+marie_residency_isolate_pending_add(struct marie_lruvec *sl,
+				  struct list_head *dst,
+				  int cap_remaining)
+{
+	unsigned long n_taken = 0;
+	int type;
+
+	for (type = 0; type < ANON_AND_FILE && cap_remaining > 0; type++) {
+		unsigned long n = marie_residency_isolate_pending_add_one_type(
+				sl, type, dst, cap_remaining);
+		n_taken += n;
+		cap_remaining -= (int)n;
+	}
+	return n_taken;
+}
+
+void marie_drain_promote_queue_one_type_locked(struct marie_lruvec *sl,
+					       int type)
+{
+	struct llist_head *q = &sl->types[type].promote_queue;
+	struct llist_node *first, *node, *next;
+
+	if (llist_empty(q))
+		return;
+
+	first = llist_del_all(q);
+
+	llist_for_each_safe(node, next, first) {
+		struct marie_pending *p =
+			container_of(node, struct marie_pending, node);
+		struct folio *folio = p->folio;
+		struct marie_transit_ctx ctx = { };
+
+		/*
+		 * PENDING_PROMOTE -> RESIDENT: a stale entry (folio
+		 * removed between walker enqueue and now) becomes a
+		 * no-op inside __marie_transit_pending_promote_to_resident
+		 * via its TRACKED + list_empty pre-check.
+		 */
+		(void)marie_transit(sl, folio, MARIE_R_PENDING_PROMOTE,
+				  MARIE_R_RESIDENT, &ctx);
+		marie_defer_pending_put(p);
+	}
+}
+
+void marie_drain_promote_queue_locked(struct marie_lruvec *sl)
+{
+	int type;
+
+	for (type = 0; type < ANON_AND_FILE; type++)
+		marie_drain_promote_queue_one_type_locked(sl, type);
+}
+
+void marie_drain_pending(struct marie_lruvec *sl)
+{
+	/*
+	 * Lock order: lru_lock outer, sl->lock inner. The drain transit
+	 * paths call marie_update_lru_size which embeds
+	 * mem_cgroup_update_lru_size — that update on mz->lru_zone_size
+	 * needs lru_lock to serialise against legacy / MGLRU updaters.
+	 */
+	/*
+	 * Pin the CPU across the accumulate-then-drain span. The drain
+	 * helpers enqueue deferred puts onto the local CPU's
+	 * marie_deferred_put_q (under spin_lock_irq, where the CPU
+	 * cannot change); once the guard releases, the task can migrate
+	 * before marie_drain_deferred_puts() reads this_cpu_ptr —
+	 * leaking the just-enqueued wrappers and their folio_get
+	 * references onto the abandoned CPU's queue.
+	 *
+	 * migrate_disable keeps producer and consumer on the same CPU
+	 * without disabling preemption, so high-priority work can still
+	 * run during the drain. On non-PREEMPT_RT this compiles to the
+	 * same primitive as preempt_disable; on PREEMPT_RT it's
+	 * strictly weaker and preferred.
+	 */
+	migrate_disable();
+	scoped_guard(spinlock_irq, &sl->lruvec->lru_lock)
+	scoped_guard(marie_both_sl, sl) {
+		marie_drain_add_queue_locked(sl);
+		marie_drain_promote_queue_locked(sl);
+	}
+
+	/* Drain deferred puts outside both locks — folio_put can chain
+	 * into __page_cache_release which itself takes lru_lock. The
+	 * surrounding migrate_disable guarantees we drain the same CPU's
+	 * queue the locked section enqueued onto. */
+	marie_drain_deferred_puts();
+	migrate_enable();
+
+	/* Install-failed entries remain on @sl->add_queue as PENDING_ADD
+	 * no-ops; they are picked up either by the next drain
+	 * (watermark-triggered) or by marie_isolate_folios's Phase 1b reclaim
+	 * source. */
+}
+
+/*
+ * Chunked variant of marie_drain_add_queue_locked: pop up to @max
+ * entries via llist_del_first and process them. Returns true if any
+ * type's add_queue is non-empty after this call (more work may remain).
+ *
+ * The @max budget is shared across both types: type 0 (anon) is
+ * processed first up to the remaining budget, then type 1 (file). This
+ * keeps the worst-case lock-hold bounded by the same MARIE_ISOLATE_BATCH
+ * cap the single-queue variant used.
+ *
+ * Caller MUST hold sl->lock + lru_lock (same as the unbounded variant).
+ */
+static bool marie_drain_add_queue_chunk(struct marie_lruvec *sl, int max)
+{
+	int type, n;
+
+	for (type = 0; type < ANON_AND_FILE && max > 0; type++) {
+		struct llist_head *q = &sl->types[type].add_queue;
+		/*
+		 * Local retry chain: wrappers whose install transit failed
+		 * (gen alloc -ENOMEM under GFP_ATOMIC) are stashed here for
+		 * the duration of this chunk instead of being re-added to
+		 * the head of @q. If we re-added them to @q, the next
+		 * llist_del_first would pop the same wrapper and we would
+		 * burn the entire @max budget on a single non-progressing
+		 * item, livelocking under sustained allocator pressure
+		 * (commonly seen during shutdown's memory churn). With a
+		 * separate retry chain we visit every wrapper at most once
+		 * per drain pass; failed wrappers re-enter @q at the end
+		 * so the next drain (watermark- or isolation-triggered)
+		 * retries them, by which time the slab pool's GFP_KERNEL
+		 * refill work has likely freed up gen-cache memory.
+		 */
+		struct llist_node *retry_first = NULL;
+
+		for (n = 0; n < max; n++) {
+			struct llist_node *node = llist_del_first(q);
+			struct marie_pending *p;
+			struct folio *folio;
+			struct marie_transit_ctx ctx = { };
+
+			if (!node)
+				break;	/* this type's queue empty */
+
+			p = container_of(node, struct marie_pending, node);
+			folio = p->folio;
+
+			if (!folio_marie_test_tracked(folio)) {
+				marie_defer_pending_put(p);
+				continue;
+			}
+			if (!list_empty(&folio->lru)) {
+				marie_defer_pending_put(p);
+				continue;
+			}
+			if (!marie_transit(sl, folio, MARIE_R_PENDING_ADD,
+					 MARIE_R_RESIDENT, &ctx)) {
+				/* Stash on local retry chain, not @q. */
+				p->node.next = retry_first;
+				retry_first = &p->node;
+				continue;
+			}
+			marie_defer_pending_put(p);
+		}
+		max -= n;
+
+		/* Re-attach retry chain to @q for the next drain pass. */
+		while (retry_first) {
+			struct llist_node *next_retry = retry_first->next;
+
+			llist_add(retry_first, q);
+			retry_first = next_retry;
+		}
+	}
+
+	return !llist_empty(&sl->types[0].add_queue) ||
+	       !llist_empty(&sl->types[1].add_queue);
+}
+
+static bool marie_drain_promote_queue_chunk(struct marie_lruvec *sl, int max)
+{
+	int type, n;
+
+	for (type = 0; type < ANON_AND_FILE && max > 0; type++) {
+		struct llist_head *q = &sl->types[type].promote_queue;
+
+		for (n = 0; n < max; n++) {
+			struct llist_node *node = llist_del_first(q);
+			struct marie_pending *p;
+			struct folio *folio;
+			struct marie_transit_ctx ctx = { };
+
+			if (!node)
+				break;
+
+			p = container_of(node, struct marie_pending, node);
+			folio = p->folio;
+
+			(void)marie_transit(sl, folio, MARIE_R_PENDING_PROMOTE,
+					  MARIE_R_RESIDENT, &ctx);
+			marie_defer_pending_put(p);
+		}
+		max -= n;
+	}
+
+	return !llist_empty(&sl->types[0].promote_queue) ||
+	       !llist_empty(&sl->types[1].promote_queue);
+}
+
+/*
+ * Watermark-triggered drain worker. Dispatched via
+ * queue_work(marie_drain_wq, &sl->drain_work) from the fault path
+ * when (sum_per_cpu(add_count) - add_count_drained) exceeds
+ * marie_add_watermark. queue_work deduplicates concurrent dispatches.
+ *
+ * Chunked drain: each invocation processes at most MARIE_ISOLATE_BATCH
+ * entries from each queue (~64 entries total, ~600 us upper bound on
+ * lock hold). When more work remains the worker re-queues itself,
+ * letting other CPUs interleave on lru_lock between chunks.
+ *
+ * @add_count_drained is updated only after a chunk that fully drained
+ * the add_queue; mid-drain updates would mislead the watermark check
+ * into thinking the producer-side queue is shorter than reality and
+ * could cause it to skip the next dispatch.
+ *
+ * @add_count_drained is written here under sl->lock but read on the
+ * fault path without it (lockless sample) — WRITE_ONCE pairs with
+ * READ_ONCE there to document data-race intent and prevent compiler
+ * tearing of the store.
+ */
+static void marie_drain_worker(struct work_struct *work)
+{
+	struct marie_lruvec *sl = container_of(work, struct marie_lruvec,
+					     drain_work);
+	bool more_add, more_promote;
+
+	/*
+	 * Lock order: lru_lock outer, sl->lock inner. See
+	 * marie_drain_pending for the lru_zone_size accounting rationale.
+	 */
+	/* Pin the CPU so the deferred puts enqueued inside the guard
+	 * are drained from the same per-CPU queue. See marie_drain_pending
+	 * for the rationale. */
+	migrate_disable();
+	scoped_guard(spinlock_irq, &sl->lruvec->lru_lock)
+	scoped_guard(marie_both_sl, sl) {
+		more_add = marie_drain_add_queue_chunk(sl, MARIE_ISOLATE_BATCH);
+		more_promote = marie_drain_promote_queue_chunk(sl,
+							     MARIE_ISOLATE_BATCH);
+
+		if (!more_add) {
+			unsigned long sum = 0;
+			int cpu;
+
+			for_each_possible_cpu(cpu)
+				sum += atomic_long_read(&sl->add_count[cpu].count);
+			WRITE_ONCE(sl->add_count_drained, sum);
+		}
+	}
+
+	marie_drain_deferred_puts();
+	migrate_enable();
+
+	/*
+	 * If either queue still has work, re-queue. queue_work is idempotent
+	 * for already-pending work, and safe to call from inside the work
+	 * function for a running instance (the workqueue core will start a
+	 * fresh run after this one completes).
+	 */
+	if (more_add || more_promote)
+		queue_work(marie_drain_wq, &sl->drain_work);
+
+	/* Install-failed entries persist on @sl->add_queue as PENDING_ADD
+	 * no-ops; they are reclaimed via marie_isolate_folios Phase 1b
+	 * when memory pressure drains the gen ring. */
+}
+
+/*
+ * ---------------------------------------------------------------------
+ *  Gen ring + lruvec lifecycle
+ * ---------------------------------------------------------------------
+ */
+
+/*
+ * Slab cache for struct marie_gen and stats counters for the gen alloc
+ * path.  The gen ring's peak occupancy is MARIE_MAX_NR_GENS per type per
+ * lruvec; marie_alloc_lruvec() pre-fills sl->gen_spare to that peak so
+ * the runtime path never hits kmem_cache_zalloc() except in a warmup
+ * race (marie_alloc_lruvec was called with GFP_ATOMIC and the prefill
+ * itself failed).
+ */
+static struct kmem_cache *marie_gen_cache;
+static atomic_long_t marie_gen_spare_hits;
+static atomic_long_t marie_gen_spare_misses;
+static atomic_long_t marie_gen_alloc_failures;
+
+static void marie_type_init(struct marie_type *t, int type)
+{
+	spin_lock_init(&t->lock);
+	t->type = type;
+	INIT_LIST_HEAD(&t->gens);
+	t->current_seq = 0;
+	t->oldest_seq = 0;
+	atomic_long_set(&t->nr_pages, 0);
+	init_llist_head(&t->add_queue);
+	init_llist_head(&t->promote_queue);
+	INIT_LIST_HEAD(&t->gen_spare);
+	t->nr_gen_spare = 0;
+}
+
+/*
+ * Return @g to @sl's spare list for @type instead of freeing it.
+ * Called by marie_try_drop_oldest() under sl->lock (only on empty
+ * gens) and by marie_type_destroy() at lruvec teardown. Teardown
+ * evicts any still-resident folios in place.
+ *
+ * Eviction order matters. __marie_install_locked publishes
+ * TRACKED before PG_lru so that a concurrent __page_cache_release
+ * cannot see an in-flight install as a Marie-untracked folio (the
+ * PG_lru=0 window means folio_test_clear_lru fails and no del fires;
+ * see the comment above set_mask_bits in __marie_install_locked).
+ *
+ * The dual on the way out is: clear PG_lru BEFORE clearing the Marie
+ * state bits. If we cleared TRACKED first, a concurrent
+ * __page_cache_release entering the (TRACKED=0, PG_lru=1) window
+ * would succeed at folio_test_clear_lru, observe TRACKED=0 in the
+ * lru_marie_del_folio fast path, fall through to legacy
+ * update_lru_size, and decrement mz->lru_zone_size for an LRU index
+ * that Marie's install never +1'd (Marie's marie_update_lru_size only
+ * mirrors via mod_lruvec_state / __mod_zone_page_state and does NOT
+ * call mem_cgroup_update_lru_size). The result is a guaranteed
+ * mz->lru_zone_size underflow visible as the WARN at memcontrol.c
+ * "lru_size went negative".
+ *
+ * Clearing PG_lru first fences out every del-side caller gated on
+ * folio_test_clear_lru (__page_cache_release, isolate_lru_folio,
+ * release_pages, ...). After that we own the folio's residency state
+ * exclusively under sl->lock and can do the rest of the cleanup
+ * without races.
+ *
+ * Folio refcount is left untouched (residents always have a live ref;
+ * the owner drops it on its own schedule). When the last ref does
+ * drop, __page_cache_release sees PG_lru=0 and skips the lru_lock
+ * cleanup entirely -- correct, because Marie has already accounted
+ * the eviction here.
+ *
+ * The actual kmem_cache_free() happens in marie_gen_spare_drain()
+ * once the lruvec is finalised.
+ */
+static void marie_gen_destroy(struct marie_lruvec *sl, int type,
+			    struct marie_gen *g)
+{
+	long ejected = 0;
+	int z;
+
+	for (z = 0; z < MAX_NR_ZONES; z++) {
+		struct folio *folio, *next_folio;
+
+		list_for_each_entry_safe(folio, next_folio,
+					 &g->folios[type][z], lru) {
+			long nr = folio_nr_pages(folio);
+			enum lru_list lru;
+			bool we_own;
+
+			/*
+			 * folio_test_clear_lru is the ownership signal for
+			 * the del. Win it: run the full eviction (-1
+			 * mz->lru_zone_size). Lose it: a concurrent path
+			 * already committed via its own atomic
+			 * test_clear_lru and is blocked at lru_lock; once
+			 * we release, its lruvec_del_folio fast path will
+			 * see TRACKED=0 (we clear it below) and fall
+			 * through to legacy update_lru_size, which -1's
+			 * mz->lru_zone_size. Either way exactly one path
+			 * decrements -- no double-decrement.
+			 */
+			we_own = folio_test_clear_lru(folio);
+
+			/* Mirror __marie_install_locked: clear PG_active
+			 * before computing folio_lru_list so we decrement
+			 * the same INACTIVE_* index install +1'd. */
+			if (folio_test_active(folio))
+				folio_clear_active(folio);
+			lru = folio_lru_list(folio);
+
+			list_del_init(&folio->lru);
+			atomic_long_sub(nr, &sl->types[type].nr_pages);
+			if (we_own) {
+				marie_update_lru_size(sl->lruvec, lru, z, -nr);
+				atomic_long_sub(nr,
+					&sl->marie_lru_zone_size[lru][z]);
+				set_mask_bits(&folio->flags.f,
+					      MARIE_STATE_MASK, 0);
+			} else {
+				/*
+				 * Concurrent path won folio_test_clear_lru
+				 * and is about to call lruvec_del_folio.
+				 * Marie no longer touches mz->lru_zone_size,
+				 * so legacy fall-through (when TRACKED=0
+				 * routes through update_lru_size(-nr)) would
+				 * underflow mz for a folio whose mz
+				 * contribution was always zero.
+				 *
+				 * Drop OUR per-bucket count + the
+				 * vmstat/zone counters now (concurrent
+				 * won't touch them because their del will
+				 * be intercepted by lru_marie_del_folio's
+				 * !sl branch -- xa_erase already cleared
+				 * the sl). Leave MARIE_TRACKED=1 so that
+				 * concurrent's lru_marie_del_folio fast
+				 * path passes the TRACKED check and reaches
+				 * the !sl branch (which returns true and
+				 * suppresses legacy fall-through). The !sl
+				 * branch clears MARIE_TRACKED for us.
+				 */
+				marie_update_lru_size(sl->lruvec, lru, z, -nr);
+				atomic_long_sub(nr,
+					&sl->marie_lru_zone_size[lru][z]);
+				/* MARIE_TRACKED stays set; !sl clears it */
+			}
+			ejected++;
+		}
+	}
+	if (ejected)
+		atomic_long_sub(ejected, &marie_nr_folios);
+	list_del(&g->gen_node);
+	list_add(&g->gen_node, &sl->types[type].gen_spare);
+	sl->types[type].nr_gen_spare++;
+}
+
+static void marie_type_destroy(struct marie_lruvec *sl, int type)
+{
+	struct marie_type *t = &sl->types[type];
+	struct marie_gen *g, *tmp;
+
+	list_for_each_entry_safe(g, tmp, &t->gens, gen_node)
+		marie_gen_destroy(sl, type, g);
+	atomic_long_set(&t->nr_pages, 0);
+}
+
+/*
+ * Hand off every folio in @child_sl's gen lists to @parent_sl. Used at
+ * memcg reparenting (mm/swap.c::lru_reparent_memcg) so that folios charged
+ * to a dying memcg never end up linked from a sl that no longer matches
+ * their objcg.
+ *
+ * Caller holds @child_sl->lock. @parent_sl->lock is NOT taken — the
+ * enqueue path uses sl->add_queue (llist) which is lock-free.
+ */
+long marie_residency_reparent_locked(struct marie_lruvec *child_sl,
+				   struct marie_lruvec *parent_sl)
+{
+	long migrated = 0;
+	int t, z;
+
+	/*
+	 * Drain pending queues so every still-tracked folio is materialised
+	 * onto a per-(t, z) gen list. After the drain, all live state for
+	 * @child_sl is reachable via the gens walk below.
+	 */
+	marie_drain_add_queue_locked(child_sl);
+	marie_drain_promote_queue_locked(child_sl);
+
+	for (t = 0; t < ANON_AND_FILE; t++) {
+		struct marie_type *type = &child_sl->types[t];
+		struct marie_gen *g, *tmp_g;
+
+		list_for_each_entry_safe(g, tmp_g, &type->gens, gen_node) {
+			for (z = 0; z < MAX_NR_ZONES; z++) {
+				struct folio *folio, *next_folio;
+
+				list_for_each_entry_safe(folio, next_folio,
+							 &g->folios[t][z], lru) {
+					long nr = folio_nr_pages(folio);
+					enum lru_list lru;
+					bool we_own;
+
+					/*
+					 * folio_test_clear_lru as ownership
+					 * signal, same pattern as
+					 * marie_gen_destroy. Win it: full
+					 * processing -- decrement child's
+					 * lru_zone_size to balance the
+					 * original install +1, clear Marie
+					 * state, hand off to parent_sl via
+					 * enqueue_add. Lose it: a concurrent
+					 * path already committed via its own
+					 * atomic test_clear_lru and is
+					 * blocked at parent's lru_lock; we
+					 * still -1 child to balance the
+					 * install but leave TRACKED=1 (and
+					 * skip the parent enqueue) so that
+					 * concurrent's eventual
+					 * lruvec_del_folio reaches Marie's
+					 * slow path on parent_sl with
+					 * state=PENDING_ADD (TRACKED=1,
+					 * list_empty=true). The
+					 * PENDING_ADD->NONE transit is a
+					 * pure bit + INIT_LIST_HEAD op, so
+					 * it does not -1 parent's
+					 * lru_zone_size and it returns true
+					 * to suppress the dispatcher
+					 * fall-through. Net: child 0
+					 * (install +1, our -1), parent 0
+					 * (never +1, never -1). The
+					 * "stuck PENDING_ADD" state is
+					 * cleared by concurrent's transit
+					 * (which clears TRACKED).
+					 */
+					we_own = folio_test_clear_lru(folio);
+
+					if (folio_test_active(folio))
+						folio_clear_active(folio);
+					lru = folio_lru_list(folio);
+
+					list_del_init(&folio->lru);
+					atomic_long_sub(nr, &child_sl->types[t].nr_pages);
+					marie_update_lru_size(
+						child_sl->lruvec, lru, z, -nr);
+					atomic_long_sub(nr,
+						&child_sl->marie_lru_zone_size[lru][z]);
+					if (we_own)
+						set_mask_bits(&folio->flags.f,
+							      MARIE_STATE_MASK,
+							      0);
+					/* else: leave TRACKED=1 for
+					 * concurrent's slow path. */
+					migrated++;
+					/*
+					 * Hand to parent only when we own
+					 * the del. The lose-case skips the
+					 * enqueue: the concurrent winner is
+					 * doing the del on parent_sl
+					 * already, and a stray enqueue here
+					 * could leave a wrapper for a folio
+					 * the concurrent path is about to
+					 * free.
+					 */
+					if (we_own && parent_sl)
+						marie_residency_enqueue_add(
+							parent_sl, folio);
+				}
+			}
+			/* Gen is empty; recycle to spare. */
+			list_del(&g->gen_node);
+			g->nr_installs = 0;
+			list_add(&g->gen_node, &child_sl->types[t].gen_spare);
+			child_sl->types[t].nr_gen_spare++;
+		}
+		atomic_long_set(&type->nr_pages, 0);
+	}
+
+	return migrated;
+}
+
+/*
+ * Pre-allocate up to MARIE_MAX_NR_GENS gens into sl->types[type].gen_spare.
+ * Called from marie_alloc_lruvec().  Failures are tolerated — the runtime
+ * path retries kmem_cache_zalloc(GFP_ATOMIC), and the existing legacy
+ * LRU fallback handles the residual case.
+ */
+static int marie_gen_spare_prefill(struct marie_lruvec *sl, int type, gfp_t gfp)
+{
+	struct marie_gen *g;
+	int i;
+
+	for (i = sl->types[type].nr_gen_spare; i < MARIE_MAX_NR_GENS; i++) {
+		g = kmem_cache_zalloc(marie_gen_cache, gfp);
+		if (!g)
+			return -ENOMEM;
+		list_add(&g->gen_node, &sl->types[type].gen_spare);
+		sl->types[type].nr_gen_spare++;
+	}
+	return 0;
+}
+
+/*
+ * Final free of every gen in sl->types[type].gen_spare.  Called from
+ * marie_free_lruvec() after marie_type_destroy() has folded any active
+ * gens into the spare.
+ */
+static void marie_gen_spare_drain(struct marie_lruvec *sl, int type)
+{
+	struct marie_gen *g, *tmp;
+
+	list_for_each_entry_safe(g, tmp, &sl->types[type].gen_spare, gen_node) {
+		list_del(&g->gen_node);
+		kmem_cache_free(marie_gen_cache, g);
+	}
+	sl->types[type].nr_gen_spare = 0;
+}
+
+struct marie_lruvec *marie_alloc_lruvec(struct lruvec *lv, gfp_t gfp)
+{
+	struct marie_lruvec *sl;
+	int t;
+
+	sl = kzalloc(sizeof(*sl), gfp);
+	if (!sl)
+		return NULL;
+
+	sl->lruvec = lv;
+	sl->memcg = lruvec_memcg(lv);
+	sl->nid = lruvec_pgdat(lv)->node_id;
+	/* Per-type locks are initialised inside marie_type_init() below. */
+
+	/*
+	 * Per-CPU push counter array and the drain worker. Each
+	 * marie_add_slot is a full cache line, eliminating false sharing
+	 * between adjacent CPUs' producer increments.
+	 *
+	 * Allocation: kmalloc rather than alloc_percpu because
+	 * marie_alloc_lruvec is reachable from marie_get_lruvec, which is
+	 * called inside folio_batch_move_lru with lruvec->lru_lock held
+	 * (atomic context). alloc_percpu's pcpu_alloc_mutex would sleep
+	 * here and crash with "BUG: scheduling while atomic" plus the
+	 * matching RCU CSWITCH WARN. kmalloc + GFP_ATOMIC has no such
+	 * mutex.
+	 *
+	 * Cache-line alignment: kmalloc does not guarantee that the
+	 * returned buffer starts on an L1_CACHE_BYTES boundary, so an
+	 * extra (L1_CACHE_BYTES - 1) bytes are allocated and PTR_ALIGN
+	 * shifts the published @add_count to the first cache line within
+	 * the buffer. The unaligned base @add_count_raw is retained for
+	 * the matching kfree.
+	 *
+	 * INIT_WORK is one-shot; cancel_work_sync in marie_drop_lruvec
+	 * releases anything we end up scheduling.
+	 */
+	{
+		size_t needed = nr_cpu_ids * sizeof(struct marie_add_slot);
+		size_t padded = needed + L1_CACHE_BYTES - 1;
+
+		sl->add_count_raw = kzalloc(padded, gfp);
+		if (!sl->add_count_raw) {
+			kfree(sl);
+			return NULL;
+		}
+		sl->add_count = PTR_ALIGN(sl->add_count_raw, L1_CACHE_BYTES);
+	}
+	INIT_WORK(&sl->drain_work, marie_drain_worker);
+
+	for (t = 0; t < ANON_AND_FILE; t++) {
+		marie_type_init(&sl->types[t], t);
+		/* gen_spare[] and nr_gen_spare are initialised inside
+		 * marie_type_init(); the prefill below populates them. */
+		/*
+		 * Best-effort: if the lruvec is being created from an
+		 * IRQ-disabled context the prefill may fail and the runtime
+		 * path will retry GFP_ATOMIC.  No reason to fail the lruvec
+		 * allocation over this.
+		 */
+		(void)marie_gen_spare_prefill(sl, t, gfp);
+	}
+	return sl;
+}
+
+void marie_free_lruvec(struct marie_lruvec *sl)
+{
+	int t;
+
+	/*
+	 * marie_type_destroy folds active gens into sl->gen_spare; the
+	 * subsequent marie_gen_spare_drain does the actual kmem_cache_free.
+	 */
+	for (t = 0; t < ANON_AND_FILE; t++) {
+		marie_type_destroy(sl, t);
+		marie_gen_spare_drain(sl, t);
+	}
+	/*
+	 * At this point the work_struct is guaranteed not to be scheduled
+	 * — either we never published @sl (alloc-error path, never
+	 * reachable from xa_load) or marie_drop_lruvec has already run
+	 * synchronize_rcu + cancel_work_sync. Free the kmalloc'd per-CPU
+	 * push-counter array via the unaligned base pointer.
+	 */
+	kfree(sl->add_count_raw);
+	kfree(sl);
+}
+
+/* Allocate a fresh gen and link it as the new head (max_seq advance). */
+int marie_advance_max_seq(struct marie_lruvec *sl, int type, gfp_t gfp)
+{
+	struct marie_type *t = &sl->types[type];
+	struct marie_gen *g;
+	int z;
+
+	if (marie_nr_gens(t) >= MARIE_MAX_NR_GENS)
+		return -EAGAIN;
+
+	g = list_first_entry_or_null(&sl->types[type].gen_spare,
+				     struct marie_gen, gen_node);
+	if (g) {
+		list_del(&g->gen_node);
+		sl->types[type].nr_gen_spare--;
+		memset(g, 0, sizeof(*g));
+		atomic_long_inc(&marie_gen_spare_hits);
+	} else {
+		/*
+		 * Spare warmup race: marie_alloc_lruvec was called with
+		 * GFP_ATOMIC and prefill itself failed.  Retry directly.
+		 */
+		g = kmem_cache_zalloc(marie_gen_cache, gfp);
+		atomic_long_inc(&marie_gen_spare_misses);
+		if (!g) {
+			atomic_long_inc(&marie_gen_alloc_failures);
+			return -ENOMEM;
+		}
+	}
+
+	for (z = 0; z < MAX_NR_ZONES; z++) {
+		INIT_LIST_HEAD(&g->folios[0][z]);
+		INIT_LIST_HEAD(&g->folios[1][z]);
+	}
+
+	if (list_empty(&t->gens))
+		t->oldest_seq = t->current_seq;
+	else
+		t->current_seq++;
+	g->seq = t->current_seq;
+	list_add(&g->gen_node, &t->gens);
+	return 0;
+}
+
+/* Is @g empty across all (type, zone) folio lists? */
+static bool marie_gen_empty(const struct marie_gen *g)
+{
+	int t, z;
+
+	for (t = 0; t < ANON_AND_FILE; t++)
+		for (z = 0; z < MAX_NR_ZONES; z++)
+			if (!list_empty(&g->folios[t][z]))
+				return false;
+	return true;
+}
+
+/* Free empty oldest gens until either the tail has folios again or we
+ * hit the MARIE_MIN_NR_GENS floor. */
+void marie_try_drop_oldest(struct marie_lruvec *sl, int type)
+{
+	struct marie_type *t = &sl->types[type];
+	struct marie_gen *g;
+
+	while (marie_nr_gens(t) > MARIE_MIN_NR_GENS) {
+		g = list_last_entry(&t->gens, struct marie_gen, gen_node);
+		if (!marie_gen_empty(g))
+			break;
+		marie_gen_destroy(sl, type, g);	/* list_del + push to spare */
+		t->oldest_seq++;
+	}
+}
+
+/* Top the ring up to MARIE_MIN_NR_GENS so isolation has a separate
+ * tail to drain while new folios land in a fresh head. */
+void marie_age(struct marie_lruvec *sl, int type, gfp_t gfp)
+{
+	while (marie_nr_gens(&sl->types[type]) < MARIE_MIN_NR_GENS) {
+		if (marie_advance_max_seq(sl, type, gfp))
+			break;	/* either at cap or out of memory */
+	}
+}
+
+/*
+ * Allocation-side aging trigger: cut a fresh empty head when the
+ * current head has accumulated marie_gen_growth_threshold installs.
+ * `nr_installs` is monotonic per gen (incremented on install only;
+ * never decremented on del or rotate-out), so the threshold fires
+ * exactly once per head's lifetime.
+ */
+void marie_age_on_add(struct marie_lruvec *sl, int type,
+		    struct marie_gen *head, gfp_t gfp)
+{
+	if (head->nr_installs > READ_ONCE(marie_gen_growth_threshold))
+		marie_advance_max_seq(sl, type, gfp);
+}
+
+/*
+ * Add path entry: always lands on the head gen, lazily creating the
+ * very first one. Caller holds sl->lock.
+ */
+struct marie_gen *marie_get_or_create_gen(struct marie_lruvec *sl, int type,
+				      gfp_t gfp)
+{
+	if (!list_empty(&sl->types[type].gens))
+		return list_first_entry(&sl->types[type].gens,
+					struct marie_gen, gen_node);
+
+	if (marie_advance_max_seq(sl, type, gfp))
+		return NULL;
+	return list_first_entry(&sl->types[type].gens,
+				struct marie_gen, gen_node);
+}
+
+void marie_residency_gen_spare_stats(long *hits, long *misses, long *failures)
+{
+	*hits     = atomic_long_read(&marie_gen_spare_hits);
+	*misses   = atomic_long_read(&marie_gen_spare_misses);
+	*failures = atomic_long_read(&marie_gen_alloc_failures);
+}
+
+int marie_residency_init(void)
+{
+	int err, cpu;
+
+	/* SLAB_PANIC: failure here means Marie cannot boot anyway. */
+	marie_gen_cache     = KMEM_CACHE(marie_gen,
+				       SLAB_RECLAIM_ACCOUNT | SLAB_PANIC);
+	marie_pending_cache = KMEM_CACHE(marie_pending, SLAB_PANIC);
+
+	/*
+	 * WQ_UNBOUND: drain runs are inherently long-running (whole
+	 * add_queue + promote_queue under sl->lock); treat them as
+	 * unbound so the per-CPU stall watchdog does not WARN.
+	 * WQ_MEM_RECLAIM: drain progress is required during memory
+	 * pressure, hence a reserved rescuer thread.
+	 */
+	marie_drain_wq = alloc_workqueue("marie_drain",
+					 WQ_UNBOUND | WQ_MEM_RECLAIM, 0);
+	if (!marie_drain_wq)
+		return -ENOMEM;
+
+	for_each_possible_cpu(cpu) {
+		struct marie_pending_pool *ppool = per_cpu_ptr(&marie_pending_pool, cpu);
+
+		ppool->top = 0;
+		INIT_WORK(&ppool->refill_work, marie_pending_pool_refill_work);
+		schedule_work_on(cpu, &ppool->refill_work);
+	}
+
+	/*
+	 * _nocalls: we already kicked the initial refill loop above; the
+	 * cpuhp callback only handles offline->online transitions after
+	 * registration so the pending wrapper pool is populated on hot-add.
+	 */
+	err = cpuhp_setup_state_nocalls(CPUHP_AP_ONLINE_DYN,
+					"mm/lru_marie_residency:pending_online",
+					marie_pending_pool_cpu_online, NULL);
+	if (err < 0) {
+		pr_err("failed to register pending cpuhp callback: %d\n", err);
+		return err;
+	}
+
+	return 0;
+}
diff --git a/mm/lru_marie_residency.h b/mm/lru_marie_residency.h
new file mode 100644
index 000000000..0852ca1e1
--- /dev/null
+++ b/mm/lru_marie_residency.h
@@ -0,0 +1,1006 @@
+/* SPDX-License-Identifier: GPL-2.0 */
+/*
+ * mm/lru_marie_residency.h — Marie residency ADT (internal to mm/).
+ *
+ * The ADT owns folio-residency state for Marie: gen ring + tier
+ * counters + per-CPU LIFO pending-wrapper pool + pending / promote /
+ * deferred-put queues + sl->lock with scoped_guard discipline. Callers
+ * in mm/lru_marie.c operate on this state only via the API declared here.
+ *
+ * Header is internal: not exposed under include/linux/. Direct field
+ * access on `struct marie_lruvec` is allowed only by ADT code in
+ * mm/lru_marie_residency.c; mm/lru_marie.c uses the API surface below.
+ */
+#ifndef _MM_LRU_MARIE_RESIDENCY_H
+#define _MM_LRU_MARIE_RESIDENCY_H
+
+#ifdef CONFIG_LRU_MARIE
+
+#include <linux/atomic.h>
+#include <linux/cleanup.h>
+#include <linux/gfp_types.h>
+#include <linux/irqflags.h>
+#include <linux/list.h>
+#include <linux/llist.h>
+#include <linux/memcontrol.h>
+#include <linux/mm_inline.h>
+#include <linux/mmzone.h>
+#include <linux/percpu.h>
+#include <linux/xarray.h>
+#include <linux/rcupdate.h>
+#include <linux/workqueue.h>
+#include <linux/spinlock.h>
+#include <linux/swap.h>		/* SWAP_CLUSTER_MAX, ANON_AND_FILE */
+#include <linux/types.h>
+#include <linux/vmstat.h>
+
+struct folio;
+struct lruvec;
+struct mem_cgroup;
+struct marie_lruvec;
+struct marie_gen;
+
+/*
+ * Fault-burst install timing: per-sl bound on the add_queue.
+ * Producers sample every (MARIE_ADD_SAMPLE_MASK + 1) pushes (per CPU).
+ * On sample, if (sum_per_cpu(add_count) - add_count_drained) exceeds
+ * marie_add_watermark, queue_work(&sl->drain_work) is invoked.
+ *
+ * marie_add_watermark is runtime-tunable via
+ * /sys/kernel/mm/lru_marie/add_watermark; default 256 sizes the queue
+ * for short drain runs (with the chunked drain in marie_drain_worker
+ * each invocation processes at most 2 * MARIE_ISOLATE_BATCH = 64
+ * entries, ~600 us upper bound on lock hold, and the worker re-queues
+ * itself if more remain). MARIE_ADD_SAMPLE_MASK is a compile-time
+ * bitmask (must be (power-of-two - 1)) and stays a #define.
+ */
+#define MARIE_ADD_SAMPLE_MASK	63UL	/* sample every 64 pushes */
+
+/*
+ * ---------------------------------------------------------------------
+ *  folio->flags accessor helpers for the Marie bit-pack (internal)
+ * ---------------------------------------------------------------------
+ *
+ * Read paths are lock-free (READ_ONCE). Write paths must be either:
+ *   (a) under sl->lock, using folio_marie_compose_state() + set_mask_bits, or
+ *   (b) lock-free atomic CMPXCHG (folio_marie_inc_tier()).
+ *
+ * folio->lru is always interpreted as a list_head; marie_residency_of()
+ * recovers the residency state from the TRACKED bit plus list_empty(lru).
+ * The bit-mask layout itself (MARIE_*_MASK / MARIE_*_PGOFF /
+ * MARIE_TIER_WIDTH) lives in include/linux/mmzone.h alongside the rest
+ * of the page-flags-layout reservation, since those constants pin
+ * how struct page's flags word is partitioned.
+ */
+
+/**
+ * folio_marie_test_tracked - is @folio claimed by Marie?
+ */
+static inline bool folio_marie_test_tracked(const struct folio *folio)
+{
+	return READ_ONCE(folio->flags.f) & MARIE_TRACKED_MASK;
+}
+
+/**
+ * folio_marie_get_tier - Marie hotness tier. Meaningful only when TRACKED.
+ */
+static inline unsigned int folio_marie_get_tier(const struct folio *folio)
+{
+	return (READ_ONCE(folio->flags.f) & MARIE_TIER_MASK) >> MARIE_TIER_PGOFF;
+}
+
+/**
+ * folio_marie_inc_tier - atomically saturating tier++. Returns the
+ *                      observed previous tier.
+ *
+ * Walker hot path. Lock-free CMPXCHG retry loop. If the returned value
+ * is < MARIE_TIER_MAX the helper incremented tier by one (new tier =
+ * returned + 1). If equal to MARIE_TIER_MAX the folio was already
+ * saturated and no write was performed; the caller should dispatch
+ * a RESIDENT -> PENDING_PROMOTE transit via the per-sl promote queue.
+ */
+static inline unsigned int folio_marie_inc_tier(struct folio *folio)
+{
+	const unsigned int max_tier = (1U << MARIE_TIER_WIDTH) - 1;
+	unsigned long old, new;
+	unsigned int prev;
+
+	old = READ_ONCE(folio->flags.f);
+	do {
+		prev = (old & MARIE_TIER_MASK) >> MARIE_TIER_PGOFF;
+		if (prev >= max_tier)
+			return prev;
+		new = (old & ~MARIE_TIER_MASK) |
+		      ((unsigned long)(prev + 1) << MARIE_TIER_PGOFF);
+	} while (!try_cmpxchg(&folio->flags.f, &old, new));
+
+	return prev;
+}
+
+/*
+ * marie_folio_lruvec_rcu - RCU-bracketed folio_lruvec() for Marie hot paths.
+ *
+ * folio_lruvec() reaches obj_cgroup_memcg() which has a lockdep predicate
+ * requiring rcu_read_lock or cgroup_mutex. Marie's drain and walker paths
+ * run under sl->lock (which disables preemption) but NOT under
+ * rcu_read_lock(); preempt-disable does not satisfy the lockdep
+ * predicate. The brief RCU bracket avoids the WARN trip; the returned
+ * pointer is used only for equality comparison or as an xarray key,
+ * never dereferenced after rcu_read_unlock().
+ */
+static inline struct lruvec *marie_folio_lruvec_rcu(struct folio *folio)
+{
+	struct lruvec *lv;
+
+	rcu_read_lock();
+	lv = folio_lruvec(folio);
+	rcu_read_unlock();
+	return lv;
+}
+
+/*
+ * marie_update_lru_size - Marie counterpart to legacy update_lru_size().
+ *
+ * Updates Marie's per-(lru, zone) accounting plus the shared global
+ * vmstat / zone counters. mz->lru_zone_size is intentionally NOT
+ * touched -- Marie maintains its own per-bucket counter
+ * (sl->marie_lru_zone_size) and lets the legacy add/del path keep
+ * mz->lru_zone_size authoritative for legacy folios only. Reads that
+ * want the consolidated per-(memcg, lru, zone) total sum both via
+ * lruvec_lru_size() / lruvec_zone_lru_size().
+ *
+ * Rationale for the split: mz->lru_zone_size is shared across Legacy
+ * / MGLRU / Marie. When Marie also wrote to it, transient races
+ * between Marie's per-folio +/-nr and the legacy bulk-transfer
+ * variants (lru_reparent_memcg, isolate_lru_folios->update_lru_sizes)
+ * had to coordinate exactly, and any miss was visible as the
+ * "lru_size went negative" WARN at memcontrol.c. Owning a dedicated
+ * counter eliminates the coordination requirement structurally -- no
+ * external path can decrement Marie's contribution without going
+ * through Marie.
+ *
+ * Caller MUST hold lruvec->lru_lock. mod_lruvec_state's per-CPU fold
+ * and __mod_zone_page_state's per-zone counter are documented as
+ * lru_lock-protected against concurrent updaters of the same lruvec.
+ */
+static inline void marie_update_lru_size(struct lruvec *lruvec,
+				       enum lru_list lru,
+				       enum zone_type zid,
+				       long nr_pages)
+{
+	struct pglist_data *pgdat = lruvec_pgdat(lruvec);
+
+	mod_lruvec_state(lruvec, NR_LRU_BASE + lru, nr_pages);
+	__mod_zone_page_state(&pgdat->node_zones[zid],
+			      NR_ZONE_LRU_BASE + lru, nr_pages);
+	/* mz->lru_zone_size is owned by legacy add/del paths; do not touch. */
+}
+
+/*
+ * Global folio counter, lives in mm/lru_marie.c for stats_show; ADT
+ * internals atomic_long_inc/dec it during install/del transitions.
+ */
+extern atomic_long_t marie_nr_folios;
+
+/*
+ * ---------------------------------------------------------------------
+ *  Residency state machine
+ * ---------------------------------------------------------------------
+ *
+ * Every Marie-tracked folio is in exactly one of four states. The state
+ * is derivable from MARIE_TRACKED_MASK plus list_empty(folio->lru):
+ * see marie_residency_of(). Only marie_transit() may move a folio
+ * between states, and every transition packages all the bookkeeping
+ * (gen / type counters, lru_size mirror, INIT_LIST_HEAD, PG_active
+ * hygiene) atomically with the bit and list updates.
+ *
+ * Allowed transitions (everything else BUILD_BUG_ON's at compile time):
+ *
+ *                       enqueue_add (CMPXCHG, lock-free)
+ *       MARIE_R_NONE  ───────────────────────►  MARIE_R_PENDING_ADD
+ *       ▲ ▲                                          │
+ *       │ │  cancel_pending (sl-locked)              │
+ *       │ └──────────────────────────────────────────┘
+ *       │                                            │ install (drain, sl-locked)
+ *       │  evict_resident (sl-locked)                │
+ *       └────────────────────────────────  MARIE_R_RESIDENT
+ *                          install_direct (sl-locked, putback)
+ *       MARIE_R_NONE ─────────────────────►  MARIE_R_RESIDENT
+ *                                                 │  ▲
+ *                                       promote   │  │ promote (drain)
+ *                                                 ▼  │
+ *                                          (loop) RESIDENT'
+ *                                                 │  ▲
+ *                       walker saturate enqueue   │  │
+ *                                                 ▼  │
+ *                                       MARIE_R_PENDING_PROMOTE
+ *
+ * RESIDENT -> RESIDENT is the in-place gen move (promote): folio stays
+ * RESIDENT, only its (gen, tier) bits change.
+ *
+ * NONE -> RESIDENT is the sl-locked direct install used by
+ * marie_putback_batch — there is no fault-path producer to worry about
+ * because the caller already holds sl->lock.
+ */
+enum marie_residency {
+	MARIE_R_NONE = 0,		/* TRACKED=0 */
+	MARIE_R_PENDING_ADD,		/* TRACKED=1, folio->lru self-loop */
+	MARIE_R_RESIDENT,		/* TRACKED=1, folio->lru linked into a gen list */
+	MARIE_R_PENDING_PROMOTE,	/* RESIDENT + on promote_queue */
+};
+
+/**
+ * marie_residency_of - lock-free state inspection.
+ *
+ * Distinguishes PENDING_ADD from RESIDENT by inspecting folio->lru: a
+ * self-looped list_head means the folio is queued but not yet linked
+ * into a gen list (PENDING_ADD); a linked one means RESIDENT. Both
+ * are lock-free atomic reads and tolerate concurrent transitions
+ * (the folio bits and lru.next are written under sl->lock; readers
+ * may observe an intermediate state but never an invalid pointer).
+ *
+ * Note: PENDING_PROMOTE is queue-side state (folio bits and lru link
+ * look identical to RESIDENT). The inspector returns RESIDENT in that
+ * case; promote-queue membership is tracked by the queue itself.
+ */
+static inline enum marie_residency marie_residency_of(const struct folio *folio)
+{
+	if (!(READ_ONCE(folio->flags.f) & MARIE_TRACKED_MASK))
+		return MARIE_R_NONE;
+	if (list_empty(&folio->lru))
+		return MARIE_R_PENDING_ADD;
+	return MARIE_R_RESIDENT;
+}
+
+/*
+ * Transit context — caller-supplied scratch for transitions that need
+ * pre-resolved data (gen pointer, type, zone, nr_pages). Transitions
+ * for which a field is not used ignore that field; marie_transit_ctx_zero
+ * gives a clean default for trivially-stateless transitions.
+ */
+struct marie_transit_ctx {
+	struct marie_gen	*gen;	/* RESIDENT-side transitions */
+	int		type;
+	int		zone;
+	long		nr;
+};
+
+#define marie_transit_ctx_zero	((struct marie_transit_ctx){ })
+
+/* Per-transition implementations (defined in mm/lru_marie_residency.c). */
+bool __marie_transit_none_to_pending_add(struct marie_lruvec *sl,
+				       struct folio *folio);
+bool __marie_transit_pending_add_to_none(struct marie_lruvec *sl,
+				       struct folio *folio);
+bool __marie_transit_pending_add_to_resident(struct marie_lruvec *sl,
+					   struct folio *folio);
+bool __marie_transit_none_to_resident(struct marie_lruvec *sl,
+				    struct folio *folio);
+bool __marie_transit_resident_to_none(struct marie_lruvec *sl, struct folio *folio,
+				    struct marie_transit_ctx *ctx);
+bool __marie_transit_resident_to_resident(struct marie_lruvec *sl,
+					struct folio *folio,
+					struct marie_transit_ctx *ctx);
+bool __marie_transit_pending_promote_to_resident(struct marie_lruvec *sl,
+					       struct folio *folio,
+					       struct marie_transit_ctx *ctx);
+
+/**
+ * marie_transit - perform a residency state transition.
+ * @sl:    target residency set
+ * @folio: subject folio
+ * @from:  expected current state (compile-time constant)
+ * @to:    target state (compile-time constant)
+ * @ctx:   per-transition context; set ctx->{gen,type,zone,nr} for
+ *         RESIDENT-side transitions, leave zeroed otherwise
+ *
+ * Templated dispatch. Both @from and @to MUST be compile-time constant
+ * enum values; the __always_inline body resolves to a single
+ * __marie_transit_X_to_Y call and the compiler dead-code-eliminates the
+ * other branches. An invalid (from, to) pair fires BUILD_BUG_ON at
+ * compile time.
+ *
+ * Returns true on success. The PENDING_ADD (lock-free) variant returns
+ * false on CMPXCHG loss; sl-locked variants return false on
+ * gen-alloc failure or stale-state CMPXCHG loss.
+ */
+static __always_inline bool
+marie_transit(struct marie_lruvec *sl, struct folio *folio,
+	    const enum marie_residency from, const enum marie_residency to,
+	    struct marie_transit_ctx *ctx)
+{
+	if (from == MARIE_R_NONE && to == MARIE_R_PENDING_ADD)
+		return __marie_transit_none_to_pending_add(sl, folio);
+	if (from == MARIE_R_PENDING_ADD && to == MARIE_R_NONE)
+		return __marie_transit_pending_add_to_none(sl, folio);
+	if (from == MARIE_R_PENDING_ADD && to == MARIE_R_RESIDENT)
+		return __marie_transit_pending_add_to_resident(sl, folio);
+	if (from == MARIE_R_NONE && to == MARIE_R_RESIDENT)
+		return __marie_transit_none_to_resident(sl, folio);
+	if (from == MARIE_R_RESIDENT && to == MARIE_R_NONE)
+		return __marie_transit_resident_to_none(sl, folio, ctx);
+	if (from == MARIE_R_RESIDENT && to == MARIE_R_RESIDENT)
+		return __marie_transit_resident_to_resident(sl, folio, ctx);
+	if (from == MARIE_R_PENDING_PROMOTE && to == MARIE_R_RESIDENT)
+		return __marie_transit_pending_promote_to_resident(sl, folio, ctx);
+
+	/*
+	 * Unreachable when (from, to) is a valid compile-time constant pair
+	 * — every supported transition is enumerated above, the compiler
+	 * keeps exactly one branch and dead-code-eliminates the rest plus
+	 * this assert. Reached only if the caller passes an unsupported
+	 * pair, which becomes a link-time / build-time error.
+	 */
+	BUILD_BUG();
+	return false;
+}
+
+/**
+ * marie_residency_enqueue_add - state-aware NONE -> PENDING_ADD enqueue.
+ * @sl:    target lruvec's residency set
+ * @folio: folio to enqueue
+ *
+ * Atomically attempts the residency transition NONE -> PENDING_ADD via
+ * a CMPXCHG on folio->flags. Only on a successful CMPXCHG does the
+ * function take a folio reference, allocate a marie_pending wrapper,
+ * and llist_add the entry on this CPU's marie_add_queue. Any other
+ * starting state (PENDING_ADD / RESIDENT / PENDING_PROMOTE) makes the
+ * call a no-op that returns false: a single folio can therefore have
+ * at most one live entry across all per-CPU queues at any moment, so
+ * duplicate enqueue is structurally impossible.
+ *
+ * Caller holds no Marie locks. Returns true iff the entry was queued.
+ */
+bool marie_residency_enqueue_add(struct marie_lruvec *sl, struct folio *folio);
+
+/**
+ * marie_residency_pop_oldest_batch - collect up to @batch_cap candidates
+ *                                  from the oldest gen of @type,
+ *                                  prefetch-pipelined, tier-ascending.
+ * @sl:        target residency set (caller holds sl->lock)
+ * @type:      0 = anon, 1 = file
+ * @nr_to_scan: caller's nr_to_scan budget
+ * @batch:     out: collected folio pointers
+ * @batch_cap: capacity of @batch
+ * @max_zone:  inclusive upper zone bound (caller's reclaim_idx clamp)
+ * @out_gen:   out: tail gen pointer (used by caller for nr_pages
+ *             accounting at evict time, and for walker_visits gating)
+ *
+ * Returns the number of folios placed in @batch. Phase-1 collect only;
+ * each batch entry is still RESIDENT (still on its tail gen list).
+ * The caller issues marie_residency_evict_resident() in phase 2 to
+ * mutate state.
+ *
+ * Implements the rolling tier-threshold sweep: tier 0 first (truly
+ * cold), then progressively hotter tiers as fallback so the gen
+ * actually drains under workloads where every folio carries a young
+ * hit.
+ */
+unsigned long
+marie_residency_pop_oldest_batch(struct marie_lruvec *sl, int type,
+			       unsigned long nr_to_scan,
+			       struct folio **batch, int batch_cap,
+			       int max_zone, struct marie_gen **out_gen);
+
+/**
+ * marie_residency_del_folio_locked - lru_marie_del_folio body (sl->lock held).
+ * @sl:               residency set
+ * @folio:            folio to remove (any Marie-tracked state)
+ * @did_inc_lru_size: out: true iff this call decremented NR_LRU_BASE
+ *                    counters (i.e. the folio was RESIDENT, not just
+ *                    PENDING_ADD)
+ *
+ * Universal external-removal handler called from lru_marie_del_folio when
+ * lruvec_del_folio fires from outside Marie (compaction, lru_activate
+ * batch drain, __page_cache_release after the last folio_put). Handles
+ * both:
+ *
+ *   - PENDING_ADD: clear TRACKED so the next drain skips the install
+ *     and only does folio_put to balance lru_marie_add_folio's folio_get.
+ *
+ *   - RESIDENT: marie_residency_evict_resident equivalent (gen-list
+ *     del + counters + lru_size mirror + bit clear).
+ *
+ * Returns true iff @folio was tracked (the caller can fall through
+ * to its remaining bookkeeping). Does NOT touch marie_nr_folios; the
+ * caller atomic_long_dec()s when *did_inc_lru_size is true.
+ */
+bool marie_residency_del_folio_locked(struct marie_lruvec *sl, struct folio *folio,
+				    bool *did_inc_lru_size);
+
+/*
+ * Walker hot-path tier promotion result codes.
+ */
+enum marie_tier_inc_result {
+	MARIE_TIER_INC_OK = 0,	/* tier observed prev (< MAX), bumped to prev+1 */
+	MARIE_TIER_INC_SATURATED,	/* tier at MAX; promote enqueued (or noted) */
+	MARIE_TIER_INC_FAILED,	/* GFP_ATOMIC alloc failed during enqueue;
+				   safe to drop, next pass retries */
+};
+
+/**
+ * marie_residency_tier_inc - walker-side hot path: bump @folio's tier.
+ * @sl:    residency set; may be NULL during xa cache miss recovery
+ *         (caller must look it up via xa_load and pass it in)
+ * @folio: subject folio (must be RESIDENT or the call is a no-op)
+ *
+ * Lock-free via folio_marie_inc_tier()'s CMPXCHG retry. On saturation
+ * (the previous tier was already MARIE_TIER_MAX) the helper enqueues a
+ * RESIDENT -> PENDING_PROMOTE transit on this CPU's promote queue;
+ * the next sl-locked drain moves the folio to the head gen with tier
+ * reset to 0 and updates the per-tier counters under sl->lock.
+ *
+ * Does NOT touch nr_per_tier[]: walker tier shifts are picked up
+ * implicitly via the tier-mismatch skip in pop_oldest_batch's
+ * threshold loop. nr_per_tier is sl-locked-only.
+ */
+enum marie_tier_inc_result marie_residency_tier_inc(struct marie_lruvec *sl,
+						struct folio *folio);
+
+/**
+ * marie_residency_pending_pool_stats - snapshot per-CPU marie_pending pool stats.
+ * @hits:     out: total per-CPU pool pop successes
+ * @misses:   out: total per-CPU pool pop misses (slab fallback)
+ * @failures: out: total slab-fallback allocation failures
+ * @refills:  out: total background refill workqueue runs
+ *
+ * Lock-free; sums per-CPU counters and reads the global atomic_long_t
+ * miss/refill counters. Used by the /sys/kernel/mm/lru_marie/stats handler.
+ */
+void marie_residency_pending_pool_stats(unsigned long *hits,
+				      unsigned long *misses,
+				      long *failures,
+				      long *refills);
+
+/*
+ * ---------------------------------------------------------------------
+ *  Gen ring sizing
+ * ---------------------------------------------------------------------
+ *
+ * Mirror MGLRU's MIN/MAX_NR_GENS so aging behaviour is comparable.
+ */
+#define MARIE_MIN_NR_GENS 2
+#define MARIE_MAX_NR_GENS 4
+
+/*
+ * MARIE_NR_TIERS = 1 << MARIE_TIER_WIDTH (P1 reserved 2 tier bits in
+ * folio->flags). Tier 0 = "never touched since added", tier
+ * MARIE_NR_TIERS-1 = saturated (further young hits trigger a promote
+ * to head gen via the per-CPU promote queue).
+ */
+#define MARIE_NR_TIERS (1U << MARIE_TIER_WIDTH)
+#define MARIE_TIER_MAX (MARIE_NR_TIERS - 1)
+
+/*
+ * Reclaim-side batch size — how many folios marie_isolate_folios pulls
+ * out of the oldest gen per call. Compile-time because batch[] is a
+ * stack array sized by it.
+ */
+#define MARIE_ISOLATE_BATCH SWAP_CLUSTER_MAX
+
+/*
+ * Allocation-side aging trigger threshold (per head gen pages) lives in
+ * mm/lru_marie.c as marie_gen_growth_threshold and is runtime-tunable via
+ * /sys/kernel/mm/lru_marie/gen_growth_threshold. Default 8192 pages
+ * (= MARIE_ISOLATE_BATCH << 8, i.e. 32 MiB). When the head gen
+ * accumulates more than this many installs, marie_age_on_add cuts a
+ * fresh empty head and demotes the previous head one notch toward the
+ * tail.
+ */
+
+/*
+ * ---------------------------------------------------------------------
+ *  data structures
+ * ---------------------------------------------------------------------
+ *
+ * Per-type independence is fundamental: each marie_type has its own
+ * monotonically growing seq counter, its own oldest seq, and its own
+ * gen list.  vm.swappiness controls only the eviction proportion
+ * between types; aging on one type never forces work on the other.
+ *
+ * Per-zone folio storage inside a generation lets reclaim isolate
+ * zones independently (matching the existing NR_LRU_LISTS / zone
+ * semantics).
+ */
+
+struct marie_gen {
+	struct list_head	gen_node;	/* marie_type::gens link */
+	unsigned long		seq;
+	/*
+	 * Monotonic install count; never decremented. Used by
+	 * marie_age_on_add to decide when the head gen has
+	 * accumulated enough faulted-in folios to cut a new head.
+	 * Once the gen is no longer the head, no further installs
+	 * feed this counter so it cannot drift.
+	 */
+	unsigned long		nr_installs;
+	/*
+	 * Number of completed marie_walk_pgdat passes since this gen was
+	 * created. Bumped at walker pass end under sl->lock; consumed by
+	 * marie_isolate_folios to gate ignore_references=true. A
+	 * value >= 1 means the walker has had at least one chance to
+	 * promote any folio in this gen via young-bit detection, so the
+	 * remaining tier-0 folios are demonstrably untouched-since-fault.
+	 */
+	unsigned int		walker_visits;
+	/*
+	 * Authoritative per-(type, zone) folio list. Each RESIDENT folio's
+	 * folio->lru is linked here. Folio death = list_head death
+	 * (folio->lru goes with the struct page), so orphan list entries
+	 * are structurally impossible.
+	 */
+	struct list_head	folios[ANON_AND_FILE][MAX_NR_ZONES];
+};
+
+struct marie_type {
+	/*
+	 * Per-type lock — protects @gens, @current_seq, @oldest_seq, the
+	 * gen list contents, @gen_spare, @nr_gen_spare and per-type residency
+	 * transits. Anon and file paths progress independently; cross-type
+	 * sections take both locks in canonical order (anon first, file
+	 * second) via the marie_both_sl guard.
+	 */
+	spinlock_t		lock;
+	/*
+	 * 0 = anon, 1 = file. Set once at marie_type_init time so the
+	 * scoped_guard(marie_type_sl, ...) entry can recover the type index
+	 * (needed for the per-CPU drain-depth counter) from a bare
+	 * struct marie_type * without an extra argument.
+	 */
+	int			type;
+	struct list_head	gens;		/* head=newest, tail=oldest */
+	unsigned long		current_seq;	/* seq of the head gen */
+	unsigned long		oldest_seq;	/* seq of the tail gen */
+	atomic_long_t		nr_pages;	/* lockless reads in marie_pick_type */
+
+	/*
+	 * Per-type pending queues. Producers route by folio type at enqueue
+	 * (folio_is_file_lru). llist is single-producer-multiple-consumer
+	 * safe; the drain that holds sl->lock is the sole consumer and uses
+	 * llist_del_all() / llist_del_first().
+	 */
+	struct llist_head	add_queue;
+	struct llist_head	promote_queue;
+
+	/*
+	 * Pre-allocated reserve of struct marie_gen for this type's gen ring.
+	 * marie_advance_max_seq() pops from here under sl->lock so the gen
+	 * alloc never visits the slab in steady state; marie_gen_destroy()
+	 * pushes back instead of freeing. Sized by marie_gen_spare_prefill()
+	 * to MARIE_MAX_NR_GENS so once warm the spare is structurally
+	 * non-empty when an advance is needed.
+	 */
+	struct list_head	gen_spare;
+	int			nr_gen_spare;
+};
+
+/*
+ * Per-CPU push counter slot for the producer-side drain trigger.
+ * One full cache line per CPU so adjacent producers never touch the
+ * same line. The atomic_long_t inside is incremented from atomic
+ * context (lruvec->lru_lock held), and read locklessly during cross-CPU
+ * sum at sample / drain time.
+ */
+struct marie_add_slot {
+	atomic_long_t		count;
+} ____cacheline_aligned_in_smp;
+
+struct marie_lruvec {
+	struct lruvec		*lruvec;
+	struct mem_cgroup	*memcg;		/* for lru_marie_exit_memcg walk */
+	int			nid;
+	struct marie_type		types[ANON_AND_FILE];
+
+	/*
+	 * Token bucket for the anon/file split.  Each shrink call adds
+	 * sc_swappiness; whenever the accumulator >= MAX_SWAPPINESS we
+	 * spend MAX_SWAPPINESS tokens on an anon batch, otherwise file.
+	 * Over many calls the spend ratio converges to s : (200 - s).
+	 *
+	 * Updated locklessly via atomic_try_cmpxchg in marie_pick_type so
+	 * the bucket is not coupled to sl->lock; once sl->lock is split per
+	 * type, the picker no longer needs to hold either type's lock just
+	 * to advance the bucket.
+	 */
+	atomic_t		swap_tokens;
+
+	/*
+	 * Producer-side drain trigger.
+	 *
+	 * @add_count is a NR_CPUs-element array of per-CPU push counters,
+	 * one cache line per CPU (marie_add_slot is __cacheline_aligned_in_smp).
+	 * Each NONE -> PENDING_ADD transition does a single
+	 * atomic_long_inc_return on its local CPU's slot. False sharing is
+	 * eliminated because adjacent CPUs touch distinct cache lines.
+	 *
+	 * @add_count_drained is the cross-CPU sum at the last completed
+	 * drain (read/written under sl->lock).
+	 *
+	 * Producers sample every (MARIE_ADD_SAMPLE_MASK + 1) pushes per CPU
+	 * and, on a sample tick, sum the per-CPU values and compare to
+	 * the baseline. On overflow they call schedule_work(&drain_work);
+	 * schedule_work deduplicates so concurrent samples coalesce.
+	 *
+	 * Why kmalloc'd array and not alloc_percpu: marie_alloc_lruvec is
+	 * reachable from marie_get_lruvec which is called inside
+	 * folio_batch_move_lru with lruvec->lru_lock held (atomic
+	 * context). alloc_percpu grabs pcpu_alloc_mutex internally and
+	 * can sleep, tripping "BUG: scheduling while atomic" plus the
+	 * matching RCU CSWITCH WARN. kmalloc + GFP_ATOMIC has no such
+	 * mutex.
+	 */
+	struct marie_add_slot	*add_count;	/* nr_cpu_ids slots */
+	void			*add_count_raw;	/* unaligned base for kfree */
+	unsigned long		add_count_drained;	/* sl->lock */
+	struct work_struct	drain_work;
+
+	/*
+	 * Authoritative per-(lru, zone) count of Marie-tracked pages on
+	 * this lruvec. Marie owns this counter exclusively -- the legacy
+	 * mz->lru_zone_size mirrors only legacy add/del activity and
+	 * never sees Marie's contribution. Readers that want the
+	 * consolidated total query both via lruvec_lru_size() /
+	 * marie_lruvec_zone_size().
+	 *
+	 * Update sites (paired ±nr): __marie_install_locked,
+	 * __marie_transit_resident_to_none, marie_gen_destroy,
+	 * marie_residency_reparent_locked, marie_fill_one_lruvec
+	 * (legacy->Marie transition), marie_drain_one_lruvec
+	 * (Marie->legacy transition).
+	 *
+	 * Atomic because some sites (gen_destroy, reparent) hold only
+	 * sl->lock while others (install, resident-to-none, fill, drain)
+	 * additionally hold lru_lock; a non-atomic counter would race
+	 * with sl-lock-only updates. NR_LRU_LISTS x MAX_NR_ZONES x 8B is
+	 * 160B per sl on a 4-zone build.
+	 */
+	atomic_long_t		marie_lru_zone_size[NR_LRU_LISTS][MAX_NR_ZONES];
+};
+
+/* lifecycle (called from mm/lru_marie.c xa lookup path) */
+struct marie_lruvec *marie_alloc_lruvec(struct lruvec *lv, gfp_t gfp);
+void marie_free_lruvec(struct marie_lruvec *sl);
+
+/* gen ring management — caller holds sl->lock */
+static inline int marie_nr_gens(const struct marie_type *t)
+{
+	if (list_empty(&t->gens))
+		return 0;
+	return (int)(t->current_seq - t->oldest_seq) + 1;
+}
+
+int marie_advance_max_seq(struct marie_lruvec *sl, int type, gfp_t gfp);
+void marie_try_drop_oldest(struct marie_lruvec *sl, int type);
+void marie_age(struct marie_lruvec *sl, int type, gfp_t gfp);
+void marie_age_on_add(struct marie_lruvec *sl, int type,
+		    struct marie_gen *head, gfp_t gfp);
+struct marie_gen *marie_get_or_create_gen(struct marie_lruvec *sl, int type,
+				      gfp_t gfp);
+
+/**
+ * marie_residency_gen_spare_stats - snapshot per-lruvec gen spare counters.
+ * @hits:     out: total spare list pop successes (steady-state path)
+ * @misses:   out: total spare list misses (warmup race path)
+ * @failures: out: total slab-allocation failures
+ *
+ * Lock-free reads of the global atomic_long_t counters.
+ */
+void marie_residency_gen_spare_stats(long *hits, long *misses, long *failures);
+
+/*
+ * ---------------------------------------------------------------------
+ *  marie_pending — pending entries for fault and walker promote
+ * ---------------------------------------------------------------------
+ *
+ * Producers enqueue onto per-sl queues (struct marie_lruvec::add_queue
+ * and ::promote_queue, lock-free llist) so cross-memcg traffic is
+ * routed by construction — the drain on each sl pulls only its own
+ * entries (S5 / B1, no cross-memcg bounce loop).
+ *
+ * Each pending entry holds a folio reference (folio_get) so the folio
+ * cannot be freed while it is queued. The reference is dropped when
+ * the drain processes the entry.
+ */
+
+struct marie_pending {
+	struct llist_node	node;
+	struct folio		*folio;
+};
+
+/*
+ * Deferred-folio_put per-CPU llist.
+ *
+ * The drain helpers and marie_isolate_folios run under sl->lock with
+ * IRQs off and each hold per-folio references that need to be dropped
+ * via folio_put. Calling folio_put() under sl->lock is unsafe in the
+ * cross-memcg case (AB-BA against lruvec->lru_lock, the memhog
+ * livelock pattern). Resolution: stash the folio in a per-CPU lock-
+ * free llist, drain — i.e. actually folio_put — *after* sl->lock
+ * release.
+ *
+ * Storage is unbounded llist of marie_pending wrappers. The wrappers
+ * come from a per-CPU LIFO pool: alloc pops from the local pool (zero
+ * slab traffic in steady state), and a workqueue refills the pool with
+ * GFP_KERNEL outside the IRQ-off critical section. GFP_ATOMIC slab
+ * fallback fires only when the pool is briefly drained by a burst
+ * the refill worker has not caught up with.
+ */
+DECLARE_PER_CPU(struct llist_head, marie_deferred_put_q);
+
+/* marie_pending alloc/free (slab-backed; GFP_ATOMIC for hot path). */
+struct marie_pending *marie_pending_alloc(struct folio *folio);
+void marie_pending_free(struct marie_pending *p);
+
+/* Deferred-put helpers (used from within sl->lock; drain runs after unlock). */
+void marie_defer_pending_put(struct marie_pending *p);
+void marie_defer_folio_put(struct folio *folio);
+void marie_drain_deferred_puts(void);
+
+/*
+ * Per-type re-entrant-drain detection. Caller (lru_marie_del_folio in
+ * mm/lru_marie.c) uses marie_in_drain_type(folio's type) to detect "we
+ * are already inside a per-type-locked drain for this folio's type on
+ * this CPU" and skip the scoped_guard re-acquire. The depth counters
+ * are per-CPU statics inside the ADT, mutated by the scoped_guard
+ * lock/unlock body (S5 / per-CPU encapsulation).
+ */
+bool marie_in_drain_type(int type);
+void marie_drain_enter_type(int type);
+void marie_drain_exit_type(int type);
+
+/*
+ * ---------------------------------------------------------------------
+ *  drain helpers
+ * ---------------------------------------------------------------------
+ *
+ * Install / promote / del / evict are folded into marie_transit (above);
+ * the drain helpers and the external marie_drain_pending entry use that
+ * dispatch. They retain their callable shape so mm/lru_marie.c can hand them
+ * off as one-line operations from inside scoped_guard(marie_sl) regions.
+ */
+
+/**
+ * marie_drain_add_queue_locked - drain pending marie_add entries for @sl.
+ * @sl: residency set being drained
+ *
+ * Loops over both types and drains each type's add_queue. Caller MUST
+ * hold both per-type locks (use the marie_both_sl guard) since the
+ * install transit on each entry touches that entry's type's gen ring.
+ *
+ * Each PENDING_ADD entry is converted to RESIDENT via the install path.
+ * On install failure (gen-alloc -ENOMEM under GFP_ATOMIC) the entry
+ * remains in PENDING_ADD with its wrapper re-llist_add'd to the
+ * matching type's add_queue; the next drain pass retries, or
+ * marie_residency_isolate_pending_add reclaims it directly when the
+ * gen ring is exhausted.
+ */
+void marie_drain_add_queue_locked(struct marie_lruvec *sl);
+
+/**
+ * marie_drain_add_queue_one_type_locked - per-type variant.
+ *
+ * Drains only @sl->types[@type].add_queue. Used by isolation paths that
+ * hold the per-type lock for @type and want to materialise PENDING_ADD
+ * entries for this type alone.
+ */
+void marie_drain_add_queue_one_type_locked(struct marie_lruvec *sl, int type);
+
+/**
+ * marie_residency_isolate_pending_add - reclaim PENDING_ADD entries
+ *                                     directly onto @dst, bypassing
+ *                                     install.
+ * @sl:            residency set
+ * @dst:           list head receiving the reclaim candidates
+ * @cap_remaining: maximum number of folios to take
+ *
+ * Used by marie_isolate_folios as a Phase 1b reclaim source after the
+ * gen ring is exhausted. Each entry undergoes PENDING_ADD -> NONE
+ * (clears bits, INIT_LIST_HEADs payload), claims PG_lru via
+ * folio_test_clear_lru, and is list_added to @dst. The wrapper's
+ * folio_get reference becomes the caller's isolation reference.
+ *
+ * Returns the number of folios placed on @dst. Caller MUST hold both
+ * per-type locks (via marie_both_sl). For type-pure isolation, prefer
+ * marie_residency_isolate_pending_add_one_type which needs only one
+ * per-type lock.
+ */
+unsigned long
+marie_residency_isolate_pending_add(struct marie_lruvec *sl,
+				  struct list_head *dst,
+				  int cap_remaining);
+
+/**
+ * marie_residency_isolate_pending_add_one_type - per-type variant.
+ *
+ * Drains only @sl->types[@type].add_queue into @dst (single-type Phase
+ * 1b). Used when the caller holds just the @type per-type lock and
+ * wants the dst list to be type-pure.
+ */
+unsigned long
+marie_residency_isolate_pending_add_one_type(struct marie_lruvec *sl,
+					     int type,
+					     struct list_head *dst,
+					     int cap_remaining);
+
+/**
+ * marie_drain_promote_queue_locked - drain pending marie_promote entries.
+ * @sl: residency set
+ *
+ * Loops over both types. Caller holds both per-type locks (marie_both_sl).
+ */
+void marie_drain_promote_queue_locked(struct marie_lruvec *sl);
+
+/**
+ * marie_drain_promote_queue_one_type_locked - per-type variant.
+ */
+void marie_drain_promote_queue_one_type_locked(struct marie_lruvec *sl,
+					       int type);
+
+/**
+ * marie_drain_pending - drain both per-sl queues for @sl from an
+ *                     unlocked context (acquires sl->lock internally).
+ *
+ * Callers that already hold sl->lock should call the _locked variants
+ * directly.
+ */
+void marie_drain_pending(struct marie_lruvec *sl);
+
+/**
+ * marie_residency_reparent_locked - hand off every folio tracked by @child_sl
+ *                                 to @parent_sl via parent's add_queue.
+ * @child_sl:  source residency set (a memcg being reparented)
+ * @parent_sl: destination residency set (parent memcg's lruvec sl); may
+ *             be NULL, in which case folios are simply detached from Marie
+ *             tracking and will be rediscovered through the normal
+ *             folio_add_lru path on next access.
+ *
+ * Drains both pending queues, walks every gen list in @child_sl, and
+ * for each folio: erases the xa entry, clears Marie state bits, clears
+ * PG_lru (a fresh marie_residency_enqueue_add on @parent_sl will set
+ * it again at install).
+ *
+ * Returns the number of folios migrated. Caller MUST hold @child_sl->lock.
+ * Caller is also responsible for atomic_long_sub'ing the returned count
+ * from marie_nr_folios (parent's drain will atomic_long_inc back when each
+ * folio reaches RESIDENT). Caller MUST NOT hold @parent_sl->lock — the
+ * enqueue path is lock-free.
+ */
+long marie_residency_reparent_locked(struct marie_lruvec *child_sl,
+				   struct marie_lruvec *parent_sl);
+
+/*
+ * scoped_guard(marie_type_sl, &sl->types[type]) — per-type lock acquisition.
+ *
+ * Equivalent to the handwritten dance:
+ *
+ *   spin_lock_irqsave(&t->lock, flags);
+ *   marie_drain_enter_type(t->type);
+ *   ... critical section touching sl->types[t->type] ...
+ *   marie_drain_exit_type(t->type);
+ *   spin_unlock_irqrestore(&t->lock, flags);
+ *
+ * The cleanup attribute on the guard variable makes the unlock +
+ * depth-counter pair a structural property of the scope, not a
+ * discipline the caller must remember on every early return / goto.
+ *
+ * Re-entry inside the scope is handled by the per-CPU per-type
+ * marie_drain_depth contract — drain helpers' folio_put recursion that
+ * lands in lru_marie_del_folio observes marie_in_drain_type(folio's
+ * type) > 0 and skips the spin_lock_irqsave for that type only. Recursion
+ * involving the *other* type lands on a depth-0 counter and proceeds to
+ * take the corresponding per-type lock as usual (the outer guard holds
+ * only one type's lock, so this is not a self-deadlock).
+ *
+ * IMPORTANT: this guard does NOT drain the per-CPU deferred_put_q on
+ * exit. Auto-draining there is unsafe: lru_marie_del_folio is reached
+ * from lruvec_del_folio which is reached from __page_cache_release with
+ * lruvec->lru_lock already held by the caller. A drain inside that
+ * scope's exit calls folio_put -> __page_cache_release ->
+ * folio_lruvec_lock_irqsave on the queued folios, deadlocking against
+ * the caller's already-held lru_lock (same lruvec on a single-node /
+ * single-memcg system, or AB-BA across nodes).
+ *
+ * Callers that produce deferred puts inside their critical section
+ * (marie_isolate_folios, marie_putback_batch, marie_drain_pending,
+ * marie_drain_worker) call marie_drain_deferred_puts() explicitly AFTER
+ * the scoped_guard scope exits and they have verified no lru_lock is
+ * held.
+ */
+DEFINE_LOCK_GUARD_1(marie_type_sl, struct marie_type,
+	/* lock */ ({
+		spin_lock_irqsave(&_T->lock->lock, _T->flags);
+		marie_drain_enter_type(_T->lock->type);
+	}),
+	/* unlock */ ({
+		marie_drain_exit_type(_T->lock->type);
+		spin_unlock_irqrestore(&_T->lock->lock, _T->flags);
+	}),
+	unsigned long flags
+)
+
+/*
+ * scoped_guard(marie_both_sl, sl) — take both types' locks.
+ *
+ * Used by cross-type call sites: drain_pending, drain_worker,
+ * drain_one_lruvec, fill_one_lruvec, putback_batch (mixed-type list),
+ * walker pass-end visit-counter bump, residency reparent.
+ *
+ * Canonical order: anon (type 0) first, file (type 1) nested with
+ * SINGLE_DEPTH_NESTING to tell lockdep the two locks are different
+ * instances despite sharing a lock class. Every cross-type site uses
+ * this same guard, so the lock order is uniform and AB-BA is
+ * structurally impossible.
+ *
+ * Both per-type drain-depth counters are incremented so that any
+ * recursive lru_marie_del_folio (regardless of folio type) sees the
+ * depth > 0 fast path for its own type and avoids re-locking.
+ */
+DEFINE_LOCK_GUARD_1(marie_both_sl, struct marie_lruvec,
+	/* lock */ ({
+		spin_lock_irqsave(&_T->lock->types[0].lock, _T->flags);
+		spin_lock_nested(&_T->lock->types[1].lock,
+				 SINGLE_DEPTH_NESTING);
+		marie_drain_enter_type(0);
+		marie_drain_enter_type(1);
+	}),
+	/* unlock */ ({
+		marie_drain_exit_type(1);
+		marie_drain_exit_type(0);
+		spin_unlock(&_T->lock->types[1].lock);
+		spin_unlock_irqrestore(&_T->lock->types[0].lock, _T->flags);
+	}),
+	unsigned long flags
+)
+
+/**
+ * marie_residency_init - one-shot init for the residency ADT.
+ *
+ * Called from marie_init() (subsys_initcall in mm/lru_marie.c). Sets up slab
+ * caches, per-CPU pools, cpuhp callbacks, and any other ADT-private
+ * runtime state. Returns 0 on success, negative errno on failure (in
+ * which case the caller propagates the error up to the initcall
+ * machinery — partial init is treated as fatal because subsequent Marie
+ * paths assume the ADT is wired up).
+ */
+int marie_residency_init(void);
+
+/*
+ * ---------------------------------------------------------------------
+ *  Cross-file glue (lifecycle xarray + walker entry points)
+ * ---------------------------------------------------------------------
+ *
+ * These declarations connect mm/lru_marie.c (dispatch / lifecycle) and
+ * mm/lru_marie_walker.c (PTE walker). They are not part of the
+ * residency ADT proper but live here to keep mm/ private headers down
+ * to a single file.
+ */
+
+/*
+ * Per-lruvec sl side-channel. Indexed by struct lruvec *. Lazy alloc on
+ * first hit; freed at memcg teardown via marie_drop_lruvec(). Walker
+ * iterates this xarray under rcu_read_lock to find sl's for a target
+ * pgdat; the dispatch hooks xa_load() it directly.
+ */
+extern struct xarray marie_lruvec_xa;
+
+/*
+ * marie_walk_pgdat - run one walker pass for @pgdat.
+ *
+ * Called from lru_marie_age_node() (kswapd hook) and
+ * lru_marie_shrink_lruvec() (direct-reclaim hook). Internally
+ * rate-limited per pgdat via a jiffies deadline so calling on every
+ * reclaim/kswapd cycle is fine.
+ */
+void marie_walk_pgdat(struct pglist_data *pgdat);
+
+/*
+ * marie_walker_init - one-shot init for the walker subsystem.
+ *
+ * Initialises per-pgdat bloom-filter spinlocks. Bitmaps themselves
+ * are lazily allocated on first Producer hit. Called from
+ * marie_init().
+ */
+void marie_walker_init(void);
+
+#endif /* CONFIG_LRU_MARIE */
+#endif /* _MM_LRU_MARIE_RESIDENCY_H */
diff --git a/mm/lru_marie_simd_arm64.c b/mm/lru_marie_simd_arm64.c
new file mode 100644
index 000000000..fe6046704
--- /dev/null
+++ b/mm/lru_marie_simd_arm64.c
@@ -0,0 +1,45 @@
+// SPDX-License-Identifier: GPL-2.0
+/*
+ * mm/lru_marie_simd_arm64.c -- ARM64 PTE young-bit scan.
+ *
+ * Scalar implementation. NEON acceleration is a future optimization --
+ * the FPSIMD context save/restore cost needs profiling against the
+ * gain on typical aarch64 cores before we commit to it.
+ *
+ * batch_begin / batch_end are no-ops here because the scan is scalar
+ * (no FPU/NEON state to preserve). The walker calls them around batched
+ * runs of _raw scans to amortise FPU bracket cost on archs that need
+ * it (x86); on arm64 they compile to nothing and the _raw scan is just
+ * a plain pte_young loop.
+ */
+
+#include <linux/lru_marie_simd.h>
+#include <linux/bitmap.h>
+#include <linux/mm.h>
+#include <asm/pgtable.h>
+
+#define PTES_PER_PMD	512
+
+void lru_marie_simd_batch_begin(void) { }
+EXPORT_SYMBOL_GPL(lru_marie_simd_batch_begin);
+
+void lru_marie_simd_batch_end(void) { }
+EXPORT_SYMBOL_GPL(lru_marie_simd_batch_end);
+
+void lru_marie_simd_young_pte_mask_raw(const void *table, unsigned long *bitmap)
+{
+	const pte_t *pte = (const pte_t *)table;
+	int i;
+
+	for (i = 0; i < PTES_PER_PMD; i++) {
+		if (pte_young(pte[i]))
+			__set_bit(i, bitmap);
+	}
+}
+EXPORT_SYMBOL_GPL(lru_marie_simd_young_pte_mask_raw);
+
+void lru_marie_simd_young_pte_mask(const void *table, unsigned long *bitmap)
+{
+	lru_marie_simd_young_pte_mask_raw(table, bitmap);
+}
+EXPORT_SYMBOL_GPL(lru_marie_simd_young_pte_mask);
diff --git a/mm/lru_marie_simd_generic.c b/mm/lru_marie_simd_generic.c
new file mode 100644
index 000000000..0f73ff561
--- /dev/null
+++ b/mm/lru_marie_simd_generic.c
@@ -0,0 +1,43 @@
+// SPDX-License-Identifier: GPL-2.0
+/*
+ * mm/lru_marie_simd_generic.c -- fallback PTE young-bit scan for arches
+ *                              without a SIMD path.
+ *
+ * Uses the arch-provided pte_young() helper so we don't need to know
+ * the accessed-bit name on every architecture.
+ *
+ * batch_begin / batch_end are no-ops here because the scan is scalar
+ * (no FPU state to preserve). See mm/lru_marie_simd_arm64.c for the
+ * same pattern and rationale.
+ */
+
+#include <linux/lru_marie_simd.h>
+#include <linux/bitmap.h>
+#include <linux/mm.h>		/* pte_young */
+#include <asm/pgtable.h>
+
+#define PTES_PER_PMD	512
+
+void lru_marie_simd_batch_begin(void) { }
+EXPORT_SYMBOL_GPL(lru_marie_simd_batch_begin);
+
+void lru_marie_simd_batch_end(void) { }
+EXPORT_SYMBOL_GPL(lru_marie_simd_batch_end);
+
+void lru_marie_simd_young_pte_mask_raw(const void *table, unsigned long *bitmap)
+{
+	const pte_t *pte = (const pte_t *)table;
+	int i;
+
+	for (i = 0; i < PTES_PER_PMD; i++) {
+		if (pte_young(pte[i]))
+			__set_bit(i, bitmap);
+	}
+}
+EXPORT_SYMBOL_GPL(lru_marie_simd_young_pte_mask_raw);
+
+void lru_marie_simd_young_pte_mask(const void *table, unsigned long *bitmap)
+{
+	lru_marie_simd_young_pte_mask_raw(table, bitmap);
+}
+EXPORT_SYMBOL_GPL(lru_marie_simd_young_pte_mask);
diff --git a/mm/lru_marie_simd_x86.c b/mm/lru_marie_simd_x86.c
new file mode 100644
index 000000000..b7a3c55e7
--- /dev/null
+++ b/mm/lru_marie_simd_x86.c
@@ -0,0 +1,166 @@
+// SPDX-License-Identifier: GPL-2.0
+/*
+ * mm/lru_marie_simd_x86.c -- x86-64 PTE young-bit scan dispatch.
+ *
+ * Three SIMD .S kernels are linked in: lru_marie_simd_x86_{sse2,avx2,avx512}.S.
+ * arch_initcall picks the widest available at boot:
+ *   AVX-512F: 8 PTEs/iter via VPTESTMQ kmask
+ *   AVX2:     4 PTEs/iter via VPCMPEQQ
+ *   SSE2:     4 PTEs/iter via PSHUFD pack
+ *
+ * SSE2 is the floor -- x86-64 ABI-mandatory since 2003, always works,
+ * no cpu_has() check needed. It's the default initial value of the
+ * static call, so even if arch_initcall runs late the walker never
+ * falls back to the slower scalar path.
+ *
+ * FPU bracket lifecycle is caller-driven:
+ *   lru_marie_simd_batch_begin()   -> kernel_fpu_begin()
+ *   lru_marie_simd_young_pte_mask_raw() x N
+ *   lru_marie_simd_batch_end()     -> kernel_fpu_end()
+ *
+ * Per-PMD bracket scope was the previous design (per-PMD ~100 ns FPU
+ * begin/end overhead). Per-pass scope was tried in P4 prep and caused
+ * ~100 ms preempt-disabled regressions because the bitmap iteration
+ * (folio_marie_inc_tier per young bit) ran inside the bracket. The
+ * current model batches FPU across N consecutive PMD scans (the walker
+ * picks N -- see MARIE_FPU_BATCH in mm/lru_marie_walker.c) so the
+ * begin/end overhead is amortised, while keeping the bitmap iteration
+ * inside the same PTL window as today; the preempt window grows by N
+ * SIMD scans (~100-300 ns each), not N full per-PMD bodies.
+ *
+ * The single-shot lru_marie_simd_young_pte_mask() is retained for any
+ * non-batched caller (currently none in-tree) and just wraps
+ * batch_begin / _raw / batch_end.
+ */
+
+#include <linux/init.h>
+#include <linux/jump_label.h>
+#include <linux/printk.h>
+#include <linux/static_call.h>
+#include <linux/lru_marie_simd.h>
+#include <linux/bitmap.h>
+#include <asm/cpufeature.h>
+#include <asm/fpu/api.h>
+#include <asm/pgtable.h>
+#include <asm/pgtable_types.h>
+
+#define PTES_PER_PMD	512
+
+/*
+ * Default true: walker uses the boot-detected SIMD wrapper. Flipped
+ * by writes to /sys/kernel/mm/lru_marie/simd; a write of 0 routes
+ * lru_marie_simd_young_pte_mask through the scalar pte_young loop
+ * below for benchmark A/B comparisons.
+ */
+DEFINE_STATIC_KEY_TRUE(marie_simd_enabled_key);
+EXPORT_SYMBOL_GPL(marie_simd_enabled_key);
+
+/* Defined in mm/lru_marie_simd_x86_{sse2,avx2,avx512}.S.
+ * Caller must hold kernel_fpu_begin/end. */
+asmlinkage void lru_marie_simd_scan_sse2(const pte_t *pte_table,
+				   unsigned long *bitmap);
+asmlinkage void lru_marie_simd_scan_avx2(const pte_t *pte_table,
+				   unsigned long *bitmap);
+asmlinkage void lru_marie_simd_scan_avx512(const pte_t *pte_table,
+				     unsigned long *bitmap);
+
+/* ------------------------------------------------------------------ */
+/* Scalar fallback                                                    */
+/* ------------------------------------------------------------------ */
+
+/*
+ * Reference scalar implementation. Used as the SIMD off-path when
+ * marie_simd_enabled_key is flipped via /sys/kernel/mm/lru_marie/simd
+ * for A/B-comparing the SIMD walker against a scalar pte_young loop
+ * without rebuilding the kernel. Also doubles as a correctness oracle
+ * for future SIMD bug fixes. No FPU state -- safe to call regardless
+ * of bracket state.
+ */
+static void marie_simd_scan_scalar(const pte_t *pte, unsigned long *bitmap)
+{
+	int i;
+
+	for (i = 0; i < PTES_PER_PMD; i++) {
+		if (pte_val(pte[i]) & _PAGE_ACCESSED)
+			__set_bit(i, bitmap);
+	}
+}
+
+/* ------------------------------------------------------------------ */
+/* Boot-time dispatch                                                 */
+/* ------------------------------------------------------------------ */
+
+/*
+ * Boot-patched direct call to the .S kernel. arch_initcall upgrades
+ * from the SSE2 default to AVX2 / AVX-512F if those feature bits are
+ * set. Each call site compiles to a single direct CALL instruction
+ * (text-patched at static_call_update time), avoiding the indirect-
+ * call retpoline tax in the per-PMD walker hot path.
+ *
+ * The static call points DIRECTLY at the .S kernel -- no FPU-bracket
+ * wrapper. Callers must hold an FPU bracket via
+ * lru_marie_simd_batch_begin/end.
+ */
+DEFINE_STATIC_CALL(marie_simd_scan, lru_marie_simd_scan_sse2);
+
+static int __init marie_simd_x86_init(void)
+{
+	/*
+	 * Pick the widest SIMD impl available at boot. Order matters:
+	 * AVX-512F first (8 PTEs/iter, simplest .S via VPTESTMQ kmask),
+	 * then AVX2 (4 PTEs/iter via VPCMPEQQ), then SSE2 (4 PTEs/iter
+	 * via PSHUFD packing trick -- already the default before this
+	 * runs, so we do nothing for the SSE2 case).
+	 */
+	if (boot_cpu_has(X86_FEATURE_AVX512F)) {
+		static_call_update(marie_simd_scan, lru_marie_simd_scan_avx512);
+		pr_info("SIMD PTE scan: AVX-512F (8 PTEs/iter)\n");
+	} else if (boot_cpu_has(X86_FEATURE_AVX2)) {
+		static_call_update(marie_simd_scan, lru_marie_simd_scan_avx2);
+		pr_info("SIMD PTE scan: AVX2 (4 PTEs/iter)\n");
+	} else {
+		/* default already = lru_marie_simd_scan_sse2 */
+		pr_info("SIMD PTE scan: SSE2 (4 PTEs/iter, x86-64 baseline)\n");
+	}
+	return 0;
+}
+/*
+ * arch_initcall fires before subsys_initcall (marie_init), so the
+ * static call is patched well before the walker first runs.
+ */
+arch_initcall(marie_simd_x86_init);
+
+/* ------------------------------------------------------------------ */
+/* Public API                                                         */
+/* ------------------------------------------------------------------ */
+
+void lru_marie_simd_batch_begin(void)
+{
+	if (static_branch_likely(&marie_simd_enabled_key))
+		kernel_fpu_begin();
+}
+EXPORT_SYMBOL_GPL(lru_marie_simd_batch_begin);
+
+void lru_marie_simd_batch_end(void)
+{
+	if (static_branch_likely(&marie_simd_enabled_key))
+		kernel_fpu_end();
+}
+EXPORT_SYMBOL_GPL(lru_marie_simd_batch_end);
+
+void lru_marie_simd_young_pte_mask_raw(const void *table, unsigned long *bitmap)
+{
+	if (static_branch_likely(&marie_simd_enabled_key))
+		static_call(marie_simd_scan)((const pte_t *)table, bitmap);
+	else
+		marie_simd_scan_scalar((const pte_t *)table, bitmap);
+}
+EXPORT_SYMBOL_GPL(lru_marie_simd_young_pte_mask_raw);
+
+void lru_marie_simd_young_pte_mask(const void *table, unsigned long *bitmap)
+{
+	lru_marie_simd_batch_begin();
+	lru_marie_simd_young_pte_mask_raw(table, bitmap);
+	lru_marie_simd_batch_end();
+}
+EXPORT_SYMBOL_GPL(lru_marie_simd_young_pte_mask);
diff --git a/mm/lru_marie_simd_x86_avx2.S b/mm/lru_marie_simd_x86_avx2.S
new file mode 100644
index 000000000..3f5b2994b
--- /dev/null
+++ b/mm/lru_marie_simd_x86_avx2.S
@@ -0,0 +1,213 @@
+/* SPDX-License-Identifier: GPL-2.0 */
+/*
+ * mm/marie_simd_x86_avx2.S -- AVX2 PTE young-bit scan for Marie walker.
+ *
+ * Processes 512 PTEs (one full PMD page table) per call, producing an
+ * 8-ulong (512-bit) young-bit bitmap.  4 PTEs are handled per SIMD
+ * iteration via a single 256-bit YMM load; 16 iterations fill one
+ * output ulong; 8 ulongs total.
+ *
+ * Variant chosen: counter-based rolled loop (outer=8, inner=16).
+ * Reason: mirrors the SSE2 kernel structure for auditability; 128
+ * fully-unrolled SIMD blocks would exceed 3000 instructions with no
+ * measurable throughput gain on modern out-of-order cores (loop
+ * overhead is < 1% of SIMD work).
+ *
+ * Why AVX2 is cleaner than SSE2 here:
+ *   AVX2 has VPCMPEQQ (256-bit, 64-bit lane equality).  SSE2 only has
+ *   PCMPEQD (32-bit lanes), which required the PSHUFD low-dword packing
+ *   trick to avoid false positives from PFN bits landing in the high 32
+ *   bits of a PTE.  With VPCMPEQQ we compare the full 64-bit PTE against
+ *   the broadcast mask (1ULL << _PAGE_ACCESSED) directly -- no packing.
+ *
+ *   After VPMOVMSKB, eax holds 32 bits: one 8-bit octet per 64-bit PTE
+ *   lane (uniformly 0xFF or 0x00 because VPCMPEQQ produces all-1s or
+ *   all-0s per 64-bit lane).  Extracting bits:
+ *     testl $0x000000FF, eax  -> PTE 0 young
+ *     testl $0x0000FF00, eax  -> PTE 1 young
+ *     testl $0x00FF0000, eax  -> PTE 2 young
+ *     testl $0xFF000000, eax  -> PTE 3 young
+ *
+ * Caller (marie_simd_scan_avx2_wrapper in mm/marie_simd_x86.c, added in
+ * Task 5) holds kernel_fpu_begin/end around this.  Do NOT call directly
+ * from C without an FPU context bracket.
+ *
+ * ABI (System V AMD64):
+ *   rdi = const pte_t *pte_table  (512 PTEs, 4096 bytes, page-table base;
+ *                                  page-aligned by the kernel page-table
+ *                                  allocator; vmovdqu is used so no stricter
+ *                                  SIMD alignment is required for the input)
+ *   rsi = unsigned long *bitmap   (8 ulongs = 64 bytes, caller pre-cleared)
+ *
+ * Register usage:
+ *   ymm0  = young-bit mask broadcast (0x20 x4, 64-bit lanes), constant
+ *   ymm1  = 4-PTE scratch register
+ *   rdi   = current PTE pointer (walks forward by 32 bytes per inner iter)
+ *   rsi   = bitmap base (constant)
+ *   rdx   = outer loop counter (8 -> 0)
+ *   rcx   = inner loop counter (16 -> 0)
+ *   rax   = vpmovmskb result / bit-extraction scratch
+ *   r8    = per-ulong accumulator
+ *   r9    = bit-position counter within current ulong (0..63)
+ *   r10   = single-bit scratch for OR-into-accumulator
+ *   r11   = bitmap write pointer (rsi + outer*8, updated each outer iter)
+ *
+ * AVX2 only (no AVX-512 zmm/kmask/opmask):
+ *   vmovdqa, vpand, vpcmpeqq, vpmovmskb, vzeroupper -- all AVX2.
+ *   All VEX-encoded to avoid SSE/AVX transition penalties.
+ *   VZEROUPPER before RET to clear upper YMM halves for subsequent
+ *   legacy SSE code.
+ */
+
+#include <linux/linkage.h>
+
+	/* -------------------------------------------------------------- */
+	/* Read-only data: young-bit mask broadcast                        */
+	/* -------------------------------------------------------------- */
+	.section .rodata
+	.align 32
+marie_avx2_young_mask:
+	/* _PAGE_ACCESSED = bit 5 = 0x20, broadcast to 4x 64-bit lanes */
+	.quad 0x0000000000000020
+	.quad 0x0000000000000020
+	.quad 0x0000000000000020
+	.quad 0x0000000000000020
+
+	/* -------------------------------------------------------------- */
+	/* Text                                                            */
+	/* -------------------------------------------------------------- */
+	.text
+
+/*
+ * void lru_marie_simd_scan_avx2(const pte_t *pte_table, unsigned long *bitmap)
+ *
+ * pte_table: rdi -- 512 PTEs (4096 bytes), page-table base (8-byte aligned)
+ * bitmap:    rsi -- 8 ulongs (64 bytes), caller pre-cleared
+ */
+SYM_FUNC_START(lru_marie_simd_scan_avx2)
+
+	/* Load young-bit mask once; ymm0 is constant for the whole call. */
+	vmovdqa	marie_avx2_young_mask(%rip), %ymm0
+
+	movq	%rsi, %r11		/* r11 = current bitmap word ptr    */
+	movl	$8, %edx		/* outer counter: 8 ulongs          */
+
+	/*
+	 * Outer loop: one iteration per output ulong (64 PTEs / 8 words).
+	 */
+.Louter_avx2:
+	xorq	%r8, %r8		/* accumulator = 0                  */
+	xorq	%r9, %r9		/* bit-position = 0                 */
+	movl	$16, %ecx		/* inner counter: 16 SIMD iters     */
+
+	/*
+	 * Inner loop: one iteration processes 4 PTEs => 4 result bits.
+	 *
+	 * Each PTE is 8 bytes; 4 PTEs = 32 bytes = one 256-bit YMM load.
+	 * rdi advances by 32 bytes per inner iteration.
+	 */
+.Linner_avx2:
+	/* Load 4 PTEs into ymm1 (unaligned; caller guarantees 8-byte align). */
+	vmovdqu	(%rdi), %ymm1		/* ymm1 = { pte3 | pte2 | pte1 | pte0 } */
+	addq	$32, %rdi
+
+	/*
+	 * Isolate the young bit (bit 5 = 0x20) in each 64-bit PTE lane.
+	 * VPAND operates on the full 256-bit register.
+	 */
+	vpand	%ymm0, %ymm1, %ymm1	/* ymm1 &= 0x20 per 64-bit lane    */
+
+	/*
+	 * VPCMPEQQ: compare each 64-bit lane against ymm0 (the mask 0x20).
+	 * If the masked PTE equals 0x20 the young bit was set; that lane
+	 * becomes all-ones (0xFFFFFFFFFFFFFFFF), otherwise all-zeros.
+	 * No PSHUFD trick needed: 64-bit lanes sidestep the PFN false-
+	 * positive that afflicts 32-bit PCMPEQD-based comparisons.
+	 */
+	vpcmpeqq %ymm0, %ymm1, %ymm1	/* ymm1[i] = young_i ? ~0 : 0      */
+
+	/*
+	 * VPMOVMSKB: extracts the MSB of each byte from the 256-bit ymm1
+	 * into a 32-bit integer.  Because VPCMPEQQ produces uniform
+	 * all-ones or all-zeros per 64-bit lane, each 8-byte group in ymm1
+	 * is either 0xFFFFFFFFFFFFFFFF or 0x0000000000000000.  The
+	 * resulting eax octet layout:
+	 *   eax[7:0]   = 0xFF (young) or 0x00  -- PTE 0
+	 *   eax[15:8]  = 0xFF (young) or 0x00  -- PTE 1
+	 *   eax[23:16] = 0xFF (young) or 0x00  -- PTE 2
+	 *   eax[31:24] = 0xFF (young) or 0x00  -- PTE 3
+	 */
+	vpmovmskb %ymm1, %eax
+
+	/*
+	 * Extract one result bit per PTE and shift into the accumulator.
+	 *
+	 * We use the CL-shift idiom (baseline x86-64): save rcx (inner
+	 * loop counter) temporarily, use cl for the variable shift, then
+	 * restore.  For each of the 4 PTEs:
+	 *   1. test eax against the octet mask
+	 *   2. setnz -> 1-byte 0 or 1
+	 *   3. zero-extend to 64 bits
+	 *   4. shift left by current bit-position (r9) using CL
+	 *   5. OR into accumulator
+	 *   6. increment bit-position
+	 */
+
+	/* PTE 0: octet [7:0] */
+	pushq	%rcx
+	movq	%r9, %rcx
+	testl	$0x000000FF, %eax
+	setnz	%r10b
+	movzbq	%r10b, %r10
+	shlq	%cl, %r10
+	orq	%r10, %r8
+	popq	%rcx
+	incq	%r9
+
+	/* PTE 1: octet [15:8] */
+	pushq	%rcx
+	movq	%r9, %rcx
+	testl	$0x0000FF00, %eax
+	setnz	%r10b
+	movzbq	%r10b, %r10
+	shlq	%cl, %r10
+	orq	%r10, %r8
+	popq	%rcx
+	incq	%r9
+
+	/* PTE 2: octet [23:16] */
+	pushq	%rcx
+	movq	%r9, %rcx
+	testl	$0x00FF0000, %eax
+	setnz	%r10b
+	movzbq	%r10b, %r10
+	shlq	%cl, %r10
+	orq	%r10, %r8
+	popq	%rcx
+	incq	%r9
+
+	/* PTE 3: octet [31:24] */
+	pushq	%rcx
+	movq	%r9, %rcx
+	testl	$0xFF000000, %eax
+	setnz	%r10b
+	movzbq	%r10b, %r10
+	shlq	%cl, %r10
+	orq	%r10, %r8
+	popq	%rcx
+	incq	%r9
+
+	decl	%ecx
+	jnz	.Linner_avx2
+
+	/* Store the completed ulong into bitmap. */
+	movq	%r8, (%r11)
+	addq	$8, %r11		/* advance bitmap write pointer     */
+
+	decl	%edx
+	jnz	.Louter_avx2
+
+	/* Clear upper YMM halves to avoid SSE/AVX transition penalties. */
+	vzeroupper
+	RET
+SYM_FUNC_END(lru_marie_simd_scan_avx2)
diff --git a/mm/lru_marie_simd_x86_avx512.S b/mm/lru_marie_simd_x86_avx512.S
new file mode 100644
index 000000000..63b5ba68a
--- /dev/null
+++ b/mm/lru_marie_simd_x86_avx512.S
@@ -0,0 +1,198 @@
+/* SPDX-License-Identifier: GPL-2.0 */
+/*
+ * mm/marie_simd_x86_avx512.S -- AVX-512F PTE young-bit scan for Marie walker.
+ *
+ * Processes 512 PTEs (one full PMD page table) per call, producing an
+ * 8-ulong (512-bit) young-bit bitmap.  8 PTEs are handled per SIMD
+ * iteration via a single 512-bit ZMM load and VPTESTMQ; 8 iterations
+ * fill one output ulong; 8 ulongs total.
+ *
+ * Variant chosen: counter-based rolled loop (outer=8, inner=8).
+ * Reason: mirrors the SSE2 and AVX2 kernel structure for auditability;
+ * a fully-unrolled variant of 64 SIMD blocks would be ~320 instructions
+ * but harder to review and provides no measurable throughput gain on
+ * modern out-of-order cores (loop overhead is < 1% of SIMD work).
+ *
+ * Why AVX-512F is the most efficient of the three .S kernels:
+ *   VPTESTMQ ANDs two ZMM registers and writes an 8-bit opmask register
+ *   (one bit per 64-bit lane = one bit per PTE), directly encoding eight
+ *   young-bit results in a single instruction.  KMOVW transfers the opmask
+ *   into a general-purpose register.  This eliminates the PMOVMSKB +
+ *   test/setnz dance that SSE2 and AVX2 require.
+ *
+ *   ~5 instructions per 8 PTEs vs ~24 instructions per 4 PTEs (SSE2/AVX2).
+ *   Per-PMD scan is approximately 10 ns of compute on a modern core.
+ *
+ * KMOVW vs KMOVB:
+ *   KMOVW (move 16-bit opmask to/from GPR) is part of AVX-512F.
+ *   KMOVB requires AVX-512BW.  VPTESTMQ on an 8-lane ZMM only sets
+ *   k1[7:0]; the upper 8 bits written by KMOVW are zero, so KMOVW
+ *   gives the correct 8-bit result.  All instructions in this file are
+ *   strictly AVX-512F (Foundation); no BW/DQ/VL/VBMI sub-extensions.
+ *
+ * Caller (marie_simd_scan_avx512_wrapper in mm/marie_simd_x86.c, added in
+ * Task 5) holds kernel_fpu_begin/end around this.  Do NOT call directly
+ * from C without an FPU context bracket.
+ *
+ * ABI (System V AMD64):
+ *   rdi = const pte_t *pte_table  (512 PTEs, 4096 bytes, page-table base)
+ *   rsi = unsigned long *bitmap   (8 ulongs = 64 bytes, caller pre-cleared)
+ *
+ * Register usage:
+ *   zmm0  = young-bit mask broadcast (0x20 x8, 64-bit lanes), constant
+ *   zmm1  = 8-PTE scratch register
+ *   k1    = VPTESTMQ result (8-bit opmask, one bit per PTE)
+ *   rdi   = current PTE pointer (walks forward by 64 bytes per inner iter)
+ *   rsi   = bitmap base (constant)
+ *   rdx   = outer loop counter (8 -> 0)
+ *   rcx   = inner loop counter (8 -> 0)
+ *   rax   = kmovw result / shift scratch
+ *   r8    = per-ulong accumulator
+ *   r9    = bit-position counter within current ulong (0, 8, 16, ..., 56)
+ *   r11   = bitmap write pointer (rsi + outer*8, updated each outer iter)
+ *
+ * Opmask register constraints:
+ *   k0 is reserved as the "no mask" predicate (all lanes active); do not
+ *   use k0 as an output register.  k1..k7 are used here (k1 only).
+ *
+ * AVX-512F only (strict Foundation subset):
+ *   vmovdqa64 (mask), vmovdqu64 (PTE data), vptestmq, kmovw, vzeroupper -- all AVX-512F.
+ *   zmm0..zmm7 only; k1 only.
+ *   VZEROUPPER before RET to avoid SSE/AVX transition penalties.
+ */
+
+#include <linux/linkage.h>
+
+	/* -------------------------------------------------------------- */
+	/* Read-only data: young-bit mask broadcast                        */
+	/* -------------------------------------------------------------- */
+	.section .rodata
+	.align 64
+marie_avx512_young_mask:
+	/* _PAGE_ACCESSED = bit 5 = 0x20, broadcast to 8x 64-bit lanes */
+	.quad 0x0000000000000020
+	.quad 0x0000000000000020
+	.quad 0x0000000000000020
+	.quad 0x0000000000000020
+	.quad 0x0000000000000020
+	.quad 0x0000000000000020
+	.quad 0x0000000000000020
+	.quad 0x0000000000000020
+
+	/* -------------------------------------------------------------- */
+	/* Text                                                            */
+	/* -------------------------------------------------------------- */
+	.text
+
+/*
+ * void lru_marie_simd_scan_avx512(const pte_t *pte_table, unsigned long *bitmap)
+ *
+ * pte_table: rdi -- 512 PTEs (4096 bytes), page-table base; page-aligned by
+ *                   the kernel page-table allocator; vmovdqu64 is used so no
+ *                   stricter SIMD alignment is required for the input
+ * bitmap:    rsi -- 8 ulongs (64 bytes), caller pre-cleared
+ */
+SYM_FUNC_START(lru_marie_simd_scan_avx512)
+
+	/* Load young-bit mask once; zmm0 is constant for the whole call. */
+	vmovdqa64	marie_avx512_young_mask(%rip), %zmm0
+
+	movq	%rsi, %r11		/* r11 = current bitmap word ptr    */
+	movl	$8, %edx		/* outer counter: 8 ulongs          */
+
+	/*
+	 * Outer loop: one iteration per output ulong (64 PTEs / 8 words).
+	 *
+	 * Each outer iteration processes 64 PTEs in 8 inner SIMD steps
+	 * (8 PTEs per step) and writes one 64-bit ulong to the bitmap.
+	 */
+.Louter_avx512:
+	xorq	%r8, %r8		/* accumulator = 0                  */
+	xorq	%r9, %r9		/* bit-position = 0 (steps of 8)    */
+	movl	$8, %ecx		/* inner counter: 8 SIMD iters      */
+
+	/*
+	 * Inner loop: one iteration processes 8 PTEs => 8 result bits.
+	 *
+	 * Each PTE is 8 bytes; 8 PTEs = 64 bytes = one 512-bit ZMM load.
+	 * rdi advances by 64 bytes per inner iteration.
+	 *
+	 * Algorithm per iteration:
+	 *   1. vmovdqu64 loads 8 PTEs into zmm1 (unaligned; page tables are
+	 *      page-aligned but rdi is the base of the 512-PTE array which
+	 *      is always 8-byte aligned, not necessarily 64-byte aligned).
+	 *   2. vptestmq ANDs zmm1 with zmm0 (mask) and sets k1[i] = 1 iff
+	 *      the masked value in lane i is nonzero (i.e. young bit set).
+	 *   3. kmovw extracts the 8-bit opmask from k1 into eax[7:0].
+	 *   4. Zero-extend al -> rax (upper bits already zero from kmovw).
+	 *   5. Shift rax left by r9 (0, 8, 16, ..., 56) to place the 8 bits
+	 *      at the correct position in the 64-bit accumulator.
+	 *   6. OR into r8 accumulator; advance bit-position by 8.
+	 *
+	 * The variable-shift idiom (shlq %cl, rax) requires the shift count
+	 * in cl.  We temporarily borrow rcx (inner loop counter) by pushing
+	 * and popping around each shift.
+	 */
+.Linner_avx512:
+	/* Load 8 PTEs into zmm1 (64 bytes, EVEX-encoded unaligned load). */
+	vmovdqu64	(%rdi), %zmm1		/* zmm1 = pte[7]..pte[0]        */
+	addq	$64, %rdi
+
+	/*
+	 * VPTESTMQ: for each 64-bit lane i, compute:
+	 *   k1[i] = (zmm1[i] & zmm0[i]) != 0 ? 1 : 0
+	 *
+	 * zmm0 holds 0x20 in all lanes.  A PTE with _PAGE_ACCESSED set has
+	 * bit 5 = 1, so the AND is nonzero => k1[i] = 1.
+	 * The 8-bit opmask k1 encodes young status for all 8 PTEs directly.
+	 *
+	 * No PSHUFD trick or PCMPEQD needed: the opmask result is exact.
+	 * No false positives from PFN high bits: VPTESTMQ tests for ANY
+	 * nonzero bit after AND with the narrow mask, but since the mask is
+	 * exactly 0x20 (single bit), the result is correct for any PFN.
+	 */
+	vptestmq	%zmm1, %zmm0, %k1	/* k1[i] = pte[i] has young bit */
+
+	/*
+	 * KMOVW: move the 16-bit opmask register k1 to eax.
+	 * VPTESTMQ on an 8-lane ZMM only sets k1[7:0]; k1[15:8] is zero.
+	 * So eax[7:0] = 8-bit young bitmap; eax[31:8] = 0 (zero-extended).
+	 * rax[63:32] is also zero because movl/kmovw zero-extends to 64 bits.
+	 *
+	 * KMOVW is in AVX-512F.  KMOVB requires AVX-512BW -- not used here.
+	 */
+	kmovw	%k1, %eax			/* eax[7:0] = 8-bit young mask  */
+
+	/*
+	 * Shift the 8-bit result to the correct position in the accumulator.
+	 * r9 = 0 for the first inner iter, 8 for the second, ..., 56 for
+	 * the eighth.  After shifting, rax holds the 8 result bits at their
+	 * correct positions within the 64-bit ulong.
+	 *
+	 * Use CL-based variable shift; save/restore rcx (inner loop counter).
+	 */
+	pushq	%rcx
+	movq	%r9, %rcx
+	shlq	%cl, %rax			/* rax <<= bit-position (0..56)  */
+	orq	%rax, %r8			/* accumulate into output ulong  */
+	popq	%rcx
+	addq	$8, %r9				/* advance bit-position by 8     */
+
+	decl	%ecx
+	jnz	.Linner_avx512
+
+	/* Store the completed ulong into bitmap. */
+	movq	%r8, (%r11)
+	addq	$8, %r11		/* advance bitmap write pointer     */
+
+	decl	%edx
+	jnz	.Louter_avx512
+
+	/*
+	 * VZEROUPPER: clear the upper halves of all YMM/ZMM registers to
+	 * avoid SSE/AVX transition penalties in subsequent legacy SSE code.
+	 * Required whenever AVX or AVX-512 code may be followed by SSE code.
+	 */
+	vzeroupper
+	RET
+SYM_FUNC_END(lru_marie_simd_scan_avx512)
diff --git a/mm/lru_marie_simd_x86_sse2.S b/mm/lru_marie_simd_x86_sse2.S
new file mode 100644
index 000000000..003029d1d
--- /dev/null
+++ b/mm/lru_marie_simd_x86_sse2.S
@@ -0,0 +1,214 @@
+/* SPDX-License-Identifier: GPL-2.0 */
+/*
+ * mm/marie_simd_x86_sse2.S -- SSE2 PTE young-bit scan for the Marie walker.
+ *
+ * Processes 512 PTEs (one full PMD page table) per call, producing an
+ * 8-ulong (512-bit) young-bit bitmap.  4 PTEs are handled per SIMD
+ * iteration; 16 iterations fill one output ulong; 8 ulongs total.
+ *
+ * Variant chosen: counter-based rolled loop (outer=8, inner=16).
+ * Reason: keeps the file ~130 lines and fully auditable for SSE2
+ * compliance; a fully-unrolled variant would be ~3000 instructions and
+ * harder to review without meaningfully faster throughput on modern OOO
+ * cores (loop overhead is < 1% of SIMD work).
+ *
+ * Caller (marie_simd_scan_sse2_wrapper in mm/marie_simd_x86.c, added in
+ * Task 5) holds kernel_fpu_begin/end around this.  Do NOT call directly
+ * from C without an FPU context bracket.
+ *
+ * ABI (System V AMD64):
+ *   rdi = const pte_t *pte_table  (512 PTEs, 4096 bytes, page-table base;
+ *                                  page-aligned by the kernel page-table
+ *                                  allocator; movdqu is used so no stricter
+ *                                  SIMD alignment is required for the input)
+ *   rsi = unsigned long *bitmap   (8 ulongs = 64 bytes, caller pre-cleared)
+ *
+ * Register usage:
+ *   xmm0  = young-bit mask broadcast (0x00000020 x4), constant
+ *   xmm1  = PTE pair 0-1 scratch
+ *   xmm2  = PTE pair 2-3 scratch
+ *   rdi   = current PTE pointer (walks forward)
+ *   rsi   = bitmap base (constant)
+ *   rdx   = outer loop counter (8 -> 0)
+ *   rcx   = inner loop counter (16 -> 0)
+ *   rax   = pmovmskb result / bit-extraction scratch
+ *   r8    = per-ulong accumulator
+ *   r9    = bit-position counter within current ulong (0..63)
+ *   r10   = single-bit scratch for OR-into-accumulator
+ *   r11   = bitmap write pointer (rsi + outer*8, updated each outer iter)
+ *
+ * SSE2 only (x86-64 ABI baseline since AMD Opteron 2003):
+ *   movdqa, pshufd, punpcklqdq, pand, pcmpeqd, pmovmskb -- all SSE2.
+ *   No SSE3, SSSE3, SSE4.x, AVX, BMI1/BMI2 instructions used.
+ *
+ * PSHUFD low-dword packing: the high 32 bits of an x86-64 PTE carry
+ * PFN bits 32-51, pkey, and NX.  If a PFN has bit 25 set (PA >= 128 GiB)
+ * with all other high PFN bits clear, the high dword would equal 0x20
+ * and produce a false positive against the young-bit mask.  PSHUFD with
+ * imm8=0x88 extracts only the low dword of each 64-bit PTE lane before
+ * the comparison, sidestepping this entirely.
+ */
+
+#include <linux/linkage.h>
+
+	/* -------------------------------------------------------------- */
+	/* Read-only data: young-bit mask broadcast                        */
+	/* -------------------------------------------------------------- */
+	.section .rodata
+	.align 16
+marie_sse2_young_mask:
+	/* _PAGE_ACCESSED = bit 5 = 0x20, broadcast to all four dwords */
+	.long 0x00000020
+	.long 0x00000020
+	.long 0x00000020
+	.long 0x00000020
+
+	/* -------------------------------------------------------------- */
+	/* Text                                                            */
+	/* -------------------------------------------------------------- */
+	.text
+
+/*
+ * void lru_marie_simd_scan_sse2(const pte_t *pte_table, unsigned long *bitmap)
+ *
+ * pte_table: rdi -- 512 PTEs (4096 bytes), page-table base (8-byte aligned)
+ * bitmap:    rsi -- 8 ulongs (64 bytes), caller pre-cleared
+ */
+SYM_FUNC_START(lru_marie_simd_scan_sse2)
+
+	/* Load young-bit mask once; xmm0 is constant for the whole call. */
+	movdqa	marie_sse2_young_mask(%rip), %xmm0
+
+	movq	%rsi, %r11		/* r11 = current bitmap word ptr    */
+	movl	$8, %edx		/* outer counter: 8 ulongs          */
+
+	/*
+	 * Outer loop: one iteration per output ulong (64 PTEs / 8 words).
+	 */
+.Louter:
+	xorq	%r8, %r8		/* accumulator = 0                  */
+	xorq	%r9, %r9		/* bit-position = 0                 */
+	movl	$16, %ecx		/* inner counter: 16 SIMD iters     */
+
+	/*
+	 * Inner loop: one iteration processes 4 PTEs => 4 result bits.
+	 *
+	 * Each PTE is 8 bytes; 4 PTEs = 32 bytes = 2 x 16-byte XMM loads.
+	 * rdi advances by 32 bytes per inner iteration.
+	 */
+.Linner:
+	/* Load PTE[0..1] and PTE[2..3] (unaligned; 8-byte align guaranteed). */
+	movdqu	(%rdi), %xmm1		/* xmm1 = { pte1_hi:pte1_lo | pte0_hi:pte0_lo } */
+	movdqu	16(%rdi), %xmm2		/* xmm2 = { pte3_hi:pte3_lo | pte2_hi:pte2_lo } */
+	addq	$32, %rdi
+
+	/*
+	 * Pack the low 32-bit dword of each PTE into one XMM register.
+	 *
+	 * pshufd imm8=0x88 = 0b_10_00_10_00:
+	 *   dst[0] = src[0]  (dword 0 = PTE low bits)
+	 *   dst[1] = src[2]  (dword 2 = next PTE low bits)
+	 *   dst[2] = src[0]  (repeated -- don't care)
+	 *   dst[3] = src[2]  (repeated -- don't care)
+	 * => xmm1 = { lo1_dup | lo0_dup | lo1 | lo0 }
+	 *    xmm2 = { lo3_dup | lo2_dup | lo3 | lo2 }
+	 *
+	 * punpcklqdq merges the low 64 bits of each:
+	 *   dst = { xmm2[63:0] | xmm1[63:0] }
+	 *       = { lo3 | lo2 | lo1 | lo0 }
+	 */
+	pshufd	$0x88, %xmm1, %xmm1
+	pshufd	$0x88, %xmm2, %xmm2
+	punpcklqdq %xmm2, %xmm1	/* xmm1 = { lo3, lo2, lo1, lo0 }   */
+
+	/* Isolate young bit (bit 5 = 0x20) in each dword. */
+	pand	%xmm0, %xmm1		/* xmm1 &= 0x20                     */
+
+	/* Compare: dword == 0x20 => all-ones (-1), else 0. */
+	pcmpeqd	%xmm0, %xmm1		/* xmm1[i] = (lo_i & 0x20 == 0x20) ? 0xFFFFFFFF : 0 */
+
+	/*
+	 * pmovmskb: takes the MSB of each byte => 16-bit result in eax.
+	 * Since each dword is either 0x00000000 or 0xFFFFFFFF, the four
+	 * nibbles of eax are uniformly 0x0 or 0xF:
+	 *   eax[3:0]   = PTE0 young (0xF) or not (0x0)
+	 *   eax[7:4]   = PTE1
+	 *   eax[11:8]  = PTE2
+	 *   eax[15:12] = PTE3
+	 */
+	pmovmskb %xmm1, %eax
+
+	/*
+	 * Extract one result bit per PTE and shift into the accumulator.
+	 *
+	 * We use the CL-shift idiom (SSE2/baseline x86):
+	 *   save rcx (inner loop counter) -> r10 temporarily, then restore.
+	 *
+	 * For each of the 4 PTEs:
+	 *   1. test eax against the nibble mask (0x000F, 0x00F0, 0x0F00, 0xF000)
+	 *   2. setnz -> 1-byte 0 or 1
+	 *   3. zero-extend to 64 bits
+	 *   4. shift left by current bit-position (r9) using CL
+	 *   5. OR into accumulator
+	 *   6. increment bit-position
+	 *
+	 * We push/pop rcx around each variable-CL shift to preserve the
+	 * inner loop counter.
+	 */
+
+	/* PTE 0: nibble [3:0] */
+	pushq	%rcx
+	movq	%r9, %rcx
+	testl	$0x000F, %eax
+	setnz	%r10b
+	movzbq	%r10b, %r10
+	shlq	%cl, %r10
+	orq	%r10, %r8
+	popq	%rcx
+	incq	%r9
+
+	/* PTE 1: nibble [7:4] */
+	pushq	%rcx
+	movq	%r9, %rcx
+	testl	$0x00F0, %eax
+	setnz	%r10b
+	movzbq	%r10b, %r10
+	shlq	%cl, %r10
+	orq	%r10, %r8
+	popq	%rcx
+	incq	%r9
+
+	/* PTE 2: nibble [11:8] */
+	pushq	%rcx
+	movq	%r9, %rcx
+	testl	$0x0F00, %eax
+	setnz	%r10b
+	movzbq	%r10b, %r10
+	shlq	%cl, %r10
+	orq	%r10, %r8
+	popq	%rcx
+	incq	%r9
+
+	/* PTE 3: nibble [15:12] */
+	pushq	%rcx
+	movq	%r9, %rcx
+	testl	$0xF000, %eax
+	setnz	%r10b
+	movzbq	%r10b, %r10
+	shlq	%cl, %r10
+	orq	%r10, %r8
+	popq	%rcx
+	incq	%r9
+
+	decl	%ecx
+	jnz	.Linner
+
+	/* Store the completed ulong into bitmap. */
+	movq	%r8, (%r11)
+	addq	$8, %r11		/* advance bitmap write pointer     */
+
+	decl	%edx
+	jnz	.Louter
+
+	RET
+SYM_FUNC_END(lru_marie_simd_scan_sse2)
diff --git a/mm/lru_marie_sort.c b/mm/lru_marie_sort.c
new file mode 100644
index 000000000..571e2c8de
--- /dev/null
+++ b/mm/lru_marie_sort.c
@@ -0,0 +1,259 @@
+/* SPDX-License-Identifier: GPL-2.0 */
+/*
+ * Marie shrink-batch natural merge sort.
+ *
+ * This file is NOT a standalone compilation unit. It is #included from
+ * lru_marie.c so that all helpers below share that file's translation
+ * unit — keeping `static` linkage, allowing the comparator to be
+ * inlined into the merge / run-detection inner loops, and avoiding the
+ * indirect-call cost that a function-pointer comparator (lib/list_sort
+ * style) would impose.
+ *
+ * lru_marie_sort.c MUST NOT appear in mm/Makefile's obj-y list. Build
+ * system sees it only through lru_marie.c's #include directive.
+ *
+ * ---------------------------------------------------------------------
+ *  VMA-cache pre-sort: natural merge sort for the per-type batch
+ * ---------------------------------------------------------------------
+ *
+ * shrink_folio_list iterates the batch sequentially and calls
+ * try_to_unmap per folio, which acquires the folio's anon_vma rwsem
+ * (anon) or i_mmap_rwsem (file). With folios sharing the same
+ * anon_vma / address_space placed adjacent in the list, consecutive
+ * try_to_unmap calls re-acquire the same rwsem whose cache line is
+ * still warm in the local CPU, plus the interval-tree / VMA / PTL /
+ * PMD-page accesses all hit warm caches. Sort cost << rmap-walk
+ * savings.
+ *
+ * lib/list_sort.c is a bottom-up power-of-two merge sort that does
+ * O(n log n) comparisons regardless of input order: ~1024 for sorted
+ * input, ~2048 for random at n=256. Marie's typical workload (single
+ * anon_vma per process dominating, so all batch folios share one
+ * mapping) is best-case sorted; we want that to run in O(n) rather
+ * than O(n log n).
+ *
+ * marie_natural_sort() detects existing ascending or descending runs
+ * in O(n) and merges them with TimSort-style stack invariants. For
+ * the all-equal case (tail /dev/zero, single anon_vma) the entire
+ * input is detected as one ascending run and returns without any
+ * merge work in n-1 comparisons.
+ *
+ * Performance (n=256, ~5 ns per inlined comparison):
+ *   - all-equal mapping (tail /dev/zero):  ~1.3 us  (lib/list_sort: ~5 us)
+ *   - mostly-sorted (few runs):            ~1.5 us  (lib/list_sort: ~5 us)
+ *   - reverse-sorted:                      ~1.5 us  (lib/list_sort: ~10 us)
+ *   - random:                              ~10 us   (lib/list_sort: ~10 us)
+ *
+ * Why not SIMD: SIMD sort wants contiguous arrays. Converting Marie's
+ * folio linked-list to an array, SIMD-sorting it, then re-linking
+ * costs ~10-15 us of fixed extract/rebuild overhead independent of
+ * input pattern. For the all-equal best case (the common case for
+ * Marie) SIMD would be ~10x slower than this scalar natural merge
+ * sort; for the worst case roughly equal. Plus SIMD requires
+ * kernel_fpu_begin / XSAVE / preempt_disable which is undesirable on
+ * the kswapd hot path.
+ *
+ * Stack depth bound: TimSort run sizes grow at least Fibonacci, so
+ * 32 entries support batches up to F(32) ~ 2 million elements. Marie's
+ * max marie_shrink_batch_threshold is 8192, well under the bound.
+ */
+
+#define MARIE_SORT_MAX_RUNS 32
+
+struct marie_sort_run {
+	struct list_head	*head;	/* singly-linked, null-terminated */
+	unsigned int		len;
+};
+
+/*
+ * Inline comparator on folio->mapping. Returns -1 / 0 / +1.
+ * folio_raw_mapping() strips PAGE_MAPPING_FLAGS and returns either
+ * anon_vma (anon batch) or address_space (file batch). Both are kernel
+ * pointers; treat as uintptr_t for ordering.
+ */
+static __always_inline int
+marie_sort_cmp(const struct list_head *a, const struct list_head *b)
+{
+	const struct folio *fa = list_entry(a, struct folio, lru);
+	const struct folio *fb = list_entry(b, struct folio, lru);
+	uintptr_t ma = (uintptr_t)folio_raw_mapping(fa);
+	uintptr_t mb = (uintptr_t)folio_raw_mapping(fb);
+
+	return (ma > mb) - (ma < mb);
+}
+
+/*
+ * Reverse a null-terminated singly-linked list in place. Returns the
+ * new head (former tail). O(n), called only for descending runs which
+ * are usually short.
+ */
+static struct list_head *marie_sort_reverse(struct list_head *list)
+{
+	struct list_head *prev = NULL;
+
+	while (list) {
+		struct list_head *next = list->next;
+
+		list->next = prev;
+		prev = list;
+		list = next;
+	}
+	return prev;
+}
+
+/*
+ * Merge two ascending sorted null-terminated singly-linked lists into
+ * one ascending list. Equal-key elements from @a come first to
+ * preserve stability.
+ */
+static struct list_head *
+marie_sort_merge(struct list_head *a, struct list_head *b)
+{
+	struct list_head *head, **tail = &head;
+
+	for (;;) {
+		if (marie_sort_cmp(a, b) <= 0) {
+			*tail = a;
+			tail = &a->next;
+			a = a->next;
+			if (!a) {
+				*tail = b;
+				return head;
+			}
+		} else {
+			*tail = b;
+			tail = &b->next;
+			b = b->next;
+			if (!b) {
+				*tail = a;
+				return head;
+			}
+		}
+	}
+}
+
+/* Merge stack[i] and stack[i+1], leaving the result at stack[i]. */
+static __always_inline void
+marie_sort_merge_at(struct marie_sort_run *stack, int i)
+{
+	stack[i].head = marie_sort_merge(stack[i].head, stack[i + 1].head);
+	stack[i].len += stack[i + 1].len;
+}
+
+/*
+ * Enforce TimSort merge invariants on the top of the stack. For runs
+ * A B C at the top (C newest):
+ *   - |A| > |B| + |C|
+ *   - |B| > |C|
+ * Merge eagerly while violated. Keeps merges size-balanced and stack
+ * depth O(log n).
+ */
+static int marie_sort_balance(struct marie_sort_run *stack, int n)
+{
+	while (n >= 2) {
+		int top = n - 1;
+
+		if (n >= 3 &&
+		    stack[top - 2].len <= stack[top - 1].len + stack[top].len) {
+			/* Three-element invariant violated: merge B with the
+			 * smaller of A and C. */
+			if (stack[top - 2].len < stack[top].len) {
+				marie_sort_merge_at(stack, top - 2);
+				stack[top - 1] = stack[top];
+			} else {
+				marie_sort_merge_at(stack, top - 1);
+			}
+			n--;
+		} else if (stack[top - 1].len <= stack[top].len) {
+			/* Two-element invariant violated: |B| > |C|. */
+			marie_sort_merge_at(stack, top - 1);
+			n--;
+		} else {
+			break;
+		}
+	}
+	return n;
+}
+
+/*
+ * Natural merge sort on a doubly-linked head. The list is treated as
+ * null-terminated singly-linked for the duration of the sort; prev
+ * pointers are rebuilt in the final pass.
+ */
+static void marie_natural_sort(struct list_head *head)
+{
+	struct marie_sort_run stack[MARIE_SORT_MAX_RUNS];
+	struct list_head *list = head->next;
+	int n_stack = 0;
+
+	/* Empty or single element: already sorted. */
+	if (list == head || list->next == head)
+		return;
+
+	/* Null-terminate for the sort. */
+	head->prev->next = NULL;
+
+	while (list) {
+		struct list_head *run_head = list;
+		struct list_head *next = list->next;
+		unsigned int run_len = 1;
+		bool descending = false;
+
+		if (next) {
+			/* First comparison decides direction. */
+			descending = (marie_sort_cmp(list, next) > 0);
+			list = next;
+			run_len++;
+
+			/* Extend the run while direction holds. */
+			if (descending) {
+				while ((next = list->next) != NULL &&
+				       marie_sort_cmp(list, next) > 0) {
+					list = next;
+					run_len++;
+				}
+			} else {
+				while ((next = list->next) != NULL &&
+				       marie_sort_cmp(list, next) <= 0) {
+					list = next;
+					run_len++;
+				}
+			}
+		}
+
+		/* Detach: terminate the run, advance to the next run start. */
+		list->next = NULL;
+		list = next;
+
+		/* Descending runs become ascending after in-place reverse. */
+		if (descending)
+			run_head = marie_sort_reverse(run_head);
+
+		/* Push the new run and rebalance. */
+		BUG_ON(n_stack >= MARIE_SORT_MAX_RUNS);
+		stack[n_stack].head = run_head;
+		stack[n_stack].len = run_len;
+		n_stack = marie_sort_balance(stack, n_stack + 1);
+	}
+
+	/* Collapse the remaining stack from top to bottom. */
+	while (n_stack > 1) {
+		marie_sort_merge_at(stack, n_stack - 2);
+		n_stack--;
+	}
+
+	/* Rebuild prev pointers and close the doubly-linked circular list. */
+	{
+		struct list_head *prev = head;
+		struct list_head *curr = stack[0].head;
+
+		head->next = curr;
+		while (curr) {
+			curr->prev = prev;
+			prev = curr;
+			curr = curr->next;
+		}
+		prev->next = head;
+		head->prev = prev;
+	}
+}
diff --git a/mm/lru_marie_walker.c b/mm/lru_marie_walker.c
new file mode 100644
index 000000000..7b8b6aefa
--- /dev/null
+++ b/mm/lru_marie_walker.c
@@ -0,0 +1,985 @@
+// SPDX-License-Identifier: GPL-2.0
+/*
+ * mm/lru_marie_walker.c — Marie's SIMD-accelerated PTE walker.
+ *
+ * The walker is Marie's hot signal harvester. Per pgdat,
+ * rate-limited via marie_walker_interval() (HZ/30..HZ depending on
+ * pressure), marie_walk_pgdat() snapshots the running mm_struct's,
+ * walks each page table to PMD granularity, and at every PMD invokes
+ * lru_marie_simd_young_pte_mask_raw() to extract the young-bit bitmap
+ * of the entire 512-PTE page in one SIMD pass (AVX-512F / AVX2 / SSE2
+ * on x86; scalar fallback on arm64 and other arches -- NEON
+ * acceleration is a future optimisation, see mm/lru_marie_simd_arm64.c).
+ * The FPU bracket around the SIMD call is held across MARIE_FPU_BATCH
+ * consecutive bloom-hit PMDs and flushed by a scoped_guard around the
+ * per-mm walk_page_range, amortising kernel_fpu_begin/end overhead.
+ * For each PTE flagged young, the walker bumps the corresponding
+ * folio's tier via the
+ * lock-free saturating CMPXCHG in marie_residency_tier_inc(); folios
+ * that saturate to MARIE_TIER_MAX are routed onto the per-sl
+ * promote_queue and drained at pass end.
+ *
+ * A per-pgdat bloom filter (marie_bloom_*) feeds back from
+ * lru_marie_look_around() (rmap-side, called from
+ * folio_referenced_one()) to the walker: rmap flags PMDs whose target
+ * folio was young, the walker reads that bitmap and skips PMDs the
+ * rmap path has not flagged. The bloom is double-buffered (active /
+ * inactive) and rotated at pass end so the walker reads the feedback
+ * accumulated during the previous reclaim window.
+ *
+ * Bloom is the *only* coupling between rmap and the walker.
+ * lru_marie_look_around() does NOT promote (no tier++, no
+ * PG_referenced) on the surrounding folios; the walker handles tier++
+ * via young-bit detection on bloom-hit PMDs. This split keeps the
+ * rmap path PTL-bounded and lock-free, while the walker pays the
+ * SIMD scan + tier++ cost only for hot PMDs.
+ */
+
+#define pr_fmt(fmt) "lru_marie: " fmt
+
+#include <linux/atomic.h>
+#include <linux/bitmap.h>
+#include <linux/cleanup.h>
+#include <linux/hash.h>
+#include <linux/list.h>
+#include <linux/lru_marie.h>
+#include <linux/lru_marie_simd.h>
+#include <linux/memcontrol.h>
+#include <linux/mm.h>
+#include <linux/mm_inline.h>
+#include <linux/mmzone.h>
+#include <linux/pagewalk.h>
+#include <linux/percpu.h>
+#include <linux/printk.h>
+#include <linux/rcupdate.h>
+#include <linux/rmap.h>
+#include <linux/sched.h>
+#include <linux/sched/mm.h>
+#include <linux/sched/signal.h>
+#include <linux/slab.h>
+#include <linux/spinlock.h>
+#include <linux/types.h>
+#include <linux/xarray.h>
+
+#include "internal.h"		/* folio_pte_batch_flags / FPB_MERGE_YOUNG_DIRTY */
+#include "lru_marie_residency.h"
+
+/*
+ * ---------------------------------------------------------------------
+ *  look-around (rmap-side opportunistic PMD scan)
+ * ---------------------------------------------------------------------
+ *
+ * lru_marie_look_around() is called from rmap.c::folio_referenced_one() while
+ * the rmap caller already holds the page table lock for the target
+ * folio's PTE.  We piggyback on that PTL to scan up to
+ * MARIE_LOOK_AROUND_BATCH PTEs of the surrounding PMD and clear young bits
+ * found there in batch — what would otherwise cost one rmap walk per
+ * neighbouring folio amortises into a single PMD pass, and subsequent
+ * folio_referenced() calls on those folios get a more accurate "young
+ * since last reclaim cycle" answer.
+ *
+ * Crucially, we do NOT call folio_set_referenced() on the surrounding
+ * folios.  Doing so would cascade into marie_isolate_folios()'s
+ * promote-in-place path and starve reclaim under fault-heavy workloads
+ * (memhog, browser tab churn) where every recently-faulted PTE has its
+ * young bit set — see the comment above the test_and_clear loop below.
+ *
+ * Returns true iff the target folio's own PTE(s) were young.  That's the
+ * value folio_referenced_one() folds into its referenced count, exactly
+ * mirroring what test_and_clear_young_ptes_notify() would have returned
+ * from the bare clear_flush_young_ptes_notify branch.
+ *
+ * Lock contract: caller holds the PTL and (via rmap_walk) one of the
+ * anon_vma / i_mmap rwsems.  We DO NOT take sl->lock here.  Promotion of
+ * folios that have an external hotness signal (PG_referenced from
+ * mark_folio_accessed) is deferred to marie_isolate_folios() which already
+ * runs under sl->lock, avoiding any new lock-ordering relationship
+ * between rmap and Marie state.
+ */
+#define MARIE_LOOK_AROUND_BATCH BITS_PER_LONG	/* PTEs scanned per call */
+
+/* Forward decl: bloom Producer used by look_around. Definition lives in
+ * the walker helpers section alongside the walker-side Consumer. */
+static void marie_bloom_set(int nid, unsigned long pmd_addr);
+
+bool lru_marie_look_around(struct page_vma_mapped_walk *pvmw, unsigned int nr)
+{
+	pte_t *pte = pvmw->pte;
+	unsigned long addr = pvmw->address;
+	unsigned long start, end;
+	struct vm_area_struct *vma = pvmw->vma;
+	struct folio *target = pfn_folio(pvmw->pfn);
+	struct mem_cgroup *memcg;
+	struct pglist_data *pgdat = folio_pgdat(target);
+	int i;
+
+	lockdep_assert_held(pvmw->ptl);
+
+	/* Always clear the target folio's own young bit and propagate the
+	 * result to the caller, regardless of whether we go on to scan the
+	 * surrounding PMD. */
+	if (!test_and_clear_young_ptes_notify(vma, addr, pte, nr))
+		return false;
+
+	/*
+	 * Producer: feed the per-pgdat bloom. The target folio was young,
+	 * so this PMD has at least one hot PTE worth visiting on the next
+	 * walker pass. This is the *only* rmap-side signal Marie gives the
+	 * walker -- look_around does NOT promote (no tier++, no
+	 * PG_referenced) on the surrounding folios; the walker handles
+	 * tier++ via young-bit detection on bloom-hit PMDs.
+	 */
+	marie_bloom_set(pgdat->node_id, addr & PMD_MASK);
+
+	/* If the PTL is contended skip the surrounding scan — somebody else
+	 * is waiting and we shouldn't extend our hold time. */
+	if (spin_is_contended(pvmw->ptl))
+		return true;
+
+	/* PFN-mapped VMAs don't carry struct folio backings on every PTE;
+	 * skip them rather than feed garbage to pfn_folio(). */
+	if (vma->vm_flags & VM_SPECIAL)
+		return true;
+
+	/* Compute a PMD-bounded surrounding range centred on @addr.  We
+	 * scan at most MARIE_LOOK_AROUND_BATCH PTEs and never cross either
+	 * the PMD or the VMA boundary. */
+	start = max(addr & PMD_MASK, vma->vm_start);
+	end = min(addr | ~PMD_MASK, vma->vm_end - 1) + 1;
+
+	if (end - start == PAGE_SIZE)
+		return true;
+
+	if (end - start > MARIE_LOOK_AROUND_BATCH * PAGE_SIZE) {
+		if (addr - start < MARIE_LOOK_AROUND_BATCH * PAGE_SIZE / 2)
+			end = start + MARIE_LOOK_AROUND_BATCH * PAGE_SIZE;
+		else if (end - addr < MARIE_LOOK_AROUND_BATCH * PAGE_SIZE / 2)
+			start = end - MARIE_LOOK_AROUND_BATCH * PAGE_SIZE;
+		else {
+			start = addr - MARIE_LOOK_AROUND_BATCH * PAGE_SIZE / 2;
+			end = addr + MARIE_LOOK_AROUND_BATCH * PAGE_SIZE / 2;
+		}
+	}
+
+	memcg = get_mem_cgroup_from_folio(target);
+
+	lazy_mmu_mode_enable();
+
+	pte -= (addr - start) / PAGE_SIZE;
+
+	for (i = 0, addr = start; addr != end;
+	     i += nr, pte += nr, addr += nr * PAGE_SIZE) {
+		unsigned long pfn;
+		pte_t ptent = ptep_get(pte);
+		struct folio *folio;
+
+		nr = 1;
+
+		/* Inline minimal get_pte_pfn — vmscan.c's version is
+		 * MGLRU-static and we only need a subset of its checks. */
+		if (!pte_present(ptent))
+			continue;
+		if (pte_special(ptent))
+			continue;
+		pfn = pte_pfn(ptent);
+		if (is_zero_pfn(pfn))
+			continue;
+		if (!pfn_valid(pfn))
+			continue;
+		if (pfn < pgdat->node_start_pfn || pfn >= pgdat_end_pfn(pgdat))
+			continue;
+
+		folio = pfn_folio(pfn);
+		if (folio_nid(folio) != pgdat->node_id)
+			continue;
+
+		rcu_read_lock();
+		if (folio_memcg(folio) != memcg)
+			folio = NULL;
+		rcu_read_unlock();
+		if (!folio)
+			continue;
+
+		if (folio_test_large(folio)) {
+			const unsigned int max_nr = (end - addr) >> PAGE_SHIFT;
+
+			nr = folio_pte_batch_flags(folio, NULL, pte, &ptent,
+						   max_nr, FPB_MERGE_YOUNG_DIRTY);
+		}
+
+		/* The target folio's young bit was already cleared above and
+		 * its referenced status will be re-derived by the caller from
+		 * our return value — don't double-clear it here. */
+		if (folio == target)
+			continue;
+
+		/*
+		 * Clear young bits across the surrounding PMD in batch.  We
+		 * deliberately do NOT call folio_set_referenced() here: under
+		 * a fault-heavy allocator (memhog, browser tab churn) every
+		 * recently-faulted PTE has its young bit set, and amplifying
+		 * that into PG_referenced on ~MARIE_LOOK_AROUND_BATCH neighbours
+		 * per rmap call cascades through promote-in-place and starves
+		 * the reclaim path of evictable folios.  Instead we let the
+		 * standard folio_check_references → KEEP path mark folios
+		 * one-by-one as they're individually visited, preserving
+		 * per-folio cardinality in the "hot" signal.
+		 */
+		test_and_clear_young_ptes_notify(vma, addr, pte, nr);
+	}
+
+	lazy_mmu_mode_disable();
+	mem_cgroup_put(memcg);
+
+	return true;
+}
+EXPORT_SYMBOL_GPL(lru_marie_look_around);
+
+/*
+ * ---------------------------------------------------------------------
+ *  Walker helpers: adaptive walker rate, per-pgdat state
+ * ---------------------------------------------------------------------
+ */
+
+/*
+ * Adaptive walker rate. High pressure -> short interval
+ * (frequent walks -> fresh tier signal); idle -> long interval (don't
+ * burn CPU). Returns jiffies until the next walker pass for this pgdat.
+ *
+ * Watermarks come from ZONE_NORMAL when present; for builds where
+ * ZONE_NORMAL is absent we fall back to the first populated zone.
+ *
+ * All four stage intervals are runtime-tunable via
+ * /sys/kernel/mm/lru_marie/walker_interval_{critical,low,normal,idle}_ms;
+ * defaults preserve the original HZ/30, HZ/10, HZ/4, HZ cadence.
+ */
+static unsigned long marie_walker_interval(struct pglist_data *pgdat)
+{
+	struct zone *zone = NULL;
+	unsigned long free, high, low, min;
+	int zid;
+
+	for (zid = 0; zid < MAX_NR_ZONES; zid++) {
+		struct zone *z = &pgdat->node_zones[zid];
+
+		if (!populated_zone(z))
+			continue;
+		if (zid == ZONE_NORMAL) {
+			zone = z;
+			break;
+		}
+		if (!zone)
+			zone = z;
+	}
+	if (!zone)
+		return READ_ONCE(marie_walker_interval_idle);
+
+	free = sum_zone_node_page_state(pgdat->node_id, NR_FREE_PAGES);
+	high = high_wmark_pages(zone);
+	low  = low_wmark_pages(zone);
+	min  = min_wmark_pages(zone);
+
+	if (free < min)
+		return READ_ONCE(marie_walker_interval_critical);
+	if (free < low)
+		return READ_ONCE(marie_walker_interval_low);
+	if (free < high)
+		return READ_ONCE(marie_walker_interval_normal);
+	return READ_ONCE(marie_walker_interval_idle);
+}
+
+/*
+ * ---------------------------------------------------------------------
+ *  Bloom filter -- rmap → walker forward feedback
+ * ---------------------------------------------------------------------
+ *
+ * Per-pgdat probabilistic set of "PMDs the rmap path saw young in since
+ * the last walker pass." Keyed by PMD index (>>PMD_SHIFT), m=1<<15
+ * (4 KiB per filter, 8 KiB per pgdat), k=2.
+ *
+ * Producer: lru_marie_look_around() (rmap-side, runs under PTL during eviction
+ *   folio_referenced walks). Sets bits in @inactive.
+ *
+ * Consumer: marie_walk_pmd_range() (walker hot path, runs under PTL).
+ *   Tests bits in @active. Bloom miss -> skip the PMD's SIMD scan.
+ *
+ * Pass-end (marie_walk_pgdat): swap active/inactive under @lock and clear
+ * the new inactive. The walker therefore reads the rmap feedback that
+ * accumulated during the previous reclaim window.
+ *
+ * @warmed_up is the force_scan kill-switch: sticky-true on the first
+ * Producer write per pgdat. Until then, the walker bypasses bloom and
+ * scans every PMD (covers cold-boot and freshly-online pgdats where
+ * rmap has never fed the filter).
+ *
+ * Lazy alloc with GFP_ATOMIC -- look_around runs under PTL, so any
+ * sleeping alloc would deadlock. Allocation failure leaves @inactive
+ * NULL; the next look_around call retries. With both bitmaps NULL the
+ * walker falls back to force_scan via @warmed_up == false.
+ */
+#define MARIE_BLOOM_SHIFT		15
+#define MARIE_BLOOM_SIZE		(1U << MARIE_BLOOM_SHIFT)	/* 32K bits */
+
+struct marie_bloom {
+	spinlock_t	lock;		/* serialises swap + alloc */
+	unsigned long	*active;	/* read by walker */
+	unsigned long	*inactive;	/* written by look_around */
+	bool		warmed_up;	/* sticky: true after first Producer set */
+};
+
+static struct marie_bloom marie_blooms[MAX_NUMNODES];
+
+static inline void marie_bloom_keys(unsigned long pmd_addr, int *key)
+{
+	u32 hash = hash_long(pmd_addr >> PMD_SHIFT, MARIE_BLOOM_SHIFT * 2);
+
+	key[0] = hash & (MARIE_BLOOM_SIZE - 1);
+	key[1] = (hash >> MARIE_BLOOM_SHIFT) & (MARIE_BLOOM_SIZE - 1);
+}
+
+static unsigned long *marie_bloom_alloc_atomic(void)
+{
+	return bitmap_zalloc(MARIE_BLOOM_SIZE, GFP_ATOMIC);
+}
+
+/*
+ * Producer: feed @pmd_addr into pgdat @nid's inactive bloom. Idempotent.
+ * Bitops are lock-free; only the lazy-alloc slow path takes b->lock.
+ */
+static void marie_bloom_set(int nid, unsigned long pmd_addr)
+{
+	struct marie_bloom *b;
+	unsigned long *filter;
+	unsigned long flags;
+	int key[2];
+
+	if (nid < 0 || nid >= MAX_NUMNODES)
+		return;
+	b = &marie_blooms[nid];
+
+	marie_bloom_keys(pmd_addr, key);
+
+	filter = READ_ONCE(b->inactive);
+	if (filter) {
+		if (!test_bit(key[0], filter))
+			set_bit(key[0], filter);
+		if (!test_bit(key[1], filter))
+			set_bit(key[1], filter);
+		if (!READ_ONCE(b->warmed_up))
+			WRITE_ONCE(b->warmed_up, true);
+		return;
+	}
+
+	/* Slow path: lazy allocate both bitmaps. */
+	spin_lock_irqsave(&b->lock, flags);
+	if (!b->inactive)
+		b->inactive = marie_bloom_alloc_atomic();
+	if (!b->active)
+		b->active = marie_bloom_alloc_atomic();
+	if (!b->inactive) {
+		spin_unlock_irqrestore(&b->lock, flags);
+		return;	/* OOM: walker will use force_scan via !warmed_up */
+	}
+	filter = b->inactive;
+	if (!test_bit(key[0], filter))
+		set_bit(key[0], filter);
+	if (!test_bit(key[1], filter))
+		set_bit(key[1], filter);
+	b->warmed_up = true;
+	spin_unlock_irqrestore(&b->lock, flags);
+}
+
+/*
+ * Consumer: walker hot path. Returns true iff @pmd_addr is in pgdat
+ * @nid's active bloom. NULL active -> false (caller's force_scan path
+ * covers it).
+ */
+static bool marie_bloom_test(int nid, unsigned long pmd_addr)
+{
+	unsigned long *filter;
+	int key[2];
+
+	if (nid < 0 || nid >= MAX_NUMNODES)
+		return false;
+
+	filter = READ_ONCE(marie_blooms[nid].active);
+	if (!filter)
+		return false;
+
+	marie_bloom_keys(pmd_addr, key);
+	return test_bit(key[0], filter) && test_bit(key[1], filter);
+}
+
+/*
+ * Pass-end: swap active <- inactive, clear new inactive. Called from
+ * marie_walk_pgdat under no other lock.
+ */
+static void marie_bloom_swap(int nid)
+{
+	struct marie_bloom *b;
+	unsigned long *tmp;
+	unsigned long flags;
+
+	if (nid < 0 || nid >= MAX_NUMNODES)
+		return;
+	b = &marie_blooms[nid];
+
+	spin_lock_irqsave(&b->lock, flags);
+	tmp = b->active;
+	b->active = b->inactive;
+	b->inactive = tmp;
+	if (b->inactive)
+		bitmap_zero(b->inactive, MARIE_BLOOM_SIZE);
+	spin_unlock_irqrestore(&b->lock, flags);
+}
+
+static inline bool marie_bloom_warmed(int nid)
+{
+	if (nid < 0 || nid >= MAX_NUMNODES)
+		return false;
+	return READ_ONCE(marie_blooms[nid].warmed_up);
+}
+
+/*
+ * Per-CPU walk context: a preallocated mm snapshot buffer so the walker
+ * doesn't kmalloc inside its hot entry path (the walker can be entered
+ * from direct reclaim, where allocator recursion is disallowed).
+ *
+ * Ownership is established by marie_walker_busy below: the pass owner
+ * pins to its CPU via migrate_disable() and claims the per-CPU ctx
+ * with this_cpu_cmpxchg(marie_walker_busy, 0, 1). A preempted-and-
+ * resumed reclaimer that reaches marie_walk_pgdat on the same CPU will
+ * find the flag set and bail, preventing concurrent reuse of the
+ * snapshot buffer. The walker pass itself stays preemptible so
+ * cond_resched() inside marie_walk_pmd_range remains effective.
+ *
+ * marie_walker_next[] lives in the walker section below alongside the
+ * rest of the walker state.
+ */
+#define MARIE_WALK_MAX_MMS	256
+
+struct marie_walk_ctx {
+	struct mm_struct	*mms[MARIE_WALK_MAX_MMS];
+	int			n_mms;
+};
+
+static DEFINE_PER_CPU(struct marie_walk_ctx, marie_walker_ctx);
+static DEFINE_PER_CPU(unsigned int, marie_walker_busy);
+
+/*
+ * ---------------------------------------------------------------------
+ *  Walker -- SIMD + adaptive + per-pgdat
+ * ---------------------------------------------------------------------
+ *
+ * Per pgdat, rate-limited via marie_walker_interval (HZ/30 .. HZ).
+ * Each PMD scans young bits in batch via lru_marie_simd_young_pte_mask_raw
+ * (AVX-512F / AVX2 / SSE2 on x86; scalar fallback on arm64 and other
+ * arches), with an enclosing FPU bracket batched across MARIE_FPU_BATCH
+ * scans. Cross-node folios are filtered out so each pgdat owns its
+ * work cleanly.
+ *
+ * The walker promote enqueues to the per-CPU promote_queue;
+ * pass-end drains both queues for the pgdat's sl's.
+ *
+ * Lock contract:
+ *   per-PMD: holds the existing pte_offset_map_lock ptl
+ *   drain + walker_visits bump: under sl->lock
+ *   per-pgdat deadline: cmpxchg on marie_walker_next[nid]
+ *
+ * Lock ordering: walker takes pte ptl (via pte_offset_map_lock); the
+ * inner per-PTE body never takes sl->lock. lru_marie_add_folio /
+ * marie_isolate_folios / lru_marie_del_folio never take ptl while holding
+ * sl->lock -- see audit in the file header -- so the pass-end drain
+ * (marie_drain_pending under sl->lock) does not invert.
+ */
+
+/*
+ * Per-pgdat walker deadline (jiffies). One pass per pgdat per
+ * marie_walker_interval(pgdat) is allowed; concurrent reclaimers /
+ * kswapd cycles atomic-cmpxchg to claim the slot.
+ *
+ * MARIE_WALK_MAX_MMS bounds the per-pass task snapshot (see the per-CPU
+ * marie_walker_ctx definition earlier in this file).
+ */
+static atomic_long_t marie_walker_next[MAX_NUMNODES];
+
+/*
+ * MARIE_FPU_BATCH — number of consecutive bloom-hit PMDs scanned under
+ * a single FPU bracket before flushing.
+ *
+ * Trade-off: larger batch amortises kernel_fpu_begin/end (~100 ns each
+ * on x86 xsave/xrstor) across more scans, but extends the preempt-
+ * disabled window proportionally because the bitmap iteration runs
+ * inside the same PTL window with FPU still held. With per-PMD total
+ * cost ~1-25 µs (dominated by folio_marie_inc_tier on set bits), a
+ * batch of 16 gives a worst-case preempt window of ~400 µs -- well
+ * inside the 100 ms regression that drove the original per-PMD design,
+ * and acceptable for desktop-grade preemption.
+ *
+ * Bloom misses do NOT advance the counter (the FPU bracket has not been
+ * opened on those PMDs), so the batch is purely "PMDs we actually
+ * scanned in a row".
+ */
+#define MARIE_FPU_BATCH		16
+
+/*
+ * Per-walk FPU batch state.  Lives inside marie_walk_arg so it is reset
+ * automatically each marie_walk_pgdat() invocation; the scoped_guard
+ * around walk_page_range() in marie_walk_one_mm() flushes any partial
+ * batch when the per-mm walk exits, guaranteeing FPU is released
+ * before mmap_read_unlock and before the next mm starts.
+ */
+struct marie_fpu_batch {
+	unsigned int	count;		/* scans in current bracket */
+	bool		held;		/* FPU bracket currently open */
+};
+
+static inline void marie_fpu_batch_open(struct marie_fpu_batch *b)
+{
+	if (!b->held) {
+		lru_marie_simd_batch_begin();
+		b->held = true;
+	}
+}
+
+static inline void marie_fpu_batch_step(struct marie_fpu_batch *b)
+{
+	if (++b->count >= MARIE_FPU_BATCH) {
+		lru_marie_simd_batch_end();
+		b->held = false;
+		b->count = 0;
+	}
+}
+
+static inline void marie_fpu_batch_flush(struct marie_fpu_batch *b)
+{
+	if (b->held) {
+		lru_marie_simd_batch_end();
+		b->held = false;
+		b->count = 0;
+	}
+}
+
+/*
+ * scoped_guard(marie_fpu_batch, &arg->fpu) — entry is a no-op (the
+ * walker opens the bracket lazily on the first bloom-hit PMD); exit
+ * flushes any in-flight bracket.  Wrapped around walk_page_range() in
+ * marie_walk_one_mm() so an early return / fault from the underlying
+ * mm walker still releases FPU before mmap_read_unlock.
+ */
+DEFINE_GUARD(marie_fpu_batch, struct marie_fpu_batch *,
+	     (void)_T,
+	     marie_fpu_batch_flush(_T))
+
+struct marie_walk_arg {
+	struct pglist_data	*pgdat;
+	struct marie_lruvec	*sl_anon_cache;	/* one-deep lruvec cache */
+	struct marie_lruvec	*sl_file_cache;
+	bool			force_scan;	/* bypass bloom gate */
+	struct marie_fpu_batch	fpu;		/* per-walk FPU bracket state */
+};
+
+static int marie_walk_pmd_range(pmd_t *pmd, unsigned long start,
+			      unsigned long end, struct mm_walk *walk)
+{
+	struct marie_walk_arg *arg = walk->private;
+	struct vm_area_struct *vma = walk->vma;
+	pte_t *pte_table, *orig_pte;
+	spinlock_t *ptl;
+	unsigned long pmd_addr;
+	unsigned long bitmap[MARIE_SIMD_PTE_BITMAP_LONGS] = { 0 };
+	int bit;
+
+	if (!vma)
+		return 0;
+
+	pmd_addr = start & PMD_MASK;
+
+	/*
+	 * Bloom gate (Consumer side of rmap → walker forward feedback).
+	 * Skip PMDs the rmap path has not flagged as recently-young; the
+	 * SIMD scan + tier++ work is paid only for hot PMDs. force_scan
+	 * bypasses the gate during cold-boot / freshly-online pgdats where
+	 * the bloom has yet to be primed by look_around. Returning before
+	 * pte_offset_map_lock() avoids the PTL cost on misses too.
+	 */
+	if (!arg->force_scan &&
+	    !marie_bloom_test(arg->pgdat->node_id, pmd_addr))
+		return 0;
+
+	/*
+	 * pte_offset_map_lock returns pte_base + pte_index(start), which may
+	 * not be at the start of the page table.  The SIMD kernel must receive
+	 * the page-table base (index 0) so that:
+	 *   (a) the 512-entry scan does not walk past the end of the page, and
+	 *   (b) bit N in the output bitmap corresponds to pte_base[N], making
+	 *       "pte_base + bit" the correct per-entry pointer in the loop.
+	 *
+	 * Keep orig_pte (= pte_base + pte_index(start)) for pte_unmap_unlock.
+	 */
+	pte_table = pte_offset_map_lock(walk->mm, pmd, start, &ptl);
+	if (!pte_table)
+		return 0;
+	orig_pte = pte_table;
+
+	/*
+	 * Open the FPU bracket lazily on the first bloom-hit PMD of this
+	 * batch and run the raw scan inside it.  marie_fpu_batch_step()
+	 * closes the bracket once we've accumulated MARIE_FPU_BATCH
+	 * scans; subsequent bloom hits reopen for the next batch.  The
+	 * scoped_guard around walk_page_range() in marie_walk_one_mm()
+	 * flushes any partial batch on walker exit.
+	 */
+	marie_fpu_batch_open(&arg->fpu);
+	lru_marie_simd_young_pte_mask_raw(pte_table - pte_index(start), bitmap);
+	marie_fpu_batch_step(&arg->fpu);
+
+	for_each_set_bit(bit, bitmap, 512) {
+		unsigned long addr = pmd_addr + bit * PAGE_SIZE;
+		pte_t *pte = orig_pte - pte_index(start) + bit;
+		pte_t ptent;
+		unsigned long pfn;
+		struct folio *folio;
+		struct marie_lruvec *sl;
+		struct lruvec *lv;
+		int type;
+		int next_bit;
+
+		/* Peek ahead at the next set bit and prefetch its
+		 * struct page into L1. The body chain below does multiple
+		 * folio-struct accesses (folio_pgdat, marie_test_tracked,
+		 * folio_is_file_lru, folio_lruvec, folio_marie_inc_tier).
+		 * Sparse bitmap iteration defeats the hardware prefetcher,
+		 * so an explicit lookahead hides struct page L2/L3 latency. */
+		next_bit = find_next_bit(bitmap, 512, bit + 1);
+		if (next_bit < 512) {
+			pte_t next_ptent = ptep_get(orig_pte - pte_index(start)
+						    + next_bit);
+			unsigned long next_pfn = pte_pfn(next_ptent);
+
+			if (pte_present(next_ptent) && pfn_valid(next_pfn))
+				__builtin_prefetch(pfn_to_page(next_pfn), 0, 3);
+		}
+
+		/* Only process PTEs within the [start, end) walk range. */
+		if (addr < start || addr >= end)
+			continue;
+
+		ptent = ptep_get(pte);
+		if (!pte_present(ptent) || pte_special(ptent))
+			continue;
+
+		pfn = pte_pfn(ptent);
+		if (is_zero_pfn(pfn) || !pfn_valid(pfn))
+			continue;
+
+		folio = pfn_folio(pfn);
+
+		/* Skip cross-node folios -- this pass is per pgdat. */
+		if (folio_pgdat(folio) != arg->pgdat)
+			continue;
+
+		/* Lock-free pre-filter: act only on folios already linked
+		 * into a gen list. TRACKED-but-list_empty folios are still
+		 * in the add_queue and will be tier-0 once drained anyway. */
+		if (!folio_marie_test_tracked(folio) || list_empty(&folio->lru))
+			continue;
+
+		if (!ptep_test_and_clear_young(vma, addr, pte))
+			continue;
+
+		type = folio_is_file_lru(folio);
+		lv = marie_folio_lruvec_rcu(folio);
+
+		/* One-deep cache: most consecutive PTEs in an mm walk hit
+		 * the same lruvec. Avoid the xa_load on every PTE. */
+		if (type == 0 && arg->sl_anon_cache &&
+		    arg->sl_anon_cache->lruvec == lv) {
+			sl = arg->sl_anon_cache;
+		} else if (type == 1 && arg->sl_file_cache &&
+			   arg->sl_file_cache->lruvec == lv) {
+			sl = arg->sl_file_cache;
+		} else {
+			/*
+			 * RCU read-side: pairs with synchronize_rcu() in
+			 * marie_drop_lruvec(). The cached @sl is then valid
+			 * for the rest of this walker pass because the
+			 * outer pgdat walk runs with preempt_disable(),
+			 * which keeps an implicit RCU read-side held for
+			 * the lifetime of the cached pointer.
+			 */
+			rcu_read_lock();
+			sl = xa_load(&marie_lruvec_xa, (unsigned long)lv);
+			rcu_read_unlock();
+			if (!sl)
+				continue;
+			if (type == 0)
+				arg->sl_anon_cache = sl;
+			else
+				arg->sl_file_cache = sl;
+		}
+
+		/*
+		 * Walker tier++: ADT API folds the folio_marie_inc_tier CMPXCHG
+		 * with the saturated -> PENDING_PROMOTE transit enqueue. The
+		 * caller (this loop) does NOT update nr_per_tier — that
+		 * counter is sl-locked-only. The transient
+		 * tier-mismatch in the prior tier's bucket is absorbed by
+		 * pop_oldest_batch's per-folio folio_marie_get_tier() check.
+		 */
+		(void)marie_residency_tier_inc(sl, folio);
+	}
+
+	pte_unmap_unlock(orig_pte, ptl);
+	cond_resched();
+	return 0;
+}
+
+static const struct mm_walk_ops marie_walk_ops = {
+	.pmd_entry	= marie_walk_pmd_range,
+	.walk_lock	= PGWALK_RDLOCK,
+};
+
+static void marie_walk_one_mm(struct mm_struct *mm, struct marie_walk_arg *arg)
+{
+	if (!mmap_read_trylock(mm))
+		return;
+	scoped_guard(marie_fpu_batch, &arg->fpu)
+		walk_page_range(mm, 0, TASK_SIZE, &marie_walk_ops, arg);
+	mmap_read_unlock(mm);
+}
+
+/**
+ * marie_walk_pgdat - run one walker pass for @pgdat.
+ *
+ * Atomically claims the per-pgdat deadline; concurrent reclaimers /
+ * kswapd cycles either advance the deadline or no-op. The walker
+ * snapshots running mm_struct's via for_each_process under RCU,
+ * walks each via the SIMD pmd_entry handler, then drains both
+ * per-CPU queues for every sl on this pgdat.
+ *
+ * Safe from any context that allows brief sleeping (cond_resched in
+ * the inner walk).
+ */
+void marie_walk_pgdat(struct pglist_data *pgdat)
+{
+	int nid = pgdat->node_id;
+	unsigned long deadline;
+	struct marie_walk_ctx *ctx;
+	struct task_struct *p;
+	struct marie_walk_arg arg = {
+		.pgdat = pgdat,
+		/*
+		 * force_scan disabled: the cold-bloom force_scan was the
+		 * dominant kswapd startup latency under fault-burst (full
+		 * PMD scan = ~45 ms on memhog 2.5 GB). The walker's role is
+		 * purely tier promotion; folio_check_references' Marie gate
+		 * (vmscan.c) is independent of walker state because
+		 * lru_marie_mark_accessed funnels external access into tier rather
+		 * than PG_referenced, so reclaim functions correctly even
+		 * with an unprimed bloom. Bloom is warmed lazily by
+		 * lru_marie_look_around during the first reclaim cycle's rmap walk.
+		 */
+		.force_scan = false,
+	};
+	unsigned long idx;
+	struct marie_lruvec *sl;
+	int i;
+
+	if (nid >= MAX_NUMNODES)
+		return;	/* defensive */
+
+	/* Atomic test-and-claim deadline for this pgdat. */
+	deadline = (unsigned long)atomic_long_read(&marie_walker_next[nid]);
+	if (time_before(jiffies, deadline))
+		return;
+	if ((unsigned long)atomic_long_cmpxchg(&marie_walker_next[nid],
+					       (long)deadline,
+					       (long)(jiffies + marie_walker_interval(pgdat))) != deadline)
+		return;	/* lost race to another reclaimer */
+
+	/*
+	 * Pin to this CPU and reentrancy-claim its per-CPU walker ctx.
+	 * The walker iterates up to MARIE_WALK_MAX_MMS mm_struct's per pass
+	 * and walks each up to TASK_SIZE; running the entire pass with
+	 * preempt_disable() makes cond_resched() inside marie_walk_pmd_range
+	 * a no-op and starves the rest of the system to RCU stall under
+	 * sustained memory pressure (observed as desktop stutter then
+	 * freeze on real hardware). migrate_disable() keeps us on the
+	 * CPU whose marie_walker_ctx we own, while marie_walker_busy stops a
+	 * preempted-and-resumed reclaimer from reaching marie_walk_pgdat
+	 * for a different pgdat on the same CPU and clobbering the
+	 * in-flight snapshot.
+	 */
+	migrate_disable();
+	if (this_cpu_cmpxchg(marie_walker_busy, 0, 1) != 0) {
+		migrate_enable();
+		return;
+	}
+
+	ctx = this_cpu_ptr(&marie_walker_ctx);
+	ctx->n_mms = 0;
+
+	rcu_read_lock();
+	for_each_process(p) {
+		struct mm_struct *mm = READ_ONCE(p->mm);
+
+		if (!mm || ctx->n_mms >= MARIE_WALK_MAX_MMS)
+			continue;
+		if (!mmget_not_zero(mm))
+			continue;
+		ctx->mms[ctx->n_mms++] = mm;
+	}
+	rcu_read_unlock();
+
+	/*
+	 * Walk preemptibly.  FPU bracket is held across MARIE_FPU_BATCH
+	 * consecutive bloom-hit PMDs (see marie_fpu_batch_* helpers above)
+	 * and flushed by the scoped_guard around walk_page_range() inside
+	 * marie_walk_one_mm(), so the per-mm walk always exits with FPU
+	 * released.  Per-pass FPU scope was tried in P4 prep and caused
+	 * ~100 ms preempt-disabled regressions on memhog (the bitmap
+	 * iteration ran inside the bracket); the batched-per-PMD scope
+	 * keeps preempt windows bounded at MARIE_FPU_BATCH x per-PMD time.
+	 */
+	for (i = 0; i < ctx->n_mms; i++) {
+		marie_walk_one_mm(ctx->mms[i], &arg);
+		mmput(ctx->mms[i]);
+	}
+
+	/*
+	 * Pass-end housekeeping: materialise this pass's saturated promotes
+	 * and bump per-gen walker_visits, per type sequentially.
+	 *
+	 * Two ways this avoids the old marie_both_sl block:
+	 *
+	 *   - add_queue is NOT drained here. The watermark-triggered
+	 *     drain_worker (and isolation's per-type entry drain) own that
+	 *     queue. Walker promotes are its own output, so we drain only
+	 *     the matching type's promote_queue.
+	 *
+	 *   - Each type's lock is acquired in its own scope, so an
+	 *     isolation pass for type B can proceed in parallel while
+	 *     walker is finishing type A's housekeeping. The old marie_both_sl
+	 *     held both locks at once and stalled the inactive-type
+	 *     reclaim path for the duration of the bump.
+	 *
+	 * rcu_read_lock() pairs with the synchronize_rcu() + direct free in
+	 * marie_drop_lruvec(): a concurrent memcg teardown that erases
+	 * @sl from the xarray cannot reclaim its memory until this
+	 * iteration releases the RCU read-side. Taking a per-type spin_lock
+	 * is permitted inside an RCU read-side critical section.
+	 */
+	rcu_read_lock();
+	xa_for_each(&marie_lruvec_xa, idx, sl) {
+		int t;
+
+		if (sl->nid != nid)
+			continue;
+
+		/*
+		 * Pin to the current CPU across this per-sl pass.
+		 *
+		 * The per-type drain enqueues deferred puts onto the
+		 * local CPU's marie_deferred_put_q (under spin_lock_irq
+		 * inside the scoped_guard, where the CPU cannot change).
+		 * Once the guard exits, spin_unlock re-enables
+		 * preemption — and under PREEMPT_RCU the surrounding
+		 * rcu_read_lock does NOT pin the task to its CPU. A
+		 * migration here would leave the just-enqueued wrappers
+		 * orphaned on the previous CPU's queue while our
+		 * marie_drain_deferred_puts() below reads the new CPU's
+		 * (empty) queue, leaking both the wrapper struct and
+		 * the folio_get reference it carries.
+		 *
+		 * migrate_disable() prevents migration without disabling
+		 * preemption — the per-type drain + walker_visits bump
+		 * + deferred-put drain can still be preempted by higher
+		 * priority work, so the latency impact is essentially
+		 * zero. On non-PREEMPT_RT kernels migrate_disable is the
+		 * same instruction sequence as preempt_disable; on
+		 * PREEMPT_RT it's strictly weaker and preferred for
+		 * exactly this kind of "pin CPU for per-CPU data" use.
+		 */
+		migrate_disable();
+
+		for (t = 0; t < ANON_AND_FILE; t++) {
+			struct marie_gen *g;
+
+			/*
+			 * Lock order: lru_lock outer, per-type lock inner —
+			 * the promote_queue drain's transit can call into
+			 * marie_update_lru_size which embeds
+			 * mem_cgroup_update_lru_size on mz->lru_zone_size.
+			 */
+			scoped_guard(spinlock_irq, &sl->lruvec->lru_lock)
+			scoped_guard(marie_type_sl, &sl->types[t]) {
+				marie_drain_promote_queue_one_type_locked(sl, t);
+
+				/*
+				 * Bump walker_visits for every gen of this
+				 * type so marie_isolate_folios can gate
+				 * ignore_references on "walker has visited
+				 * this gen at least once." A walker pass
+				 * scans every PTE in the pgdat which can
+				 * touch folios from any gen of any type.
+				 */
+				list_for_each_entry(g, &sl->types[t].gens,
+						    gen_node)
+					g->walker_visits++;
+			}
+		}
+
+		/* Defer-put queue drains outside both locks (folio_put may
+		 * recurse into __page_cache_release which takes lru_lock).
+		 * migrate_disable above guarantees we drain the SAME CPU's
+		 * queue we enqueued onto. */
+		marie_drain_deferred_puts();
+
+		migrate_enable();
+	}
+	rcu_read_unlock();
+
+	/*
+	 * Pass-end bloom rotation: the inactive filter has accumulated
+	 * Producer (look_around) feedback during this reclaim window;
+	 * promote it to active so the next pass scans those PMDs. The
+	 * old active is recycled as the new inactive, cleared of stale
+	 * bits.
+	 */
+	marie_bloom_swap(nid);
+
+	/* Release the per-CPU ctx claim before allowing migration. */
+	this_cpu_write(marie_walker_busy, 0);
+	migrate_enable();
+}
+
+/**
+ * lru_marie_age_node - kswapd's pre-reclaim aging hook.
+ *
+ * MGLRU's `lru_gen_age_node()` analogue. Called from kswapd_age_node()
+ * before direct reclaim machinery runs, so the gen ring has fresh
+ * hot/cold ordering by the time pressure builds. Delegates to the
+ * per-pgdat walker; rate-limiting is internal so calling on every
+ * kswapd cycle is fine.
+ */
+void lru_marie_age_node(struct pglist_data *pgdat, struct scan_control *sc)
+{
+	marie_walk_pgdat(pgdat);
+}
+EXPORT_SYMBOL_GPL(lru_marie_age_node);
+
+/**
+ * marie_walker_init - one-shot init for the walker.
+ *
+ * Initialises per-pgdat bloom-filter spinlocks. Bitmaps themselves
+ * are lazily allocated by marie_bloom_set() on first Producer hit
+ * (under PTL, GFP_ATOMIC). Called from marie_init() in mm/lru_marie.c.
+ */
+void marie_walker_init(void)
+{
+	int nid;
+
+	for (nid = 0; nid < MAX_NUMNODES; nid++)
+		spin_lock_init(&marie_blooms[nid].lock);
+}
