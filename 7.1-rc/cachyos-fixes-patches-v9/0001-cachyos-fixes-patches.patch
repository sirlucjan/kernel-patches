diff --git a/mm/page_alloc.c b/mm/page_alloc.c
index 887fd5a5d..6e3587732 100644
--- a/mm/page_alloc.c
+++ b/mm/page_alloc.c
@@ -7033,8 +7033,7 @@ static int __alloc_contig_verify_gfp_mask(gfp_t gfp_mask, gfp_t *gfp_cc_mask)
 
