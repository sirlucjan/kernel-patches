+++ b/drivers/mfd/macsmc-core.c
@@ -22,6 +22,7 @@ static const struct mfd_cell apple_smc_devs[] = {
 
 static const struct mfd_cell apple_smc_acpi_devs[] = {
 	MFD_CELL_NAME("macsmc-hwmon"),
