@@ -439,7 +462,10 @@ static int macsmc_hwmon_write_fan(struct device *dev, u32 attr, int channel,
 					      &hwmon->fan.fans[channel].set, val);
 	} else if (!val) {
 		if (hwmon->fan.fans[channel].manual) {
-			ret = macsmc_hwmon_write_key(hwmon->smc,
