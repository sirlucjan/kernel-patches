From 7dedb4af7147c2c2a86f854d4f623a6b09d7dbd9 Mon Sep 17 00:00:00 2001
From: Eric Naim <dnaim@cachyos.org>
Date: Sun, 29 Mar 2026 22:18:22 +0800
Subject: [PATCH 21/31] fixup! vmalloc: Optimize vfree

Signed-off-by: Eric Naim <dnaim@cachyos.org>
---
 mm/vmalloc.c | 5 -----
 1 file changed, 5 deletions(-)

diff --git a/mm/vmalloc.c b/mm/vmalloc.c
index 5f393f26e..c2873b4e4 100644
--- a/mm/vmalloc.c
+++ b/mm/vmalloc.c
@@ -3442,7 +3442,6 @@ void vfree_atomic(const void *addr)
 void vfree(const void *addr)
 {
 	struct vm_struct *vm;
-	int i;
 
 	if (unlikely(in_interrupt())) {
 		vfree_atomic(addr);
@@ -3468,10 +3467,6 @@ void vfree(const void *addr)
 	/* All pages of vm should be charged to same memcg, so use first one. */
 	if (vm->nr_pages && !(vm->flags & VM_MAP_PUT_PAGES))
 		mod_memcg_page_state(vm->pages[0], MEMCG_VMALLOC, -vm->nr_pages);
-	if (!(vm->flags & VM_MAP_PUT_PAGES)) {
-		for (i = 0; i < vm->nr_pages; i++)
-			mod_lruvec_page_state(vm->pages[i], NR_VMALLOC, -1);
-	}
 	free_pages_bulk(vm->pages, vm->nr_pages);
 
 	if (!(vm->flags & VM_MAP_PUT_PAGES))
-- 
2.53.0

