From ce5285e4b182920d35f1bfbd61e9cd5f6c9166e0 Mon Sep 17 00:00:00 2001
From: Eric Naim <dnaim@cachyos.org>
Date: Fri, 17 Apr 2026 10:13:07 +0800
Subject: [PATCH 21/33] Revert "sched/idle: Symmetric idle entry/exit hooks for
 accurate avg_idle tracking"

This reverts commit 234eeb845c997e1e1f185fe9cdfc32cb3c4cdfed.

Signed-off-by: Eric Naim <dnaim@cachyos.org>
---
 kernel/sched/core.c | 3 ---
 1 file changed, 3 deletions(-)

diff --git a/kernel/sched/core.c b/kernel/sched/core.c
index c9b606ee2..5e05268e5 100644
--- a/kernel/sched/core.c
+++ b/kernel/sched/core.c
@@ -3627,9 +3627,6 @@ static inline void ttwu_do_wakeup(struct task_struct *p)
 
 void update_rq_avg_idle(struct rq *rq)
 {
-	if (!rq->idle_stamp)
-		return;
-
 	u64 delta = rq_clock(rq) - rq->idle_stamp;
 	u64 max = 2*rq->max_idle_balance_cost;
 
