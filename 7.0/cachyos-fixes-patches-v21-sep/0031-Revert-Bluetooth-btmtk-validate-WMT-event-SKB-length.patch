From 7fdab81ba41a854b938596a8ff50fe4c59c457cf Mon Sep 17 00:00:00 2001
From: Eric Naim <dnaim@cachyos.org>
Date: Fri, 15 May 2026 16:55:17 +0800
Subject: [PATCH 31/31] Revert "Bluetooth: btmtk: validate WMT event SKB length
 before struct access"

This reverts commit 70d37a8b9229e394cc17ddad47e90b81d80fcd09.
Breaks bluetooth for mediatek. Revert until its fixed.

Signed-off-by: Eric Naim <dnaim@cachyos.org>
---
 drivers/bluetooth/btmtk.c | 15 ++-------------
 1 file changed, 2 insertions(+), 13 deletions(-)

diff --git a/drivers/bluetooth/btmtk.c b/drivers/bluetooth/btmtk.c
index 31ff133b6..fa7533578 100644
--- a/drivers/bluetooth/btmtk.c
+++ b/drivers/bluetooth/btmtk.c
@@ -654,13 +654,8 @@ static int btmtk_usb_hci_wmt_sync(struct hci_dev *hdev,
 	if (data->evt_skb == NULL)
 		goto err_free_wc;
 
-	wmt_evt = skb_pull_data(data->evt_skb, sizeof(*wmt_evt));
-	if (!wmt_evt) {
-		bt_dev_err(hdev, "WMT event too short (%u bytes)",
-			   data->evt_skb->len);
-		err = -EINVAL;
-		goto err_free_skb;
-	}
+	/* Parse and handle the return WMT event */
+	wmt_evt = (struct btmtk_hci_wmt_evt *)data->evt_skb->data;
 	if (wmt_evt->whdr.op != hdr->op) {
 		bt_dev_err(hdev, "Wrong op received %d expected %d",
 			   wmt_evt->whdr.op, hdr->op);
@@ -676,12 +671,6 @@ static int btmtk_usb_hci_wmt_sync(struct hci_dev *hdev,
 			status = BTMTK_WMT_PATCH_DONE;
 		break;
 	case BTMTK_WMT_FUNC_CTRL:
-		if (!skb_pull_data(data->evt_skb,
-				   sizeof(wmt_evt_funcc->status))) {
-			err = -EINVAL;
-			goto err_free_skb;
-		}
-
 		wmt_evt_funcc = (struct btmtk_hci_wmt_evt_funcc *)wmt_evt;
 		if (be16_to_cpu(wmt_evt_funcc->status) == 0x404)
 			status = BTMTK_WMT_ON_DONE;
-- 
2.54.0

