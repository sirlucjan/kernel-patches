From 3011c098349fa3c5b2374f3ba86d1752cc254f67 Mon Sep 17 00:00:00 2001
From: Eric Naim <dnaim@cachyos.org>
Date: Fri, 17 Apr 2026 13:21:32 +0800
Subject: [PATCH 28/30] fixup! clockevents: Add missing resets of the
 next_event_forced flag

Signed-off-by: Eric Naim <dnaim@cachyos.org>
---
 kernel/time/clockevents.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/kernel/time/clockevents.c b/kernel/time/clockevents.c
index 7f5474bcb..69379b34b 100644
--- a/kernel/time/clockevents.c
+++ b/kernel/time/clockevents.c
@@ -335,7 +335,7 @@ int clockevents_program_event(struct clock_event_device *dev, ktime_t expires,
 	if (delta > (int64_t)dev->min_delta_ns) {
 		delta = min(delta, (int64_t) dev->max_delta_ns);
 		clc = ((unsigned long long) delta * dev->mult) >> dev->shift;
-		if (!dev->set_next_event((unsigned long) cycles, dev)) {
+		if (!dev->set_next_event((unsigned long) clc, dev)) {
 			dev->next_event_forced = 0;
 			return 0;
 		}
-- 
2.53.0

