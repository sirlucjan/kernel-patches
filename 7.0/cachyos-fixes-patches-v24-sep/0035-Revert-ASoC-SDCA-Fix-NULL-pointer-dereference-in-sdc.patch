From c29b698d502a231175a09cb21414e88e88ae08d7 Mon Sep 17 00:00:00 2001
From: Eric Naim <dnaim@cachyos.org>
Date: Sat, 16 May 2026 14:39:38 +0800
Subject: [PATCH 35/43] Revert "ASoC: SDCA: Fix NULL pointer dereference in
 sdca_jack_process()"

This reverts commit 05648a54354eb6a55c3d0e3cee830676c2416823.

This commit was properly fixed by 4e53116437e91, so it is not needed.

Signed-off-by: Eric Naim <dnaim@cachyos.org>
---
 sound/soc/sdca/sdca_jack.c | 12 ++----------
 1 file changed, 2 insertions(+), 10 deletions(-)

diff --git a/sound/soc/sdca/sdca_jack.c b/sound/soc/sdca/sdca_jack.c
index b52d88a08..49d317d3b 100644
--- a/sound/soc/sdca/sdca_jack.c
+++ b/sound/soc/sdca/sdca_jack.c
@@ -37,21 +37,13 @@ int sdca_jack_process(struct sdca_interrupt *interrupt)
 	struct device *dev = interrupt->dev;
 	struct snd_soc_component *component = interrupt->component;
 	struct snd_soc_card *card = component->card;
-	struct rw_semaphore *rwsem;
+	struct rw_semaphore *rwsem = &card->snd_card->controls_rwsem;
 	struct jack_state *state = interrupt->priv;
-	struct snd_kcontrol *kctl;
+	struct snd_kcontrol *kctl = state->kctl;
 	struct snd_ctl_elem_value *ucontrol __free(kfree) = NULL;
 	unsigned int reg, val;
 	int ret;
 
-	if (!card || !card->snd_card) {
-		dev_dbg(dev, "card not yet bound, deferring jack event\n");
-		return -ENODEV;
-	}
-
-	rwsem = &card->snd_card->controls_rwsem;
-	kctl = state->kctl;
-
 	guard(rwsem_write)(rwsem);
 
 	if (!kctl) {
-- 
