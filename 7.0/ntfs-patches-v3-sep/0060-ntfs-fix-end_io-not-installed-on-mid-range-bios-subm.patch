From 50a31f8907f9d06f8a6a4b19228e9b268ff28025 Mon Sep 17 00:00:00 2001
From: Peter Jung <admin@ptr1337.dev>
Date: Wed, 22 Apr 2026 19:27:37 +0200
Subject: [PATCH 60/60] ntfs: fix end_io not installed on mid-range bios
 submitted by iomap

iomap may submit accumulated bios during read_folio_range before
submit_read is called. The previous code only installed the NTFS
end_io handler in submit_read, so those intermediate bios missed
the straddle-block zeroing.

Wrap read_folio_range to install ntfs_iomap_read_end_io on each bio
after the range read, and have submit_read only submit the final bio.
---
 fs/ntfs/aops.c | 26 +++++++++++++++++++++-----
 1 file changed, 21 insertions(+), 5 deletions(-)

diff --git a/fs/ntfs/aops.c b/fs/ntfs/aops.c
index 1fbf832ad..3fe755377 100644
--- a/fs/ntfs/aops.c
+++ b/fs/ntfs/aops.c
@@ -37,16 +37,32 @@ static void ntfs_iomap_read_end_io(struct bio *bio)
 	bio_put(bio);
 }
 
-static void ntfs_iomap_bio_submit_read(const struct iomap_iter *iter,
-	struct iomap_read_folio_ctx *ctx)
+static int ntfs_iomap_read_folio_range(const struct iomap_iter *iter,
+	struct iomap_read_folio_ctx *ctx, size_t len)
+{
+	int ret = iomap_bio_read_ops.read_folio_range(iter, ctx, len);
+	struct bio *bio = ctx->read_ctx;
+
+	/*
+	 * iomap may submit an accumulated bio mid-range before submit_read
+	 * runs, so install the NTFS end_io on every bio here to ensure the
+	 * straddle-block zeroing happens on all bios, not just the last.
+	 */
+	if (!ret && bio)
+		bio->bi_end_io = ntfs_iomap_read_end_io;
+	return ret;
+}
+
+static void ntfs_iomap_bio_submit_read(struct iomap_read_folio_ctx *ctx)
 {
 	struct bio *bio = ctx->read_ctx;
-	bio->bi_end_io = ntfs_iomap_read_end_io;
-	submit_bio(bio);
+
+	if (bio)
+		submit_bio(bio);
 }
 
 static const struct iomap_read_ops ntfs_iomap_bio_read_ops = {
-	.read_folio_range	= iomap_bio_read_folio_range,
+	.read_folio_range	= ntfs_iomap_read_folio_range,
 	.submit_read		= ntfs_iomap_bio_submit_read,
 };
 
