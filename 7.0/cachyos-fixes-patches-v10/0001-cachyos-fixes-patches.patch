diff --git a/mm/page_alloc.c b/mm/page_alloc.c
index e31cdd7dc..76d5a49cb 100644
--- a/mm/page_alloc.c
+++ b/mm/page_alloc.c
@@ -7102,8 +7102,7 @@ static int __alloc_contig_verify_gfp_mask(gfp_t gfp_mask, gfp_t *gfp_cc_mask)
 
