From ccfe9a1ac077216fcc888118f61f5825d5fab93b Mon Sep 17 00:00:00 2001
From: Masahito S <firelzrd@gmail.com>
Date: Fri, 17 Apr 2026 07:16:02 +0900
Subject: [PATCH 20/38] sched/idle: Symmetric idle entry/exit hooks for
 accurate avg_idle tracking

[ naim: Early return for less diffs ]

Signed-off-by: Eric Naim <dnaim@cachyos.org>
---
 kernel/sched/core.c | 3 +++
 1 file changed, 3 insertions(+)

diff --git a/kernel/sched/core.c b/kernel/sched/core.c
index 3782ae515..1ff5052b5 100644
--- a/kernel/sched/core.c
+++ b/kernel/sched/core.c
@@ -3627,6 +3627,9 @@ static inline void ttwu_do_wakeup(struct task_struct *p)
 
 void update_rq_avg_idle(struct rq *rq)
 {
+	if (!rq->idle_stamp)
+		return;
+
 	u64 delta = rq_clock(rq) - rq->idle_stamp;
 	u64 max = 2*rq->max_idle_balance_cost;
 
-- 
