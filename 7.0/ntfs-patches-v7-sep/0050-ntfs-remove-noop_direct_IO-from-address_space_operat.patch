From 549e6cd0ce574286a830ad0ef099e31ac91e072b Mon Sep 17 00:00:00 2001
From: Hyunchul Lee <hyc.lee@gmail.com>
Date: Mon, 6 Apr 2026 10:24:16 +0900
Subject: [PATCH 50/90] ntfs: remove noop_direct_IO from
 address_space_operations

Since commit a2ad63daa88b ("VFS: add FMODE_CAN_ODIRECT file flag"),
noop_direct_io is not required.

Signed-off-by: Hyunchul Lee <hyc.lee@gmail.com>
Signed-off-by: Namjae Jeon <linkinjeon@kernel.org>
---
 fs/ntfs/aops.c | 1 -
 1 file changed, 1 deletion(-)

diff --git a/fs/ntfs/aops.c b/fs/ntfs/aops.c
index b59f3cc31..1fbf832ad 100644
--- a/fs/ntfs/aops.c
+++ b/fs/ntfs/aops.c
@@ -281,7 +281,6 @@ const struct address_space_operations ntfs_aops = {
 	.read_folio		= ntfs_read_folio,
 	.readahead		= ntfs_readahead,
 	.writepages		= ntfs_writepages,
-	.direct_IO		= noop_direct_IO,
 	.dirty_folio		= iomap_dirty_folio,
 	.bmap			= ntfs_bmap,
 	.migrate_folio		= filemap_migrate_folio,
-- 
2.54.0

