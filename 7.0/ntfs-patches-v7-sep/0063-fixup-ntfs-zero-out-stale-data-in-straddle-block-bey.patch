From: Eric Naim <dnaim@cachyos.org>
Date: Thu, 23 Apr 2026 12:59:26 +0800
Subject: [PATCH 63/90] fixup! ntfs: zero out stale data in straddle block
 beyond initialized_size

Signed-off-by: Eric Naim <dnaim@cachyos.org>
---
 fs/ntfs/aops.c | 3 +--
 1 file changed, 1 insertion(+), 2 deletions(-)

diff --git a/fs/ntfs/aops.c b/fs/ntfs/aops.c
index 1fbf832ad..d91417d07 100644
--- a/fs/ntfs/aops.c
+++ b/fs/ntfs/aops.c
@@ -37,8 +37,7 @@ static void ntfs_iomap_read_end_io(struct bio *bio)
 	bio_put(bio);
 }
 
-static void ntfs_iomap_bio_submit_read(const struct iomap_iter *iter,
-	struct iomap_read_folio_ctx *ctx)
+static void ntfs_iomap_bio_submit_read(struct iomap_read_folio_ctx *ctx)
 {
 	struct bio *bio = ctx->read_ctx;
 	bio->bi_end_io = ntfs_iomap_read_end_io;
