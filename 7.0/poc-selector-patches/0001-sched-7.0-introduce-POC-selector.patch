+			if (range > 32)
+				static_branch_disable_cpuslocked(&sched_poc_packed);
+		} else {
+			sd->shared->poc_fast_eligible = false;
+			static_branch_disable_cpuslocked(&sched_poc_packed);
+		}
+		memset(sd->shared->poc_idle_cpus, 0,
+		       sizeof(sd->shared->poc_idle_cpus));
