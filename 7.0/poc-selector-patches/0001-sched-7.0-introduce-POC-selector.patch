+static bool poc_check_all_llc_eligible(void)
+{
+	int cpu;
+
+	for_each_online_cpu(cpu) {
+		struct sched_domain_shared *sd_share;
+
+		scoped_guard(rcu) {
+			sd_share = rcu_dereference(per_cpu(sd_llc_shared, cpu));
+			if (sd_share && !sd_share->poc_fast_eligible)
+				return false;
+		}
+	}
+	return true;
+}
