+++ b/drivers/gpu/drm/i915/display/intel_frontbuffer.c
@@ -97,6 +97,7 @@ static void frontbuffer_flush(struct intel_display *display,
 	might_sleep();
 	intel_td_flush(display);
 	intel_drrs_flush(display, frontbuffer_bits);
+	intel_psr_panel_replay_exit(display);
 	intel_psr_flush(display, frontbuffer_bits, origin);
 	intel_fbc_flush(display, frontbuffer_bits, origin);
 }
diff --git a/drivers/gpu/drm/i915/display/intel_psr.c b/drivers/gpu/drm/i915/display/intel_psr.c
index 7600b494b..49b462aec 100644
--- a/drivers/gpu/drm/i915/display/intel_psr.c
+++ b/drivers/gpu/drm/i915/display/intel_psr.c
@@ -1200,6 +1200,8 @@ static void tgl_psr2_disable_dc3co(struct intel_dp *intel_dp)
 	psr2_program_idle_frames(intel_dp, psr_compute_idle_frames(intel_dp));
 }
 
+static void intel_psr_activate(struct intel_dp *intel_dp);
+
 static void tgl_dc3co_disable_work(struct work_struct *work)
 {
 	struct intel_dp *intel_dp =
@@ -1210,6 +1212,13 @@ static void tgl_dc3co_disable_work(struct work_struct *work)
 	if (delayed_work_pending(&intel_dp->psr.dc3co_work))
 		goto unlock;
 
+	/* Panel Replay ALPM cursor-lag workaround re-activation path. */
+	if (intel_dp->psr.panel_replay_enabled &&
+	    intel_dp->psr.enabled && !intel_dp->psr.active) {
+		intel_psr_activate(intel_dp);
+		goto unlock;
