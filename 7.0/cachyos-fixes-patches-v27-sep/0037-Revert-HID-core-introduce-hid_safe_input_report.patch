From 867f004b8df3e1cc62fae52e50e9568daf6560da Mon Sep 17 00:00:00 2001
From: Peter Jung <admin@ptr1337.dev>
Date: Sat, 23 May 2026 13:49:56 +0200
Subject: [PATCH 37/46] Revert "HID: core: introduce hid_safe_input_report()"

This reverts commit 14166c909a3cf5050804445e746f6f542eed25d0.
---
 drivers/hid/hid-core.c             | 25 -------------------------
 drivers/hid/i2c-hid/i2c-hid-core.c |  7 +++----
 drivers/hid/usbhid/hid-core.c      | 11 +++++------
 include/linux/hid.h                |  2 --
 4 files changed, 8 insertions(+), 37 deletions(-)

diff --git a/drivers/hid/hid-core.c b/drivers/hid/hid-core.c
index 570884039..ecc02a6ce 100644
--- a/drivers/hid/hid-core.c
+++ b/drivers/hid/hid-core.c
@@ -2177,7 +2177,6 @@ static int __hid_input_report(struct hid_device *hid, enum hid_report_type type,
  * @interrupt: distinguish between interrupt and control transfers
  *
  * This is data entry for lower layers.
- * Legacy, please use hid_safe_input_report() instead.
  */
 int hid_input_report(struct hid_device *hid, enum hid_report_type type, u8 *data, u32 size,
 		     int interrupt)
@@ -2188,30 +2187,6 @@ int hid_input_report(struct hid_device *hid, enum hid_report_type type, u8 *data
 }
 EXPORT_SYMBOL_GPL(hid_input_report);
 
-/**
- * hid_safe_input_report - report data from lower layer (usb, bt...)
- *
- * @hid: hid device
- * @type: HID report type (HID_*_REPORT)
- * @data: report contents
- * @bufsize: allocated size of the data buffer
- * @size: useful size of data parameter
- * @interrupt: distinguish between interrupt and control transfers
- *
- * This is data entry for lower layers.
- * Please use this function instead of the non safe version because we provide
- * here the size of the buffer, allowing hid-core to make smarter decisions
- * regarding the incoming buffer.
- */
-int hid_safe_input_report(struct hid_device *hid, enum hid_report_type type, u8 *data,
-			  size_t bufsize, u32 size, int interrupt)
-{
-	return __hid_input_report(hid, type, data, bufsize, size, interrupt, 0,
-				  false, /* from_bpf */
-				  false /* lock_already_taken */);
-}
-EXPORT_SYMBOL_GPL(hid_safe_input_report);
-
 bool hid_match_one_id(const struct hid_device *hdev,
 		      const struct hid_device_id *id)
 {
diff --git a/drivers/hid/i2c-hid/i2c-hid-core.c b/drivers/hid/i2c-hid/i2c-hid-core.c
index e0a302544..5a183af3d 100644
--- a/drivers/hid/i2c-hid/i2c-hid-core.c
+++ b/drivers/hid/i2c-hid/i2c-hid-core.c
@@ -574,10 +574,9 @@ static void i2c_hid_get_input(struct i2c_hid *ihid)
 		if (ihid->hid->group != HID_GROUP_RMI)
 			pm_wakeup_event(&ihid->client->dev, 0);
 
-		hid_safe_input_report(ihid->hid, HID_INPUT_REPORT,
-				      ihid->inbuf + sizeof(__le16),
-				      ihid->bufsize - sizeof(__le16),
-				      ret_size - sizeof(__le16), 1);
+		hid_input_report(ihid->hid, HID_INPUT_REPORT,
+				ihid->inbuf + sizeof(__le16),
+				ret_size - sizeof(__le16), 1);
 	}
 
 	return;
diff --git a/drivers/hid/usbhid/hid-core.c b/drivers/hid/usbhid/hid-core.c
index 047d390d5..fd3e1aedc 100644
--- a/drivers/hid/usbhid/hid-core.c
+++ b/drivers/hid/usbhid/hid-core.c
@@ -283,9 +283,9 @@ static void hid_irq_in(struct urb *urb)
 			break;
 		usbhid_mark_busy(usbhid);
 		if (!test_bit(HID_RESUME_RUNNING, &usbhid->iofl)) {
-			hid_safe_input_report(urb->context, HID_INPUT_REPORT,
-					      urb->transfer_buffer, urb->transfer_buffer_length,
-					      urb->actual_length, 1);
+			hid_input_report(urb->context, HID_INPUT_REPORT,
+					 urb->transfer_buffer,
+					 urb->actual_length, 1);
 			/*
 			 * autosuspend refused while keys are pressed
 			 * because most keyboards don't wake up when
@@ -482,10 +482,9 @@ static void hid_ctrl(struct urb *urb)
 	switch (status) {
 	case 0:			/* success */
 		if (usbhid->ctrl[usbhid->ctrltail].dir == USB_DIR_IN)
-			hid_safe_input_report(urb->context,
+			hid_input_report(urb->context,
 				usbhid->ctrl[usbhid->ctrltail].report->type,
-				urb->transfer_buffer, urb->transfer_buffer_length,
-				urb->actual_length, 0);
+				urb->transfer_buffer, urb->actual_length, 0);
 		break;
 	case -ESHUTDOWN:	/* unplug */
 		unplug = 1;
diff --git a/include/linux/hid.h b/include/linux/hid.h
index c9e0ebe9c..7e113e699 100644
--- a/include/linux/hid.h
+++ b/include/linux/hid.h
@@ -998,8 +998,6 @@ struct hid_field *hid_find_field(struct hid_device *hdev, unsigned int report_ty
 int hid_set_field(struct hid_field *, unsigned, __s32);
 int hid_input_report(struct hid_device *hid, enum hid_report_type type, u8 *data, u32 size,
 		     int interrupt);
-int hid_safe_input_report(struct hid_device *hid, enum hid_report_type type, u8 *data,
-			  size_t bufsize, u32 size, int interrupt);
 struct hid_field *hidinput_get_led_field(struct hid_device *hid);
 unsigned int hidinput_count_leds(struct hid_device *hid);
 __s32 hidinput_calc_abs_res(const struct hid_field *field, __u16 code);
-- 
2.54.0

